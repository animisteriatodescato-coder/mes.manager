@page "/cataloghi/anime"
@using MudBlazor
@inject MESManager.Application.Interfaces.IAnimeService AnimeService

<h3>Catalogo Anime</h3>

@if (animeList == null)
{
    <p>Caricamento...</p>
}
else
{
    <button class="btn btn-primary mb-2" @onclick="ShowAdd">Aggiungi</button>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Codice</th>
                <th>Descrizione</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in animeList)
            {
                <tr>
                    <td>@a.Codice</td>
                    <td>@a.Descrizione</td>
                    <td>
                        <button class="btn btn-sm btn-secondary me-1" @onclick="() => ShowEdit(a)">Modifica</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => Delete(a)">Elimina</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (showForm)
{
    <EditForm Model="editModel" OnValidSubmit="Save">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div class="mb-2">
            <label>Codice</label>
            <MudTextField @bind-Value="editModel.Codice" />
        </div>
        <div class="mb-2">
            <label>Descrizione</label>
            <MudTextField @bind-Value="editModel.Descrizione" />
        </div>
        <button class="btn btn-success me-2" type="submit">Salva</button>
        <button class="btn btn-secondary" type="button" @onclick="HideForm">Annulla</button>
    </EditForm>
}

@code {
    private List<MESManager.Application.DTOs.AnimeDto>? animeList;
    private MESManager.Application.DTOs.AnimeDto editModel = new();
    private int? editId = null;
    private bool showForm = false;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        animeList = await AnimeService.GetAllAsync();
        showForm = false;
        StateHasChanged();
    }

    private void ShowAdd()
    {
        editModel = new();
        editId = null;
        showForm = true;
    }

    private void ShowEdit(MESManager.Application.DTOs.AnimeDto dto)
    {
        editModel = new MESManager.Application.DTOs.AnimeDto { Codice = dto.Codice, Descrizione = dto.Descrizione };
        editId = animeList?.IndexOf(dto);
        showForm = true;
    }

    private void HideForm()
    {
        showForm = false;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(editModel.Codice))
            return;
        if (editId == null)
            await AnimeService.AddAsync(editModel);
        else
            await AnimeService.UpdateAsync(editId.Value + 1, editModel); // Semplice, da migliorare con Id reale
        await Load();
    }

    private async Task Delete(MESManager.Application.DTOs.AnimeDto dto)
    {
        var idx = animeList?.IndexOf(dto);
        if (idx != null && idx >= 0)
            await AnimeService.DeleteAsync(idx.Value + 1); // Semplice, da migliorare con Id reale
        await Load();
    }
}
