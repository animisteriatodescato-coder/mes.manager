@page "/cataloghi/non-conformita"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = MESManager.Web.Constants.PaginaPolicy.CatNonConformita)]
@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@using MESManager.Web.Services
@using MESManager.Web.Components.Dialogs.Cataloghi
@using MudBlazor
@inject INonConformitaService NcService
@inject IAnimeService AnimeService
@inject ICommessaAppService CommessaAppService
@inject ITabelleService TabelleService
@inject MESManager.Application.Services.CurrentUserService CurrentUserService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Non Conformità</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="mt-2 px-3" data-testid="page-non-conformita">
<MudPaper Elevation="1" Class="pa-3">

    @* ── TOOLBAR ── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2" Wrap="Wrap.Wrap">
        <MudIcon Icon="@Icons.Material.Filled.ReportProblem" Color="Color.Error" />
        <MudText Typo="Typo.h6" Class="me-2">Non Conformità e Segnalazioni</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="_searchText"
                      Placeholder="Cerca articolo, cliente, descrizione…"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Style="width:260px" Immediate="true" DebounceInterval="220"
                      AdornmentIcon="@Icons.Material.Filled.Search" Adornment="Adornment.End"
                      data-testid="input-nc-search" />
        <MudSelect T="string" @bind-Value="_filtroStato" Label="Stato" Variant="Variant.Outlined"
                   Margin="Margin.Dense" Style="width:140px" data-testid="select-nc-stato">
            <MudSelectItem Value="@("")">Tutti</MudSelectItem>
            <MudSelectItem Value="@("Aperta")">Aperte</MudSelectItem>
            <MudSelectItem Value="@("InGestione")">In Gestione</MudSelectItem>
            <MudSelectItem Value="@("Chiusa")">Chiuse</MudSelectItem>
        </MudSelect>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.AddCircle"
                   OnClick="@ApriNuovaNc"
                   data-testid="btn-nuova-nc">
            Nuova NC
        </MudButton>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="@LoadData">Aggiorna</MudButton>
    </MudStack>

    @* ── LISTA ── *@
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Error" Class="mb-2" />
    }
    else if (!RigheVisibili.Any())
    {
        <MudAlert Severity="Severity.Info" Class="mt-2">
            Nessuna segnalazione trovata. Premi "Nuova NC" per registrarne una.
        </MudAlert>
    }
    else
    {
        <MudTable Items="@RigheVisibili" GroupBy="@_groupDef" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm"
                  SortLabel="Ordina" data-testid="tabella-nc">
            <ColGroup>
                <col style="width:100px" />
                <col style="width:140px" />
                <col style="width:130px" />
                <col style="width:120px" />
                <col style="width:100px" />
                <col style="width:110px" />
                <col />
                <col style="width:100px" />
                <col style="width:110px" />
            </ColGroup>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="@(new Func<NonConformitaDto, object>(x => x.DataSegnalazione))">Data</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="@(new Func<NonConformitaDto, object>(x => x.CodiceArticolo))">Articolo</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="@(new Func<NonConformitaDto, object>(x => x.Cliente ?? string.Empty))">Cliente</MudTableSortLabel></MudTh>
                <MudTh>Tipologia</MudTh>
                <MudTh><MudTableSortLabel SortBy="@(new Func<NonConformitaDto, object>(x => x.Gravita))">Gravità</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="@(new Func<NonConformitaDto, object>(x => x.Esito ?? string.Empty))">Esito</MudTableSortLabel></MudTh>
                <MudTh>Descrizione / Motivo</MudTh>
                <MudTh><MudTableSortLabel SortBy="@(new Func<NonConformitaDto, object>(x => x.Stato))">Stato</MudTableSortLabel></MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <GroupHeaderTemplate>
                <MudTh colspan="9" Style="padding:6px 12px;background:var(--mud-palette-background-grey)">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle2"><b>@context.Key</b></MudText>
                        @{
                            var descr = _articoliDescr.TryGetValue(context.Key?.ToString() ?? "", out var d) ? d : null;
                        }
                        @if (!string.IsNullOrWhiteSpace(descr))
                        {
                            <MudText Typo="Typo.caption" Style="opacity:.7">— @descr</MudText>
                        }
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@context.Items.Count() NC</MudChip>
                        @{
                            int aperte = context.Items.Count(x => x.Stato != "Chiusa");
                        }
                        @if (aperte > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">@aperte aperte</MudChip>
                        }
                    </MudStack>
                </MudTh>
            </GroupHeaderTemplate>
            <RowTemplate>
                <MudTd DataLabel="Data">@context.DataSegnalazione.ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Articolo">
                    <MudText Typo="Typo.body2"><b>@context.CodiceArticolo</b></MudText>
                    @if (!string.IsNullOrWhiteSpace(context.DescrizioneArticolo))
                    {
                        <MudText Typo="Typo.caption" Style="opacity:.7">@context.DescrizioneArticolo</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Cliente">@(context.Cliente ?? "-")</MudTd>
                <MudTd DataLabel="Tipologia">
                    @if (!string.IsNullOrWhiteSpace(context.TipologiaNc))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@context.TipologiaNc</MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Style="opacity:.5">—</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Gravità">
                    <MudChip T="string" Size="Size.Small" Color="@GetGravitaColor(context.Gravita)" Variant="Variant.Filled">
                        @context.Gravita
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Esito">
                    @if (context.Esito == "Positivo")
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">Positivo</MudChip>
                    }
                    else if (context.Esito == "Negativo")
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Filled.Cancel">Negativo</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">In corso</MudChip>
                    }
                </MudTd>
                <MudTd DataLabel="Descrizione / Motivo">
                    <MudText Typo="Typo.body2" Style="max-width:280px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"
                             title="@context.Descrizione">
                        @context.Descrizione
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(context.MotivoProblema))
                    {
                        <MudText Typo="Typo.caption" Style="opacity:.7;max-width:280px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"
                                 title="@context.MotivoProblema">
                            🔍 @context.MotivoProblema
                        </MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Stato">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatoColor(context.Stato)">@context.Stato</MudChip>
                </MudTd>
                <MudTd>
                    <MudStack Row="true" Spacing="0">
                        <MudIconButton Icon="@Icons.Material.Filled.AttachFile" Size="Size.Small" Color="Color.Secondary"
                                       Title="Allegati" OnClick="@(() => ApriAllegatiAsync(context))"
                                       data-testid="btn-nc-allegati" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                       Title="Modifica" OnClick="@(() => ApriModifica(context))"
                                       data-testid="btn-nc-edit" />
                        @if (context.Stato != "Chiusa")
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success"
                                           Title="Chiudi" OnClick="@(() => ConfermaChiudi(context))"
                                           data-testid="btn-nc-chiudi" />
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       Title="Elimina" OnClick="@(() => ConfermaElimina(context))"
                                       data-testid="btn-nc-delete" />
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

</MudPaper>
</MudContainer>

@* ── DIALOG NUOVA / MODIFICA NC ── *@
<MudDialog @bind-Visible="_dialogOpen" Options="_dialogOptions">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.ReportProblem" Color="Color.Error" />
            <MudText Typo="Typo.h6">@(_editingId.HasValue ? "Modifica" : "Nuova") Non Conformità / Segnalazione</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6">
                <MudRadioGroup T="string" @bind-Value="_form.Tipo">
                    <MudRadio T="string" Value="@("NonConformita")" Color="Color.Error">Non Conformità</MudRadio>
                    <MudRadio T="string" Value="@("Segnalazione")" Color="Color.Warning">Segnalazione</MudRadio>
                </MudRadioGroup>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="string" @bind-Value="_form.Gravita" Label="Gravità *" Variant="Variant.Outlined"
                           Margin="Margin.Dense" data-testid="select-form-gravita">
                    <MudSelectItem Value="@("Bassa")">🟢 Bassa</MudSelectItem>
                    <MudSelectItem Value="@("Media")">🟡 Media</MudSelectItem>
                    <MudSelectItem Value="@("Alta")">🟠 Alta</MudSelectItem>
                    <MudSelectItem Value="@("Critica")">🔴 Critica</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="8">
                <MudAutocomplete T="string"
                                 Value="_form.CodiceArticolo"
                                 ValueChanged="OnArticoloSelezionato"
                                 Label="Codice articolo *"
                                 SearchFunc="CercaArticoli"
                                 CoerceText="true"
                                 CoerceValue="true"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 MinCharacters="0"
                                 DebounceInterval="150"
                                 Clearable="true"
                                 HelperText="Scegli da CatalogoAnime o inserisci manualmente"
                                 data-testid="autocomplete-articolo" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudDatePicker @bind-Date="_dataForm" Label="Data segnalazione" DateFormat="dd/MM/yyyy"
                               Editable="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                               PickerVariant="PickerVariant.Dialog" data-testid="dp-data-nc" />
            </MudItem>
            @if (!string.IsNullOrWhiteSpace(_form.DescrizioneArticolo))
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Style="opacity:.7">📦 @_form.DescrizioneArticolo</MudText>
                </MudItem>
            }
            <MudItem xs="12" sm="6">
                <MudAutocomplete T="string"
                                 @bind-Value="_form.Cliente"
                                 Label="Cliente"
                                 SearchFunc="CercaClienti"
                                 CoerceText="true"
                                 CoerceValue="true"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 MinCharacters="0"
                                 DebounceInterval="150"
                                 Clearable="true"
                                 data-testid="autocomplete-cliente" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="string" @bind-Value="_form.TipologiaNc" Label="Tipologia NC" Variant="Variant.Outlined"
                           Margin="Margin.Dense" Clearable="true" data-testid="select-form-tipologia">
                    @foreach (var tip in _tipologieNc)
                    {
                        <MudSelectItem Value="@tip.Descrizione">@tip.Descrizione</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Descrizione" Label="Descrizione problema *"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2"
                              HelperText="Descrivi il problema segnalato dal cliente"
                              data-testid="input-nc-descrizione" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.MotivoProblema" Label="Motivo tecnico del problema"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2"
                              HelperText="Analisi della causa radice (opzionale)"
                              data-testid="input-nc-motivo" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.AzioneCorrettiva" Label="Azione correttiva"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2"
                              HelperText="Cosa è stato fatto o pianificato"
                              data-testid="input-nc-azione" />
            </MudItem>

            @* ── SEZIONE ESITO ── *@
            <MudItem xs="12">
                <MudDivider Class="mb-1" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">✅ Esito</MudText>
                <MudRadioGroup T="string" @bind-Value="_form.Esito" data-testid="radio-esito">
                    <MudRadio T="string" Value="@((string?)null)" Color="Color.Default">Non valutato</MudRadio>
                    <MudRadio T="string" Value="@("Positivo")" Color="Color.Success">✅ Positivo (chiude la NC)</MudRadio>
                    <MudRadio T="string" Value="@("Negativo")" Color="Color.Error">❌ Negativo (richiede nuova azione)</MudRadio>
                </MudRadioGroup>
            </MudItem>
            @if (_form.Esito == "Negativo")
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-1">
                        Esito negativo: inserisci una nuova azione correttiva.
                    </MudAlert>
                    <MudTextField @bind-Value="_form.AzioneCorrettiva" Label="Nuova azione correttiva *"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3"
                                  HelperText="Obbligatorio con esito negativo" Class="mt-1"
                                  data-testid="input-nc-azione-negativo" />
                </MudItem>
            }
            @if (_form.Esito != "Positivo")
            {
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="_form.Stato" Label="Stato" Variant="Variant.Outlined"
                               Margin="Margin.Dense" data-testid="select-form-stato">
                        <MudSelectItem Value="@("Aperta")">Aperta</MudSelectItem>
                        <MudSelectItem Value="@("InGestione")">In Gestione</MudSelectItem>
                        <MudSelectItem Value="@("Chiusa")">Chiusa</MudSelectItem>
                    </MudSelect>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _dialogOpen = false)">Annulla</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   Disabled="@(!FormValido)"
                   OnClick="@SalvaAsync"
                   data-testid="btn-nc-salva">
            Salva
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _loading;
    private List<NonConformitaDto> _nc = new();
    private List<MESManager.Domain.Constants.LookupItem> _tipologieNc = new();
    private List<string> _articoliCodici = new();
    private Dictionary<string, string> _articoliDescr = new(StringComparer.OrdinalIgnoreCase);
    private List<string> _clienti = new();
    private string _searchText = string.Empty;
    private string _filtroStato = "Aperta";

    private TableGroupDefinition<NonConformitaDto> _groupDef = new()
    {
        GroupName   = "Articolo",
        Indentation = false,
        Expandable  = true,
        IsInitiallyExpanded = true,
        Selector    = (e) => e.CodiceArticolo
    };

    // Dialog
    private bool _dialogOpen;
    private Guid? _editingId;
    private NonConformitaDto _form = new();
    private DateTime? _dataForm = DateTime.Today;
    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true };

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;

        // Sequenziale (DbContext scoped)
        _nc = await NcService.GetAllAsync();
        var anime = await AnimeService.GetAllAsync();
        _articoliCodici = anime.Select(a => a.CodiceArticolo).OrderBy(c => c).ToList();
        _articoliDescr  = anime
            .Where(a => !string.IsNullOrWhiteSpace(a.DescrizioneArticolo))
            .GroupBy(a => a.CodiceArticolo, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.First().DescrizioneArticolo ?? "", StringComparer.OrdinalIgnoreCase);
        var clientiList = await CommessaAppService.GetClienteNomiDistinctAsync();
        _clienti = clientiList;
        // Singleton - chiamata sincrona sicura
        _tipologieNc = TabelleService.GetTipologiaNcList();

        _loading = false;
    }

    private IEnumerable<NonConformitaDto> RigheVisibili => _nc.Where(nc =>
    {
        if (!string.IsNullOrWhiteSpace(_filtroStato) && nc.Stato != _filtroStato) return false;
        if (string.IsNullOrWhiteSpace(_searchText)) return true;
        var q = _searchText.Trim();
        return nc.CodiceArticolo.Contains(q, StringComparison.OrdinalIgnoreCase)
            || (nc.Cliente?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || nc.Descrizione.Contains(q, StringComparison.OrdinalIgnoreCase)
            || (nc.DescrizioneArticolo?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false);
    });

    // ── Autocomplete ──────────────────────────────────────────────────────────

    private Task<IEnumerable<string>> CercaArticoli(string? value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(_articoliCodici.Take(20).AsEnumerable());
        return Task.FromResult(
            _articoliCodici.Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase)).Take(20).AsEnumerable());
    }

    private Task<IEnumerable<string>> CercaClienti(string? value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(_clienti.Take(20).AsEnumerable());
        return Task.FromResult(
            _clienti.Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase)).Take(20).AsEnumerable());
    }

    private void OnArticoloSelezionato(string? codice)
    {
        _form.CodiceArticolo = codice ?? string.Empty;
        _form.DescrizioneArticolo = codice != null && _articoliDescr.TryGetValue(codice, out var d) ? d : null;
    }

    // ── Dialog ───────────────────────────────────────────────────────────────

    private void ApriNuovaNc()
    {
        _editingId = null;
        _form = new NonConformitaDto { Tipo = "NonConformita", Gravita = "Media", Stato = "Aperta", Esito = null };
        _dataForm = DateTime.Today;
        _dialogOpen = true;
    }

    private void ApriModifica(NonConformitaDto nc)
    {
        _editingId = nc.Id;
        _form = new NonConformitaDto
        {
            Id                  = nc.Id,
            CodiceArticolo      = nc.CodiceArticolo,
            DescrizioneArticolo = nc.DescrizioneArticolo,
            Cliente             = nc.Cliente,
            DataSegnalazione    = nc.DataSegnalazione,
            Tipo                = nc.Tipo,
            Gravita             = nc.Gravita,
            Descrizione         = nc.Descrizione,
            MotivoProblema      = nc.MotivoProblema,
            AzioneCorrettiva    = nc.AzioneCorrettiva,
            TipologiaNc         = nc.TipologiaNc,
            Esito               = nc.Esito,
            Stato               = nc.Stato
        };
        _dataForm = nc.DataSegnalazione;
        _dialogOpen = true;
    }

    private bool FormValido =>
        !string.IsNullOrWhiteSpace(_form.CodiceArticolo) &&
        !string.IsNullOrWhiteSpace(_form.Descrizione) &&
        (_form.Esito != "Negativo" || !string.IsNullOrWhiteSpace(_form.AzioneCorrettiva));

    private async Task SalvaAsync()
    {
        if (!FormValido) return;
        _form.DataSegnalazione = _dataForm ?? DateTime.Today;

        try
        {
            if (_editingId.HasValue)
            {
                await NcService.UpdateAsync(_form, CurrentUserService.UserId ?? "");
                Snackbar.Add("NC aggiornata.", Severity.Success);
            }
            else
            {
                await NcService.CreateAsync(_form, CurrentUserService.UserId ?? "");
                Snackbar.Add("NC registrata.", Severity.Success);
            }
            _dialogOpen = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    private async Task ApriAllegatiAsync(NonConformitaDto nc)
    {
        var p = new DialogParameters<AllegatiNcDialog>
        {
            { x => x.NonConformitaId, nc.Id },
            { x => x.Label, $"{nc.CodiceArticolo} — {nc.DataSegnalazione:dd/MM/yyyy}" }
        };
        await DialogService.ShowAsync<AllegatiNcDialog>("Allegati Non Conformità", p,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
    }

    private async Task ConfermaChiudi(NonConformitaDto nc)
    {
        var result = await DialogService.ShowMessageBox(
            "Chiudi NC",
            $"Chiudere la NC su {nc.CodiceArticolo}?",
            yesText: "Chiudi", cancelText: "Annulla");
        if (result != true) return;

        await NcService.ChiudiAsync(nc.Id, null, CurrentUserService.UserId ?? "");
        Snackbar.Add("NC chiusa.", Severity.Success);
        await LoadData();
    }

    private async Task ConfermaElimina(NonConformitaDto nc)
    {
        var result = await DialogService.ShowMessageBox(
            "Elimina NC",
            $"Eliminare definitivamente la NC su {nc.CodiceArticolo} del {nc.DataSegnalazione:dd/MM/yyyy}?",
            yesText: "Elimina", cancelText: "Annulla");
        if (result != true) return;

        await NcService.DeleteAsync(nc.Id);
        Snackbar.Add("NC eliminata.", Severity.Success);
        await LoadData();
    }

    // ── Helpers colori ────────────────────────────────────────────────────────

    private static Color GetGravitaColor(string gravita) => gravita switch
    {
        "Critica" => Color.Error,
        "Alta"    => Color.Warning,
        "Media"   => Color.Info,
        _         => Color.Success
    };

    private static Color GetStatoColor(string stato) => stato switch
    {
        "Aperta"     => Color.Error,
        "InGestione" => Color.Warning,
        "Chiusa"     => Color.Success,
        _            => Color.Default
    };
}
