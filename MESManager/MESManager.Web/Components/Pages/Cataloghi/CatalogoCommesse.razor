@page "/cataloghi/commesse"
@using MESManager.Application.DTOs
@using MESManager.Web.Models
@using MESManager.Web.Services
@using Microsoft.JSInterop
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject PreferencesService PreferencesService
@inject IJSRuntime JSRuntime
@inject IPageToolbarService PageToolbarService
@implements IAsyncDisposable

<PageTitle>Catalogo Commesse</PageTitle>

<div class="commesse-page">
    <div class="settings-panel">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap" Class="mb-3">
            <MudText Typo="Typo.h6" data-testid="commesse-title">Commesse</MudText>
            <MudSpacer />

            
            <MudTextField @bind-Value="searchText"
                         Placeholder="Cerca in tutte le colonne..."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Style="width: 280px;"
                         Immediate="true"
                         DebounceInterval="280"
                         OnDebounceIntervalElapsed="OnSearchDebounced" />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ViewColumn" OnClick="@ToggleColumnPanel">Colonne</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="@ResetGrid">Reset</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" OnClick="@ExportCsv">Export CSV</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Settings" OnClick="@(() => showSettings = !showSettings)">Impostazioni</MudButton>
        </MudStack>
        
        @if (showSettings)
        {
            <MudPaper Class="pa-4 mt-2" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Wrap="Wrap.Wrap">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Font Size:</MudText>
                        <MudNumericField Value="@settings.FontSize" Min="10" Max="24" Step="1" 
                                        Variant="Variant.Outlined" Margin="Margin.Dense"
                                        ValueChanged="@(async (int val) => { settings.FontSize = val; await ApplyUiSettings(); })" 
                                        Style="width: 80px;" />
                    </MudStack>
                    
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Row Height:</MudText>
                        <MudNumericField Value="@settings.RowHeight" Min="25" Max="80" Step="5" 
                                        Variant="Variant.Outlined" Margin="Margin.Dense"
                                        ValueChanged="@(async (int val) => { settings.RowHeight = val; await ApplyUiSettings(); })" 
                                        Style="width: 80px;" />
                    </MudStack>
                    
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Density:</MudText>
                        <MudSelect Value="@settings.Density" 
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  ValueChanged="@(async (string val) => { settings.Density = val; await ApplyUiSettings(); })" 
                                  Style="width: 120px;">
                            <MudSelectItem Value="@("Compact")">Compact</MudSelectItem>
                            <MudSelectItem Value="@("Normal")">Normal</MudSelectItem>
                            <MudSelectItem Value="@("Comfortable")">Comfortable</MudSelectItem>
                        </MudSelect>
                    </MudStack>
                    
                    <MudCheckBox Value="@settings.Zebra" Label="Zebra" Color="Color.Primary"
                                ValueChanged="@(async (bool val) => { settings.Zebra = val; await ApplyUiSettings(); })" />
                    
                    <MudCheckBox Value="@settings.GridLines" Label="Grid Lines" Color="Color.Primary"
                                ValueChanged="@(async (bool val) => { settings.GridLines = val; await ApplyUiSettings(); })" />
                </MudStack>
            </MudPaper>
        }
    </div>

    <div id="commesseGrid" class="ag-theme-alpine" 
         data-testid="commesse-grid"
         style="width: 100%; height: calc(100vh - 150px);">
    </div>

    <MudDialog @bind-Visible="showColumnDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Medium }">
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.ViewColumn" Class="mr-2" />
                Gestione Colonne
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudList T="string" Dense="true">
                @foreach (var col in columnList)
                {
                    var currentCol = col;
                    <MudListItem T="string">
                        <MudSwitch Value="@currentCol.Visible" 
                                   Color="Color.Primary" 
                                   Label="@currentCol.HeaderName"
                                   T="bool"
                                   ValueChanged="@(async (bool val) => { currentCol.Visible = val; await OnColumnVisibilityChanged(currentCol.Field, val); })" />
                    </MudListItem>
                }
            </MudList>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => showColumnDialog = false)">Chiudi</MudButton>
        </DialogActions>
    </MudDialog>

    <MudPaper Class="footer-info pa-1 mt-2" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Totale: <strong>@totalRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Success">Aperte: <strong>@aperteCount</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Default">Chiuse: <strong>@chiuseCount</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Filtrate: <strong>@filteredRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Selezionate: <strong>@selectedRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Ultimo aggiornamento: <strong>@lastUpdate.ToString("HH:mm:ss")</strong></MudText>
            <MudSpacer />
            <MudChip T="string" Size="Size.Small" Color="@(isLoading ? Color.Warning : Color.Success)" 
                     Icon="@(isLoading ? Icons.Material.Filled.HourglassEmpty : Icons.Material.Filled.CheckCircle)">
                @gridStatus
            </MudChip>
        </MudStack>
    </MudPaper>
</div>

<style>
    .commesse-page {
        position: relative;
    }

    .toolbar-sticky {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--mud-palette-surface);
        padding: 0.1 rem 0;
        margin-bottom: 0.2rem;
    }

    /* Gestione Colonne in dark mode */
    @@media (prefers-color-scheme: dark) {
        .ag-theme-alpine .ag-side-bar,
        .ag-theme-alpine .ag-tool-panel-wrapper,
        .ag-theme-alpine .ag-column-select-panel,
        .ag-theme-alpine .ag-column-panel {
            background-color: #1e1e1e !important;
        }

        .ag-theme-alpine .ag-column-select-header,
        .ag-theme-alpine .ag-column-select-column-label,
        .ag-theme-alpine .ag-column-select-column-group,
        .ag-theme-alpine .ag-column-select-header-label,
        .ag-theme-alpine .ag-filter-toolpanel-header {
            color: #201e1e !important;
        }

        .ag-theme-alpine .ag-input-field-input,
        .ag-theme-alpine .ag-text-field-input {
            background-color: #2d2d2d !important;
            color: #625454 !important;
            border-color: #444 !important;
        }
    }
</style>

@code {
    private List<CommessaDto> _commesse = new();
    private GridUiSettings settings = new();
    // Rimossa ricerca globale, ora si usano i filtri per colonna stile Excel
    private bool showSettings = false;
    private string searchText = string.Empty;
    private bool showColumnDialog = false;
    private List<ColumnInfo> columnList = new();

    private int totalRows = 0;
    private int filteredRows = 0;
    private int selectedRows = 0;
    private int aperteCount = 0;
    private int chiuseCount = 0;
    private DateTime lastUpdate = DateTime.MinValue;
    private bool isLoading = false;
    private string gridStatus = "Pronto";
    private IJSObjectReference? jsModule;

    private async Task OnSearchDebounced(string value)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("commesseGrid.setQuickFilter", value);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error filtering grid: {ex.Message}");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        PageToolbarService.SetActivePage("commesse", this);
        
        Console.WriteLine("Fetching commesse from API...");
        _commesse = await Http.GetFromJsonAsync<List<CommessaDto>>("api/Commesse") ?? new();
        Console.WriteLine($"Fetched {_commesse.Count} commesse");
        
        totalRows = _commesse.Count;
        aperteCount = _commesse.Count(c => c.Stato == "Aperta");
        chiuseCount = _commesse.Count(c => c.Stato == "Chiusa");
        lastUpdate = DateTime.Now;
        
        var savedSettings = await PreferencesService.GetAsync<GridUiSettings>("commesse-grid-settings");
        if (savedSettings != null)
        {
            settings = savedSettings;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Delay per assicurarsi che gli script siano caricati
            await Task.Delay(100);
            await InitializeGrid();
            
            // Sottoscrivi agli eventi di cambio statistiche
            jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/stats-listener.js");
            await jsModule.InvokeVoidAsync("subscribeToStatsChanges", DotNetObjectReference.Create(this));
        }
    }

    [JSInvokable]
    public async Task UpdateStats()
    {
        try
        {
            var stats = await JSRuntime.InvokeAsync<GridStats>("commesseGrid.getStats");
            totalRows = stats.Total;
            filteredRows = stats.Filtered;
            selectedRows = stats.Selected;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating stats: {ex.Message}");
        }
    }

    [JSInvokable]
    public async Task SaveGridStateFromJs()
    {
        await SaveGridState();
    }

    private async Task InitializeGrid()
    {
        try
        {
            Console.WriteLine($"InitializeGrid called with {_commesse.Count} commesse");
            
            // DIAGNOSTICA: verifica proprietà del primo elemento
            if (_commesse.Count > 0)
            {
                var first = _commesse[0];
                Console.WriteLine($"C# Object properties - Codice: {first.Codice}, InternalOrdNo: {first.InternalOrdNo}, Line: {first.Line}, Description: {first.Description}");
            }
            
            // Verifica che window.commesseGrid esista
            var exists = await JSRuntime.InvokeAsync<bool>("eval", "typeof window.commesseGrid !== 'undefined'");
            if (!exists)
            {
                Console.WriteLine("ERROR: window.commesseGrid is not defined!");
                return;
            }

            // Serializza con camelCase e passa come stringa JSON da parsare in JS
            var jsonOptions = new JsonSerializerOptions 
            { 
                PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
                WriteIndented = false
            };
            var jsonData = JsonSerializer.Serialize(_commesse, jsonOptions);
            
            // DIAGNOSTICA: mostra un estratto del JSON serializzato
            var preview = jsonData.Length > 500 ? jsonData.Substring(0, 500) + "..." : jsonData;
            Console.WriteLine($"Serialized JSON preview: {preview}");

            // Passa il JSON come stringa e fallo parsare in JavaScript
            await JSRuntime.InvokeVoidAsync("eval", $"commesseGrid.init('commesseGrid', JSON.parse({System.Text.Json.JsonSerializer.Serialize(jsonData)}), {System.Text.Json.JsonSerializer.Serialize(settings.ColumnStateJson)})");
            await ApplyUiSettings();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing grid: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
        }
    }

    private async Task ToggleColumnPanel()
    {
        try
        {
            // Recupera lista colonne dal grid
            columnList = await JSRuntime.InvokeAsync<List<ColumnInfo>>("commesseGrid.getAllColumns");
            showColumnDialog = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error toggling column panel: {ex.Message}");
        }
    }

    private async Task OnColumnVisibilityChanged(string field, bool visible)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("commesseGrid.setColumnVisible", field, visible);
            await SaveGridState();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error changing column visibility: {ex.Message}");
        }
    }

    private async Task ResetGrid()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("commesseGrid.resetState");
            settings = new GridUiSettings();
            // Ricerca globale rimossa
            await PreferencesService.RemoveAsync("commesse-grid-settings");
            await ApplyUiSettings();
            StateHasChanged();
        }
        catch { }
    }

    private async Task ExportCsv()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("commesseGrid.exportCsv");
        }
        catch { }
    }

    private async Task ApplyUiSettings()
    {
        try
        {
            var densityPadding = GetDensityPadding();
            await JSRuntime.InvokeVoidAsync("commesseGrid.setUiVars", 
                settings.FontSize, 
                settings.RowHeight, 
                densityPadding,
                settings.Zebra,
                settings.GridLines);
            await SaveSettings();
            StateHasChanged();
        }
        catch { }
    }

    private string GetDensityPadding()
    {
        return settings.Density switch
        {
            "Compact" => "4px",
            "Comfortable" => "12px",
            _ => "8px"
        };
    }

    private async Task SaveGridState()
    {
        await SaveSettings();
    }

    private async Task SaveSettings()
    {
        try
        {
            var state = await JSRuntime.InvokeAsync<string>("commesseGrid.getState");
            settings.ColumnStateJson = state;
            await PreferencesService.SetAsync("commesse-grid-settings", settings);
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        // Deregistra questa pagina
        PageToolbarService.SetActivePage("commesse", null);
        
        if (jsModule != null)
        {
            await jsModule.DisposeAsync();
        }
        
        try
        {
            await SaveSettings();
        }
        catch { }
    }
    
    // Metodi pubblici per essere chiamati dalla AppBar
    public async Task OnSearchDebounced_Public(string value)
    {
        searchText = value;
        await OnSearchDebounced(value);
    }
    
    public async Task ToggleColumnPanel_Public() => await ToggleColumnPanel();
    public async Task ResetGrid_Public() => await ResetGrid();
    public async Task ExportCsv_Public() => await ExportCsv();
    public void ToggleSettings_Public()
    {
        showSettings = !showSettings;
        StateHasChanged();
    }

    private class GridStats
    {
        public int Total { get; set; }
        public int Filtered { get; set; }
        public int Selected { get; set; }
    }

    private class ColumnInfo
    {
        public string Field { get; set; } = string.Empty;
        public string HeaderName { get; set; } = string.Empty;
        public bool Visible { get; set; }
    }
}


