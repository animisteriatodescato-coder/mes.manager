@page "/cataloghi/commesse"
@inherits CatalogoGridBase
@using MESManager.Application.DTOs
@using MESManager.Web.Models
@using MESManager.Web.Services
@using MESManager.Web.Components.Dialogs
@inject HttpClient Http
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Catalogo Commesse</PageTitle>

<div class="mes-grid-page" data-testid="page-catalogo-commesse">
    <MudPaper Class="settings-panel toolbar-sticky pa-2 mb-1" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudTextField @bind-Value="searchText"
                         data-testid="input-commesse-search"
                         Placeholder="Cerca in tutte le colonne..."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Style="width: 280px;"
                         Immediate="true"
                         DebounceInterval="280"
                         OnDebounceIntervalElapsed="OnSearchDebounced" />
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ViewColumn" OnClick="@ToggleColumnPanel" data-testid="btn-commesse-columns">Colonne</MudButton>
            <FixResetMenu OnFix="@FixGridState" OnReset="@ResetToFixedState" />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" OnClick="@ExportCsv" data-testid="btn-commesse-export">Export CSV</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Settings" OnClick="@(() => showSettings = !showSettings)" data-testid="btn-commesse-settings">Impostazioni</MudButton>
        </MudStack>
        
        @if (showSettings)
        {
            <GridSettingsPanel @bind-Settings="settings" OnApplySettings="ApplyUiSettings" />
        }
    </MudPaper>

    <div id="commesseGrid" class="ag-theme-alpine mes-ag-grid" 
         data-testid="commesse-grid">
    </div>

    <MudPaper Class="footer-info pa-1 mt-2" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Totale: <strong>@totalRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Success">Aperte: <strong>@aperteCount</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Default">Chiuse: <strong>@chiuseCount</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Filtrate: <strong>@filteredRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Selezionate: <strong>@selectedRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Ultimo aggiornamento: <strong>@lastUpdate.ToString("HH:mm:ss")</strong></MudText>
            <MudSpacer />
            <MudChip T="string" Size="Size.Small" Color="@(isLoading ? Color.Warning : Color.Success)" 
                     Icon="@(isLoading ? Icons.Material.Filled.HourglassEmpty : Icons.Material.Filled.CheckCircle)"
                     data-testid="status-catalogo-commesse">
                @gridStatus
            </MudChip>
        </MudStack>
    </MudPaper>
</div>

<style>
    /* Gestione Colonne in dark mode */
    @@media (prefers-color-scheme: dark) {
        .ag-theme-alpine .ag-side-bar,
        .ag-theme-alpine .ag-tool-panel-wrapper,
        .ag-theme-alpine .ag-column-select-panel,
        .ag-theme-alpine .ag-column-panel {
            background-color: #1e1e1e !important;
        }

        .ag-theme-alpine .ag-column-select-header,
        .ag-theme-alpine .ag-column-select-column-label,
        .ag-theme-alpine .ag-column-select-column-group,
        .ag-theme-alpine .ag-column-select-header-label,
        .ag-theme-alpine .ag-filter-toolpanel-header {
            color: #201e1e !important;
        }

        .ag-theme-alpine .ag-input-field-input,
        .ag-theme-alpine .ag-text-field-input {
            background-color: #2d2d2d !important;
            color: #625454 !important;
            border-color: #444 !important;
        }
    }
</style>

@code {
    //  Identità griglia 
    protected override string GridNamespace => "commesseGrid";
    protected override string SettingsKey   => "commesse-grid";
    protected override string PageKey       => "commesse";

    private List<CommessaDto> _commesse = new();
    private int aperteCount = 0;
    private int chiuseCount = 0;
    private IJSObjectReference? jsModule;

    protected override async Task OnInitializedAsync()
    {
        PageToolbarService.SetActivePage(PageKey, this);
        _commesse   = await Http.GetFromJsonAsync<List<CommessaDto>>("api/Commesse") ?? new();
        totalRows   = _commesse.Count;
        aperteCount = _commesse.Count(c => c.Stato == "Aperta");
        chiuseCount = _commesse.Count(c => c.Stato == "Chiusa");
        lastUpdate  = DateTime.Now;
        await LoadSavedSettings();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("commesseGrid.setDotNetRef", DotNetObjectReference.Create(this));
            await InitializeGridJs(_commesse);
            jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/stats-listener.js");
            await jsModule.InvokeVoidAsync("subscribeToStatsChanges", DotNetObjectReference.Create(this));
        }
    }

    [JSInvokable]
    public async Task UpdateStats()
    {
        await UpdateGridStats();
    }

    [JSInvokable]
    public async Task ViewRicetta(string codiceArticolo)
    {
        try
        {
            var parameters = new DialogParameters<RicettaViewDialog>
            {
                { x => x.CodiceArticolo, codiceArticolo }
            };
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Large,
                CloseOnEscapeKey = true,
                CloseButton = true
            };
            await DialogService.ShowAsync<RicettaViewDialog>($"Ricetta: {codiceArticolo}", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore apertura ricetta: {ex.Message}", Severity.Error);
        }
    }

    [JSInvokable]
    public async Task SaveGridStateFromJs()
    {
        await SaveSettings();
    }

    public override async ValueTask DisposeAsync()
    {
        if (jsModule != null) await jsModule.DisposeAsync();
        await base.DisposeAsync();
    }
}