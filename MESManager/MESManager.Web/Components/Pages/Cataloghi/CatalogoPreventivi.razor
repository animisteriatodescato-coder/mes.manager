@page "/cataloghi/preventivi"
@using MESManager.Application.DTOs
@using MESManager.Domain.Enums
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Catalogo Preventivi</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4" data-testid="page-catalogo-preventivi">
    <!-- TOOLBAR -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4" Wrap="Wrap.Wrap">
        <MudText Typo="Typo.h5">Preventivi</MudText>
        <MudSpacer />
        
        <MudTextField @bind-Value="searchText" Placeholder="Cerca..." Variant="Variant.Outlined"
                 data-testid="input-preventivi-search"
                     Margin="Margin.Dense" Style="width:250px;" Immediate="true"
                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                     DebounceInterval="300" OnDebounceIntervalElapsed="@OnSearchChanged" />
        
        <MudSelect T="QuoteStatus?" @bind-Value="filterStatus" Label="Stato" Variant="Variant.Outlined"
              data-testid="select-preventivi-stato"
                  Margin="Margin.Dense" Dense="true" Style="width:150px;" Clearable="true">
            <MudSelectItem T="QuoteStatus?" Value="@((QuoteStatus?)null)">Tutti</MudSelectItem>
            <MudSelectItem T="QuoteStatus?" Value="@QuoteStatus.Draft">Bozza</MudSelectItem>
            <MudSelectItem T="QuoteStatus?" Value="@QuoteStatus.Sent">Inviato</MudSelectItem>
            <MudSelectItem T="QuoteStatus?" Value="@QuoteStatus.Accepted">Accettato</MudSelectItem>
            <MudSelectItem T="QuoteStatus?" Value="@QuoteStatus.Rejected">Rifiutato</MudSelectItem>
            <MudSelectItem T="QuoteStatus?" Value="@QuoteStatus.Expired">Scaduto</MudSelectItem>
        </MudSelect>
        
        <MudDateRangePicker @bind-DateRange="dateRange" Label="Periodo" Variant="Variant.Outlined"
                   data-testid="daterange-preventivi"
                           Margin="Margin.Dense" Style="width:280px;" Clearable="true" />
        
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.FilterAlt"
              OnClick="@ApplyFilters" data-testid="btn-preventivi-filtra">Filtra</MudButton>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Clear"
              OnClick="@ClearFilters" data-testid="btn-preventivi-reset">Reset</MudButton>
        
        <MudDivider Vertical="true" FlexItem="true" />
        
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.FileUpload"
              OnClick="@(() => showImportDialog = true)" data-testid="btn-preventivi-importa">Importa Listino</MudButton>
        
        <MudButton Variant="Variant.Filled" Color="Color.Primary" 
              StartIcon="@Icons.Material.Filled.Add"
              OnClick="@CreateNewQuote" data-testid="btn-preventivi-nuovo">Nuovo Preventivo</MudButton>
    </MudStack>

    <!-- STATISTICHE -->
    <MudGrid Spacing="2" Class="mb-4">
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Default" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption">Totale</MudText>
                        <MudText Typo="Typo.h6"><b>@quotes.Count</b></MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Default" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption">Bozze</MudText>
                        <MudText Typo="Typo.h6"><b>@quotes.Count(q => q.Status == QuoteStatus.Draft)</b></MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Send" Color="Color.Info" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption">Inviati</MudText>
                        <MudText Typo="Typo.h6"><b>@quotes.Count(q => q.Status == QuoteStatus.Sent)</b></MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption">Accettati</MudText>
                        <MudText Typo="Typo.h6"><b>@quotes.Count(q => q.Status == QuoteStatus.Accepted)</b></MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Euro" Color="Color.Primary" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption">Valore Accettati</MudText>
                        <MudText Typo="Typo.h6"><b>€ @quotes.Where(q => q.Status == QuoteStatus.Accepted).Sum(q => q.TotalGross).ToString("N0")</b></MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Percent" Color="Color.Secondary" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption">Tasso Conv.</MudText>
                        <MudText Typo="Typo.h6"><b>@CalculateConversionRate()%</b></MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- TABELLA PREVENTIVI -->
    <MudPaper Elevation="2">
        @if (isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        
        <MudTable Items="@filteredQuotes" Dense="true" Hover="true" Striped="true"
             data-testid="table-preventivi"
                 Loading="@isLoading" LoadingProgressColor="Color.Primary"
                 FixedHeader="true" Height="calc(100vh - 450px)">
            <HeaderContent>
                <MudTh><MudTableSortLabel T="QuoteDto" SortBy="@(x => x.Number)">Numero</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="QuoteDto" SortBy="@(x => x.Date)">Data</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="QuoteDto" SortBy="@(x => x.ClienteName)">Cliente</MudTableSortLabel></MudTh>
                <MudTh>Oggetto</MudTh>
                <MudTh Style="text-align:right;"><MudTableSortLabel T="QuoteDto" SortBy="@(x => x.TotalGross)">Totale</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="QuoteDto" SortBy="@(x => x.Status)">Stato</MudTableSortLabel></MudTh>
                <MudTh>Scadenza</MudTh>
                <MudTh Style="width:150px;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Numero">
                    <MudLink Href="@($"/cataloghi/preventivi/{context.Id}")">
                        <b>@context.Number</b>
                    </MudLink>
                </MudTd>
                <MudTd DataLabel="Data">@context.Date.ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Cliente">@context.ClienteName</MudTd>
                <MudTd DataLabel="Oggetto">
                    <MudText Style="max-width:250px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                        @context.Subject
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Totale" Style="text-align:right;">
                    <b>€ @context.TotalGross.ToString("N2")</b>
                </MudTd>
                <MudTd DataLabel="Stato">
                    <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">
                        @GetStatusLabel(context.Status)
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Scadenza">
                    @if (context.ValidUntil.HasValue)
                    {
                        var isExpired = context.ValidUntil.Value < DateTime.Today && context.Status == QuoteStatus.Sent;
                        <MudText Color="@(isExpired ? Color.Error : Color.Default)">
                            @context.ValidUntil.Value.ToString("dd/MM/yyyy")
                            @if (isExpired)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Color="Color.Error" />
                            }
                        </MudText>
                    }
                </MudTd>
                <MudTd>
                    <MudStack Row="true" Spacing="1">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                      OnClick="@(() => EditQuote(context))" Title="Modifica" data-testid="btn-preventivi-edit" />
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                      OnClick="@(() => DuplicateQuote(context))" Title="Duplica" data-testid="btn-preventivi-duplica" />
                        <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf" Size="Size.Small"
                                      OnClick="@(() => DownloadPdf(context))" Title="PDF" data-testid="btn-preventivi-pdf" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                      OnClick="@(() => DeleteQuote(context))" Title="Elimina"
                                      Disabled="@(context.Status != QuoteStatus.Draft)" data-testid="btn-preventivi-elimina" />
                    </MudStack>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" RowsPerPageString="Righe per pagina:" />
            </PagerContent>
            <NoRecordsContent>
                <MudText>Nessun preventivo trovato</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
</MudContainer>

<!-- DIALOG: Import Listino -->
<MudDialog @bind-Visible="showImportDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }" data-testid="dlg-preventivi-importa">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.FileUpload" Class="mr-2" />
            Importa Listino Prezzi
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="importPriceListName" Label="Nome Listino" Variant="Variant.Outlined"
                         Required="true" />
            <MudTextField @bind-Value="importPriceListVersion" Label="Versione" Variant="Variant.Outlined"
                         Required="true" Placeholder="es: 1.0, 2024.01" />
            <MudCheckBox @bind-Value="importAsDefault" Label="Imposta come listino predefinito" Color="Color.Primary" />
            
            <MudFileUpload T="IBrowserFile" FilesChanged="@OnImportFileSelected" Accept=".xlsx,.xls">
                <ActivatorContent>
                    <MudButton Variant="Variant.Outlined" FullWidth="true" StartIcon="@Icons.Material.Filled.CloudUpload" data-testid="btn-preventivi-importa-file">
                        @(importFile != null ? importFile.Name : "Seleziona file Excel")
                    </MudButton>
                </ActivatorContent>
            </MudFileUpload>

            @if (importResult != null)
            {
                <MudAlert Severity="@(importResult.Success ? Severity.Success : Severity.Error)" Dense="true">
                    @if (importResult.Success)
                    {
                        <span>Importati @importResult.ImportedCount articoli con successo.</span>
                    }
                    else
                    {
                        @if (importResult.Errors?.Any() == true)
                        {
                            <span>Errore: @string.Join(", ", importResult.Errors.Select(e => e.ErrorMessage).Take(3))</span>
                        }
                        else
                        {
                            <span>Errore: @(importResult.ErrorMessage ?? "Errore sconosciuto")</span>
                        }
                    }
                </MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseImportDialog" data-testid="btn-preventivi-importa-annulla">Annulla</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                  OnClick="@ImportPriceList" Disabled="@(importFile == null || isImporting)" data-testid="btn-preventivi-importa-conferma">
            @(isImporting ? "Importazione..." : "Importa")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<QuoteDto> quotes = new();
    private bool isLoading = true;
    
    // Filtri
    private string searchText = "";
    private QuoteStatus? filterStatus = null;
    private DateRange? dateRange = null;

    // Import dialog
    private bool showImportDialog = false;
    private IBrowserFile? importFile = null;
    private string importPriceListName = "";
    private string importPriceListVersion = "1.0";
    private bool importAsDefault = false;
    private bool isImporting = false;
    private ExcelImportResultDto? importResult = null;

    private IEnumerable<QuoteDto> filteredQuotes => quotes;

    protected override async Task OnInitializedAsync()
    {
        await LoadQuotes();
    }

    private async Task LoadQuotes()
    {
        try
        {
            isLoading = true;
            
            var url = "api/quotes";
            var queryParams = new List<string>();
            
            if (!string.IsNullOrWhiteSpace(searchText))
                queryParams.Add($"search={Uri.EscapeDataString(searchText)}");
            
            if (filterStatus.HasValue)
                queryParams.Add($"status={filterStatus.Value}");
            
            if (dateRange?.Start.HasValue == true)
                queryParams.Add($"fromDate={dateRange.Start.Value:yyyy-MM-dd}");
            
            if (dateRange?.End.HasValue == true)
                queryParams.Add($"toDate={dateRange.End.Value:yyyy-MM-dd}");
            
            if (queryParams.Any())
                url += "?" + string.Join("&", queryParams);

            var response = await Http.GetFromJsonAsync<List<QuoteDto>>(url);
            quotes = response ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore caricamento: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnSearchChanged(string value)
    {
        searchText = value;
        await LoadQuotes();
    }

    private async Task ApplyFilters()
    {
        await LoadQuotes();
    }

    private async Task ClearFilters()
    {
        searchText = "";
        filterStatus = null;
        dateRange = null;
        await LoadQuotes();
    }

    private void CreateNewQuote()
    {
        Nav.NavigateTo("/cataloghi/preventivi/nuovo");
    }

    private void EditQuote(QuoteDto quote)
    {
        Nav.NavigateTo($"/cataloghi/preventivi/{quote.Id}");
    }

    private async Task DuplicateQuote(QuoteDto quote)
    {
        try
        {
            var response = await Http.PostAsync($"api/quotes/{quote.Id}/duplicate", null);
            if (response.IsSuccessStatusCode)
            {
                var newQuote = await response.Content.ReadFromJsonAsync<QuoteDto>();
                Snackbar.Add($"Preventivo duplicato: {newQuote?.Number}", Severity.Success);
                await LoadQuotes();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore duplicazione: {ex.Message}", Severity.Error);
        }
    }

    private async Task DownloadPdf(QuoteDto quote)
    {
        try
        {
            var response = await Http.GetAsync($"api/quotes/{quote.Id}/pdf");
            if (response.IsSuccessStatusCode)
            {
                var bytes = await response.Content.ReadAsByteArrayAsync();
                var fileName = $"Preventivo_{quote.Number}.pdf";
                await JS.InvokeVoidAsync("downloadFile", bytes, fileName, "application/pdf");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore generazione PDF: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteQuote(QuoteDto quote)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Eliminare il preventivo {quote.Number}?");
        if (!confirmed) return;

        try
        {
            var response = await Http.DeleteAsync($"api/quotes/{quote.Id}");
            if (response.IsSuccessStatusCode)
            {
                quotes.Remove(quote);
                Snackbar.Add("Preventivo eliminato", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore eliminazione: {ex.Message}", Severity.Error);
        }
    }

    // Import Listino
    private void OnImportFileSelected(IBrowserFile file)
    {
        importFile = file;
        importResult = null;
    }

    private async Task ImportPriceList()
    {
        if (importFile == null || string.IsNullOrWhiteSpace(importPriceListName)) return;

        try
        {
            isImporting = true;
            importResult = null;

            var content = new MultipartFormDataContent();
            var stream = importFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            content.Add(new StreamContent(stream), "file", importFile.Name);
            content.Add(new StringContent(importPriceListName), "name");
            content.Add(new StringContent(importPriceListVersion), "version");
            content.Add(new StringContent(importAsDefault.ToString()), "isDefault");

            var response = await Http.PostAsync("api/pricelists/import", content);
            if (response.IsSuccessStatusCode)
            {
                importResult = await response.Content.ReadFromJsonAsync<ExcelImportResultDto>();
                if (importResult?.Success == true)
                {
                    Snackbar.Add($"Listino importato: {importResult.ImportedCount} articoli", Severity.Success);
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                importResult = new ExcelImportResultDto { Success = false, ErrorMessage = error };
            }
        }
        catch (Exception ex)
        {
            importResult = new ExcelImportResultDto { Success = false, ErrorMessage = ex.Message };
        }
        finally
        {
            isImporting = false;
        }
    }

    private void CloseImportDialog()
    {
        showImportDialog = false;
        importFile = null;
        importPriceListName = "";
        importPriceListVersion = "1.0";
        importAsDefault = false;
        importResult = null;
    }

    private Color GetStatusColor(QuoteStatus status) => status switch
    {
        QuoteStatus.Draft => Color.Default,
        QuoteStatus.Sent => Color.Info,
        QuoteStatus.Accepted => Color.Success,
        QuoteStatus.Rejected => Color.Error,
        QuoteStatus.Expired => Color.Warning,
        _ => Color.Default
    };

    private string GetStatusLabel(QuoteStatus status) => status switch
    {
        QuoteStatus.Draft => "Bozza",
        QuoteStatus.Sent => "Inviato",
        QuoteStatus.Accepted => "Accettato",
        QuoteStatus.Rejected => "Rifiutato",
        QuoteStatus.Expired => "Scaduto",
        _ => status.ToString()
    };

    private int CalculateConversionRate()
    {
        var closedQuotes = quotes.Count(q => q.Status == QuoteStatus.Accepted || q.Status == QuoteStatus.Rejected);
        if (closedQuotes == 0) return 0;
        var accepted = quotes.Count(q => q.Status == QuoteStatus.Accepted);
        return (int)Math.Round(100.0 * accepted / closedQuotes);
    }
}
