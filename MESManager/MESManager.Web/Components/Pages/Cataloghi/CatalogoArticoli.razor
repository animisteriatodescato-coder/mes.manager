@page "/cataloghi/articoli"
@inherits CatalogoGridBase
@using MESManager.Web.Models
@using MESManager.Web.Services
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Catalogo Articoli</PageTitle>

<div class="articoli-page" data-testid="page-catalogo-articoli">
    <div class="settings-panel">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap" Class="mb-3">
            <MudTextField @bind-Value="searchText"
                         data-testid="input-articoli-search"
                         Placeholder="Cerca in tutte le colonne..."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Style="width: 280px;"
                         Immediate="true"
                         DebounceInterval="280"
                         OnDebounceIntervalElapsed="OnSearchDebounced" />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ViewColumn" OnClick="@ToggleColumnPanel" data-testid="btn-articoli-columns">Colonne</MudButton>
            <FixResetMenu OnFix="@FixGridState" OnReset="@ResetToFixedState" />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" OnClick="@ExportCsv" data-testid="btn-articoli-export">Export CSV</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Settings" OnClick="@(() => showSettings = !showSettings)" data-testid="btn-articoli-settings">Impostazioni</MudButton>
        </MudStack>
    </div>
    
    @if (showSettings)
    {
        <GridSettingsPanel @bind-Settings="settings" OnApplySettings="ApplyUiSettings" />
    }

        <div id="articoliGrid" class="ag-theme-alpine" 
            data-testid="grid-catalogo-articoli"
         style="width: 100%; height: calc(100vh - 150px);">
    </div>

    <MudPaper Class="footer-info pa-1 mt-2" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Totale righe: <strong>@totalRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Righe filtrate: <strong>@filteredRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Righe selezionate: <strong>@selectedRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Ultimo aggiornamento: <strong>@lastUpdate.ToString("HH:mm:ss")</strong></MudText>
            <MudSpacer />
            <MudChip T="string" Size="Size.Small" Color="@(isLoading ? Color.Warning : Color.Success)" 
                     Icon="@(isLoading ? Icons.Material.Filled.HourglassEmpty : Icons.Material.Filled.CheckCircle)"
                     data-testid="status-catalogo-articoli">
                @gridStatus
            </MudChip>
        </MudStack>
    </MudPaper>
</div>

<style>
    .articoli-page {
        position: relative;
    }

    .toolbar-sticky {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--mud-palette-surface);
        padding: 0.1 rem 0;
        margin-bottom: 0.2rem;
    }
    
    .footer-info {
        position: sticky;
        bottom: 0;
        z-index: 10;
        background: var(--mud-palette-surface);
        border-top: 2px solid var(--mud-palette-primary);
    }

    /* Gestione Colonne in dark mode */
    @@media (prefers-color-scheme: dark) {
        .ag-theme-alpine .ag-side-bar,
        .ag-theme-alpine .ag-tool-panel-wrapper,
        .ag-theme-alpine .ag-column-select-panel,
        .ag-theme-alpine .ag-column-panel {
            background-color: var(--mes-bg-secondary) !important;
        }

        .ag-theme-alpine .ag-column-select-header,
        .ag-theme-alpine .ag-column-select-column-label,
        .ag-theme-alpine .ag-column-select-column-group,
        .ag-theme-alpine .ag-column-select-header-label,
        .ag-theme-alpine .ag-filter-toolpanel-header {
            color: var(--mes-text-primary) !important;
        }

        .ag-theme-alpine .ag-input-field-input,
        .ag-theme-alpine .ag-text-field-input {
            background-color: var(--mes-bg-surface) !important;
            color: var(--mes-text-primary) !important;
            border-color: var(--mes-grid-border) !important;
        }
    }
</style>

@code {
    //  Identità griglia (cambia SOLO queste 3 righe per un nuovo cliente) 
    protected override string GridNamespace => "articoliGrid";
    protected override string SettingsKey   => "articoli-grid";
    protected override string PageKey       => "articoli";

    private List<ArticoloDto> _articoli = new();
    private System.Threading.Timer? _statsTimer;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        gridStatus = "Caricamento...";
        PageToolbarService.SetActivePage(PageKey, this);
        StateHasChanged();

        _articoli    = await Http.GetFromJsonAsync<List<ArticoloDto>>("api/Articoli") ?? new();
        totalRows    = _articoli.Count;
        filteredRows = _articoli.Count;
        lastUpdate   = DateTime.Now;
        isLoading    = false;
        gridStatus   = "Pronto";

        await LoadSavedSettings();
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            await InitializeGridJs(_articoli);

            _statsTimer = new System.Threading.Timer(
                async _ => { try { await InvokeAsync(UpdateGridStats); } catch { } },
                null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
        }
    }

    public override async ValueTask DisposeAsync()
    {
        if (_statsTimer != null) { await _statsTimer.DisposeAsync(); _statsTimer = null; }
        await base.DisposeAsync();
    }

    private class ArticoloDto
    {
        public Guid     Id              { get; set; }
        public string   Codice          { get; set; } = string.Empty;
        public string   Descrizione     { get; set; } = string.Empty;
        public decimal  Prezzo          { get; set; }
        public bool     Attivo          { get; set; }
        public DateTime UltimaModifica  { get; set; }
        public DateTime TimestampSync   { get; set; }
    }
}