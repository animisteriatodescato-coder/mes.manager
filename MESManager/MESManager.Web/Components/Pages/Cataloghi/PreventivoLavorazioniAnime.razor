@page "/cataloghi/preventivi-anime/nuovo"  
@page "/cataloghi/preventivi-anime/{Id:guid}"
@using MESManager.Application.DTOs
@using MESManager.Domain.Enums
@inject HttpClient Http
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Preventivo Lavorazioni Anime</PageTitle>

<style>
    .header-preventivo {
        background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
        border-left: 4px solid #d32f2f;
        padding: 24px;
        margin-bottom: 16px;
    }
    
    .numero-preventivo {
        color: #d32f2f;
        font-size: 1.8rem;
        font-weight: 700;
        letter-spacing: 1px;
    }
    
    .table-preventivo {
        width: 100%;
        font-size: 0.85rem;
        border-collapse: collapse;
    }
    
    .table-preventivo th {
        background-color: #2c2c2c;
        color: white;
        padding: 12px 8px;
        text-align: center;
        font-weight: 600;
        white-space: nowrap;
        border: 1px solid #444;
    }
    
    .table-preventivo td {
        padding: 8px;
        border: 1px solid #ddd;
        vertical-align: middle;
    }
    
    .table-preventivo input[type="text"],
    .table-preventivo input[type="number"],
    .table-preventivo select {
        width: 100%;
        padding: 6px;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 0.85rem;
    }
    
    .table-preventivo tr:hover {
        background-color: #f9f9f9;
    }
    
    .totale-box {
        background: #1a1a1a;
        color: white;
        padding: 24px;
        border-radius: 8px;
        text-align: center;
        margin-top: 16px;
    }
    
    .totale-label {
        font-size: 0.9rem;
        opacity: 0.8;
        margin-bottom: 8px;
    }
    
    .totale-valore {
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 8px;
    }
    
    .margine-info {
        font-size: 0.85rem;
        opacity: 0.7;
    }
    
    .margine-badge {
        background: #d32f2f;
        color: white;
        padding: 8px 20px;
        border-radius: 24px;
        font-weight: 700;
        font-size: 1.1rem;
        display: inline-block;
    }
    
    .btn-aggiungi {
        background-color: #f5f5f5;
        border: 2px dashed #ccc;
        padding: 12px 24px;
        cursor: pointer;
        border-radius: 4px;
        margin-top: 8px;
        display: inline-block;
        color: #666;
        font-weight: 500;
    }
    
    .btn-aggiungi:hover {
        background-color: #e0e0e0;
        border-color: #999;
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="pa-4">
    
    <!-- HEADER -->
    <MudPaper Class="header-preventivo" Elevation="0">
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.h6"><b>La Mia Azienda</b></MudText>
                <MudText Typo="Typo.body2">Via Esempio, 1 - 00100 Roma</MudText>
            </MudItem>
            <MudItem xs="12" md="8" Style="text-align: right;">
                <div class="numero-preventivo">@numeroPreventivo</div>
                <MudText Typo="Typo.caption">N° Preventivo</MudText>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- INTESTAZIONE PREVENTIVO -->
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudGrid Spacing="3">
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="nomeCliente" Label="CLIENTE" Variant="Variant.Outlined" 
                             Margin="Margin.Dense" Placeholder="Nome cliente..." />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudDatePicker @bind-Date="dataPreventivo" Label="DATA" Variant="Variant.Outlined"
                              Margin="Margin.Dense" DateFormat="dd/MM/yyyy" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.body1" Style="width:120px;"><b>MARGINE (@marginePercent%)</b></MudText>
                    <MudSlider @bind-Value="marginePercent" Min="0" Max="50" Step="1" 
                              Color="Color.Error" Style="flex:1;" />
                    <div class="margine-badge">@marginePercent%</div>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- TABELLA ARTICOLI -->
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <table class="table-preventivo">
            <thead>
                <tr>
                    <th style="width:40px;">#</th>
                    <th style="width:100px;">CODICE</th>
                    <th style="width:180px;">DESCRIZIONE</th>
                    <th style="width:180px;">LAVORAZIONE</th>
                    <th style="width:80px;">PESO KG</th>
                    <th style="width:70px;">FIGURE</th>
                    <th style="width:70px;">LOTTO</th>
                    <th style="width:70px;">SPARI/H</th>
                    <th style="width:70px;">VERN./H</th>
                    <th style="width:70px;">INCOLL.</th>
                    <th style="width:70px;">IMB.</th>
                    <th style="width:60px;">QTÀ</th>
                    <th style="width:100px;">COSTO/PZ</th>
                    <th style="width:110px;">P.VENDITA/PZ</th>
                    <th style="width:50px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach(var riga in righePreventivo)
                {
                    <tr>
                        <td style="text-align:center;">@riga.Index</td>
                        <td>
                            <input type="text" @bind="riga.Codice" @bind:event="oninput" placeholder="COD" />
                        </td>
                        <td>
                            <input type="text" @bind="riga.Descrizione" @bind:event="oninput" placeholder="Descrizione..." />
                        </td>
                        <td>
                            <select @bind="riga.LavorazioneId" @bind:after="@(async () => await OnLavorazioneChanged(riga))">
                                <option value="">-- Seleziona --</option>
                                @foreach(var lav in tipiLavorazione)
                                {
                                    <option value="@lav.Id">@lav.Nome</option>
                                }
                            </select>
                        </td>
                        <td>
                            <input type="number" step="0.01" @bind="riga.PesoKg" @bind:event="oninput" 
                                  @bind:after="@(async () => await CalcolaPrezzoRiga(riga))" />
                        </td>
                        <td>
                            <input type="number" @bind="riga.Figure" @bind:event="oninput" 
                                  @bind:after="@(async () => await CalcolaPrezzoRiga(riga))" />
                        </td>
                        <td>
                            <input type="number" @bind="riga.Lotto" @bind:event="oninput"
                                  @bind:after="@(async () => await CalcolaPrezzoRiga(riga))" />
                        </td>
                        <td>
                            <input type="number" step="0.1" @bind="riga.SpariOrari" @bind:event="oninput"
                                  @bind:after="@(async () => await CalcolaPrezzoRiga(riga))" />
                        </td>
                        <td>
                            <input type="number" step="0.1" @bind="riga.VerniciaturaPezziOra" @bind:event="oninput"
                                  @bind:after="@(async () => await CalcolaPrezzoRiga(riga))" />
                        </td>
                        <td>
                            <input type="number" step="0.1" @bind="riga.IncollaggioOre" @bind:event="oninput"
                                  @bind:after="@(async () => await CalcolaPrezzoRiga(riga))" />
                        </td>
                        <td>
                            <input type="number" step="0.1" @bind="riga.ImballaggioOre" @bind:event="oninput"
                                  @bind:after="@(async () => await CalcolaPrezzoRiga(riga))" />
                        </td>
                        <td>
                            <input type="number" @bind="riga.Quantita" @bind:event="oninput"
                                  @bind:after="RicalcolaTotali" />
                        </td>
                        <td style="text-align:right; font-weight:600;">
                            € @riga.CostoPezzo.ToString("N2")
                        </td>
                        <td style="text-align:right; font-weight:600; color:#d32f2f;">
                            € @riga.PrezzoVenditaPezzo.ToString("N2")
                        </td>
                        <td style="text-align:center;">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" 
                                          Color="Color.Error" OnClick="@(() => RimuoviRiga(riga))" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        
        <div class="btn-aggiungi" @onclick="AggiungiArticolo">
            + Aggiungi articolo
        </div>
    </MudPaper>

    <MudGrid Spacing="3">
        <!-- NOTE -->
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.subtitle2" Class="mb-2"><b>NOTE</b></MudText>
                <MudTextField @bind-Value="note" Variant="Variant.Outlined" Lines="4" 
                             Placeholder="Note aggiuntive per il cliente..." />
            </MudPaper>
        </MudItem>
        
        <!-- TOTALE -->
        <MudItem xs="12" md="4">
            <div class="totale-box">
                <div class="totale-label">TOTALE PREVENTIVO</div>
                <div class="totale-valore">€ @totalePreventivo.ToString("N2")</div>
                <div class="margine-info">Margine incluso: @marginePercent%</div>
            </div>
        </MudItem>
    </MudGrid>

    <!-- AZIONI -->
    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd" Class="mt-4">
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" 
                  OnClick="@Indietro">Indietro</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.PictureAsPdf">
            Genera PDF
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                  OnClick="@SalvaPreventivo" Disabled="@salvataggioInCorso">
            @(salvataggioInCorso ? "Salvataggio..." : "Salva")
        </MudButton>
    </MudStack>

</MudContainer>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    // Dati preventivo
    private string numeroPreventivo = "PRV-2026-492";
    private string nomeCliente = "";
    private DateTime? dataPreventivo = DateTime.Today;
    private int marginePercent = 30;
    private string note = "";
    private decimal totalePreventivo = 0m;
    private bool salvataggioInCorso = false;

    // Liste master
    private List<WorkProcessingTypeDto> tipiLavorazione = new();
    private List<RigaPreventivo> righePreventivo = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Carica tipi lavorazione disponibili
            var response = await Http.GetFromJsonAsync<List<WorkProcessingTypeDto>>("api/workprocessing/types");
            tipiLavorazione = response?.Where(t => t.Attivo && !t.Archiviato).OrderBy(t => t.Ordinamento).ToList() ?? new();

            if (Id.HasValue)
            {
                // TODO: Carica preventivo esistente
            }
            else
            {
                // Nuovo preventivo - aggiungi riga vuota iniziale
                AggiungiArticolo();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore caricamento: {ex.Message}", Severity.Error);
        }
    }

    private void AggiungiArticolo()
    {
        righePreventivo.Add(new RigaPreventivo 
        { 
            Index = righePreventivo.Count + 1,
            Quantita = 1,
            Figure = 3,
            Lotto = 150,
            SpariOrari = 42
        });
    }

    private void RimuoviRiga(RigaPreventivo riga)
    {
        righePreventivo.Remove(riga);
        // Ricalcola indici
        for (int i = 0; i < righePreventivo.Count; i++)
        {
            righePreventivo[i].Index = i + 1;
        }
        RicalcolaTotali();
    }

    private async Task OnLavorazioneChanged(RigaPreventivo riga)
    {
        if (string.IsNullOrEmpty(riga.LavorazioneId)) return;
        
        try
        {
            // Carica parametri correnti per questa lavorazione
            var response = await Http.GetFromJsonAsync<WorkProcessingParameterDto>(
                $"api/workprocessing/types/{riga.LavorazioneId}/parameters");
            
            if (response != null)
            {
                riga.ParametriLavorazione = response;
                await CalcolaPrezzoRiga(riga);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore caricamento parametri: {ex.Message}", Severity.Warning);
        }
    }

    private async Task CalcolaPrezzoRiga(RigaPreventivo riga)
    {
        if (string.IsNullOrEmpty(riga.LavorazioneId) || riga.ParametriLavorazione == null)
        {
            return;
        }

        // Validazione input
        if (riga.PesoKg <= 0 || riga.Lotto <= 0 || riga.SpariOrari <= 0)
        {
            return;
        }

        try
        {
            // Chiama API di calcolo
            var input = new WorkProcessingCalculationInput
            {
                WorkProcessingTypeId = Guid.Parse(riga.LavorazioneId),
                PesoKg = riga.PesoKg,
                Figure = riga.Figure,
                Lotto = riga.Lotto,
                SpariOrari = riga.SpariOrari,
                VerniciaturaPezziOra = riga.VerniciaturaPezziOra,
                IncollaggioOre = riga.IncollaggioOre,
                ImballaggioOre = riga.ImballaggioOre,
                MarginePercent = marginePercent
            };

            var response = await Http.PostAsJsonAsync("api/workprocessing/calculate", input);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<WorkProcessingCalculationResult>();
                if (result != null)
                {
                    riga.CostoPezzo = result.CostoTotalePezzo;
                    riga.PrezzoVenditaPezzo = result.PrezzoVenditaPezzo;
                    
                    RicalcolaTotali();
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore calcolo: {ex.Message}", Severity.Error);
        }
    }

    private void RicalcolaTotali()
    {
        totalePreventivo = righePreventivo.Sum(r => r.PrezzoVenditaPezzo * r.Quantita);
    }

    private async Task SalvaPreventivo()
    {
        if (string.IsNullOrWhiteSpace(nomeCliente))
        {
            Snackbar.Add("Inserisci il nome del cliente", Severity.Warning);
            return;
        }

        if (righePreventivo.Count == 0)
        {
            Snackbar.Add("Aggiungi almeno un articolo", Severity.Warning);
            return;
        }

        try
        {
            salvataggioInCorso = true;
            
            // TODO: Implementare salvataggio completo

            await Task.Delay(500); // Simula salvataggio
            
            Snackbar.Add("Preventivo salvato con successo!", Severity.Success);
            Nav.NavigateTo("/cataloghi/preventivi");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore salvataggio: {ex.Message}", Severity.Error);
        }
        finally
        {
            salvataggioInCorso = false;
        }
    }

    private void Indietro()
    {
        Nav.NavigateTo("/cataloghi/preventivi");
    }

    // Classe helper per gestione righe
    private class RigaPreventivo
    {
        public int Index { get; set; }
        public string Codice { get; set; } = "";
        public string Descrizione { get; set; } = "";
        public string LavorazioneId { get; set; } = "";
        public decimal PesoKg { get; set; } = 0.34m;
        public int Figure { get; set; } = 3;
        public int Lotto { get; set; } = 150;
        public decimal SpariOrari { get; set; } = 42;
        public decimal VerniciaturaPezziOra { get; set; } = 0;
        public decimal IncollaggioOre { get; set; } = 0;
        public decimal ImballaggioOre { get; set; } = 0;
        public int Quantita { get; set; } = 1;
        public decimal CostoPezzo { get; set; } = 0m;
        public decimal PrezzoVenditaPezzo { get; set; } = 0m;
        
        public WorkProcessingParameterDto? ParametriLavorazione { get; set; }
    }
}
