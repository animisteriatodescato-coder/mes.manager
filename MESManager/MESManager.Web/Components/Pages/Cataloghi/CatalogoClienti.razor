@page "/cataloghi/clienti"

<PageTitle>Catalogo Clienti</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Catalogo Clienti</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mb-4" StartIcon="@Icons.Material.Filled.Add">
    Nuovo Cliente
</MudButton>

<MudTable Items="@_clienti" Hover="true" Breakpoint="Breakpoint.Sm" SortLabel="Ordina per" FixedHeader="true" Height="600px">
    <HeaderContent>
        <MudTh Style="min-width:120px;max-width:300px;font-size:1.3rem;font-weight:bold;background:#222;position:sticky;top:0;z-index:2;cursor:pointer;">Codice</MudTh>
        <MudTh Style="min-width:200px;max-width:600px;font-size:1.3rem;font-weight:bold;background:#222;position:sticky;top:0;z-index:2;cursor:pointer;">Ragione Sociale</MudTh>
        <MudTh Style="min-width:200px;max-width:400px;font-size:1.3rem;font-weight:bold;background:#222;position:sticky;top:0;z-index:2;cursor:pointer;">Email</MudTh>
        <MudTh Style="min-width:120px;max-width:300px;font-size:1.3rem;font-weight:bold;background:#222;position:sticky;top:0;z-index:2;cursor:pointer;">Note</MudTh>
        <MudTh Style="min-width:80px;max-width:120px;font-size:1.3rem;font-weight:bold;background:#222;position:sticky;top:0;z-index:2;cursor:pointer;">Attivo</MudTh>
        <MudTh Style="min-width:160px;max-width:200px;font-size:1.3rem;font-weight:bold;background:#222;position:sticky;top:0;z-index:2;cursor:pointer;">Ultima Modifica</MudTh>
        <MudTh Style="min-width:120px;max-width:200px;font-size:1.3rem;font-weight:bold;background:#222;position:sticky;top:0;z-index:2;cursor:pointer;">Sync</MudTh>
        <MudTh Style="min-width:80px;max-width:120px;font-size:1.3rem;font-weight:bold;background:#222;position:sticky;top:0;z-index:2;">Azioni</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Codice">@context.Codice</MudTd>
        <MudTd DataLabel="Ragione Sociale">@context.RagioneSociale</MudTd>
        <MudTd DataLabel="Email">@context.Email</MudTd>
        <MudTd DataLabel="Note">@context.Note</MudTd>
        <MudTd DataLabel="Attivo">@context.Attivo</MudTd>
        <MudTd DataLabel="Ultima Modifica">@context.UltimaModifica.ToString("g")</MudTd>
        <MudTd DataLabel="Sync">@context.TimestampSync.ToString("g")</MudTd>
        <MudTd DataLabel="Azioni">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
        </MudTd>
    </RowTemplate>
</MudTable>

@inject HttpClient Http
@inject NavigationManager Nav

@code {
    private List<ClienteDto> _clienti = new();

    protected override async Task OnInitializedAsync()
    {
        Http.BaseAddress = new Uri(Nav.BaseUri);
        _clienti = await Http.GetFromJsonAsync<List<ClienteDto>>("api/Clienti");
    }

    private class ClienteDto
    {
        public Guid Id { get; set; }
        public string Codice { get; set; } = string.Empty;
        public string RagioneSociale { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Note { get; set; } = string.Empty;
        public bool Attivo { get; set; }
        public DateTime UltimaModifica { get; set; }
        public DateTime TimestampSync { get; set; }
    }
}
