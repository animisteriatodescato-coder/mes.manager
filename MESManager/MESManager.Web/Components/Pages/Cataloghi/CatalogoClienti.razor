@page "/cataloghi/clienti"
@using MESManager.Web.Models
@using MESManager.Web.Services
@using Microsoft.JSInterop
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject PreferencesService PreferencesService
@inject IJSRuntime JSRuntime
@inject IPageToolbarService PageToolbarService
@implements IAsyncDisposable

<PageTitle>Catalogo Clienti</PageTitle>

<div class="clienti-page" data-testid="page-catalogo-clienti" style="display: flex; flex-direction: column; height: calc(100vh - 100px); overflow: hidden;">
    <div class="settings-panel">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap" Class="mb-3">
            <MudTextField @bind-Value="searchText"
                         data-testid="input-clienti-search"
                         Placeholder="Cerca in tutte le colonne..."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Style="width: 280px;"
                         Immediate="true"
                         DebounceInterval="280"
                         OnDebounceIntervalElapsed="OnSearchDebounced" />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ViewColumn" OnClick="@ToggleColumnPanel" data-testid="btn-clienti-columns">Colonne</MudButton>
            <FixResetMenu OnFix="@FixGridState" OnReset="@ResetToFixedState" />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" OnClick="@ExportCsv" data-testid="btn-clienti-export">Export CSV</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Settings" OnClick="@(() => showSettings = !showSettings)" data-testid="btn-clienti-settings">Impostazioni</MudButton>
        </MudStack>
    </div>
    
    @if (showSettings)
    {
        <MudPaper Class="pa-4 mt-2" Elevation="1">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Wrap="Wrap.Wrap">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText>Font Size:</MudText>
                    <MudNumericField Value="@settings.FontSize" Min="10" Max="24" Step="1" 
                                    Variant="Variant.Outlined" Margin="Margin.Dense"
                                    ValueChanged="@(async (int val) => { settings.FontSize = val; await ApplyUiSettings(); })" 
                                    Style="width: 80px;" />
                </MudStack>
                
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText>Row Height:</MudText>
                    <MudNumericField Value="@settings.RowHeight" Min="25" Max="80" Step="5" 
                                    Variant="Variant.Outlined" Margin="Margin.Dense"
                                    ValueChanged="@(async (int val) => { settings.RowHeight = val; await ApplyUiSettings(); })" 
                                    Style="width: 80px;" />
                </MudStack>
                
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText>Density:</MudText>
                    <MudSelect Value="@settings.Density" 
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              ValueChanged="@(async (string val) => { settings.Density = val; await ApplyUiSettings(); })" 
                              Style="width: 120px;">
                        <MudSelectItem Value="@("Compact")">Compact</MudSelectItem>
                        <MudSelectItem Value="@("Normal")">Normal</MudSelectItem>
                        <MudSelectItem Value="@("Comfortable")">Comfortable</MudSelectItem>
                    </MudSelect>
                </MudStack>
                
                <MudCheckBox Value="@settings.Zebra" Label="Zebra" Color="Color.Primary"
                            ValueChanged="@(async (bool val) => { settings.Zebra = val; await ApplyUiSettings(); })" />
                
                <MudCheckBox Value="@settings.GridLines" Label="Grid Lines" Color="Color.Primary"
                            ValueChanged="@(async (bool val) => { settings.GridLines = val; await ApplyUiSettings(); })" />
            </MudStack>
        </MudPaper>
    }

        <div id="clientiGrid" class="ag-theme-alpine" 
            data-testid="grid-catalogo-clienti"
         style="width: 100%; flex: 1; min-height: 0;">
    </div>

    <MudPaper Class="footer-info pa-1" Elevation="1" Style="flex-shrink: 0;">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Totale righe: <strong>@totalRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Righe filtrate: <strong>@filteredRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Righe selezionate: <strong>@selectedRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Ultimo aggiornamento: <strong>@lastUpdate.ToString("HH:mm:ss")</strong></MudText>
            <MudSpacer />
            <MudChip T="string" Size="Size.Small" Color="@(isLoading ? Color.Warning : Color.Success)" 
                     Icon="@(isLoading ? Icons.Material.Filled.HourglassEmpty : Icons.Material.Filled.CheckCircle)"
                     data-testid="status-catalogo-clienti">
                @gridStatus
            </MudChip>
        </MudStack>
    </MudPaper>
</div>

<style>
    .clienti-page {
        position: relative;
    }

    .toolbar-sticky {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--mud-palette-surface);
        padding: 0.1 rem 0;
        margin-bottom: 0.2rem;
    }

    /* Gestione Colonne in dark mode */
    @@media (prefers-color-scheme: dark) {
        .ag-theme-alpine .ag-side-bar,
        .ag-theme-alpine .ag-tool-panel-wrapper,
        .ag-theme-alpine .ag-column-select-panel,
        .ag-theme-alpine .ag-column-panel {
            background-color: #1e1e1e !important;
        }

        .ag-theme-alpine .ag-column-select-header,
        .ag-theme-alpine .ag-column-select-column-label,
        .ag-theme-alpine .ag-column-select-column-group,
        .ag-theme-alpine .ag-column-select-header-label,
        .ag-theme-alpine .ag-filter-toolpanel-header {
            color: #201e1e !important;
        }

        .ag-theme-alpine .ag-input-field-input,
        .ag-theme-alpine .ag-text-field-input {
            background-color: #2d2d2d !important;
            color: #333232 !important;
            border-color: #444 !important;
        }
    }
</style>

@code {
    private List<ClienteDto> _clienti = new();
    private GridUiSettings settings = new();
    private bool showSettings = false;
    private string searchText = string.Empty;
    private IJSObjectReference? jsModule = null;

    private int totalRows = 0;
    private int filteredRows = 0;
    private int selectedRows = 0;
    private DateTime lastUpdate = DateTime.MinValue;
    private bool isLoading = false;
    private string gridStatus = "Pronto";

    private async Task OnSearchDebounced(string value)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("clientiGrid.setQuickFilter", value);
        }
        catch
        {
            // Error filtering grid
        }
    }

    protected override async Task OnInitializedAsync()
    {
        PageToolbarService.SetActivePage("clienti", this);
        
        _clienti = await Http.GetFromJsonAsync<List<ClienteDto>>("api/Clienti") ?? new();
        
        var savedSettings = await PreferencesService.GetAsync<GridUiSettings>("clienti-grid-settings");
        if (savedSettings != null)
        {
            settings = savedSettings;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            await InitializeGrid();
            
            // Subscribe to stats changes
            jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/stats-listener-clienti.js");
            await jsModule.InvokeVoidAsync("subscribeToStatsChanges", DotNetObjectReference.Create(this));
        }
    }

    private async Task InitializeGrid()
    {
        try
        {
            var exists = await JSRuntime.InvokeAsync<bool>("eval", "typeof window.clientiGrid !== 'undefined'");
            if (!exists)
            {
                // clientiGrid is not defined
                return;
            }

            await JSRuntime.InvokeVoidAsync("clientiGrid.init", "clientiGrid", _clienti, settings.ColumnStateJson);
            await ApplyUiSettings();
        }
        catch
        {
            // Error initializing grid
        }
    }

    private async Task ToggleColumnPanel()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("clientiGrid.toggleColumnPanel");
        }
        catch { }
    }

    private async Task FixGridState()
    {
        try
        {
            var gridState = await JSRuntime.InvokeAsync<string>("clientiGrid.getState");
            await PreferencesService.SetAsync("clienti-grid-fixed-state", gridState);
            await PreferencesService.SetAsync("clienti-grid-fixed-settings", JsonSerializer.Serialize(settings));
        }
        catch { }
    }

    private async Task ResetToFixedState()
    {
        try
        {
            var fixedState = await PreferencesService.GetAsync<string>("clienti-grid-fixed-state");
            var fixedSettings = await PreferencesService.GetAsync<string>("clienti-grid-fixed-settings");
            
            if (!string.IsNullOrEmpty(fixedState))
            {
                await JSRuntime.InvokeVoidAsync("clientiGrid.setState", fixedState);
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("clientiGrid.resetState");
            }
            
            if (!string.IsNullOrEmpty(fixedSettings))
            {
                settings = JsonSerializer.Deserialize<GridUiSettings>(fixedSettings) ?? new GridUiSettings();
            }
            else
            {
                settings = new GridUiSettings();
            }
            
            await ApplyUiSettings();
            StateHasChanged();
        }
        catch { }
    }

    private async Task ExportCsv()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("clientiGrid.exportCsv");
        }
        catch { }
    }

    private async Task ApplyUiSettings()
    {
        try
        {
            var densityPadding = GetDensityPadding();
            await JSRuntime.InvokeVoidAsync("clientiGrid.setUiVars", 
                settings.FontSize, 
                settings.RowHeight, 
                densityPadding,
                settings.Zebra,
                settings.GridLines);
            await SaveSettings();
            StateHasChanged();
        }
        catch { }
    }

    private string GetDensityPadding()
    {
        return settings.Density switch
        {
            "Compact" => "4px",
            "Comfortable" => "12px",
            _ => "8px"
        };
    }

    private async Task SaveSettings()
    {
        try
        {
            var state = await JSRuntime.InvokeAsync<string>("clientiGrid.getState");
            settings.ColumnStateJson = state;
            await PreferencesService.SetAsync("clienti-grid-settings", settings);
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        // Deregistra questa pagina
        PageToolbarService.SetActivePage("clienti", null);
        
        if (jsModule != null)
        {
            await jsModule.DisposeAsync();
        }
        
        try
        {
            await SaveSettings();
        }
        catch { }
    }
    
    [JSInvokable]
    public async Task UpdateStats()
    {
        try
        {
            var stats = await JSRuntime.InvokeAsync<GridStats>("clientiGrid.getStats");
            totalRows = stats.Total;
            filteredRows = stats.Filtered;
            selectedRows = stats.Selected;
            lastUpdate = DateTime.Now;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[CLIENTI] Error updating stats: {ex.Message}");
        }
    }
    
    // Metodi pubblici per essere chiamati dalla AppBar
    public async Task OnSearchDebounced_Public(string value)
    {
        searchText = value;
        await OnSearchDebounced(value);
    }
    
    public async Task ToggleColumnPanel_Public() => await ToggleColumnPanel();
    public async Task ResetGrid_Public() => await ResetToFixedState();
    public async Task ExportCsv_Public() => await ExportCsv();
    public void ToggleSettings_Public()
    {
        showSettings = !showSettings;
        StateHasChanged();
    }

    private class ClienteDto
    {
        public Guid Id { get; set; }
        public string Codice { get; set; } = string.Empty;
        public string RagioneSociale { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Note { get; set; } = string.Empty;
        public bool Attivo { get; set; }
        public DateTime UltimaModifica { get; set; }
        public DateTime TimestampSync { get; set; }
    }
    
    private class GridStats
    {
        public int Total { get; set; }
        public int Filtered { get; set; }
        public int Selected { get; set; }
    }
}
