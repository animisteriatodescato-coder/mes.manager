@page "/cataloghi/anime"
@using MESManager.Web.Models
@using MESManager.Web.Services
@using MESManager.Application.DTOs
@using MESManager.Application.Services
@using MESManager.Web.Components.Dialogs
@using Microsoft.JSInterop
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject PreferencesService PreferencesService
@inject CurrentUserService CurrentUserService
@inject IJSRuntime JSRuntime
@inject IPageToolbarService PageToolbarService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@implements IAsyncDisposable

<PageTitle>Catalogo Anime</PageTitle>

<div class="anime-page" data-testid="page-catalogo-anime">
    <div class="settings-panel">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap" Class="mb-3">
            <MudTextField @bind-Value="searchText"
                         data-testid="input-anime-search"
                         Placeholder="Cerca in tutte le colonne..."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Style="width: 280px;"
                         Immediate="true"
                         DebounceInterval="280"
                         OnDebounceIntervalElapsed="OnSearchDebounced" />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="@RefreshGridData" data-testid="btn-anime-refresh">Aggiorna</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ViewColumn" OnClick="@ToggleColumnPanel" data-testid="btn-anime-columns">Colonne</MudButton>
            <FixResetMenu OnFix="@FixGridState" OnReset="@ResetToFixedState" />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" OnClick="@ExportCsv" data-testid="btn-anime-export">Export CSV</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Settings" OnClick="@(() => showSettings = !showSettings)" data-testid="btn-anime-settings">Impostazioni</MudButton>
        </MudStack>
        
        @if (showSettings)
        {
            <GridSettingsPanel @bind-Settings="settings" OnApplySettings="ApplyUiSettings" />
        }
    </div>

        <div id="animeGrid" class="ag-theme-alpine" 
            data-testid="grid-catalogo-anime"
         style="width: 100%; height: calc(100vh - 150px);">
    </div>

    <MudPaper Class="footer-info pa-1 mt-2" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Totale righe: <strong>@totalRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Righe filtrate: <strong>@filteredRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Righe selezionate: <strong>@selectedRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Ultimo aggiornamento: <strong>@lastUpdate.ToString("HH:mm:ss")</strong></MudText>
            <MudSpacer />
            <MudChip T="string" Size="Size.Small" Color="@(isLoading ? Color.Warning : Color.Success)" 
                     Icon="@(isLoading ? Icons.Material.Filled.HourglassEmpty : Icons.Material.Filled.CheckCircle)"
                     data-testid="status-catalogo-anime">
                @gridStatus
            </MudChip>
        </MudStack>
    </MudPaper>
</div>

<style>
    .anime-page {
        position: relative;
    }

    .toolbar-sticky {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--mud-palette-surface);
        padding: 0.1rem 0;
        margin-bottom: 0.2rem;
    }

    @@media (prefers-color-scheme: dark) {
        .ag-theme-alpine .ag-side-bar,
        .ag-theme-alpine .ag-tool-panel-wrapper,
        .ag-theme-alpine .ag-column-select-panel,
        .ag-theme-alpine .ag-column-panel {
            background-color: #1e1e1e !important;
        }

        .ag-theme-alpine .ag-column-select-header,
        .ag-theme-alpine .ag-column-select-column-label,
        .ag-theme-alpine .ag-column-select-column-group,
        .ag-theme-alpine .ag-column-select-header-label,
        .ag-theme-alpine .ag-filter-toolpanel-header {
            color: #201e1e !important;
        }

        .ag-theme-alpine .ag-input-field-input,
        .ag-theme-alpine .ag-text-field-input {
            background-color: #2d2d2d !important;
            color: #333232 !important;
            border-color: #444 !important;
        }
    }
</style>

@code {
    private List<AnimeDto> _anime = new();
    private GridUiSettings settings = new();
    private bool showSettings = false;
    private string searchText = string.Empty;
    private DotNetObjectReference<CatalogoAnime>? _dotNetRef;

    private int totalRows = 0;
    private int filteredRows = 0;
    private int selectedRows = 0;
    private DateTime lastUpdate = DateTime.MinValue;
    private bool isLoading = false;
    private string gridStatus = "Pronto";
    private bool _isDataLoaded = false;
    private bool _isGridInitialized = false;

    private async Task OnSearchDebounced(string value)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("animeGrid.setQuickFilter", value);
        }
        catch
        {
            // Error filtering grid
        }
    }

    protected override async Task OnInitializedAsync()
    {
        PageToolbarService.SetActivePage("anime", this);
        
        isLoading = true;
        gridStatus = "Caricamento...";
        
        _anime = await Http.GetFromJsonAsync<List<AnimeDto>>("api/Anime") ?? new();
        
        _isDataLoaded = true;
        isLoading = false;
        gridStatus = "Pronto";
        
        var savedSettings = await PreferencesService.GetAsync<GridUiSettings>("anime-grid-settings");
        if (savedSettings != null)
        {
            settings = savedSettings;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Aspetta che i dati siano caricati con un loop (max 30 secondi)
            int maxWait = 150; // 150 * 200ms = 30 secondi
            int waited = 0;
            while (!_isDataLoaded && waited < maxWait)
            {
                await Task.Delay(200);
                waited++;
            }
            
            if (_isDataLoaded && !_isGridInitialized)
            {
                _isGridInitialized = true;
                await Task.Delay(100);
                await InitializeGrid();
            }
        }
    }

    private async Task RefreshGridData()
    {
        try
        {
            isLoading = true;
            gridStatus = "Aggiornamento...";
            StateHasChanged();
            
            _anime = await Http.GetFromJsonAsync<List<AnimeDto>>("api/Anime") ?? new();
            
            await JSRuntime.InvokeVoidAsync("animeGrid.updateData", _anime, null);
            await UpdateGridStats();
            
            isLoading = false;
            gridStatus = "Pronto";
            StateHasChanged();
        }
        catch
        {
            // Error refreshing grid data
            isLoading = false;
            gridStatus = "Errore";
            StateHasChanged();
        }
    }

    private async Task InitializeGrid()
    {
        try
        {
            var exists = await JSRuntime.InvokeAsync<bool>("eval", "typeof window.animeGrid !== 'undefined'");
            if (!exists)
            {
                // animeGrid is not defined
                return;
            }

            // Imposta l'utente corrente per la griglia (per salvare le preferenze per-utente)
            var userId = CurrentUserService.CurrentUserId?.ToString() ?? "";
            await JSRuntime.InvokeVoidAsync("animeGrid.setCurrentUser", userId);
            
            // Inizializza la grid con lo stato colonne salvato nelle preferenze
            await JSRuntime.InvokeVoidAsync("animeGrid.init", "animeGrid", _anime, settings.ColumnStateJson);
            
            // Registra DotNetObjectReference per callback JS->Blazor (double-click)
            _dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("animeGrid.registerDotNetRef", _dotNetRef);
            
            await ApplyUiSettings();
            
            // Aggiorna le statistiche dopo l'inizializzazione
            await UpdateGridStats();
        }
        catch
        {
            // Error initializing grid
        }
    }

    private async Task ToggleColumnPanel()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("animeGrid.toggleColumnPanel");
        }
        catch { }
    }

    private async Task FixGridState()
    {
        try
        {
            var gridState = await JSRuntime.InvokeAsync<string>("animeGrid.getState");
            await PreferencesService.SetAsync("anime-grid-fixed-state", gridState);
            await PreferencesService.SetAsync("anime-grid-fixed-settings", JsonSerializer.Serialize(settings));
        }
        catch { }
    }

    private async Task ResetToFixedState()
    {
        try
        {
            var fixedState = await PreferencesService.GetAsync<string>("anime-grid-fixed-state");
            var fixedSettings = await PreferencesService.GetAsync<string>("anime-grid-fixed-settings");
            
            if (!string.IsNullOrEmpty(fixedState))
            {
                await JSRuntime.InvokeVoidAsync("animeGrid.setState", fixedState);
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("animeGrid.resetState");
            }
            
            if (!string.IsNullOrEmpty(fixedSettings))
            {
                settings = JsonSerializer.Deserialize<GridUiSettings>(fixedSettings) ?? new GridUiSettings();
            }
            else
            {
                settings = new GridUiSettings();
            }
            
            await ApplyUiSettings();
            StateHasChanged();
        }
        catch { }
    }

    private async Task ExportCsv()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("animeGrid.exportCsv");
        }
        catch { }
    }

    private async Task ApplyUiSettings()
    {
        try
        {
            var densityPadding = GetDensityPadding();
            await JSRuntime.InvokeVoidAsync("animeGrid.setUiVars", 
                settings.FontSize, 
                settings.RowHeight, 
                densityPadding,
                settings.Zebra,
                settings.GridLines);
            await SaveSettings();
            StateHasChanged();
        }
        catch { }
    }

    private string GetDensityPadding()
    {
        return settings.Density switch
        {
            "Compact" => "4px",
            "Comfortable" => "12px",
            _ => "8px"
        };
    }

    private async Task SaveSettings()
    {
        try
        {
            var state = await JSRuntime.InvokeAsync<string>("animeGrid.getState");
            settings.ColumnStateJson = state;
            await PreferencesService.SetAsync("anime-grid-settings", settings);
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        PageToolbarService.SetActivePage("anime", null);
        
        try
        {
            await SaveSettings();
            _dotNetRef?.Dispose();
        }
        catch { }
    }

    [JSInvokable]
    public async Task OnRowDoubleClicked(AnimeDto anime)
    {
        try
        {
            var parameters = new DialogParameters<AnimeEditDialog>
            {
                { x => x.Anime, anime }
            };
            
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Large,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            
            var dialog = await DialogService.ShowAsync<AnimeEditDialog>("Modifica Anima", parameters, options);
            var result = await dialog.Result;
            
            if (result != null && !result.Canceled && result.Data is AnimeDto updatedAnime)
            {
                // Aggiorna i dati nella griglia
                var index = _anime.FindIndex(a => a.Id == updatedAnime.Id);
                if (index >= 0)
                {
                    _anime[index] = updatedAnime;
                    // Passa l'ID per mantenere la selezione sulla riga modificata
                    await JSRuntime.InvokeVoidAsync("animeGrid.updateData", _anime, updatedAnime.Id);
                    Snackbar.Add("Anima aggiornata con successo", Severity.Success);
                }
            }
        }
        catch (Exception ex)
        {
            // Error opening edit dialog
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }
    
    [JSInvokable]
    public async Task ViewRicetta(string codiceArticolo)
    {
        try
        {
            var parameters = new DialogParameters<RicettaViewDialog>
            {
                { x => x.CodiceArticolo, codiceArticolo }
            };
            
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Large,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            
            await DialogService.ShowAsync<RicettaViewDialog>("Visualizza Ricetta", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore apertura ricetta: {ex.Message}", Severity.Error);
        }
    }
    
    // Metodi pubblici per essere chiamati dalla AppBar
    public async Task OnSearchDebounced_Public(string value)
    {
        searchText = value;
        await OnSearchDebounced(value);
    }
    
    public async Task ToggleColumnPanel_Public() => await ToggleColumnPanel();
    public async Task ResetGrid_Public() => await ResetToFixedState();
    public async Task ExportCsv_Public() => await ExportCsv();
    public void ToggleSettings_Public()
    {
        showSettings = !showSettings;
        StateHasChanged();
    }

    private async Task UpdateGridStats()
    {
        try
        {
            var stats = await JSRuntime.InvokeAsync<GridStats>("animeGrid.getStats");
            totalRows = stats.Total;
            filteredRows = stats.Filtered;
            selectedRows = stats.Selected;
            lastUpdate = DateTime.Now;
            StateHasChanged();
        }
        catch
        {
            // Error updating stats
        }
    }

    private class GridStats
    {
        public int Total { get; set; }
        public int Filtered { get; set; }
        public int Selected { get; set; }
    }
}
