@page "/cataloghi/anime"
@inherits CatalogoGridBase
@using MESManager.Web.Models
@using MESManager.Web.Services
@using MESManager.Application.DTOs
@using MESManager.Application.Services
@using MESManager.Web.Components.Dialogs
@inject HttpClient Http
@inject NavigationManager Nav
@inject CurrentUserService CurrentUserService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Catalogo Anime</PageTitle>

<div class="mes-grid-page" data-testid="page-catalogo-anime">
    <MudPaper Class="settings-panel toolbar-sticky pa-2 mb-1" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudTextField @bind-Value="searchText"
                         data-testid="input-anime-search"
                         Placeholder="Cerca in tutte le colonne..."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Style="width: 280px;"
                         Immediate="true"
                         DebounceInterval="280"
                         OnDebounceIntervalElapsed="OnSearchDebounced" />
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="@RefreshGridData" data-testid="btn-anime-refresh">Aggiorna</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ViewColumn" OnClick="@ToggleColumnPanel" data-testid="btn-anime-columns">Colonne</MudButton>
            <FixResetMenu OnFix="@FixGridState" OnReset="@ResetToFixedState" />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" OnClick="@ExportCsv" data-testid="btn-anime-export">Export CSV</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Settings" OnClick="@(() => showSettings = !showSettings)" data-testid="btn-anime-settings">Impostazioni</MudButton>
        </MudStack>
        
        @if (showSettings)
        {
            <GridSettingsPanel @bind-Settings="settings" OnApplySettings="ApplyUiSettings" />
        }
    </MudPaper>

    <div id="animeGrid" class="ag-theme-alpine mes-ag-grid" 
         data-testid="grid-catalogo-anime">
    </div>

    <MudPaper Class="footer-info pa-1 mt-2" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Totale righe: <strong>@totalRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Righe filtrate: <strong>@filteredRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Righe selezionate: <strong>@selectedRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Ultimo aggiornamento: <strong>@lastUpdate.ToString("HH:mm:ss")</strong></MudText>
            <MudSpacer />
            <MudChip T="string" Size="Size.Small" Color="@(isLoading ? Color.Warning : Color.Success)" 
                     Icon="@(isLoading ? Icons.Material.Filled.HourglassEmpty : Icons.Material.Filled.CheckCircle)"
                     data-testid="status-catalogo-anime">
                @gridStatus
            </MudChip>
        </MudStack>
    </MudPaper>
</div>

@code {
    //  Identità griglia 
    protected override string GridNamespace => "animeGrid";
    protected override string SettingsKey   => "anime-grid";
    protected override string PageKey       => "anime";

    private List<AnimeDto> _anime = new();
    private DotNetObjectReference<CatalogoAnime>? _dotNetRef;
    private bool _isDataLoaded    = false;
    private bool _isGridInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        PageToolbarService.SetActivePage(PageKey, this);
        isLoading = true;
        gridStatus = "Caricamento...";
        StateHasChanged();

        _anime = await Http.GetFromJsonAsync<List<AnimeDto>>("api/Anime") ?? new();
        _isDataLoaded = true;
        isLoading = false;
        gridStatus = "Pronto";

        await LoadSavedSettings();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            int maxWait = 150;
            int waited  = 0;
            while (!_isDataLoaded && waited < maxWait)
            {
                await Task.Delay(200);
                waited++;
            }

            if (_isDataLoaded && !_isGridInitialized)
            {
                _isGridInitialized = true;
                await Task.Delay(100);

                var userId = CurrentUserService.CurrentUserId?.ToString() ?? "";
                await JSRuntime.InvokeVoidAsync("animeGrid.setCurrentUser", userId);

                _dotNetRef = DotNetObjectReference.Create(this);
                await InitializeGridJs(_anime);
                await JSRuntime.InvokeVoidAsync("animeGrid.registerDotNetRef", _dotNetRef);
                await UpdateGridStats();
            }
        }
    }

    private async Task RefreshGridData()
    {
        try
        {
            isLoading = true;
            gridStatus = "Aggiornamento...";
            StateHasChanged();

            _anime = await Http.GetFromJsonAsync<List<AnimeDto>>("api/Anime") ?? new();
            await JSRuntime.InvokeVoidAsync("animeGrid.updateData", _anime, null);
            await UpdateGridStats();

            isLoading = false;
            gridStatus = "Pronto";
            StateHasChanged();
        }
        catch
        {
            isLoading = false;
            gridStatus = "Errore";
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnRowDoubleClicked(AnimeDto anime)
    {
        try
        {
            var parameters = new DialogParameters<AnimeEditDialog>
            {
                { x => x.Anime, anime }
            };
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Large,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            var dialog = await DialogService.ShowAsync<AnimeEditDialog>("Modifica Anima", parameters, options);
            var result = await dialog.Result;

            if (result != null && !result.Canceled && result.Data is AnimeDto updatedAnime)
            {
                var index = _anime.FindIndex(a => a.Id == updatedAnime.Id);
                if (index >= 0)
                {
                    _anime[index] = updatedAnime;
                    await JSRuntime.InvokeVoidAsync("animeGrid.updateData", _anime, updatedAnime.Id);
                    Snackbar.Add("Anima aggiornata con successo", Severity.Success);
                }
            }
            else
            {
                // Dialog annullato: refresha comunque la cella foto per mostrare foto appena caricate/eliminate
                await JSRuntime.InvokeVoidAsync("animeGrid.refreshFotoRow", anime.Id);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    [JSInvokable]
    public async Task ViewRicetta(string codiceArticolo)
    {
        try
        {
            var parameters = new DialogParameters<RicettaViewDialog>
            {
                { x => x.CodiceArticolo, codiceArticolo },
                { x => x.ShowImportButton, true }
            };
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Large,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            await DialogService.ShowAsync<RicettaViewDialog>("Visualizza Ricetta", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore apertura ricetta: {ex.Message}", Severity.Error);
        }
    }

    [JSInvokable]
    public async Task ImportaRicetta(string codiceArticolo)
    {
        try
        {
            var parameters = new DialogParameters<ImportaRicettaMacchinaDialog>
            {
                { x => x.CodiceArticolo, codiceArticolo }
            };
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            await DialogService.ShowAsync<ImportaRicettaMacchinaDialog>("Importa Ricetta da Macchina", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore importazione ricetta: {ex.Message}", Severity.Error);
        }
    }

    public override async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        await base.DisposeAsync();
    }
}