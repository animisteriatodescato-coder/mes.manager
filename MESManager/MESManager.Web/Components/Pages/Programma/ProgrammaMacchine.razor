@page "/programma/programma-macchine"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = MESManager.Web.Constants.PaginaPolicy.ProgrammaMacchine)]
@using MESManager.Application.DTOs
@using MESManager.Web.Models
@using MESManager.Web.Services
@using MESManager.Web.Components.Dialogs
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.SignalR.Client
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject PreferencesService PreferencesService
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>Programma Macchine</PageTitle>

<div class="mes-grid-page" data-testid="page-programma-macchine">
    <MudPaper Class="settings-panel toolbar-sticky pa-2 mb-1" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudTextField @bind-Value="searchText"
                         Placeholder="Cerca in tutte le colonne..."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Style="width: 280px;"
                         Immediate="true"
                         DebounceInterval="280"
                         OnDebounceIntervalElapsed="OnSearchDebounced" />
            <MudSpacer />
            <MudButton Variant="@(_mostraChiuse ? Variant.Filled : Variant.Outlined)"
                       Color="@(_mostraChiuse ? Color.Warning : Color.Default)"
                       StartIcon="@(_mostraChiuse ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                       OnClick="@ToggleMostraChiuse">
                Chiuse @(_mostraChiuse ? "ON" : "OFF")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.ViewColumn" OnClick="@ToggleColumnPanel">Colonne</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="@RefreshData" data-testid="btn-refresh">Aggiorna</MudButton>
            <FixResetMenu OnFix="@FixGridState" OnReset="@ResetToFixedState"
                         ShowGlobalSave="@IsAdmin" OnSaveGlobal="@SaveAsGlobalDefault" />
            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Download" OnClick="@ExportCsv">Export CSV</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Print" OnClick="@PrintCommesse">Stampa</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Settings" OnClick="@(() => showSettings = !showSettings)">Impostazioni</MudButton>
        </MudStack>
        
        @if (showSettings)
        {
            <MudPaper Class="pa-4 mt-2" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Wrap="Wrap.Wrap">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Font Size:</MudText>
                        <MudNumericField Value="@settings.FontSize" Min="10" Max="24" Step="1" 
                                        Variant="Variant.Outlined" Margin="Margin.Dense"
                                        ValueChanged="@(async (int val) => { settings.FontSize = val; await ApplyUiSettings(); })" 
                                        Style="width: 80px;" />
                    </MudStack>
                    
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Row Height:</MudText>
                        <MudNumericField Value="@settings.RowHeight" Min="25" Max="80" Step="5" 
                                        Variant="Variant.Outlined" Margin="Margin.Dense"
                                        ValueChanged="@(async (int val) => { settings.RowHeight = val; await ApplyUiSettings(); })" 
                                        Style="width: 80px;" />
                    </MudStack>
                    
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Density:</MudText>
                        <MudSelect Value="@settings.Density" 
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  ValueChanged="@(async (string val) => { settings.Density = val; await ApplyUiSettings(); })" 
                                  Style="width: 120px;">
                            <MudSelectItem Value="@("Compact")">Compact</MudSelectItem>
                            <MudSelectItem Value="@("Normal")">Normal</MudSelectItem>
                            <MudSelectItem Value="@("Comfortable")">Comfortable</MudSelectItem>
                        </MudSelect>
                    </MudStack>
                    
                    <MudCheckBox Value="@settings.GridLines" Label="Grid Lines" Color="Color.Primary"
                                ValueChanged="@(async (bool val) => { settings.GridLines = val; await ApplyUiSettings(); })" />
                </MudStack>
            </MudPaper>
        }
    </MudPaper>

    <div id="programmaMacchineGrid" class="ag-theme-alpine mes-ag-grid" 
         data-testid="grid-programma">
    </div>

    <MudDialog @bind-Visible="showColumnDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.ViewColumn" Class="mr-2" />
                Gestione Colonne
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudSimpleTable Dense="true" Hover="true" Style="max-height: 400px; overflow-y: auto;">
                <thead>
                    <tr>
                        <th style="width: 50%;">Colonna</th>
                        <th style="width: 25%; text-align: center;"><MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" /> Visibile</th>
                        <th style="width: 25%; text-align: center;"><MudIcon Icon="@Icons.Material.Filled.Print" Size="Size.Small" /> Stampa</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var col in columnList)
                    {
                        var currentCol = col;
                        <tr>
                            <td>@currentCol.HeaderName</td>
                            <td style="text-align: center;">
                                <MudSwitch Value="@currentCol.Visible" 
                                           Color="Color.Primary" 
                                           T="bool"
                                           ValueChanged="@(async (bool val) => { currentCol.Visible = val; await OnColumnVisibilityChanged(currentCol.Field, val); })" />
                            </td>
                            <td style="text-align: center;">
                                <MudSwitch Value="@currentCol.PrintVisible" 
                                           Color="Color.Secondary" 
                                           T="bool"
                                           ValueChanged="@(async (bool val) => { currentCol.PrintVisible = val; await SavePrintColumnSettings(); })" />
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </DialogContent>
        <DialogActions>
            <MudButton Variant="Variant.Text" OnClick="@SelectAllPrintColumns">Seleziona Tutte Stampa</MudButton>
            <MudButton Variant="Variant.Text" OnClick="@DeselectAllPrintColumns">Deseleziona Tutte Stampa</MudButton>
            <MudSpacer />
            <MudButton OnClick="@(() => showColumnDialog = false)">Chiudi</MudButton>
        </DialogActions>
    </MudDialog>

    <LabelPrintDialog @ref="_labelDialog" />

    <MudPaper Class="footer-info pa-1 mt-2" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.caption" Color="Color.Primary">Commesse Programmate: <strong>@totalRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Filtrate: <strong>@filteredRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Selezionate: <strong>@selectedRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Ultimo aggiornamento: <strong>@lastUpdate.ToString("HH:mm:ss")</strong></MudText>
            <MudSpacer />
            <MudChip T="string" Size="Size.Small" Color="@(isLoading ? Color.Warning : Color.Success)" 
                     Icon="@(isLoading ? Icons.Material.Filled.HourglassEmpty : Icons.Material.Filled.CheckCircle)"
                     data-testid="status-info">
                @gridStatus
            </MudChip>
        </MudStack>
    </MudPaper>
</div>

<style>
    #printableCommesse {
        display: none;
    }

    @@media print {
        /* Hide the page content */
        .mes-grid-page,
        .settings-panel,
        .footer-info,
        #programmaMacchineGrid,
        .mud-dialog,
        .mud-dialog-overlay {
            display: none !important;
        }
        
        /* Show only the printable div */
        #printableCommesse {
            display: block !important;
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            width: 100% !important;
            height: auto !important;
            z-index: 999999 !important;
            padding: 10mm !important;
            box-sizing: border-box !important;
        }

        /* Force colors for table cells during printing */
        #printableCommesse table,
        #printableCommesse th,
        #printableCommesse td,
        #printableCommesse tr {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
        
        @@page {
            size: landscape;
            margin: 5mm;
        }
    }
</style>

<div id="printableCommesse">
    <!-- La tabella verrà generata dinamicamente da JavaScript -->
</div>

@code {
    [CascadingParameter(Name = "IsReadOnly")] private bool IsReadOnly { get; set; }
    [CascadingParameter(Name = "IsAdmin")]    private bool IsAdmin    { get; set; }

    private List<CommessaDto> _commesse = new();
    private List<CommessaDto> _allCommesse = new();
    private List<MacchinaDto> _macchine = new();
    private GridUiSettings settings = new();
    private bool showSettings = false;
    private string searchText = string.Empty;
    private bool showColumnDialog = false;
    private bool _mostraChiuse = false;
    private List<ColumnInfo> columnList = new();
    
    private int totalRows = 0;
    private int filteredRows = 0;
    private int selectedRows = 0;
    private DateTime lastUpdate = DateTime.MinValue;
    private bool isLoading = false;
    
    private LabelPrintDialog? _labelDialog;
    private string gridStatus = "Pronto";
    private IJSObjectReference? jsModule;
    private bool _isGridInitialized = false;
    private bool _isDataLoaded = false;
    private bool _isLoadingData = false;
    
    // SignalR
    private HubConnection? _hubConnection;

    private async Task OnSearchDebounced(string value)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setQuickFilter", value);
        }
        catch
        {
            // Error filtering grid
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _isDataLoaded = false;
        
        // Carica macchine dal database
        _macchine = await Http.GetFromJsonAsync<List<MacchinaDto>>("api/Macchine") ?? new();
        
        await LoadData();
        _isDataLoaded = true;
        
        var savedSettings = await PreferencesService.GetAsync<GridUiSettings>("programma-macchine-grid-settings");
        if (savedSettings != null)
        {
            settings = savedSettings;
        }
        
        // Inizializza SignalR per aggiornamenti real-time
        await InitializeSignalR();
    }
    
    private async Task InitializeSignalR()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(Nav.ToAbsoluteUri("/hubs/pianificazione"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<PianificazioneNotification>("PianificazioneUpdated", async (notification) =>
            {
                // Ricarica i dati quando vengono spostare commesse nel Gantt
                await InvokeAsync(async () =>
                {
                    await LoadData(force: true);
                    StateHasChanged();
                    if (_isGridInitialized)
                    {
                        await RefreshGrid();
                    }
                });
            });

            await _hubConnection.StartAsync();
            
            // Iscriviti agli aggiornamenti del Gantt
            await _hubConnection.InvokeAsync("SubscribeToGantt");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Errore connessione SignalR: {ex.Message}");
        }
    }
    
    private void ApplyFilter()
    {
        _commesse = _allCommesse.Where(c =>
            c.NumeroMacchina.HasValue &&
            c.StatoProgramma != "Completata" &&
            c.StatoProgramma != "Archiviata" &&
            (_mostraChiuse || c.Stato != "Chiusa")
        ).ToList();
    }

    private async Task ToggleMostraChiuse()
    {
        _mostraChiuse = !_mostraChiuse;
        ApplyFilter();
        totalRows = _commesse.Count;
        filteredRows = _commesse.Count;
        gridStatus = $"{_commesse.Count} commesse programmate{(_mostraChiuse ? " (incl. Chiuse)" : "")}";
        if (_isGridInitialized)
            await RefreshGrid();
        StateHasChanged();
    }

    private async Task RefreshGrid()
    {
        try
        {
            // _commesse è già filtrato - passa direttamente alla griglia
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.updateData", _commesse);
        }
        catch { }
    }

    private async Task LoadData(bool force = false)
    {
        if (_isLoadingData && !force)
        {
            return;
        }
        
        _isLoadingData = true;
        
        try
        {
            isLoading = true;
            gridStatus = "Caricamento...";
            StateHasChanged();
            
            _allCommesse = await Http.GetFromJsonAsync<List<CommessaDto>>("api/Commesse") ?? new();
            
            // � DEBUG: Log BEFORE filtro
            Console.WriteLine($"[PROGRAMMA] BEFORE filtro: {_allCommesse.Count} commesse totali");
            Console.WriteLine($"[PROGRAMMA] Con macchina: {_allCommesse.Count(c => c.NumeroMacchina.HasValue)}");
            Console.WriteLine($"[PROGRAMMA] Con data inizio: {_allCommesse.Count(c => c.DataInizioPrevisione.HasValue)}");
            Console.WriteLine($"[PROGRAMMA] StatoProgramma values: {string.Join(", ", _allCommesse.Select(c => c.StatoProgramma).Distinct())}");
            Console.WriteLine($"[PROGRAMMA] Stato values: {string.Join(", ", _allCommesse.Select(c => c.Stato).Distinct())}");
            
            // Applica filtro centralizzato (rispetta _mostraChiuse)
            ApplyFilter();
            
            // 🔍 DEBUG: Log AFTER filtro
            Console.WriteLine($"[PROGRAMMA] AFTER filtro: {_commesse.Count} commesse visualizzabili");
            if (_commesse.Count == 0 && _allCommesse.Count > 0)
            {
                Console.WriteLine("[PROGRAMMA] ⚠️ FILTRO HA ELIMINATO TUTTO! Verifica condizioni:");
                var sample = _allCommesse.Take(5);
                foreach (var c in sample)
                {
                    Console.WriteLine($"  - {c.Codice}: NumMacchina={c.NumeroMacchina}, DataInizio={c.DataInizioPrevisione}, StatoProg={c.StatoProgramma}, Stato={c.Stato}");
                }
            }
            
            // Conteggio totale
            var programmate = _commesse;
            
            totalRows = programmate.Count;
            filteredRows = programmate.Count;
            lastUpdate = DateTime.Now;
            isLoading = false;
            
            // ⚠️ IMPORTANTE: Mostra count reale, non "Pronto"
            gridStatus = $"{programmate.Count} commesse programmate{(_mostraChiuse ? " (incl. Chiuse)" : "")}";
            
            Console.WriteLine($"[PROGRAMMA] gridStatus = '{gridStatus}', totalRows = {totalRows}");
        }
        finally
        {
            _isLoadingData = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Aspetta che i dati siano caricati con un loop (max 30 secondi)
            int maxWait = 150; // 150 * 200ms = 30 secondi
            int waited = 0;
            while (!_isDataLoaded && waited < maxWait)
            {
                await Task.Delay(200);
                waited++;
            }
            
            if (_isDataLoaded && !_isGridInitialized)
            {
                _isGridInitialized = true;
                await Task.Delay(100);
                await InitializeGrid();
                
                jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/stats-listener-programma.js");
                await jsModule.InvokeVoidAsync("subscribeToStatsChanges", DotNetObjectReference.Create(this));
            }
        }
    }

    [JSInvokable]
    public async Task UpdateStats()
    {
        try
        {
            var stats = await JSRuntime.InvokeAsync<GridStats>("programmaMacchineGrid.getStats");
            totalRows = stats.Total;
            filteredRows = stats.Filtered;
            selectedRows = stats.Selected;
            StateHasChanged();
        }
        catch
        {
            // Error updating stats
        }
    }

    [JSInvokable]
    public async Task SaveGridStateFromJs()
    {
        await SaveGridState();
    }

    [JSInvokable]
    public async Task ViewRicetta(string codiceArticolo)
    {
        try
        {
            var parameters = new DialogParameters<RicettaViewDialog>
            {
                { x => x.CodiceArticolo, codiceArticolo },
                { x => x.ShowImportButton, true },
                { x => x.ShowTransmitButton, true },
                { x => x.IsReadOnly, IsReadOnly }
            };
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Large,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            await DialogService.ShowAsync<RicettaViewDialog>($"Ricetta: {codiceArticolo}", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore apertura ricetta: {ex.Message}", Severity.Error);
        }
    }

    [JSInvokable]
    public async Task ImportaRicetta(string codiceArticolo)
    {
        if (IsReadOnly) return;
        try
        {
            var parameters = new DialogParameters<ImportaRicettaMacchinaDialog>
            {
                { x => x.CodiceArticolo, codiceArticolo }
            };
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            await DialogService.ShowAsync<ImportaRicettaMacchinaDialog>("Importa Ricetta da Macchina", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore importazione ricetta: {ex.Message}", Severity.Error);
        }
    }

    [JSInvokable]
    public async Task OnMachineSelectionChanged(string commessaId, string? numeroMacchina)
    {
        // Ricarica i dati per riflettere le modifiche
        await RefreshData();
    }

    [JSInvokable]
    public async Task OnGridNeedRefresh()
    {
        // Chiamato dal JS dopo riordino frecce o cambio statoProgramma
        // Usa il percorso C# per applicare i filtri corretti (mostraChiuse, esclusione Completate, ecc.)
        await RefreshData();
    }

    [JSInvokable]
    public async Task OnRowDoubleClick(string articoloCodice)
    {
        try
        {
            // Carica l'AnimeDto dal codice articolo
            var anime = await Http.GetFromJsonAsync<AnimeDto>($"/api/Anime/by-codice/{string.Join('/', articoloCodice.Split('/').Select(Uri.EscapeDataString))}");
            
            if (anime == null)
            {
                Snackbar.Add($"Anima con codice {articoloCodice} non trovata", Severity.Warning);
                return;
            }
            
            var parameters = new DialogParameters<AnimeEditDialog>
            {
                { x => x.Anime, anime },
                { x => x.IsReadOnly, IsReadOnly }
            };
            
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Large,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            
            var dialog = await DialogService.ShowAsync<AnimeEditDialog>("Modifica Anima", parameters, options);
            var result = await dialog.Result;
            
            if (result != null && !result.Canceled && result.Data is AnimeDto updatedAnime)
            {
                // Ricarica i dati per riflettere le modifiche
                await RefreshData();
                Snackbar.Add("Anima aggiornata con successo", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
        
        StateHasChanged();
    }

    private async Task InitializeGrid()
    {
        try
        {
            Console.WriteLine($"[PROGRAMMA] InitializeGrid() START - _commesse.Count = {_commesse.Count}");
            
            var exists = await JSRuntime.InvokeAsync<bool>("eval", "typeof window.programmaMacchineGrid !== 'undefined'");
            if (!exists)
            {
                Console.WriteLine("[PROGRAMMA] ❌ programmaMacchineGrid NON definito in window");
                return;
            }
            else
            {
                Console.WriteLine("[PROGRAMMA] ✅ programmaMacchineGrid definito");
            }

            var jsonOptions = new JsonSerializerOptions 
            { 
                PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
                WriteIndented = false
            };
            
            // Passa le macchine al JavaScript PRIMA di inizializzare la griglia
            var macchineJson = JsonSerializer.Serialize(_macchine, jsonOptions);
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setMachines", _macchine);
            Console.WriteLine($"[PROGRAMMA] Macchine serializzate: {_macchine.Count} elementi");
            
            var jsonData = JsonSerializer.Serialize(_commesse, jsonOptions);
            Console.WriteLine($"[PROGRAMMA] Dati serializzati: {jsonData.Length} caratteri, {_commesse.Count} commesse");

            await JSRuntime.InvokeVoidAsync("eval", $"programmaMacchineGrid.init('programmaMacchineGrid', JSON.parse({System.Text.Json.JsonSerializer.Serialize(jsonData)}), {System.Text.Json.JsonSerializer.Serialize(settings.ColumnStateJson)})");
            Console.WriteLine($"[PROGRAMMA] ✅ Grid.init() completato");
            
            // Passa il DotNetReference per il doppio clic
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setDotNetHelper", DotNetObjectReference.Create(this));
            
            await ApplyUiSettings();
            Console.WriteLine($"[PROGRAMMA] InitializeGrid() END");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PROGRAMMA] ❌ ERRORE in InitializeGrid: {ex.Message}");
        }
    }

    private async Task ToggleColumnPanel()
    {
        try
        {
            columnList = await JSRuntime.InvokeAsync<List<ColumnInfo>>("programmaMacchineGrid.getAllColumns");
            // Carica le impostazioni di stampa salvate
            await LoadPrintColumnSettings();
            showColumnDialog = true;
        }
        catch
        {
            // Error toggling column panel
        }
    }

    private async Task OnColumnVisibilityChanged(string field, bool visible)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setColumnVisible", field, visible);
            
            // Sincronizza anche la colonna stampa quando si attiva la visibilità
            var col = columnList.FirstOrDefault(c => c.Field == field);
            if (col != null && visible)
            {
                col.PrintVisible = true;
                await SavePrintColumnSettings();
            }
            
            await SaveGridState();
        }
        catch
        {
            // Error changing column visibility
        }
    }

    private async Task RefreshData()
    {
        await LoadData(force: true);
        
        try
        {
            var jsonOptions = new JsonSerializerOptions 
            { 
                PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
                WriteIndented = false
            };
            var jsonData = JsonSerializer.Serialize(_commesse, jsonOptions);
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.updateData", _commesse);
        }
        catch
        {
            // Error updating grid
        }
        
        StateHasChanged();
    }

    private async Task FixGridState()
    {
        try
        {
            // Salva lo stato attuale della griglia come stato "fixed"
            var gridState = await JSRuntime.InvokeAsync<string>("programmaMacchineGrid.getState");
            await PreferencesService.SetAsync("programma-macchine-grid-fixed-state", gridState);
            await PreferencesService.SetAsync("programma-macchine-grid-fixed-settings", JsonSerializer.Serialize(settings));
        }
        catch
        {
            // Error fixing grid state
        }
    }

    private async Task ResetToFixedState()
    {
        try
        {
            // Ripristina lo stato salvato con Fix
            var fixedState = await PreferencesService.GetAsync<string>("programma-macchine-grid-fixed-state");
            var fixedSettings = await PreferencesService.GetAsync<string>("programma-macchine-grid-fixed-settings");
            
            if (!string.IsNullOrEmpty(fixedState))
            {
                await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setState", fixedState);
            }
            else
            {
                // Se non c'è stato salvato, resetta allo stato default
                await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.resetState");
            }
            
            if (!string.IsNullOrEmpty(fixedSettings))
            {
                settings = JsonSerializer.Deserialize<GridUiSettings>(fixedSettings) ?? new GridUiSettings();
            }
            else
            {
                settings = new GridUiSettings();
            }
            
            await ApplyUiSettings();
            StateHasChanged();
        }
        catch
        {
            // Error resetting to fixed state
        }
    }

    private async Task SaveAsGlobalDefault()
    {
        try
        {
            var gridState = await JSRuntime.InvokeAsync<string>("programmaMacchineGrid.getState");
            settings.ColumnStateJson = gridState;
            await PreferencesService.SetGlobalAsync("programma-macchine-grid-settings", settings);
        }
        catch { }
    }

    private async Task ExportCsv()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.exportCsv");
        }
        catch { }
    }

    private async Task PrintCommesse()
    {
        try
        {
            // Ottieni le colonne da stampare
            var printColumns = await PreferencesService.GetAsync<List<string>>("programma-macchine-print-columns");
            // Usa un iframe nascosto per stampare, così non interferisce con la pagina principale
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.printViaIframe", printColumns, settings.FontSize);
        }
        catch
        {
            // Error printing
        }
    }

    private async Task ApplyUiSettings()
    {
        try
        {
            var densityPadding = GetDensityPadding();
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setUiVars", 
                settings.FontSize, 
                settings.RowHeight, 
                densityPadding,
                false, // zebra non usato (usiamo colori per macchina)
                settings.GridLines);
            await SaveSettings();
            StateHasChanged();
        }
        catch { }
    }

    private string GetDensityPadding()
    {
        return settings.Density switch
        {
            "Compact" => "4px",
            "Comfortable" => "12px",
            _ => "8px"
        };
    }

    private async Task SaveGridState()
    {
        await SaveSettings();
    }

    private async Task SaveSettings()
    {
        try
        {
            var state = await JSRuntime.InvokeAsync<string>("programmaMacchineGrid.getState");
            settings.ColumnStateJson = state;
            await PreferencesService.SetAsync("programma-macchine-grid-settings", settings);
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
        {
            try
            {
                await _hubConnection.DisposeAsync();
            }
            catch { }
        }
        
        if (jsModule != null)
        {
            try
            {
                await jsModule.DisposeAsync();
            }
            catch { }
        }
        
        try
        {
            await SaveSettings();
        }
        catch { }
    }
    
