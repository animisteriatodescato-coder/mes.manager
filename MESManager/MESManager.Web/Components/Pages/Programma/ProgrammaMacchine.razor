    private class ColumnInfo
    {
        public string Field { get; set; } = string.Empty;
        public string HeaderName { get; set; } = string.Empty;
        public bool Visible { get; set; }
        public bool PrintVisible { get; set; } = true;
    }

    private async Task SavePrintColumnSettings()
    {
        try
        {
            var printColumns = columnList.Where(c => c.PrintVisible).Select(c => c.Field).ToList();
            await PreferencesService.SetAsync("programma-macchine-print-columns", printColumns);
        }
        catch { }
    }

    private async Task LoadPrintColumnSettings()
    {
        try
        {
            var savedPrintColumns = await PreferencesService.GetAsync<List<string>>("programma-macchine-print-columns");
            if (savedPrintColumns != null)
            {
                // Se ci sono impostazioni salvate, usa quelle
                foreach (var col in columnList)
                {
                    col.PrintVisible = savedPrintColumns.Contains(col.Field);
                }
            }
            else
            {
                // Se non ci sono impostazioni salvate, sincronizza con visibilità
                foreach (var col in columnList)
                {
                    col.PrintVisible = col.Visible;
                }
            }
        }
        catch 
        {
            // In caso di errore, sincronizza con visibilità
            foreach (var col in columnList)
            {
                col.PrintVisible = col.Visible;
            }
        }
    }

    private async Task SelectAllPrintColumns()
    {
        foreach (var col in columnList)
        {
            col.PrintVisible = true;
        }
        await SavePrintColumnSettings();
        StateHasChanged();
    }

    private async Task DeselectAllPrintColumns()
    {
        foreach (var col in columnList)
        {
            col.PrintVisible = false;
        }
        await SavePrintColumnSettings();
        StateHasChanged();
    }

