    private async Task InitializeGrid()
    {
        try
        {
            Console.WriteLine($"[PROGRAMMA] InitializeGrid() START - _commesse.Count = {_commesse.Count}");
            
            var exists = await JSRuntime.InvokeAsync<bool>("eval", "typeof window.programmaMacchineGrid !== 'undefined'");
            if (!exists)
            {
                Console.WriteLine("[PROGRAMMA] ❌ programmaMacchineGrid NON definito in window");
                return;
            }
            else
            {
                Console.WriteLine("[PROGRAMMA] ✅ programmaMacchineGrid definito");
            }

            var jsonOptions = new JsonSerializerOptions 
            { 
                PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
                WriteIndented = false
            };
            
            // Passa le macchine al JavaScript PRIMA di inizializzare la griglia
            var macchineJson = JsonSerializer.Serialize(_macchine, jsonOptions);
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setMachines", _macchine);
            Console.WriteLine($"[PROGRAMMA] Macchine serializzate: {_macchine.Count} elementi");
            
            var jsonData = JsonSerializer.Serialize(_commesse, jsonOptions);
            Console.WriteLine($"[PROGRAMMA] Dati serializzati: {jsonData.Length} caratteri, {_commesse.Count} commesse");

            await JSRuntime.InvokeVoidAsync("eval", $"programmaMacchineGrid.init('programmaMacchineGrid', JSON.parse({System.Text.Json.JsonSerializer.Serialize(jsonData)}), {System.Text.Json.JsonSerializer.Serialize(settings.ColumnStateJson)})");
            Console.WriteLine($"[PROGRAMMA] ✅ Grid.init() completato");
            
            // Passa il DotNetReference per il doppio clic
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setDotNetHelper", DotNetObjectReference.Create(this));
            
            await ApplyUiSettings();
            Console.WriteLine($"[PROGRAMMA] InitializeGrid() END");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PROGRAMMA] ❌ ERRORE in InitializeGrid: {ex.Message}");
        }
    }

