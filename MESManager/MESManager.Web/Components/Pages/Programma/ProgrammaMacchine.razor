@page "/programma/programma-macchine"
@using MESManager.Application.DTOs
@using MESManager.Web.Models
@using MESManager.Web.Services
@using Microsoft.JSInterop
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject PreferencesService PreferencesService
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>Programma Macchine</PageTitle>

<div class="programma-macchine-page">
    <div class="settings-panel">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap" Class="mb-3">
            <MudText Typo="Typo.h6" data-testid="programma-macchine-title">Programma Macchine</MudText>
            <MudSpacer />
            
            <MudTextField @bind-Value="searchText"
                         Placeholder="Cerca in tutte le colonne..."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Style="width: 280px;"
                         Immediate="true"
                         DebounceInterval="280"
                         OnDebounceIntervalElapsed="OnSearchDebounced" />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ViewColumn" OnClick="@ToggleColumnPanel">Colonne</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="@RefreshData">Aggiorna</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.RestartAlt" OnClick="@ResetGrid">Reset</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" OnClick="@ExportCsv">Export CSV</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Print" OnClick="@PrintCommesse">Stampa</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Settings" OnClick="@(() => showSettings = !showSettings)">Impostazioni</MudButton>
        </MudStack>
        
        @if (showSettings)
        {
            <MudPaper Class="pa-4 mt-2" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Wrap="Wrap.Wrap">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Font Size:</MudText>
                        <MudNumericField Value="@settings.FontSize" Min="10" Max="24" Step="1" 
                                        Variant="Variant.Outlined" Margin="Margin.Dense"
                                        ValueChanged="@(async (int val) => { settings.FontSize = val; await ApplyUiSettings(); })" 
                                        Style="width: 80px;" />
                    </MudStack>
                    
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Row Height:</MudText>
                        <MudNumericField Value="@settings.RowHeight" Min="25" Max="80" Step="5" 
                                        Variant="Variant.Outlined" Margin="Margin.Dense"
                                        ValueChanged="@(async (int val) => { settings.RowHeight = val; await ApplyUiSettings(); })" 
                                        Style="width: 80px;" />
                    </MudStack>
                    
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Density:</MudText>
                        <MudSelect Value="@settings.Density" 
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  ValueChanged="@(async (string val) => { settings.Density = val; await ApplyUiSettings(); })" 
                                  Style="width: 120px;">
                            <MudSelectItem Value="@("Compact")">Compact</MudSelectItem>
                            <MudSelectItem Value="@("Normal")">Normal</MudSelectItem>
                            <MudSelectItem Value="@("Comfortable")">Comfortable</MudSelectItem>
                        </MudSelect>
                    </MudStack>
                    
                    <MudCheckBox Value="@settings.GridLines" Label="Grid Lines" Color="Color.Primary"
                                ValueChanged="@(async (bool val) => { settings.GridLines = val; await ApplyUiSettings(); })" />
                </MudStack>
            </MudPaper>
        }
    </div>

    <div id="programmaMacchineGrid" class="ag-theme-alpine" 
         data-testid="programma-macchine-grid"
         style="width: 100%; height: calc(100vh - 150px);">
    </div>

    <MudDialog @bind-Visible="showColumnDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Medium }">
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.ViewColumn" Class="mr-2" />
                Gestione Colonne
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudList T="string" Dense="true">
                @foreach (var col in columnList)
                {
                    var currentCol = col;
                    <MudListItem T="string">
                        <MudSwitch Value="@currentCol.Visible" 
                                   Color="Color.Primary" 
                                   Label="@currentCol.HeaderName"
                                   T="bool"
                                   ValueChanged="@(async (bool val) => { currentCol.Visible = val; await OnColumnVisibilityChanged(currentCol.Field, val); })" />
                    </MudListItem>
                }
            </MudList>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => showColumnDialog = false)">Chiudi</MudButton>
        </DialogActions>
    </MudDialog>

    <MudPaper Class="footer-info pa-1 mt-2" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.caption" Color="Color.Primary">Commesse Programmate: <strong>@totalRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Filtrate: <strong>@filteredRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Selezionate: <strong>@selectedRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Ultimo aggiornamento: <strong>@lastUpdate.ToString("HH:mm:ss")</strong></MudText>
            <MudSpacer />
            <MudStack Row="true" Spacing="1">
                <MudChip T="string" Size="Size.Small" Style="background-color: #e3f2fd;">Macchine Pari</MudChip>
                <MudChip T="string" Size="Size.Small" Style="background-color: #e8f5e9;">Macchine Dispari</MudChip>
            </MudStack>
            <MudChip T="string" Size="Size.Small" Color="@(isLoading ? Color.Warning : Color.Success)" 
                     Icon="@(isLoading ? Icons.Material.Filled.HourglassEmpty : Icons.Material.Filled.CheckCircle)">
                @gridStatus
            </MudChip>
        </MudStack>
    </MudPaper>
</div>

<style>
    .programma-macchine-page {
        position: relative;
    }

    #printableCommesse {
        display: none;
    }

    @@media print {
        .programma-macchine-page {
            display: none !important;
        }
        
        #printableCommesse {
            display: block !important;
        }
        
        @@page {
            size: landscape;
            margin: 10mm;
        }
    }
</style>

<div id="printableCommesse">
    <!-- La tabella verrà generata dinamicamente da JavaScript -->
</div>

@code {
    private List<CommessaDto> _commesse = new();
    private List<CommessaDto> _allCommesse = new();
    private GridUiSettings settings = new();
    private bool showSettings = false;
    private string searchText = string.Empty;
    private bool showColumnDialog = false;
    private List<ColumnInfo> columnList = new();
    
    private int totalRows = 0;
    private int filteredRows = 0;
    private int selectedRows = 0;
    private DateTime lastUpdate = DateTime.MinValue;
    private bool isLoading = false;
    private string gridStatus = "Pronto";
    private IJSObjectReference? jsModule;
    private bool _isGridInitialized = false;
    private bool _isDataLoaded = false;
    private bool _isLoadingData = false;

    private async Task OnSearchDebounced(string value)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setQuickFilter", value);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error filtering grid: {ex.Message}");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _isDataLoaded = false;
        await LoadData();
        _isDataLoaded = true;
        
        var savedSettings = await PreferencesService.GetAsync<GridUiSettings>("programma-macchine-grid-settings");
        if (savedSettings != null)
        {
            settings = savedSettings;
        }
    }

    private async Task LoadData(bool force = false)
    {
        if (_isLoadingData && !force)
        {
            Console.WriteLine("LoadData already in progress, skipping...");
            return;
        }
        
        _isLoadingData = true;
        
        try
        {
            isLoading = true;
            gridStatus = "Caricamento...";
            StateHasChanged();
            
            _allCommesse = await Http.GetFromJsonAsync<List<CommessaDto>>("api/Commesse") ?? new();
            
            // Filter only open commesse with numeroMacchina assigned
            _commesse = _allCommesse.Where(c => c.Stato == "Aperta" && !string.IsNullOrEmpty(c.NumeroMacchina)).ToList();
            Console.WriteLine($"ProgrammaMacchine: Loaded {_allCommesse.Count} total, filtered to {_commesse.Count} with machine");
            
            totalRows = _commesse.Count;
            filteredRows = _commesse.Count;
            lastUpdate = DateTime.Now;
            isLoading = false;
            gridStatus = "Pronto";
        }
        finally
        {
            _isLoadingData = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Aspetta che i dati siano caricati con un loop (max 30 secondi)
            int maxWait = 150; // 150 * 200ms = 30 secondi
            int waited = 0;
            while (!_isDataLoaded && waited < maxWait)
            {
                await Task.Delay(200);
                waited++;
            }
            
            if (_isDataLoaded && !_isGridInitialized)
            {
                _isGridInitialized = true;
                Console.WriteLine($"ProgrammaMacchine: Initializing grid with {_commesse.Count} rows");
                await Task.Delay(100);
                await InitializeGrid();
                
                jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/stats-listener-programma.js");
                await jsModule.InvokeVoidAsync("subscribeToStatsChanges", DotNetObjectReference.Create(this));
            }
            else if (!_isDataLoaded)
            {
                Console.WriteLine("ProgrammaMacchine: Timeout waiting for data");
            }
        }
    }

    [JSInvokable]
    public async Task UpdateStats()
    {
        try
        {
            var stats = await JSRuntime.InvokeAsync<GridStats>("programmaMacchineGrid.getStats");
            totalRows = stats.Total;
            filteredRows = stats.Filtered;
            selectedRows = stats.Selected;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating stats: {ex.Message}");
        }
    }

    [JSInvokable]
    public async Task SaveGridStateFromJs()
    {
        await SaveGridState();
    }

    [JSInvokable]
    public async Task OnMachineSelectionChanged(string commessaId, string? numeroMacchina)
    {
        Console.WriteLine($"Machine selection changed: {commessaId} -> {numeroMacchina}");
        // Ricarica i dati per riflettere le modifiche
        await RefreshData();
    }

    private async Task InitializeGrid()
    {
        try
        {
            var exists = await JSRuntime.InvokeAsync<bool>("eval", "typeof window.programmaMacchineGrid !== 'undefined'");
            if (!exists)
            {
                Console.WriteLine("ERROR: window.programmaMacchineGrid is not defined!");
                return;
            }

            var jsonOptions = new JsonSerializerOptions 
            { 
                PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
                WriteIndented = false
            };
            var jsonData = JsonSerializer.Serialize(_commesse, jsonOptions);

            await JSRuntime.InvokeVoidAsync("eval", $"programmaMacchineGrid.init('programmaMacchineGrid', JSON.parse({System.Text.Json.JsonSerializer.Serialize(jsonData)}), {System.Text.Json.JsonSerializer.Serialize(settings.ColumnStateJson)})");
            await ApplyUiSettings();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing grid: {ex.Message}");
        }
    }

    private async Task ToggleColumnPanel()
    {
        try
        {
            columnList = await JSRuntime.InvokeAsync<List<ColumnInfo>>("programmaMacchineGrid.getAllColumns");
            showColumnDialog = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error toggling column panel: {ex.Message}");
        }
    }

    private async Task OnColumnVisibilityChanged(string field, bool visible)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setColumnVisible", field, visible);
            await SaveGridState();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error changing column visibility: {ex.Message}");
        }
    }

    private async Task RefreshData()
    {
        Console.WriteLine("RefreshData called");
        await LoadData(force: true);
        
        try
        {
            var jsonOptions = new JsonSerializerOptions 
            { 
                PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
                WriteIndented = false
            };
            var jsonData = JsonSerializer.Serialize(_commesse, jsonOptions);
            Console.WriteLine($"RefreshData: updating grid with {_commesse.Count} rows");
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.updateData", _commesse);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating grid: {ex.Message}");
        }
        
        StateHasChanged();
    }

    private async Task ResetGrid()
    {
        try
        {
            Console.WriteLine("ResetGrid called");
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.resetState");
            settings = new GridUiSettings();
            await PreferencesService.RemoveAsync("programma-macchine-grid-settings");
            await ApplyUiSettings();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error resetting grid: {ex.Message}");
        }
    }

    private async Task ExportCsv()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.exportCsv");
        }
        catch { }
    }

    private async Task PrintCommesse()
    {
        try
        {
            // Genera la tabella di stampa dinamicamente dalla griglia
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.generatePrintTable");
            // Apri la finestra di stampa
            await JSRuntime.InvokeVoidAsync("eval", "window.print()");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error printing: {ex.Message}");
        }
    }

    private async Task ApplyUiSettings()
    {
        try
        {
            var densityPadding = GetDensityPadding();
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setUiVars", 
                settings.FontSize, 
                settings.RowHeight, 
                densityPadding,
                false, // zebra non usato (usiamo colori per macchina)
                settings.GridLines);
            await SaveSettings();
            StateHasChanged();
        }
        catch { }
    }

    private string GetDensityPadding()
    {
        return settings.Density switch
        {
            "Compact" => "4px",
            "Comfortable" => "12px",
            _ => "8px"
        };
    }

    private async Task SaveGridState()
    {
        await SaveSettings();
    }

    private async Task SaveSettings()
    {
        try
        {
            var state = await JSRuntime.InvokeAsync<string>("programmaMacchineGrid.getState");
            settings.ColumnStateJson = state;
            await PreferencesService.SetAsync("programma-macchine-grid-settings", settings);
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        if (jsModule != null)
        {
            try
            {
                await jsModule.DisposeAsync();
            }
            catch { }
        }
        
        try
        {
            await SaveSettings();
        }
        catch { }
    }

    private class GridStats
    {
        public int Total { get; set; }
        public int Filtered { get; set; }
        public int Selected { get; set; }
    }

    private class ColumnInfo
    {
        public string Field { get; set; } = string.Empty;
        public string HeaderName { get; set; } = string.Empty;
        public bool Visible { get; set; }
    }
}
