@page "/programma/programma-macchine"
@using MESManager.Application.DTOs
@using MESManager.Web.Models
@using MESManager.Web.Services
@using MESManager.Web.Components.Dialogs
@using Microsoft.JSInterop
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject PreferencesService PreferencesService
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>Programma Macchine</PageTitle>

<div class="programma-macchine-page">
    <div class="settings-panel">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap" Class="mb-3">
            <MudText Typo="Typo.h6" data-testid="programma-macchine-title">Programma Macchine</MudText>
            <MudSpacer />
            
            <MudTextField @bind-Value="searchText"
                         Placeholder="Cerca in tutte le colonne..."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Style="width: 280px;"
                         Immediate="true"
                         DebounceInterval="280"
                         OnDebounceIntervalElapsed="OnSearchDebounced" />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ViewColumn" OnClick="@ToggleColumnPanel">Colonne</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="@RefreshData">Aggiorna</MudButton>
            <FixResetMenu OnFix="@FixGridState" OnReset="@ResetToFixedState" />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" OnClick="@ExportCsv">Export CSV</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Print" OnClick="@PrintCommesse">Stampa</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Settings" OnClick="@(() => showSettings = !showSettings)">Impostazioni</MudButton>
        </MudStack>
        
        @if (showSettings)
        {
            <MudPaper Class="pa-4 mt-2" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Wrap="Wrap.Wrap">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Font Size:</MudText>
                        <MudNumericField Value="@settings.FontSize" Min="10" Max="24" Step="1" 
                                        Variant="Variant.Outlined" Margin="Margin.Dense"
                                        ValueChanged="@(async (int val) => { settings.FontSize = val; await ApplyUiSettings(); })" 
                                        Style="width: 80px;" />
                    </MudStack>
                    
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Row Height:</MudText>
                        <MudNumericField Value="@settings.RowHeight" Min="25" Max="80" Step="5" 
                                        Variant="Variant.Outlined" Margin="Margin.Dense"
                                        ValueChanged="@(async (int val) => { settings.RowHeight = val; await ApplyUiSettings(); })" 
                                        Style="width: 80px;" />
                    </MudStack>
                    
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Density:</MudText>
                        <MudSelect Value="@settings.Density" 
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  ValueChanged="@(async (string val) => { settings.Density = val; await ApplyUiSettings(); })" 
                                  Style="width: 120px;">
                            <MudSelectItem Value="@("Compact")">Compact</MudSelectItem>
                            <MudSelectItem Value="@("Normal")">Normal</MudSelectItem>
                            <MudSelectItem Value="@("Comfortable")">Comfortable</MudSelectItem>
                        </MudSelect>
                    </MudStack>
                    
                    <MudCheckBox Value="@settings.GridLines" Label="Grid Lines" Color="Color.Primary"
                                ValueChanged="@(async (bool val) => { settings.GridLines = val; await ApplyUiSettings(); })" />
                </MudStack>
            </MudPaper>
        }
    </div>

    <div id="programmaMacchineGrid" class="ag-theme-alpine" 
         data-testid="programma-macchine-grid"
         style="width: 100%; height: calc(100vh - 150px);">
    </div>

    <MudDialog @bind-Visible="showColumnDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.ViewColumn" Class="mr-2" />
                Gestione Colonne
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudSimpleTable Dense="true" Hover="true" Style="max-height: 400px; overflow-y: auto;">
                <thead>
                    <tr>
                        <th style="width: 50%;">Colonna</th>
                        <th style="width: 25%; text-align: center;"><MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" /> Visibile</th>
                        <th style="width: 25%; text-align: center;"><MudIcon Icon="@Icons.Material.Filled.Print" Size="Size.Small" /> Stampa</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var col in columnList)
                    {
                        var currentCol = col;
                        <tr>
                            <td>@currentCol.HeaderName</td>
                            <td style="text-align: center;">
                                <MudSwitch Value="@currentCol.Visible" 
                                           Color="Color.Primary" 
                                           T="bool"
                                           ValueChanged="@(async (bool val) => { currentCol.Visible = val; await OnColumnVisibilityChanged(currentCol.Field, val); })" />
                            </td>
                            <td style="text-align: center;">
                                <MudSwitch Value="@currentCol.PrintVisible" 
                                           Color="Color.Secondary" 
                                           T="bool"
                                           ValueChanged="@(async (bool val) => { currentCol.PrintVisible = val; await SavePrintColumnSettings(); })" />
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </DialogContent>
        <DialogActions>
            <MudButton Variant="Variant.Text" OnClick="@SelectAllPrintColumns">Seleziona Tutte Stampa</MudButton>
            <MudButton Variant="Variant.Text" OnClick="@DeselectAllPrintColumns">Deseleziona Tutte Stampa</MudButton>
            <MudSpacer />
            <MudButton OnClick="@(() => showColumnDialog = false)">Chiudi</MudButton>
        </DialogActions>
    </MudDialog>

    <MudPaper Class="footer-info pa-1 mt-2" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.caption" Color="Color.Primary">Commesse Programmate: <strong>@totalRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Filtrate: <strong>@filteredRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Selezionate: <strong>@selectedRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Ultimo aggiornamento: <strong>@lastUpdate.ToString("HH:mm:ss")</strong></MudText>
            <MudSpacer />
            <MudStack Row="true" Spacing="1">
                <MudChip T="string" Size="Size.Small" Style="background-color: #e8f5e9;">Verde Chiaro</MudChip>
                <MudChip T="string" Size="Size.Small" Style="background-color: #c8e6c9;">Verde Scuro</MudChip>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">(alternati per cambio macchina)</MudText>
            </MudStack>
            <MudChip T="string" Size="Size.Small" Color="@(isLoading ? Color.Warning : Color.Success)" 
                     Icon="@(isLoading ? Icons.Material.Filled.HourglassEmpty : Icons.Material.Filled.CheckCircle)">
                @gridStatus
            </MudChip>
        </MudStack>
    </MudPaper>
</div>

<style>
    .programma-macchine-page {
        position: relative;
    }

    #printableCommesse {
        display: none;
    }

    @@media print {
        /* Hide the page content */
        .programma-macchine-page,
        .settings-panel,
        .footer-info,
        #programmaMacchineGrid,
        .mud-dialog,
        .mud-dialog-overlay {
            display: none !important;
        }
        
        /* Show only the printable div */
        #printableCommesse {
            display: block !important;
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            width: 100% !important;
            height: auto !important;
            z-index: 999999 !important;
            padding: 10mm !important;
            box-sizing: border-box !important;
        }

        /* Force colors for table cells during printing */
        #printableCommesse table,
        #printableCommesse th,
        #printableCommesse td,
        #printableCommesse tr {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
        
        @@page {
            size: landscape;
            margin: 5mm;
        }
    }
</style>

<div id="printableCommesse">
    <!-- La tabella verrà generata dinamicamente da JavaScript -->
</div>

@code {
    private List<CommessaDto> _commesse = new();
    private List<CommessaDto> _allCommesse = new();
    private GridUiSettings settings = new();
    private bool showSettings = false;
    private string searchText = string.Empty;
    private bool showColumnDialog = false;
    private List<ColumnInfo> columnList = new();
    
    private int totalRows = 0;
    private int filteredRows = 0;
    private int selectedRows = 0;
    private DateTime lastUpdate = DateTime.MinValue;
    private bool isLoading = false;
    private string gridStatus = "Pronto";
    private IJSObjectReference? jsModule;
    private bool _isGridInitialized = false;
    private bool _isDataLoaded = false;
    private bool _isLoadingData = false;

    private async Task OnSearchDebounced(string value)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setQuickFilter", value);
        }
        catch
        {
            // Error filtering grid
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _isDataLoaded = false;
        await LoadData();
        _isDataLoaded = true;
        
        var savedSettings = await PreferencesService.GetAsync<GridUiSettings>("programma-macchine-grid-settings");
        if (savedSettings != null)
        {
            settings = savedSettings;
        }
    }

    private async Task LoadData(bool force = false)
    {
        if (_isLoadingData && !force)
        {
            return;
        }
        
        _isLoadingData = true;
        
        try
        {
            isLoading = true;
            gridStatus = "Caricamento...";
            StateHasChanged();
            
            _allCommesse = await Http.GetFromJsonAsync<List<CommessaDto>>("api/Commesse") ?? new();
            
            // Filter only open commesse (la griglia JS farà ulteriori filtri per macchina e stato)
            _commesse = _allCommesse.Where(c => c.Stato == "Aperta").ToList();
            
            // Conteggio delle commesse programmate (con macchina assegnata e non archiviate)
            var programmate = _commesse.Where(c => 
                !string.IsNullOrEmpty(c.NumeroMacchina) &&
                c.StatoProgramma != "Archiviata"
            ).ToList();
            
            totalRows = programmate.Count;
            filteredRows = programmate.Count;
            lastUpdate = DateTime.Now;
            isLoading = false;
            gridStatus = "Pronto";
        }
        finally
        {
            _isLoadingData = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Aspetta che i dati siano caricati con un loop (max 30 secondi)
            int maxWait = 150; // 150 * 200ms = 30 secondi
            int waited = 0;
            while (!_isDataLoaded && waited < maxWait)
            {
                await Task.Delay(200);
                waited++;
            }
            
            if (_isDataLoaded && !_isGridInitialized)
            {
                _isGridInitialized = true;
                await Task.Delay(100);
                await InitializeGrid();
                
                jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/stats-listener-programma.js");
                await jsModule.InvokeVoidAsync("subscribeToStatsChanges", DotNetObjectReference.Create(this));
            }
        }
    }

    [JSInvokable]
    public async Task UpdateStats()
    {
        try
        {
            var stats = await JSRuntime.InvokeAsync<GridStats>("programmaMacchineGrid.getStats");
            totalRows = stats.Total;
            filteredRows = stats.Filtered;
            selectedRows = stats.Selected;
            StateHasChanged();
        }
        catch
        {
            // Error updating stats
        }
    }

    [JSInvokable]
    public async Task SaveGridStateFromJs()
    {
        await SaveGridState();
    }

    [JSInvokable]
    public async Task OnMachineSelectionChanged(string commessaId, string? numeroMacchina)
    {
        // Ricarica i dati per riflettere le modifiche
        await RefreshData();
    }

    [JSInvokable]
    public async Task OnRowDoubleClick(string articoloCodice)
    {
        try
        {
            // Carica l'AnimeDto dal codice articolo
            var anime = await Http.GetFromJsonAsync<AnimeDto>($"/api/Anime/by-codice/{Uri.EscapeDataString(articoloCodice)}");
            
            if (anime == null)
            {
                Snackbar.Add($"Anima con codice {articoloCodice} non trovata", Severity.Warning);
                return;
            }
            
            var parameters = new DialogParameters<AnimeEditDialog>
            {
                { x => x.Anime, anime }
            };
            
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Large,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            
            var dialog = await DialogService.ShowAsync<AnimeEditDialog>("Modifica Anima", parameters, options);
            var result = await dialog.Result;
            
            if (result != null && !result.Canceled && result.Data is AnimeDto updatedAnime)
            {
                // Ricarica i dati per riflettere le modifiche
                await RefreshData();
                Snackbar.Add("Anima aggiornata con successo", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
        
        StateHasChanged();
    }

    private async Task InitializeGrid()
    {
        try
        {
            var exists = await JSRuntime.InvokeAsync<bool>("eval", "typeof window.programmaMacchineGrid !== 'undefined'");
            if (!exists)
            {
                // programmaMacchineGrid is not defined
                return;
            }

            var jsonOptions = new JsonSerializerOptions 
            { 
                PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
                WriteIndented = false
            };
            var jsonData = JsonSerializer.Serialize(_commesse, jsonOptions);

            await JSRuntime.InvokeVoidAsync("eval", $"programmaMacchineGrid.init('programmaMacchineGrid', JSON.parse({System.Text.Json.JsonSerializer.Serialize(jsonData)}), {System.Text.Json.JsonSerializer.Serialize(settings.ColumnStateJson)})");
            
            // Passa il DotNetReference per il doppio clic
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setDotNetHelper", DotNetObjectReference.Create(this));
            
            await ApplyUiSettings();
        }
        catch
        {
            // Error initializing grid
        }
    }

    private async Task ToggleColumnPanel()
    {
        try
        {
            columnList = await JSRuntime.InvokeAsync<List<ColumnInfo>>("programmaMacchineGrid.getAllColumns");
            // Carica le impostazioni di stampa salvate
            await LoadPrintColumnSettings();
            showColumnDialog = true;
        }
        catch
        {
            // Error toggling column panel
        }
    }

    private async Task OnColumnVisibilityChanged(string field, bool visible)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setColumnVisible", field, visible);
            
            // Sincronizza anche la colonna stampa quando si attiva la visibilità
            var col = columnList.FirstOrDefault(c => c.Field == field);
            if (col != null && visible)
            {
                col.PrintVisible = true;
                await SavePrintColumnSettings();
            }
            
            await SaveGridState();
        }
        catch
        {
            // Error changing column visibility
        }
    }

    private async Task RefreshData()
    {
        await LoadData(force: true);
        
        try
        {
            var jsonOptions = new JsonSerializerOptions 
            { 
                PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
                WriteIndented = false
            };
            var jsonData = JsonSerializer.Serialize(_commesse, jsonOptions);
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.updateData", _commesse);
        }
        catch
        {
            // Error updating grid
        }
        
        StateHasChanged();
    }

    private async Task FixGridState()
    {
        try
        {
            // Salva lo stato attuale della griglia come stato "fixed"
            var gridState = await JSRuntime.InvokeAsync<string>("programmaMacchineGrid.getState");
            await PreferencesService.SetAsync("programma-macchine-grid-fixed-state", gridState);
            await PreferencesService.SetAsync("programma-macchine-grid-fixed-settings", JsonSerializer.Serialize(settings));
        }
        catch
        {
            // Error fixing grid state
        }
    }

    private async Task ResetToFixedState()
    {
        try
        {
            // Ripristina lo stato salvato con Fix
            var fixedState = await PreferencesService.GetAsync<string>("programma-macchine-grid-fixed-state");
            var fixedSettings = await PreferencesService.GetAsync<string>("programma-macchine-grid-fixed-settings");
            
            if (!string.IsNullOrEmpty(fixedState))
            {
                await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setState", fixedState);
            }
            else
            {
                // Se non c'è stato salvato, resetta allo stato default
                await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.resetState");
            }
            
            if (!string.IsNullOrEmpty(fixedSettings))
            {
                settings = JsonSerializer.Deserialize<GridUiSettings>(fixedSettings) ?? new GridUiSettings();
            }
            else
            {
                settings = new GridUiSettings();
            }
            
            await ApplyUiSettings();
            StateHasChanged();
        }
        catch
        {
            // Error resetting to fixed state
        }
    }

    private async Task ExportCsv()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.exportCsv");
        }
        catch { }
    }

    private async Task PrintCommesse()
    {
        try
        {
            // Ottieni le colonne da stampare
            var printColumns = await PreferencesService.GetAsync<List<string>>("programma-macchine-print-columns");
            // Usa un iframe nascosto per stampare, così non interferisce con la pagina principale
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.printViaIframe", printColumns);
        }
        catch
        {
            // Error printing
        }
    }

    private async Task ApplyUiSettings()
    {
        try
        {
            var densityPadding = GetDensityPadding();
            await JSRuntime.InvokeVoidAsync("programmaMacchineGrid.setUiVars", 
                settings.FontSize, 
                settings.RowHeight, 
                densityPadding,
                false, // zebra non usato (usiamo colori per macchina)
                settings.GridLines);
            await SaveSettings();
            StateHasChanged();
        }
        catch { }
    }

    private string GetDensityPadding()
    {
        return settings.Density switch
        {
            "Compact" => "4px",
            "Comfortable" => "12px",
            _ => "8px"
        };
    }

    private async Task SaveGridState()
    {
        await SaveSettings();
    }

    private async Task SaveSettings()
    {
        try
        {
            var state = await JSRuntime.InvokeAsync<string>("programmaMacchineGrid.getState");
            settings.ColumnStateJson = state;
            await PreferencesService.SetAsync("programma-macchine-grid-settings", settings);
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        if (jsModule != null)
        {
            try
            {
                await jsModule.DisposeAsync();
            }
            catch { }
        }
        
        try
        {
            await SaveSettings();
        }
        catch { }
    }

    private class GridStats
    {
        public int Total { get; set; }
        public int Filtered { get; set; }
        public int Selected { get; set; }
    }

    private class ColumnInfo
    {
        public string Field { get; set; } = string.Empty;
        public string HeaderName { get; set; } = string.Empty;
        public bool Visible { get; set; }
        public bool PrintVisible { get; set; } = true;
    }

    private async Task SavePrintColumnSettings()
    {
        try
        {
            var printColumns = columnList.Where(c => c.PrintVisible).Select(c => c.Field).ToList();
            await PreferencesService.SetAsync("programma-macchine-print-columns", printColumns);
        }
        catch { }
    }

    private async Task LoadPrintColumnSettings()
    {
        try
        {
            var savedPrintColumns = await PreferencesService.GetAsync<List<string>>("programma-macchine-print-columns");
            if (savedPrintColumns != null)
            {
                // Se ci sono impostazioni salvate, usa quelle
                foreach (var col in columnList)
                {
                    col.PrintVisible = savedPrintColumns.Contains(col.Field);
                }
            }
            else
            {
                // Se non ci sono impostazioni salvate, sincronizza con visibilità
                foreach (var col in columnList)
                {
                    col.PrintVisible = col.Visible;
                }
            }
        }
        catch 
        {
            // In caso di errore, sincronizza con visibilità
            foreach (var col in columnList)
            {
                col.PrintVisible = col.Visible;
            }
        }
    }

    private async Task SelectAllPrintColumns()
    {
        foreach (var col in columnList)
        {
            col.PrintVisible = true;
        }
        await SavePrintColumnSettings();
        StateHasChanged();
    }

    private async Task DeselectAllPrintColumns()
    {
        foreach (var col in columnList)
        {
            col.PrintVisible = false;
        }
        await SavePrintColumnSettings();
        StateHasChanged();
    }
}
