    [JSInvokable]
    public async Task OnPrintLabelClick(CommessaDto commessa)
    {
        selectedCommessaForLabel = commessa;
        currentArticoloCodice = commessa.ArticoloCodice;
        labelFotoUrl = null;
        
        // Verifica dati completi
        campiMancanti.Clear();
        if (string.IsNullOrEmpty(commessa.CodiceAnime))
            campiMancanti.Add("Codice Anima");
        if (string.IsNullOrEmpty(commessa.ClienteRagioneSociale))
            campiMancanti.Add("Cliente (Ragione Sociale)");
        
        if (campiMancanti.Count > 0)
        {
            showMissingDataDialog = true;
        }
        else
        {
            // Calcola quantità iniziale
            var qp = commessa.QuantitaPiano ?? 0;
            var np = commessa.NumeroPiani ?? 0;
            labelQuantita = qp * np > 0 ? qp * np : 1;
            labelQuantitaVuota = false;
            
            // Carica foto con priorità 2
            await LoadLabelFotoAsync(commessa.ArticoloCodice);
            
            showLabelDialog = true;
        }
        StateHasChanged();
    }
    
    private async Task LoadLabelFotoAsync(string? codiceArticolo)
    {
        if (string.IsNullOrEmpty(codiceArticolo))
        {
            labelFotoUrl = null;
            return;
        }
        
        try
        {
            var allegati = await Http.GetFromJsonAsync<AllegatiArticoloResponse>($"/api/allegati-articoli/articolo/{Uri.EscapeDataString(codiceArticolo)}");
            if (allegati?.Foto != null)
            {
                var foto = allegati.Foto.FirstOrDefault(f => f.Priorita == 2) ?? allegati.Foto.FirstOrDefault();
                if (foto != null)
                {
                    labelFotoUrl = $"/api/allegati-articoli/{foto.Id}/file";
                }
            }
        }
        catch
        {
            labelFotoUrl = null;
        }
    }

