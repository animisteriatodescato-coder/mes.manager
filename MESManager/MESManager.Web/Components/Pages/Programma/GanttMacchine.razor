@page "/programma/gantt-macchine"
@layout MainLayout
@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@using Microsoft.AspNetCore.SignalR.Client
@using System.Net.Http.Json
@inject IJSRuntime JS
@inject HttpClient Http
@inject IMacchinaAppService MacchinaService
@inject ICalendarioLavoroAppService CalendarioService
@inject IImpostazioniGanttAppService ImpostazioniGanttService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ILogger<GanttMacchine> _logger
@implements IAsyncDisposable

<PageTitle>Gantt Macchine</PageTitle>

<div data-testid="page-gantt-macchine">
<MudPaper Class="pa-4 mb-4">
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@RefreshGantt">
            <MudIcon Icon="@Icons.Material.Filled.Refresh" Class="mr-1" /> Aggiorna
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="@RicalcolaTutto" data-testid="btn-ricalcola-tutto">
            <MudIcon Icon="@Icons.Material.Filled.Calculate" Class="mr-1" /> Ricalcola Tutto
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="@EsportaSuProgramma" data-testid="btn-salva-impostazioni">
            <MudIcon Icon="@Icons.Material.Filled.Upload" Class="mr-1" /> Esporta su Programma
        </MudButton>
        <MudDivider Vertical="true" FlexItem="true" />
        <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="@OpenBilanciamentoDialog" Disabled="@(_selectedCommessa == null)">
            <MudIcon Icon="@Icons.Material.Filled.Balance" Class="mr-1" /> Suggerisci Macchina
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="@OpenPriorityDialog" Disabled="@(_selectedCommessa == null)">
            <MudIcon Icon="@Icons.Material.Filled.Flag" Class="mr-1" /> Priorità
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="@(_selectedCommessa?.Bloccata == true ? Color.Error : Color.Default)" OnClick="@ToggleLock" Disabled="@(_selectedCommessa == null)">
            <MudIcon Icon="@(_selectedCommessa?.Bloccata == true ? Icons.Material.Filled.Lock : Icons.Material.Filled.LockOpen)" Class="mr-1" />
            @(_selectedCommessa?.Bloccata == true ? "Sblocca" : "Blocca")
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@ArchiviaSelezionata" Disabled="@(_selectedCommessa == null)">
            <MudIcon Icon="@Icons.Material.Filled.Archive" Class="mr-1" /> Archivia
        </MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="@OpenVincoliDialog" Disabled="@(_selectedCommessa == null)">
            <MudIcon Icon="@Icons.Material.Filled.Event" Class="mr-1" /> Vincoli
        </MudButton>
    </MudStack>
    <MudText Typo="Typo.caption" Class="mt-2" Color="Color.Secondary">
        Trascina le commesse per spostarle tra macchine. Clicca su una commessa per modificarne le impostazioni.
    </MudText>
    @if (_selectedCommessa != null)
    {
        <MudChip T="string" Color="Color.Primary" Size="Size.Small" Class="mt-2">
            Selezionata: @_selectedCommessa.Codice - @_selectedCommessa.Description
        </MudChip>
    }
</MudPaper>

<MudPaper Class="pa-4" data-testid="gantt-container">
    <div id="gantt-chart" style="width: 100%; height: calc(100vh - 200px);" @onclick="OnGanttClick"></div>
</MudPaper>

<!-- Dialog Bilanciamento -->
<MudDialog @bind-IsVisible="_bilanciamentoDialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Medium }">
    <TitleContent>
        <MudText Typo="Typo.h6">Suggerimenti Macchina per @_selectedCommessa?.Codice</MudText>
    </TitleContent>
    <DialogContent>
        @if (_suggerimenti.Count == 0)
        {
            <MudProgressCircular Indeterminate="true" />
            <MudText>Analizzando macchine disponibili...</MudText>
        }
        else
        {
            <MudList T="string">
                @foreach (var sug in _suggerimenti)
                {
                    <MudListItem T="string">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.body1"><strong>@sug.NomeMacchina</strong></MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">Carico: @sug.CaricoPercentuale%</MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Fine: @sug.DataFinePrevista.ToString("dd/MM HH:mm")</MudChip>
                            <MudSpacer />
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => ApplicaSuggerimento(sug))">
                                Sposta qui
                            </MudButton>
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _bilanciamentoDialogOpen = false)">Annulla</MudButton>
    </DialogActions>
</MudDialog>

<!-- Dialog Priorità -->
<MudDialog @bind-IsVisible="_priorityDialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Small }">
    <TitleContent>
        <MudText Typo="Typo.h6">Modifica Priorità - @_selectedCommessa?.Codice</MudText>
    </TitleContent>
    <DialogContent>
        <MudNumericField @bind-Value="_newPriority" Label="Priorità" HelperText="Minore = più urgente (1-999)" Min="1" Max="999" />
        <MudText Typo="Typo.caption" Class="mt-2">
            Valori comuni: 1-50 (Urgente), 100 (Normale), 200+ (Bassa)
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _priorityDialogOpen = false)">Annulla</MudButton>
        <MudButton Color="Color.Primary" OnClick="@SalvaPriorita">Salva</MudButton>
    </DialogActions>
</MudDialog>

<!-- Dialog Vincoli -->
<MudDialog @bind-IsVisible="_vincoliDialogOpen" Options="new DialogOptions { MaxWidth = MaxWidth.Medium }">
    <TitleContent>
        <MudText Typo="Typo.h6">Vincoli Temporali - @_selectedCommessa?.Codice</MudText>
    </TitleContent>
    <DialogContent>
        <MudDatePicker @bind-Date="_newVincoloInizio" 
                       Label="Non può iniziare prima del" 
                       Clearable="true"
                       MaxDate="_newVincoloFine" />
        <MudDatePicker @bind-Date="_newVincoloFine" 
                       Label="Deve finire entro il" 
                       Clearable="true" 
                       Class="mt-3"
                       MinDate="_newVincoloInizio" />
        <MudAlert Severity="Severity.Info" Class="mt-3">
            I vincoli limitano quando la commessa può essere pianificata. Lascia vuoto per rimuoverli.
        </MudAlert>
        @if (_newVincoloInizio.HasValue && _newVincoloFine.HasValue && _newVincoloInizio > _newVincoloFine)
        {
            <MudAlert Severity="Severity.Error" Class="mt-2">
                Errore: la data fine vincolo non può essere precedente alla data inizio vincolo.
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _vincoliDialogOpen = false)">Annulla</MudButton>
        <MudButton Color="Color.Primary" OnClick="@SalvaVincoli" Disabled="@(_newVincoloInizio.HasValue && _newVincoloFine.HasValue && _newVincoloInizio > _newVincoloFine)">Salva</MudButton>
    </DialogActions>
</MudDialog>

</div>

@code {
    private List<MacchinaDto> macchine = new();
    private CalendarioLavoroDto? calendario;
    private ImpostazioniGanttDto? impostazioniGantt;
    private List<CommessaGanttDto> commesseGantt = new();
    private HubConnection? _hubConnection;
    private bool _isConnected;
    private DotNetObjectReference<GanttMacchine>? _dotNetRef;
    private CommessaGanttDto? _selectedCommessa;
    private bool _bilanciamentoDialogOpen;
    private bool _priorityDialogOpen;
    private bool _vincoliDialogOpen;
    private int _newPriority = 100;
    private DateTime? _newVincoloInizio;
    private DateTime? _newVincoloFine;
    private List<SuggerimentoMacchina> _suggerimenti = new();

    protected override async Task OnInitializedAsync()
    {
        macchine = await MacchinaService.GetListaAsync();
        calendario = await CalendarioService.GetAsync();
        impostazioniGantt = await ImpostazioniGanttService.GetAsync();
        
        // Carica le commesse pianificate
        await LoadCommesseGantt();
        
        // Inizializza connessione SignalR
        await InitializeSignalR();
    }
    
    private async Task InitializeSignalR()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/pianificazione"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<GanttUpdateNotification>("PianificazioneUpdated", async (notification) =>
            {
                if (notification.Type == "FullRecalculation")
                {
                    await LoadCommesseGantt();
                    await UpdateGanttTasks();
                    await InvokeAsync(StateHasChanged);
                }
            });

            _hubConnection.Reconnected += async (connectionId) =>
            {
                _isConnected = true;
                await InvokeAsync(StateHasChanged);
            };

            _hubConnection.Closed += async (error) =>
            {
                _isConnected = false;
                await InvokeAsync(StateHasChanged);
            };

            await _hubConnection.StartAsync();
            _isConnected = true;
            
            // Iscriviti agli aggiornamenti
            await _hubConnection.InvokeAsync("SubscribeToGantt");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Errore connessione SignalR: {ex.Message}");
            _isConnected = false;
        }
    }
    
    private async Task LoadCommesseGantt()
    {
        try
        {
            var response = await Http.GetAsync("api/pianificazione");
            if (response.IsSuccessStatusCode)
            {
                commesseGantt = await response.Content.ReadFromJsonAsync<List<CommessaGanttDto>>() ?? new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Errore nel caricamento delle commesse: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            
            _dotNetRef = DotNetObjectReference.Create(this);
            
            // Passa le macchine, le impostazioni e le commesse al JavaScript
            var macchineAttive = macchine
                .Where(m => m.AttivaInGantt)
                .OrderBy(m => m.OrdineVisualizazione)
                .Select(m => new { m.Id, m.Nome, m.Codice, m.OrdineVisualizazione })
                .ToList();
            
            var settings = new
            {
                machines = macchineAttive,
                calendar = calendario,
                setupTime = impostazioniGantt,
                tasks = commesseGantt.Select(c => new
                {
                    id = c.Id,
                    codice = c.Codice,
                    description = c.Description,
                    numeroMacchina = c.NumeroMacchina,
                    nomeMacchina = c.NomeMacchina,
                    quantita = c.QuantitaRichiesta,
                    dataInizioPrevisione = c.DataInizioPrevisione,
                    dataFinePrevisione = c.DataFinePrevisione,
                    durataMinuti = c.DurataPrevistaMinuti,
                    stato = c.Stato,
                    statoProgramma = c.StatoProgramma,
                    coloreStato = c.ColoreStato,
                    percentualeCompletamento = c.PercentualeCompletamento,
                    ordineSequenza = c.OrdineSequenza,
                    priorita = c.Priorita,
                    bloccata = c.Bloccata,
                    vincoloDataInizio = c.VincoloDataInizio,
                    vincoloDataFine = c.VincoloDataFine,
                    datiIncompleti = c.DatiIncompleti,
                    hasRicetta = c.HasRicetta,
                    numeroParametri = c.NumeroParametri,
                    ricettaUltimaModifica = c.RicettaUltimaModifica
                }).ToList()
            };
            
            await JS.InvokeVoidAsync("GanttMacchine.initialize", "gantt-chart", settings);
            await JS.InvokeVoidAsync("GanttMacchine.setDotNetHelper", _dotNetRef);
        }
    }
    
    [JSInvokable]
    public async Task OnCommessaMoved(SpostaCommessaResponse result)
    {
        // Aggiorna lo stato locale
        await LoadCommesseGantt();
        Snackbar.Add("Commessa spostata con successo", Severity.Success);
        await InvokeAsync(StateHasChanged);
    }
    
    [JSInvokable]
    public async Task OnFullRecalculation()
    {
        await LoadCommesseGantt();
        await UpdateGanttTasks();
        await InvokeAsync(StateHasChanged);
    }
    
    private async Task UpdateGanttTasks()
    {
        var tasks = commesseGantt.Select(c => new
        {
            id = c.Id,
            codice = c.Codice,
            description = c.Description,
            numeroMacchina = c.NumeroMacchina,
            nomeMacchina = c.NomeMacchina,
            quantita = c.QuantitaRichiesta,
            dataInizioPrevisione = c.DataInizioPrevisione,
            dataFinePrevisione = c.DataFinePrevisione,
            durataMinuti = c.DurataPrevistaMinuti,
            stato = c.Stato,
            statoProgramma = c.StatoProgramma,
            coloreStato = c.ColoreStato,
            percentualeCompletamento = c.PercentualeCompletamento,
            ordineSequenza = c.OrdineSequenza,
            priorita = c.Priorita,
            bloccata = c.Bloccata,
            vincoloDataInizio = c.VincoloDataInizio,
            vincoloDataFine = c.VincoloDataFine,
            datiIncompleti = c.DatiIncompleti,
            hasRicetta = c.HasRicetta,
            numeroParametri = c.NumeroParametri,
            ricettaUltimaModifica = c.RicettaUltimaModifica
        }).ToList();
        
        await JS.InvokeVoidAsync("GanttMacchine.updateTasks", tasks);
    }

    private async Task RefreshGantt()
    {
        await LoadCommesseGantt();
        await UpdateGanttTasks();
        Snackbar.Add("Gantt aggiornato", Severity.Info);
    }
    
    private async Task RicalcolaTutto()
    {
        try
        {
            var response = await Http.PostAsync("api/pianificazione/ricalcola-tutto", null);
            if (response.IsSuccessStatusCode)
            {
                await RefreshGantt();
                Snackbar.Add("Tutte le commesse ricalcolate", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore nel ricalcolo: {ex.Message}", Severity.Error);
        }
    }
    
    [JSInvokable]
    public async Task OnCommessaSelected(Guid commessaId)
    {
        _logger.LogInformation("Commessa selezionata: {CommessaId}", commessaId);
        _selectedCommessa = commesseGantt.FirstOrDefault(c => c.Id == commessaId);
        if (_selectedCommessa != null)
        {
            _logger.LogInformation("Commessa trovata: {Codice} - Priorita: {Priorita}, Bloccata: {Bloccata}", 
                _selectedCommessa.Codice, _selectedCommessa.Priorita, _selectedCommessa.Bloccata);
        }
        else
        {
            _logger.LogWarning("Commessa {CommessaId} non trovata nella lista", commessaId);
        }
        await InvokeAsync(StateHasChanged);
    }
    
    private void OnGanttClick()
    {
        // Handled by JS callback
    }
    
    private async Task OpenBilanciamentoDialog()
    {
        if (_selectedCommessa == null)
        {
            Snackbar.Add("Seleziona prima una commessa cliccando su una barra nel Gantt", Severity.Warning);
            return;
        }
        
        _bilanciamentoDialogOpen = true;
        _suggerimenti.Clear();
        await InvokeAsync(StateHasChanged);
        
        try
        {
            var response = await Http.GetAsync($"api/pianificazione/suggerisci-macchina/{_selectedCommessa.Id}");
            if (response.IsSuccessStatusCode)
            {
                var suggerimenti = await response.Content.ReadFromJsonAsync<List<SuggerimentoMacchina>>() ?? new();
                _suggerimenti = suggerimenti.OrderBy(s => s.DataFinePrevista).Take(5).ToList();
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                _logger.LogError("Errore API suggerisci-macchina: {Error}", error);
                Snackbar.Add($"Errore dal server: {response.StatusCode}", Severity.Error);
                _bilanciamentoDialogOpen = false;
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Errore caricamento suggerimenti");
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
            _bilanciamentoDialogOpen = false;
        }
    }
    
    private async Task ApplicaSuggerimento(SuggerimentoMacchina sug)
    {
        if (_selectedCommessa == null) return;
        
        try
        {
            var request = new SpostaCommessaRequest
            {
                CommessaId = _selectedCommessa.Id,
                TargetMacchina = sug.NumeroMacchina,
                TargetDataInizio = null // Accoda in fondo
            };
            
            var response = await Http.PostAsJsonAsync("api/pianificazione/sposta-commessa", request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<SpostaCommessaResponse>();
                if (result?.Success == true)
                {
                    await RefreshGantt();
                    Snackbar.Add($"Commessa spostata su {sug.NomeMacchina}", Severity.Success);
                    _bilanciamentoDialogOpen = false;
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }
    
    private void OpenPriorityDialog()
    {
        if (_selectedCommessa == null)
        {
            Snackbar.Add("Seleziona prima una commessa cliccando su una barra nel Gantt", Severity.Warning);
            return;
        }
        _newPriority = _selectedCommessa.Priorita;
        _priorityDialogOpen = true;
    }
    
    private async Task SalvaPriorita()
    {
        if (_selectedCommessa == null) return;
        
        try
        {
            var response = await Http.PutAsJsonAsync($"api/pianificazione/{_selectedCommessa.Id}/priorita", new { Priorita = _newPriority });
            if (response.IsSuccessStatusCode)
            {
                _selectedCommessa.Priorita = _newPriority;
                await RefreshGantt();
                Snackbar.Add("Priorità aggiornata", Severity.Success);
                _priorityDialogOpen = false;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }
    
    private async Task ToggleLock()
    {
        if (_selectedCommessa == null) return;
        
        try
        {
            var newState = !_selectedCommessa.Bloccata;
            var response = await Http.PutAsJsonAsync($"api/pianificazione/{_selectedCommessa.Id}/blocca", new { Bloccata = newState });
            if (response.IsSuccessStatusCode)
            {
                _selectedCommessa.Bloccata = newState;
                await RefreshGantt();
                Snackbar.Add(newState ? "Commessa bloccata" : "Commessa sbloccata", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }
    
    private void OpenVincoliDialog()
    {
        if (_selectedCommessa == null)
        {
            Snackbar.Add("Seleziona prima una commessa cliccando su una barra nel Gantt", Severity.Warning);
            return;
        }
        _newVincoloInizio = _selectedCommessa.VincoloDataInizio;
        _newVincoloFine = _selectedCommessa.VincoloDataFine;
        _vincoliDialogOpen = true;
    }
    
    private async Task SalvaVincoli()
    {
        if (_selectedCommessa == null) return;
        
        try
        {
            var response = await Http.PutAsJsonAsync($"api/pianificazione/{_selectedCommessa.Id}/vincoli", new 
            { 
                VincoloDataInizio = _newVincoloInizio, 
                VincoloDataFine = _newVincoloFine 
            });
            
            if (response.IsSuccessStatusCode)
            {
                _selectedCommessa.VincoloDataInizio = _newVincoloInizio;
                _selectedCommessa.VincoloDataFine = _newVincoloFine;
                await RefreshGantt();
                Snackbar.Add("Vincoli aggiornati", Severity.Success);
                _vincoliDialogOpen = false;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }
    
    private async Task EsportaSuProgramma()
    {
        try
        {
            var response = await Http.PostAsync("api/pianificazione/esporta-su-programma", null);
            var result = await response.Content.ReadFromJsonAsync<EsportaProgrammaResult>();
            var success = response.IsSuccessStatusCode && (result?.Success ?? false);

            if (success)
            {
                Snackbar.Add("Programmazione esportata con successo!", Severity.Success);
                // Naviga alla pagina Programma Macchine dopo 1 secondo
                await Task.Delay(1000);
                NavigationManager.NavigateTo("/programma/programma-macchine");
                return;
            }

            var message = result?.Message ?? await response.Content.ReadAsStringAsync();
            Snackbar.Add($"Errore esportazione: {message}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    private sealed class EsportaProgrammaResult
    {
        public bool Success { get; set; }
        public string? Message { get; set; }
    }

    private async Task ArchiviaSelezionata()
    {
        if (_selectedCommessa == null)
        {
            Snackbar.Add("Seleziona una commessa prima di archiviare", Severity.Warning);
            return;
        }

        var confirm = await JS.InvokeAsync<bool>("confirm", $"Archiviare la commessa {_selectedCommessa.Codice}?");
        if (!confirm)
        {
            return;
        }

        var request = new HttpRequestMessage(HttpMethod.Patch, $"api/Commesse/{_selectedCommessa.Id}/stato-programma")
        {
            Content = JsonContent.Create(new { statoProgramma = "Archiviata" })
        };

        var response = await Http.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Commessa archiviata", Severity.Success);
            await RefreshGantt();
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            Snackbar.Add($"Errore archiviazione: {error}", Severity.Error);
        }
    }
    
    public async ValueTask DisposeAsync()
    {
        await JS.InvokeVoidAsync("GanttMacchine.dispose");
        
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
        
        _dotNetRef?.Dispose();
    }
    
    // Classe interna per le notifiche SignalR
    private class GanttUpdateNotification
    {
        public string Type { get; set; } = "";
        public List<CommessaGanttDto>? CommesseAggiornate { get; set; }
    }
    
    // Classe per i suggerimenti macchina
    private class SuggerimentoMacchina
    {
        public int NumeroMacchina { get; set; }
        public string NomeMacchina { get; set; } = "";
        public int CaricoPercentuale { get; set; }
        public DateTime DataFinePrevista { get; set; }
        public int PosizioneInCoda { get; set; }
    }
}
