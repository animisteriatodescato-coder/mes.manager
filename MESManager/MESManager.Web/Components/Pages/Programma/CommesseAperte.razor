    private async Task ToggleColumnPanel()
    {
        try
        {
            columnList = await JSRuntime.InvokeAsync<List<ColumnInfo>>("commesseAperteGrid.getAllColumns");
            showColumnDialog = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error toggling column panel: {ex.Message}");
        }
    }

    private async Task OnColumnVisibilityChanged(string field, bool visible)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("commesseAperteGrid.setColumnVisible", field, visible);
            await SaveGridState();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error changing column visibility: {ex.Message}");
        }
    }

    private async Task ResetGrid()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("commesseAperteGrid.resetState");
            settings = new GridUiSettings();
            await PreferencesService.RemoveAsync("commesse-aperte-grid-settings");
            await ApplyUiSettings();
            StateHasChanged();
        }
        catch { }
    }

    private async Task ExportCsv()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("commesseAperteGrid.exportCsv");
        }
        catch { }
    }

    private async Task ApplyUiSettings()
    {
        try
        {
            var densityPadding = GetDensityPadding();
            await JSRuntime.InvokeVoidAsync("commesseAperteGrid.setUiVars", 
                settings.FontSize, 
                settings.RowHeight, 
                densityPadding,
                settings.Zebra,
                settings.GridLines);
            await SaveSettings();
            StateHasChanged();
        }
        catch { }
    }

    private string GetDensityPadding()
    {
        return settings.Density switch
        {
            "Compact" => "4px",
            "Comfortable" => "12px",
            _ => "8px"
        };
    }

    private async Task SaveGridState()
    {
        await SaveSettings();
    }

    private async Task SaveSettings()
    {
        try
        {
            var state = await JSRuntime.InvokeAsync<string>("commesseAperteGrid.getState");
            settings.ColumnStateJson = state;
            await PreferencesService.SetAsync("commesse-aperte-grid-settings", settings);
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        PageToolbarService.SetActivePage("commesse-aperte", null);
        
        if (jsModule != null)
        {
            await jsModule.DisposeAsync();
        }
        
        try
        {
            await SaveSettings();
        }
        catch { }
    }
    
