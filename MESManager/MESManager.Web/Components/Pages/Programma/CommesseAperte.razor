    private async Task ToggleColumnPanel()
    {
        try
        {
            columnList = await JSRuntime.InvokeAsync<List<ColumnInfo>>("commesseAperteGrid.getAllColumns");
            showColumnDialog = true;
        }
        catch
        {
            // Error toggling column panel
        }
    }

    private async Task OnColumnVisibilityChanged(string field, bool visible)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("commesseAperteGrid.setColumnVisible", field, visible);
            await SaveGridState();
        }
        catch
        {
            // Error changing column visibility
        }
    }

    private async Task FixGridState()
    {
        try
        {
            var gridState = await JSRuntime.InvokeAsync<string>("commesseAperteGrid.getState");
            await PreferencesService.SetAsync("commesse-aperte-grid-fixed-state", gridState);
            await PreferencesService.SetAsync("commesse-aperte-grid-fixed-settings", JsonSerializer.Serialize(settings));
        }
        catch { }
    }

    private async Task ResetToFixedState()
    {
        try
        {
            var fixedState = await PreferencesService.GetAsync<string>("commesse-aperte-grid-fixed-state");
            var fixedSettings = await PreferencesService.GetAsync<string>("commesse-aperte-grid-fixed-settings");
            
            if (!string.IsNullOrEmpty(fixedState))
            {
                await JSRuntime.InvokeVoidAsync("commesseAperteGrid.setState", fixedState);
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("commesseAperteGrid.resetState");
            }
            
            if (!string.IsNullOrEmpty(fixedSettings))
            {
                settings = JsonSerializer.Deserialize<GridUiSettings>(fixedSettings) ?? new GridUiSettings();
            }
            else
            {
                settings = new GridUiSettings();
            }
            
            await ApplyUiSettings();
            StateHasChanged();
        }
        catch { }
    }

    private async Task ExportCsv()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("commesseAperteGrid.exportCsv");
        }
        catch { }
    }

    private async Task ApplyUiSettings()
    {
        try
        {
            var densityPadding = GetDensityPadding();
            await JSRuntime.InvokeVoidAsync("commesseAperteGrid.setUiVars", 
                settings.FontSize, 
                settings.RowHeight, 
                densityPadding,
                settings.Zebra,
                settings.GridLines);
            await SaveSettings();
            StateHasChanged();
        }
        catch { }
    }

    private string GetDensityPadding()
    {
        return settings.Density switch
        {
            "Compact" => "4px",
            "Comfortable" => "12px",
            _ => "8px"
        };
    }

    private async Task SaveGridState()
    {
        await SaveSettings();
    }

    private async Task SaveSettings()
    {
        try
        {
            var state = await JSRuntime.InvokeAsync<string>("commesseAperteGrid.getState");
            settings.ColumnStateJson = state;
            await PreferencesService.SetAsync("commesse-aperte-grid-settings", settings);
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        PageToolbarService.SetActivePage("commesse-aperte", null);
        
        if (jsModule != null)
        {
            try
            {
                await jsModule.DisposeAsync();
            }
            catch { }
        }
        
        try
        {
            await SaveSettings();
        }
        catch { }
    }
    
    // Metodi pubblici per essere chiamati dalla AppBar
    public async Task OnSearchDebounced_Public(string value)
    {
        searchText = value;
        await OnSearchDebounced(value);
    }
    
    public async Task ToggleColumnPanel_Public() => await ToggleColumnPanel();
    public async Task ResetGrid_Public() => await ResetToFixedState();
    public async Task ExportCsv_Public() => await ExportCsv();
    public void ToggleSettings_Public()
    {
        showSettings = !showSettings;
        StateHasChanged();
    }

