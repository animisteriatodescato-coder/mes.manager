@page "/programma/commesse-aperte"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = MESManager.Web.Constants.PaginaPolicy.CommesseAperte)]
@using MESManager.Application.DTOs
@using MESManager.Application.Services
@using MESManager.Web.Models
@using MESManager.Web.Services
@using MESManager.Web.Components.Dialogs
@using Microsoft.JSInterop
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject PreferencesService PreferencesService
@inject CurrentUserService CurrentUserService
@inject IJSRuntime JSRuntime
@inject IPageToolbarService PageToolbarService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>Commesse Aperte</PageTitle>

<div class="mes-grid-page" data-testid="page-commesse-aperte">
    <MudPaper Class="settings-panel toolbar-sticky pa-2 mb-1" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudTextField @bind-Value="searchText"
                         Placeholder="Cerca in tutte le colonne..."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Style="width: 280px;"
                         Immediate="true"
                         DebounceInterval="280"
                         OnDebounceIntervalElapsed="OnSearchDebounced" />
            <MudSwitch Value="@showArchived" 
                       Color="Color.Warning" 
                       Label="Archiviate" 
                       T="bool"
                       ValueChanged="@OnShowArchivedChanged" />
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="@RefreshGridData" data-testid="btn-refresh">Aggiorna</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Timeline" OnClick="@CaricaSuGantt" Disabled="@IsReadOnly" data-testid="btn-carica-su-gantt">
                🚀 Carica su Gantt
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.ViewColumn" OnClick="@ToggleColumnPanel">Colonne</MudButton>
            <FixResetMenu OnFix="@FixGridState" OnReset="@ResetToFixedState"
                         ShowGlobalSave="@IsAdmin" OnSaveGlobal="@SaveAsGlobalDefault" />
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Download" OnClick="@ExportCsv">Export CSV</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Settings" OnClick="@(() => showSettings = !showSettings)">Impostazioni</MudButton>
        </MudStack>
        
        @if (showSettings)
        {
            <MudPaper Class="pa-4 mt-2" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Wrap="Wrap.Wrap">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Font Size:</MudText>
                        <MudNumericField Value="@settings.FontSize" Min="10" Max="24" Step="1" 
                                        Variant="Variant.Outlined" Margin="Margin.Dense"
                                        ValueChanged="@(async (int val) => { settings.FontSize = val; await ApplyUiSettings(); })" 
                                        Style="width: 80px;" />
                    </MudStack>
                    
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Row Height:</MudText>
                        <MudNumericField Value="@settings.RowHeight" Min="25" Max="80" Step="5" 
                                        Variant="Variant.Outlined" Margin="Margin.Dense"
                                        ValueChanged="@(async (int val) => { settings.RowHeight = val; await ApplyUiSettings(); })" 
                                        Style="width: 80px;" />
                    </MudStack>
                    
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Density:</MudText>
                        <MudSelect Value="@settings.Density" 
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  ValueChanged="@(async (string val) => { settings.Density = val; await ApplyUiSettings(); })" 
                                  Style="width: 120px;">
                            <MudSelectItem Value="@("Compact")">Compact</MudSelectItem>
                            <MudSelectItem Value="@("Normal")">Normal</MudSelectItem>
                            <MudSelectItem Value="@("Comfortable")">Comfortable</MudSelectItem>
                        </MudSelect>
                    </MudStack>
                    
                    <MudCheckBox Value="@settings.Zebra" Label="Zebra" Color="Color.Primary"
                                ValueChanged="@(async (bool val) => { settings.Zebra = val; await ApplyUiSettings(); })" />
                    
                    <MudCheckBox Value="@settings.GridLines" Label="Grid Lines" Color="Color.Primary"
                                ValueChanged="@(async (bool val) => { settings.GridLines = val; await ApplyUiSettings(); })" />
                </MudStack>
            </MudPaper>
        }
    </MudPaper>

    <div id="commesseAperteGrid" class="ag-theme-alpine mes-ag-grid" 
         data-testid="grid-commesse">
    </div>

    <MudDialog @bind-Visible="showColumnDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Medium }">
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.ViewColumn" Class="mr-2" />
                Gestione Colonne
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudList T="string" Dense="true">
                @foreach (var col in columnList)
                {
                    var currentCol = col;
                    <MudListItem T="string">
                        <MudSwitch Value="@currentCol.Visible" 
                                   Color="Color.Primary" 
                                   Label="@currentCol.HeaderName"
                                   T="bool"
                                   ValueChanged="@(async (bool val) => { currentCol.Visible = val; await OnColumnVisibilityChanged(currentCol.Field, val); })" />
                    </MudListItem>
                }
            </MudList>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => showColumnDialog = false)">Chiudi</MudButton>
        </DialogActions>
    </MudDialog>

    <LabelPrintDialog @ref="_labelDialog" />

    <MudPaper Class="footer-info pa-1" Elevation="1" Style="flex-shrink: 0;">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.caption" Color="Color.Success">Totale Aperte: <strong>@totalRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Filtrate: <strong>@filteredRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Selezionate: <strong>@selectedRows</strong></MudText>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">Ultimo aggiornamento: <strong>@lastUpdate.ToString("HH:mm:ss")</strong></MudText>
            <MudSpacer />
            <MudChip T="string" Size="Size.Small" Color="@(isLoading ? Color.Warning : Color.Success)" 
                     Icon="@(isLoading ? Icons.Material.Filled.HourglassEmpty : Icons.Material.Filled.CheckCircle)"
                     data-testid="status-message">
                @gridStatus
            </MudChip>
        </MudStack>
    </MudPaper>
</div>

<style>
    /* Abilita selezione testo nelle celle della grid */
    .ag-theme-alpine .ag-cell {
        user-select: text !important;
        -webkit-user-select: text !important;
        -moz-user-select: text !important;
        -ms-user-select: text !important;
    }
    /* Dark mode AG Grid panel: centralizzato in app.css via .mud-theme-dark */

</style>

@code {
    [CascadingParameter(Name = "IsReadOnly")] private bool IsReadOnly { get; set; }
    [CascadingParameter(Name = "IsAdmin")]    private bool IsAdmin    { get; set; }

    private List<CommessaDto> _commesse = new();
    private GridUiSettings settings = new();
    private bool showSettings = false;
    private string searchText = string.Empty;
    private bool showColumnDialog = false;
    private List<ColumnInfo> columnList = new();

    private int totalRows = 0;
    private int filteredRows = 0;
    private int selectedRows = 0;
    private DateTime lastUpdate = DateTime.MinValue;
    private bool isLoading = false;
    private string gridStatus = "Pronto";
    private IJSObjectReference? jsModule;
    private bool _isGridInitialized = false;
    private bool _isDataLoaded = false;
    private bool _isLoadingData = false;
    private bool showArchived = false;
    
    private LabelPrintDialog? _labelDialog;

    private async Task OnSearchDebounced(string value)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("commesseAperteGrid.setQuickFilter", value);
        }
        catch
        {
            // Error filtering grid
        }
    }

    /// <summary>
    /// 🚀 CARICA SU GANTT - Auto-scheduler intelligente v1.48
    /// Prende la commessa selezionata e mostra un dialog di selezione macchina
    /// Se non si seleziona nulla, usa l'auto-scheduler
    /// </summary>
    private async Task CaricaSuGantt()
    {
        if (IsReadOnly) return;
        try
        {
            // Ottieni righe selezionate da AG-Grid
            var selectedRows = await JSRuntime.InvokeAsync<CommessaDto[]>("commesseAperteGrid.getSelectedRows");
            
            if (selectedRows == null || selectedRows.Length == 0)
            {
                Snackbar.Add("⚠️ Seleziona una commessa dalla griglia", Severity.Warning);
                return;
            }
            
            if (selectedRows.Length > 1)
            {
                Snackbar.Add("⚠️ Seleziona una sola commessa alla volta", Severity.Warning);
                return;
            }
            
            var commessa = selectedRows[0];
            
            // Verifica se già ha una macchina assegnata
            if (commessa.NumeroMacchina.HasValue)
            {
                var confirm = await DialogService.ShowMessageBox(
                    "Commessa già assegnata",
                    $"La commessa {commessa.Codice} è già assegnata a macchina {commessa.NumeroMacchina}. Vuoi ri-caricarla sul Gantt?",
                    yesText: "Sì, ricarica",
                    cancelText: "Annulla"
                );
                
                if (confirm != true)
                {
                    return;
                }
            }
            
            // 🎯 Carica macchine disponibili per questa commessa
            List<MacchinaDisponibileDto>? macchineDisponibili = null;
            try
            {
                macchineDisponibili = await Http.GetFromJsonAsync<List<MacchinaDisponibileDto>>($"api/pianificazione/macchine-disponibili/{commessa.Id}");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ Errore caricamento macchine disponibili: {ex.Message}");
            }
            
            int? macchinaSelezionata = null;
            
            // 📋 Mostra dialog di selezione macchina solo se ci sono macchine disponibili
            if (macchineDisponibili != null && macchineDisponibili.Any())
            {
                var dialogParameters = new DialogParameters
                {
                    ["Commessa"] = commessa,
                    ["MacchineDisponibili"] = macchineDisponibili
                };
                
                var dialogOptions = new DialogOptions 
                { 
                    MaxWidth = MaxWidth.Small, 
                    FullWidth = true,
                    CloseOnEscapeKey = true,
                    CloseButton = true
                };
                
                var dialog = await DialogService.ShowAsync<DialoSelezioneSceltaMacchina>("Seleziona Macchina", dialogParameters, dialogOptions);
                var result = await dialog.Result;
                
                // result può essere null se il dialog viene chiuso in modo anomalo
                if (result is null || result.Canceled)
                    return;
                
                if (result.Data is int numeroMacchina)
                    macchinaSelezionata = numeroMacchina;
                // Se result.Data è null → auto-scheduler
            }
            
            Snackbar.Add("🚀 Caricamento in corso...", Severity.Info);
            
            // Chiamata API con macchina selezionata (o null per auto-scheduler)
            var requestBody = macchinaSelezionata.HasValue 
                ? new { NumeroMacchina = macchinaSelezionata.Value } 
                : null;
            
            var response = await Http.PostAsJsonAsync($"api/pianificazione/carica-su-gantt/{commessa.Id}", requestBody);
            
            if (response.IsSuccessStatusCode)
            {
                var apiResult = await response.Content.ReadFromJsonAsync<CaricaSuGanttResponse>();
                
                if (apiResult != null && apiResult.Success)
                {
                    Snackbar.Add(
                        $"✅ {commessa.Codice} caricata su macchina {apiResult.MacchinaAssegnata} - {apiResult.Motivazione}",
                        Severity.Success,
                        config => { config.VisibleStateDuration = 5000; }
                    );
                    
                    // Refresh griglia per rimuovere la commessa appena caricata
                    await Task.Delay(500);
                    await RefreshGridData();
                }
                else
                {
                    Snackbar.Add($"❌ Errore: {apiResult?.ErrorMessage ?? "Risposta non valida"}", Severity.Error);
                }
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"❌ Errore HTTP {response.StatusCode}: {errorContent}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ Errore: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnShowArchivedChanged(bool value)
    {
        showArchived = value;
        // Imposta la variabile globale JavaScript per il refresh
        await JSRuntime.InvokeVoidAsync("eval", $"window.commesseAperteShowArchived = {value.ToString().ToLower()}");
        await LoadData(true);
        await ReinitializeGrid();
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        PageToolbarService.SetActivePage("commesse-aperte", this);
        
        isLoading = true;
        gridStatus = "Caricamento...";
        _isDataLoaded = false;
        
        await LoadData();
        
        _isDataLoaded = true;
        isLoading = false;
        gridStatus = "Pronto";
        
        var savedSettings = await PreferencesService.GetAsync<GridUiSettings>("commesse-aperte-grid-settings");
        if (savedSettings != null)
        {
            settings = savedSettings;
        }
    }
    
    private async Task RefreshGridData()
    {
        try
        {
            await LoadData();
            await ReinitializeGrid();
            StateHasChanged();
        }
        catch
        {
            // Error refreshing grid data
        }
    }
    
    private async Task ReinitializeGrid()
    {
        try
        {
            var jsonOptions = new JsonSerializerOptions 
            { 
                PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
                WriteIndented = false
            };
            var jsonData = JsonSerializer.Serialize(_commesse, jsonOptions);
            
            // Call reinit method which will destroy old grid first
            await JSRuntime.InvokeVoidAsync("commesseAperteGrid.reinit", jsonData);
        }
        catch
        {
            // Error reinitializing grid
        }
    }

    private async Task LoadData(bool force = false)
    {
        if (_isLoadingData && !force)
        {
            return;
        }
        
        _isLoadingData = true;
        
        try
        {
            var allCommesse = await Http.GetFromJsonAsync<List<CommessaDto>>("api/Commesse") ?? new();
            
            // Filtra solo le commesse aperte, e opzionalmente esclude archiviate
            if (showArchived)
            {
                _commesse = allCommesse.Where(c => c.Stato == "Aperta").ToList();
            }
            else
            {
                _commesse = allCommesse.Where(c => c.Stato == "Aperta" && c.StatoProgramma != "Archiviata").ToList();
            }
            
            totalRows = _commesse.Count;
            filteredRows = _commesse.Count;
            lastUpdate = DateTime.Now;
        }
        finally
        {
            _isLoadingData = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Aspetta che i dati siano caricati con un loop (max 30 secondi)
            int maxWait = 150; // 150 * 200ms = 30 secondi
            int waited = 0;
            while (!_isDataLoaded && waited < maxWait)
            {
                await Task.Delay(200);
                waited++;
            }
            
            if (_isDataLoaded && !_isGridInitialized)
            {
                _isGridInitialized = true;
                await Task.Delay(100);
                await InitializeGrid();
                
                jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/stats-listener.js");
                await jsModule.InvokeVoidAsync("subscribeToStatsChanges", DotNetObjectReference.Create(this));
            }
        }
    }

    [JSInvokable]
    public async Task UpdateStats()
    {
        try
        {
            var stats = await JSRuntime.InvokeAsync<GridStats>("commesseAperteGrid.getStats");
            totalRows = stats.Total;
            filteredRows = stats.Filtered;
            selectedRows = stats.Selected;
            StateHasChanged();
        }
        catch
        {
            // Error updating stats
        }
    }

    [JSInvokable]
    public async Task SaveGridStateFromJs()
    {
        await SaveGridState();
    }

    [JSInvokable]
    public async Task ViewRicetta(string codiceArticolo)
    {
        try
        {
            var parameters = new DialogParameters<RicettaViewDialog>
            {
                { x => x.CodiceArticolo, codiceArticolo },
                { x => x.ShowImportButton, true },
                { x => x.IsReadOnly, IsReadOnly }
            };
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Large,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            await DialogService.ShowAsync<RicettaViewDialog>($"Ricetta: {codiceArticolo}", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore apertura ricetta: {ex.Message}", Severity.Error);
        }
    }

    [JSInvokable]
    public async Task ImportaRicetta(string codiceArticolo)
    {
        if (IsReadOnly) return;
        try
        {
            var parameters = new DialogParameters<ImportaRicettaMacchinaDialog>
            {
                { x => x.CodiceArticolo, codiceArticolo }
            };
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            await DialogService.ShowAsync<ImportaRicettaMacchinaDialog>("Importa Ricetta da Macchina", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore importazione ricetta: {ex.Message}", Severity.Error);
        }
    }

    [JSInvokable]
    public async Task OnRowDoubleClick(string articoloCodice)
    {
        if (IsReadOnly) return;
        try
        {
            var anime = await Http.GetFromJsonAsync<AnimeDto>($"/api/Anime/by-codice/{string.Join('/', articoloCodice.Split('/').Select(Uri.EscapeDataString))}");

            if (anime == null)
            {
                Snackbar.Add($"Anima con codice {articoloCodice} non trovata", Severity.Warning);
                return;
            }

            var parameters = new DialogParameters<AnimeEditDialog>
            {
                { x => x.Anime, anime }
            };
            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Large,
                FullWidth = true,
                CloseButton = true,
                CloseOnEscapeKey = true
            };
            var dialog = await DialogService.ShowAsync<AnimeEditDialog>("Modifica Anima", parameters, options);
            var result = await dialog.Result;

            if (result != null && !result.Canceled && result.Data is AnimeDto updatedAnime)
            {
                Snackbar.Add("Anima aggiornata con successo", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    private async Task InitializeGrid()
    {
        try
        {
            var exists = await JSRuntime.InvokeAsync<bool>("eval", "typeof window.commesseAperteGrid !== 'undefined'");
            if (!exists)
            {
                // commesseAperteGrid is not defined
                return;
            }

            var jsonOptions = new JsonSerializerOptions 
            { 
                PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
                WriteIndented = false
            };
            var jsonData = JsonSerializer.Serialize(_commesse, jsonOptions);

            // Imposta l'utente corrente per la griglia (per salvare le preferenze per-utente)
            var userId = CurrentUserService.UserId ?? "";
            await JSRuntime.InvokeVoidAsync("commesseAperteGrid.setCurrentUser", userId);

            await JSRuntime.InvokeVoidAsync("eval", $"commesseAperteGrid.init('commesseAperteGrid', JSON.parse({System.Text.Json.JsonSerializer.Serialize(jsonData)}), {System.Text.Json.JsonSerializer.Serialize(settings.ColumnStateJson)})");
            
            // Registra il DotNetHelper per i callback JS
            await JSRuntime.InvokeVoidAsync("commesseAperteGrid.setDotNetHelper", DotNetObjectReference.Create(this));
            
            await ApplyUiSettings();
        }
        catch
        {
            // Error initializing grid
        }
    }

    [JSInvokable]
    public async Task OnPrintLabelClick(CommessaDto commessa)
    {
        if (_labelDialog != null)
            await _labelDialog.OpenAsync(commessa);
    }

    
    private async Task ToggleColumnPanel()
    {
        try
        {
            columnList = await JSRuntime.InvokeAsync<List<ColumnInfo>>("commesseAperteGrid.getAllColumns");
            showColumnDialog = true;
        }
        catch
        {
            // Error toggling column panel
        }
    }

    private async Task OnColumnVisibilityChanged(string field, bool visible)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("commesseAperteGrid.setColumnVisible", field, visible);
            await SaveGridState();
        }
        catch
        {
            // Error changing column visibility
        }
    }

    private async Task FixGridState()
    {
        try
        {
            var gridState = await JSRuntime.InvokeAsync<string>("commesseAperteGrid.getState");
            await PreferencesService.SetAsync("commesse-aperte-grid-fixed-state", gridState);
            await PreferencesService.SetAsync("commesse-aperte-grid-fixed-settings", JsonSerializer.Serialize(settings));
        }
        catch { }
    }

    private async Task ResetToFixedState()
    {
        try
        {
            var fixedState = await PreferencesService.GetAsync<string>("commesse-aperte-grid-fixed-state");
            var fixedSettings = await PreferencesService.GetAsync<string>("commesse-aperte-grid-fixed-settings");
            
            if (!string.IsNullOrEmpty(fixedState))
            {
                await JSRuntime.InvokeVoidAsync("commesseAperteGrid.setState", fixedState);
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("commesseAperteGrid.resetState");
            }
            
            if (!string.IsNullOrEmpty(fixedSettings))
            {
                settings = JsonSerializer.Deserialize<GridUiSettings>(fixedSettings) ?? new GridUiSettings();
            }
            else
            {
                settings = new GridUiSettings();
            }
            
            await ApplyUiSettings();
            StateHasChanged();
        }
        catch { }
    }

    private async Task SaveAsGlobalDefault()
    {
        try
        {
            var gridState = await JSRuntime.InvokeAsync<string>("commesseAperteGrid.getState");
            settings.ColumnStateJson = gridState;
            await PreferencesService.SetGlobalAsync("commesse-aperte-grid-settings", settings);
        }
        catch { }
    }

    private async Task ExportCsv()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("commesseAperteGrid.exportCsv");
        }
        catch { }
    }

    private async Task ApplyUiSettings()
    {
        try
        {
            var densityPadding = GetDensityPadding();
            await JSRuntime.InvokeVoidAsync("commesseAperteGrid.setUiVars", 
                settings.FontSize, 
                settings.RowHeight, 
                densityPadding,
                settings.Zebra,
                settings.GridLines);
            await SaveSettings();
            StateHasChanged();
        }
        catch { }
    }

    private string GetDensityPadding()
    {
        return settings.Density switch
        {
            "Compact" => "4px",
            "Comfortable" => "12px",
            _ => "8px"
        };
    }

    private async Task SaveGridState()
    {
        await SaveSettings();
    }

    private async Task SaveSettings()
    {
        try
        {
            var state = await JSRuntime.InvokeAsync<string>("commesseAperteGrid.getState");
            settings.ColumnStateJson = state;
            await PreferencesService.SetAsync("commesse-aperte-grid-settings", settings);
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        PageToolbarService.SetActivePage("commesse-aperte", null);
        
        if (jsModule != null)
        {
            try
            {
                await jsModule.DisposeAsync();
            }
            catch { }
        }
        
        try
        {
            await SaveSettings();
        }
        catch { }
    }
    
    // Metodi pubblici per essere chiamati dalla AppBar
    public async Task OnSearchDebounced_Public(string value)
    {
        searchText = value;
        await OnSearchDebounced(value);
    }
    
    public async Task ToggleColumnPanel_Public() => await ToggleColumnPanel();
    public async Task ResetGrid_Public() => await ResetToFixedState();
    public async Task ExportCsv_Public() => await ExportCsv();
    public void ToggleSettings_Public()
    {
        showSettings = !showSettings;
        StateHasChanged();
    }

    private class GridStats
    {
        public int Total { get; set; }
