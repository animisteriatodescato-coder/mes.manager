@page "/sync/gantt"
@using MESManager.Application.DTOs
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@inject NavigationManager NavManager
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar

<PageTitle>Sincronizzazione Gantt</PageTitle>

<MudGrid>
    <MudItem xs="12">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">Importazione Anime</MudText>
            
            <MudStack Spacing="4">
                <!-- Importazione da Gantt -->
                <div>
                    <MudText Typo="Typo.subtitle1" Class="mb-2">Importa da Database Gantt</MudText>
                    <MudAlert Severity="Severity.Info" Class="mb-3">
                        Questa funzione importa i dati delle Anime dal sistema Gantt esterno.
                        L'operazione potrebbe richiedere alcuni minuti.
                    </MudAlert>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Success" 
                              StartIcon="@Icons.Material.Filled.CloudDownload"
                              OnClick="@ImportaFromGantt"
                              Disabled="@_importando"
                              Size="Size.Large">
                        @if (_importando)
                        {
                            <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                            <span>Importazione in corso...</span>
                        }
                        else
                        {
                            <span>Importa da Gantt</span>
                        }
                    </MudButton>
                </div>

                <MudDivider />

                <!-- Importazione da Excel -->
                <div>
                    <MudText Typo="Typo.subtitle1" Class="mb-2">Importa da File Excel</MudText>
                    <MudAlert Severity="Severity.Warning" Class="mb-3">
                        Carica il file Excel con i dati completi degli articoli.
                        Questa operazione sostituirà tutti i dati esistenti nel database.
                    </MudAlert>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudFileUpload T="IBrowserFile" 
                                      Accept=".xls,.xlsx" 
                                      FilesChanged="OnFileSelected"
                                      MaximumFileCount="1">
                            <ActivatorContent>
                                <MudButton HtmlTag="label"
                                          Variant="Variant.Outlined"
                                          Color="Color.Primary"
                                          StartIcon="@Icons.Material.Filled.CloudUpload">
                                    Seleziona File Excel
                                </MudButton>
                            </ActivatorContent>
                        </MudFileUpload>

                        @if (_selectedFile != null)
                        {
                            <MudChip T="string" Color="Color.Info" Size="Size.Small">
                                @_selectedFile.Name (@FormatFileSize(_selectedFile.Size))
                            </MudChip>
                        }

                        <MudButton Variant="Variant.Filled" 
                                  Color="Color.Primary" 
                                  StartIcon="@Icons.Material.Filled.Upload"
                                  OnClick="@ImportaFromExcel"
                                  Disabled="@(_importandoExcel || _selectedFile == null)"
                                  Size="Size.Medium">
                            @if (_importandoExcel)
                            {
                                <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                                <span>Caricamento...</span>
                            }
                            else
                            {
                                <span>Importa Excel</span>
                            }
                        </MudButton>
                    </MudStack>
                </div>

                @if (_risultati != null && _risultati.Any())
                {
                    <MudDivider />
                    
                    <MudText Typo="Typo.h6" Class="mt-4">Risultati Ultima Importazione</MudText>
                    
                    <MudSimpleTable Dense="true" Hover="true" Bordered="true">
                        <thead>
                            <tr>
                                <th>Codice Anima</th>
                                <th>Codice Articolo</th>
                                <th>Descrizione Articolo</th>
                                <th>Stato</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var anima in _risultati)
                            {
                                <tr>
                                    <td><strong>@anima.CodiceAnime</strong></td>
                                    <td>@anima.CodiceArticolo</td>
                                    <td>@anima.DescrizioneArticolo</td>
                                    <td>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Importato</MudChip>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                    
                    <MudText Typo="Typo.body2" Class="mt-2">
                        Totale anime importate: <strong>@_risultati.Count</strong>
                    </MudText>
                }
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private bool _importando = false;
    private bool _importandoExcel = false;
    private IBrowserFile? _selectedFile = null;
    private List<AnimeDto>? _risultati = null;

    private void OnFileSelected(IBrowserFile file)
    {
        _selectedFile = file;
        StateHasChanged();
    }

    private string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private async Task ImportaFromExcel()
    {
        if (_selectedFile == null) return;

        _importandoExcel = true;
        _risultati = null;
        StateHasChanged();

        try
        {
            var httpClient = HttpClientFactory.CreateClient();
            var baseUri = new Uri(NavManager.BaseUri);
            var importUrl = new Uri(baseUri, "api/Anime/import-excel");

            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(_selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024)); // 10MB max
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("application/vnd.ms-excel");
            content.Add(fileContent, "file", _selectedFile.Name);

            var response = await httpClient.PostAsync(importUrl, content);
            if (response.IsSuccessStatusCode)
            {
                var responseText = await response.Content.ReadAsStringAsync();
                var result = JsonSerializer.Deserialize<JsonElement>(responseText);
                var count = result.TryGetProperty("ImportedCount", out var countProp) ? countProp.GetInt32() : 0;
                
                Snackbar.Add($"✓ Importazione completata: {count} anime importati da Excel", Severity.Success);
                
                // Ricarica i dati per mostrare i risultati
                var animeUrl = new Uri(baseUri, "api/Anime");
                _risultati = await httpClient.GetFromJsonAsync<List<AnimeDto>>(animeUrl) ?? new();
                
                // Resetta il file selezionato
                _selectedFile = null;
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                var errorResponse = JsonSerializer.Deserialize<JsonElement>(errorText);
                var errorMessage = errorResponse.TryGetProperty("Error", out var errorProp) 
                    ? errorProp.GetString() 
                    : "Errore sconosciuto durante l'importazione";
                Snackbar.Add($"✗ Errore: {errorMessage}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"✗ Errore durante l'importazione Excel: {ex.Message}", Severity.Error);
        }
        finally
        {
            _importandoExcel = false;
            StateHasChanged();
        }
    }

    private async Task ImportaFromGantt()
    {
        _importando = true;
        _risultati = null;
        StateHasChanged();

        try
        {
            var httpClient = HttpClientFactory.CreateClient();
            var baseUri = new Uri(NavManager.BaseUri);
            var importUrl = new Uri(baseUri, "api/Anime/import");
            
            var response = await httpClient.PostAsync(importUrl, null);
            if (response.IsSuccessStatusCode)
            {
                var responseText = await response.Content.ReadAsStringAsync();
                var result = JsonSerializer.Deserialize<JsonElement>(responseText);
                var count = result.TryGetProperty("ImportedCount", out var countProp) ? countProp.GetInt32() : 0;
                
                Snackbar.Add($"✓ Importazione completata: {count} anime importati da Gantt", Severity.Success);
                
                // Ricarica i dati per mostrare i risultati
                var animeUrl = new Uri(baseUri, "api/Anime");
                _risultati = await httpClient.GetFromJsonAsync<List<AnimeDto>>(animeUrl) ?? new();
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                var errorResponse = JsonSerializer.Deserialize<JsonElement>(errorText);
                var errorMessage = errorResponse.TryGetProperty("Error", out var errorProp) 
                    ? errorProp.GetString() 
                    : "Errore sconosciuto durante l'importazione";
                Snackbar.Add($"✗ Errore: {errorMessage}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"✗ Errore durante l'importazione: {ex.Message}", Severity.Error);
        }
        finally
        {
            _importando = false;
            StateHasChanged();
        }
    }
}
