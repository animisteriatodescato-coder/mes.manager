@page "/sync/macchine"
@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@using MESManager.Infrastructure.Services
@implements IAsyncDisposable
@inject IPlcAppService PlcService
@inject IPlcSyncCoordinator SyncCoordinator
@inject ISnackbar Snackbar

<PageTitle>Sync Macchine</PageTitle>

<MudGrid>
    @* CONTROLLO SYNC *@
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
                Controllo Sincronizzazione
            </MudText>
            
            <MudStack Spacing="3">
                <MudNumericField T="int" 
                                @bind-Value="_intervalSeconds" 
                                Label="Intervallo (secondi)"
                                Min="5" Max="300"
                                Step="5"
                                Variant="Variant.Outlined"
                                Adornment="Adornment.End"
                                AdornmentText="sec"
                                Disabled="@_isRunning"
                                HelperText="Da 5 a 300 secondi" />
                
                @if (!_isRunning)
                {
                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Success" 
                              StartIcon="@Icons.Material.Filled.PlayArrow"
                              OnClick="StartSync"
                              FullWidth="true"
                              Size="Size.Large">
                        AVVIA SYNC
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Error" 
                              StartIcon="@Icons.Material.Filled.Stop"
                              OnClick="StopSync"
                              FullWidth="true"
                              Size="Size.Large">
                        FERMA SYNC
                    </MudButton>
                }
                
                @if (_isRunning)
                {
                    <MudAlert Severity="Severity.Success" Dense="true">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <span>Prossima sync tra <strong>@_secondsToNext</strong> sec</span>
                            <MudProgressCircular Size="Size.Small" Value="@GetProgressValue()" Color="Color.Success" />
                        </MudStack>
                    </MudAlert>
                }
                
                @if (_isSyncing)
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                    <MudText Typo="Typo.caption" Align="Align.Center">Sincronizzazione in corso...</MudText>
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    @* STATO MACCHINE *@
    <MudItem xs="12" md="8">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Router" Class="mr-2" />
                Stato Macchine PLC
            </MudText>
            
            @if (_macchineRealtime.Any())
            {
                <MudSimpleTable Dense="true" Hover="true">
                    <thead>
                        <tr>
                            <th>Macchina</th>
                            <th>IP</th>
                            <th>Stato</th>
                            <th>Ultimo Aggiornamento</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in _macchineRealtime.OrderBy(x => x.MacchinaNumero))
                        {
                            <tr>
                                <td><strong>@m.MacchinaNumero</strong></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(m.IndirizzoPLC))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@m.IndirizzoPLC</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">N/A</MudChip>
                                    }
                                </td>
                                <td>
                                    @if (m.IsConnessa)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">Online</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Filled.Error">Offline</MudChip>
                                    }
                                </td>
                                <td>
                                    @if (m.UltimoAggiornamento > DateTime.MinValue)
                                    {
                                        <span title="@m.UltimoAggiornamento.ToString("dd/MM/yyyy HH:mm:ss")">
                                            @FormatTimeAgo(DateTime.Now - m.UltimoAggiornamento)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="mud-text-disabled">Mai</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
                
                <MudStack Row="true" Class="mt-3">
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">@_macchineRealtime.Count(m => m.IsConnessa) Online</MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Error">@_macchineRealtime.Count(m => !m.IsConnessa) Offline</MudChip>
                </MudStack>
            }
            else
            {
                <MudAlert Severity="Severity.Info">Nessuna macchina trovata</MudAlert>
            }
        </MudPaper>
    </MudItem>

    @* LOG SINCRONIZZAZIONI *@
    <MudItem xs="12">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" />
                Log Sincronizzazioni
            </MudText>
            
            @if (_syncLogs.Any())
            {
                <MudSimpleTable Dense="true" Hover="true" Style="max-height: 300px; overflow-y: auto;">
                    <thead>
                        <tr>
                            <th style="width: 150px;">Orario</th>
                            <th>Risultato</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in _syncLogs)
                        {
                            <tr>
                                <td>@log.Timestamp.ToString("HH:mm:ss")</td>
                                <td>
                                    @if (log.IsSuccess)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" Class="mr-1" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" Class="mr-1" />
                                    }
                                    @log.Message
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Nessun log disponibile. Avvia la sincronizzazione.</MudText>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    // Stato
    private List<PlcRealtimeDto> _macchineRealtime = new();
    private List<SyncLogEntry> _syncLogs = new();
    private bool _isRunning = false;
    private bool _isSyncing = false;
    private int _intervalSeconds = 30;
    private int _secondsToNext = 0;
    
    // Timer
    private PeriodicTimer? _syncTimer;
    private PeriodicTimer? _countdownTimer;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        await LoadMacchineAsync();
    }

    private async Task LoadMacchineAsync()
    {
        try
        {
            _macchineRealtime = await PlcService.GetRealtimeDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore caricamento: {ex.Message}", Severity.Error);
        }
    }

    private void StartSync()
    {
        _isRunning = true;
        _secondsToNext = _intervalSeconds;
        _cts = new CancellationTokenSource();
        
        // Timer countdown (ogni secondo)
        _ = RunCountdownAsync(_cts.Token);
        
        // Timer sync
        _ = RunSyncLoopAsync(_cts.Token);
        
        AddLog(true, $"Sync avviata - intervallo {_intervalSeconds} sec");
        Snackbar.Add($"Sincronizzazione avviata ogni {_intervalSeconds} secondi", Severity.Success);
    }

    private void StopSync()
    {
        _isRunning = false;
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = null;
        
        AddLog(true, "Sync fermata");
        Snackbar.Add("Sincronizzazione fermata", Severity.Info);
        StateHasChanged();
    }

    private async Task RunCountdownAsync(CancellationToken ct)
    {
        _countdownTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        
        try
        {
            while (await _countdownTimer.WaitForNextTickAsync(ct))
            {
                if (_secondsToNext > 0)
                    _secondsToNext--;
                    
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        finally
        {
            _countdownTimer?.Dispose();
        }
    }

    private async Task RunSyncLoopAsync(CancellationToken ct)
    {
        _syncTimer = new PeriodicTimer(TimeSpan.FromSeconds(_intervalSeconds));
        
        // Prima sync immediata
        await ExecuteSyncAsync();
        
        try
        {
            while (await _syncTimer.WaitForNextTickAsync(ct))
            {
                _secondsToNext = _intervalSeconds;
                await ExecuteSyncAsync();
            }
        }
        catch (OperationCanceledException) { }
        finally
        {
            _syncTimer?.Dispose();
        }
    }

    private async Task ExecuteSyncAsync()
    {
        if (_isSyncing) return;
        
        _isSyncing = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var results = await SyncCoordinator.SyncTutteMacchineAsync();
            var successi = results.Count(r => r.Successo);
            var errori = results.Count(r => !r.Successo);
            
            if (errori > 0)
            {
                AddLog(false, $"Sync: {successi} OK, {errori} errori");
            }
            else
            {
                AddLog(true, $"Sync completata: {successi} macchine");
            }
            
            // Ricarica stato macchine
            await LoadMacchineAsync();
        }
        catch (Exception ex)
        {
            AddLog(false, $"Errore: {ex.Message}");
        }
        finally
        {
            _isSyncing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void AddLog(bool success, string message)
    {
        _syncLogs.Insert(0, new SyncLogEntry
        {
            Timestamp = DateTime.Now,
            IsSuccess = success,
            Message = message
        });
        
        // Mantieni solo ultimi 50 log
        if (_syncLogs.Count > 50)
            _syncLogs.RemoveAt(_syncLogs.Count - 1);
    }

    private double GetProgressValue()
    {
        if (_intervalSeconds == 0) return 0;
        return (double)_secondsToNext / _intervalSeconds * 100;
    }

    private string FormatTimeAgo(TimeSpan timeSpan)
    {
        if (timeSpan.TotalSeconds < 60)
            return $"{(int)timeSpan.TotalSeconds} sec fa";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes} min fa";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours} ore fa";
        return $"{(int)timeSpan.TotalDays} giorni fa";
    }

    public ValueTask DisposeAsync()
    {
        _cts?.Cancel();
        _syncTimer?.Dispose();
        _countdownTimer?.Dispose();
        _cts?.Dispose();
        return ValueTask.CompletedTask;
    }

    private class SyncLogEntry
    {
        public DateTime Timestamp { get; set; }
        public bool IsSuccess { get; set; }
        public string Message { get; set; } = string.Empty;
    }
}
