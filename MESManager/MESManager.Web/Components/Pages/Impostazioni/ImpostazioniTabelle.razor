@page "/impostazioni/tabelle"
@using MESManager.Application.DTOs
@inject ISnackbar Snackbar

<PageTitle>Impostazioni Tabelle</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4" data-testid="page-impostazioni-tabelle">
    <MudText Typo="Typo.h4" Class="mb-4">Gestione Tabelle</MudText>

    @if (isLoading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="mt-4">
            <!-- Tab Tabelle Colla -->
            <MudTabPanel Text="Tabella Colla" Icon="@Icons.Material.Filled.TableRows">
                <MudPaper Class="pa-4 mt-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Gestione Tabella Colla</MudText>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Success" 
                              StartIcon="@Icons.Material.Filled.Add"
                              Class="mb-4" 
                              OnClick="AggiungiColla"
                              data-testid="btn-tabelle-colla-add">
                        Aggiungi Colla
                    </MudButton>

                    <MudTable Items="@colla" Hover="true" Striped="true" data-testid="table-tabelle-colla">
                        <HeaderContent>
                            <MudTh>Codice Colla</MudTh>
                            <MudTh>Descrizione Colla</MudTh>
                            <MudTh>Azioni</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Codice Colla">
                                <MudTextField @bind-Value="context.Codice" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Descrizione Colla">
                                <MudTextField @bind-Value="context.Descrizione" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Azioni">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                              Color="Color.Error" 
                                              Size="Size.Small" 
                                              OnClick="@(() => EliminaColla(context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Primary" 
                              Class="mt-4" 
                              OnClick="SalvaCollaAsync"
                              data-testid="btn-tabelle-colla-salva">
                        Salva Modifiche Colla
                    </MudButton>
                </MudPaper>
            </MudTabPanel>

            <!-- Tab Tabelle Vernice -->
            <MudTabPanel Text="Tabella Vernice" Icon="@Icons.Material.Filled.TableRows">
                <MudPaper Class="pa-4 mt-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Gestione Tabella Vernice</MudText>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Success" 
                              StartIcon="@Icons.Material.Filled.Add"
                              Class="mb-4" 
                              OnClick="AggiungiVernice"
                              data-testid="btn-tabelle-vernice-add">
                        Aggiungi Vernice
                    </MudButton>

                    <MudTable Items="@vernice" Hover="true" Striped="true" data-testid="table-tabelle-vernice">
                        <HeaderContent>
                            <MudTh>Codice Vernice</MudTh>
                            <MudTh>Descrizione Vernice</MudTh>
                            <MudTh>Azioni</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Codice Vernice">
                                <MudTextField @bind-Value="context.Codice" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Descrizione Vernice">
                                <MudTextField @bind-Value="context.Descrizione" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Azioni">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                              Color="Color.Error" 
                                              Size="Size.Small" 
                                              OnClick="@(() => EliminaVernice(context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Primary" 
                              Class="mt-4" 
                              OnClick="SalvaVerniceAsync"
                              data-testid="btn-tabelle-vernice-salva">
                        Salva Modifiche Vernice
                    </MudButton>
                </MudPaper>
            </MudTabPanel>

            <!-- Tab Tabelle Sabbia -->
            <MudTabPanel Text="Tabella Sabbia" Icon="@Icons.Material.Filled.TableRows">
                <MudPaper Class="pa-4 mt-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Gestione Tabella Sabbia</MudText>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Success" 
                              StartIcon="@Icons.Material.Filled.Add"
                              Class="mb-4" 
                              OnClick="AggiungiSabbia"
                              data-testid="btn-tabelle-sabbia-add">
                        Aggiungi Sabbia
                    </MudButton>

                    <MudTable Items="@sabbia" Hover="true" Striped="true" data-testid="table-tabelle-sabbia">
                        <HeaderContent>
                            <MudTh>Codice Sabbia</MudTh>
                            <MudTh>Descrizione Sabbia</MudTh>
                            <MudTh>Azioni</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Codice Sabbia">
                                <MudTextField @bind-Value="context.Codice" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Descrizione Sabbia">
                                <MudTextField @bind-Value="context.Descrizione" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Azioni">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                              Color="Color.Error" 
                                              Size="Size.Small" 
                                              OnClick="@(() => EliminaSabbia(context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Primary" 
                              Class="mt-4" 
                              OnClick="SalvaSabbiaAsync"
                              data-testid="btn-tabelle-sabbia-salva">
                        Salva Modifiche Sabbia
                    </MudButton>
                </MudPaper>
            </MudTabPanel>

            <!-- Tab Tabelle Imballo -->
            <MudTabPanel Text="Tabella Imballo" Icon="@Icons.Material.Filled.TableRows">
                <MudPaper Class="pa-4 mt-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Gestione Tabella Imballo</MudText>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Success" 
                              StartIcon="@Icons.Material.Filled.Add"
                              Class="mb-4" 
                              OnClick="AggiungiImballo"
                              data-testid="btn-tabelle-imballo-add">
                        Aggiungi Imballo
                    </MudButton>

                    <MudTable Items="@imballo" Hover="true" Striped="true" data-testid="table-tabelle-imballo">
                        <HeaderContent>
                            <MudTh>Codice Imballo</MudTh>
                            <MudTh>Descrizione Imballo</MudTh>
                            <MudTh>Azioni</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Codice Imballo">
                                <MudTextField @bind-Value="context.Codice" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Descrizione Imballo">
                                <MudTextField @bind-Value="context.Descrizione" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Azioni">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                              Color="Color.Error" 
                                              Size="Size.Small" 
                                              OnClick="@(() => EliminaImballo(context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Primary" 
                              Class="mt-4" 
                              OnClick="SalvaImballoAsync"
                              data-testid="btn-tabelle-imballo-salva">
                        Salva Modifiche Imballo
                    </MudButton>
                </MudPaper>
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>

@code {
    private bool isLoading = false;
    
    private List<CollaDto> colla = new();
    private List<VerniceDto> vernice = new();
    private List<SabbiaDto> sabbia = new();
    private List<ImballoDto> imballo = new();

    protected override async Task OnInitializedAsync()
    {
        await CaricaDatiAsync();
    }

    private async Task CaricaDatiAsync()
    {
        isLoading = true;
        try
        {
            // Inizializza con dati di esempio basati sugli screenshot
            colla = new List<CollaDto>
            {
                new() { Codice = "-1", Descrizione = "BIANCA" },
                new() { Codice = "-2", Descrizione = "A CALDO" },
                new() { Codice = "-3", Descrizione = "ROSSA S.G" }
            };

            vernice = new List<VerniceDto>
            {
                new() { Codice = "-1", Descrizione = "" },
                new() { Codice = "-2", Descrizione = "YELLOW COVER" },
                new() { Codice = "-3", Descrizione = "CASTING COVER ZR" },
                new() { Codice = "-4", Descrizione = "CASTING COVER RK" },
                new() { Codice = "-5", Descrizione = "CASTINGCOVER 2001" },
                new() { Codice = "-6", Descrizione = "ARCOPAL 9030" },
                new() { Codice = "-7", Descrizione = "HYDRO COVER 22 Z" },
                new() { Codice = "-8", Descrizione = "FGR 55" }
            };

            sabbia = new List<SabbiaDto>
            {
                new() { Codice = "-1", Descrizione = "" },
                new() { Codice = "310/60", Descrizione = "310/60" },
                new() { Codice = "33BD600X", Descrizione = "33BD600X" },
                new() { Codice = "360/10", Descrizione = "360/10" },
                new() { Codice = "44/10", Descrizione = "SCARANELLO" },
                new() { Codice = "C1/30D", Descrizione = "C1/30D" },
                new() { Codice = "CP35B", Descrizione = "CP35B" },
                new() { Codice = "NB30B", Descrizione = "NB30B" },
                new() { Codice = "OLIVINA", Descrizione = "OLIVINA" },
                new() { Codice = "UP30B", Descrizione = "UP30B" }
            };

            imballo = new List<ImballoDto>
            {
                new() { Codice = "-1", Descrizione = "CASSA GRANDE" },
                new() { Codice = "-2", Descrizione = "CASSA PICCOLA" },
                new() { Codice = "-3", Descrizione = "CASSA LUNGA" },
                new() { Codice = "-4", Descrizione = "PIANALE EURO" },
                new() { Codice = "-5", Descrizione = "PIANALE QUADRATO" },
                new() { Codice = "-6", Descrizione = "CARRELLI A PIANI" },
                new() { Codice = "-7", Descrizione = "CARRELLI GRANDI" },
                new() { Codice = "-8", Descrizione = "SCATOLE" }
            };

            await Task.CompletedTask;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AggiungiColla() => colla.Add(new CollaDto { Codice = "", Descrizione = "" });
    private void AggiungiVernice() => vernice.Add(new VerniceDto { Codice = "", Descrizione = "" });
    private void AggiungiSabbia() => sabbia.Add(new SabbiaDto { Codice = "", Descrizione = "" });
    private void AggiungiImballo() => imballo.Add(new ImballoDto { Codice = "", Descrizione = "" });

    private void EliminaColla(CollaDto collaItem) => colla.Remove(collaItem);
    private void EliminaVernice(VerniceDto verniceItem) => vernice.Remove(verniceItem);
    private void EliminaSabbia(SabbiaDto sabbiaItem) => sabbia.Remove(sabbiaItem);
    private void EliminaImballo(ImballoDto imballoItem) => imballo.Remove(imballoItem);

    private Task SalvaCollaAsync()
    {
        try
        {
            // TODO: Implementare salvataggio su database locale
            Snackbar.Add("Modifiche Colla salvate con successo!", Severity.Success);
            return Task.CompletedTask;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore nel salvataggio: {ex.Message}", Severity.Error);
            return Task.CompletedTask;
        }
    }

    private Task SalvaVerniceAsync()
    {
        try
        {
            // TODO: Implementare salvataggio su database locale
            Snackbar.Add("Modifiche Vernice salvate con successo!", Severity.Success);
            return Task.CompletedTask;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore nel salvataggio: {ex.Message}", Severity.Error);
            return Task.CompletedTask;
        }
    }

    private Task SalvaSabbiaAsync()
    {
        try
        {
            // TODO: Implementare salvataggio su database locale
            Snackbar.Add("Modifiche Sabbia salvate con successo!", Severity.Success);
            return Task.CompletedTask;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore nel salvataggio: {ex.Message}", Severity.Error);
            return Task.CompletedTask;
        }
    }

    private Task SalvaImballoAsync()
    {
        try
        {
            // TODO: Implementare salvataggio su database locale
            Snackbar.Add("Modifiche Imballo salvate con successo!", Severity.Success);
            return Task.CompletedTask;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore nel salvataggio: {ex.Message}", Severity.Error);
            return Task.CompletedTask;
        }
    }

    public class CollaDto 
    { 
        public string Codice { get; set; } = string.Empty;
        public string Descrizione { get; set; } = string.Empty;
    }
    
    public class VerniceDto 
    { 
        public string Codice { get; set; } = string.Empty;
        public string Descrizione { get; set; } = string.Empty;
    }
    
    public class SabbiaDto 
    { 
        public string Codice { get; set; } = string.Empty;
        public string Descrizione { get; set; } = string.Empty;
    }
    
    public class ImballoDto 
    { 
        public string Codice { get; set; } = string.Empty;
        public string Descrizione { get; set; } = string.Empty;
    }
}
