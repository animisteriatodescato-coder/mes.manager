@page "/impostazioni/tabelle"
@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@inject ISnackbar Snackbar
@inject HttpClient Http
@inject IPreventivoService PreventivoService

<PageTitle>Impostazioni Tabelle</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4" data-testid="page-impostazioni-tabelle">
    <MudText Typo="Typo.h4" Class="mb-4">Gestione Tabelle</MudText>

    @if (isLoading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="mt-4">
            <!-- Tab Tabelle Colla -->
            <MudTabPanel Text="Tabella Colla" Icon="@Icons.Material.Filled.TableRows">
                <MudPaper Class="pa-4 mt-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Gestione Tabella Colla</MudText>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Success" 
                              StartIcon="@Icons.Material.Filled.Add"
                              Class="mb-4" 
                              OnClick="AggiungiColla"
                              data-testid="btn-tabelle-colla-add">
                        Aggiungi Colla
                    </MudButton>

                    <MudTable Items="@colla" Hover="true" Striped="true" data-testid="table-tabelle-colla">
                        <HeaderContent>
                            <MudTh>Codice Colla</MudTh>
                            <MudTh>Descrizione Colla</MudTh>
                            <MudTh>Azioni</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Codice Colla">
                                <MudTextField @bind-Value="context.Codice" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Descrizione Colla">
                                <MudTextField @bind-Value="context.Descrizione" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Azioni">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                              Color="Color.Error" 
                                              Size="Size.Small" 
                                              OnClick="@(() => EliminaColla(context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Primary" 
                              Class="mt-4" 
                              OnClick="SalvaCollaAsync"
                              data-testid="btn-tabelle-colla-salva">
                        Salva Modifiche Colla
                    </MudButton>
                </MudPaper>
            </MudTabPanel>

            <!-- Tab Tabelle Vernice -->
            <MudTabPanel Text="Tabella Vernice" Icon="@Icons.Material.Filled.TableRows">
                <MudPaper Class="pa-4 mt-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Gestione Tabella Vernice</MudText>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Success" 
                              StartIcon="@Icons.Material.Filled.Add"
                              Class="mb-4" 
                              OnClick="AggiungiVernice"
                              data-testid="btn-tabelle-vernice-add">
                        Aggiungi Vernice
                    </MudButton>

                    <MudTable Items="@vernice" Hover="true" Striped="true" data-testid="table-tabelle-vernice">
                        <HeaderContent>
                            <MudTh>Codice Vernice</MudTh>
                            <MudTh>Descrizione Vernice</MudTh>
                            <MudTh>Azioni</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Codice Vernice">
                                <MudTextField @bind-Value="context.Codice" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Descrizione Vernice">
                                <MudTextField @bind-Value="context.Descrizione" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Azioni">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                              Color="Color.Error" 
                                              Size="Size.Small" 
                                              OnClick="@(() => EliminaVernice(context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Primary" 
                              Class="mt-4" 
                              OnClick="SalvaVerniceAsync"
                              data-testid="btn-tabelle-vernice-salva">
                        Salva Modifiche Vernice
                    </MudButton>
                </MudPaper>
            </MudTabPanel>

            <!-- Tab Tabelle Sabbia -->
            <MudTabPanel Text="Tabella Sabbia" Icon="@Icons.Material.Filled.TableRows">
                <MudPaper Class="pa-4 mt-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Gestione Tabella Sabbia</MudText>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Success" 
                              StartIcon="@Icons.Material.Filled.Add"
                              Class="mb-4" 
                              OnClick="AggiungiSabbia"
                              data-testid="btn-tabelle-sabbia-add">
                        Aggiungi Sabbia
                    </MudButton>

                    <MudTable Items="@sabbia" Hover="true" Striped="true" data-testid="table-tabelle-sabbia">
                        <HeaderContent>
                            <MudTh>Codice Sabbia</MudTh>
                            <MudTh>Descrizione Sabbia</MudTh>
                            <MudTh>Azioni</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Codice Sabbia">
                                <MudTextField @bind-Value="context.Codice" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Descrizione Sabbia">
                                <MudTextField @bind-Value="context.Descrizione" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Azioni">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                              Color="Color.Error" 
                                              Size="Size.Small" 
                                              OnClick="@(() => EliminaSabbia(context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Primary" 
                              Class="mt-4" 
                              OnClick="SalvaSabbiaAsync"
                              data-testid="btn-tabelle-sabbia-salva">
                        Salva Modifiche Sabbia
                    </MudButton>
                </MudPaper>
            </MudTabPanel>

            <!-- Tab Tabelle Imballo -->
            <MudTabPanel Text="Tabella Imballo" Icon="@Icons.Material.Filled.TableRows">
                <MudPaper Class="pa-4 mt-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Gestione Tabella Imballo</MudText>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Success" 
                              StartIcon="@Icons.Material.Filled.Add"
                              Class="mb-4" 
                              OnClick="AggiungiImballo"
                              data-testid="btn-tabelle-imballo-add">
                        Aggiungi Imballo
                    </MudButton>

                    <MudTable Items="@imballo" Hover="true" Striped="true" data-testid="table-tabelle-imballo">
                        <HeaderContent>
                            <MudTh>Codice Imballo</MudTh>
                            <MudTh>Descrizione Imballo</MudTh>
                            <MudTh>Azioni</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Codice Imballo">
                                <MudTextField @bind-Value="context.Codice" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Descrizione Imballo">
                                <MudTextField @bind-Value="context.Descrizione" Variant="Variant.Text" />
                            </MudTd>
                            <MudTd DataLabel="Azioni">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                              Color="Color.Error" 
                                              Size="Size.Small" 
                                              OnClick="@(() => EliminaImballo(context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Primary" 
                              Class="mt-4" 
                              OnClick="SalvaImballoAsync"
                              data-testid="btn-tabelle-imballo-salva">
                        Salva Modifiche Imballo
                    </MudButton>
                </MudPaper>
            </MudTabPanel>
            <!-- Tab Sabbia Preventivi -->
            <MudTabPanel Text="Sabbia Preventivi" Icon="@Icons.Material.Filled.Grain">
                <MudPaper Class="pa-4 mt-4">
                    <MudText Typo="Typo.h6" Class="mb-1">Tipi Sabbia — Preventivi</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">Prezzi e parametri usati nel calcolo preventivi. Non influenzano le tabelle anime.</MudText>

                    <MudButton Variant="Variant.Filled" Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Add"
                               Class="mb-4" OnClick="AggiungiTipoSabbia"
                               data-testid="btn-prev-sabbia-add">
                        Aggiungi tipo sabbia
                    </MudButton>

                    <MudTable Items="@_tipiSabbia" Hover="true" Striped="true" data-testid="table-prev-sabbia">
                        <HeaderContent>
                            <MudTh>Codice</MudTh>
                            <MudTh>Nome</MudTh>
                            <MudTh>Famiglia</MudTh>
                            <MudTh>€/ora</MudTh>
                            <MudTh>€/kg sabbia</MudTh>
                            <MudTh>Spari default</MudTh>
                            <MudTh>Ordine</MudTh>
                            <MudTh>Azioni</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><MudTextField @bind-Value="context.Codice" Variant="Variant.Text" /></MudTd>
                            <MudTd><MudTextField @bind-Value="context.Nome" Variant="Variant.Text" /></MudTd>
                            <MudTd>
                                <MudSelect @bind-Value="context.Famiglia" Variant="Variant.Text" Dense="true">
                                    <MudSelectItem Value="@("distribut")">Distributori</MudSelectItem>
                                    <MudSelectItem Value="@("cerabeads")">Cerabeads</MudSelectItem>
                                    <MudSelectItem Value="@("normale")">Normale</MudSelectItem>
                                </MudSelect>
                            </MudTd>
                            <MudTd><MudNumericField @bind-Value="context.EuroOra" HideSpinButtons="true" Variant="Variant.Text" Format="F2" /></MudTd>
                            <MudTd><MudNumericField @bind-Value="context.PrezzoKg" HideSpinButtons="true" Variant="Variant.Text" Format="F4" /></MudTd>
                            <MudTd><MudNumericField @bind-Value="context.SpariDefault" HideSpinButtons="true" Variant="Variant.Text" /></MudTd>
                            <MudTd><MudNumericField @bind-Value="context.Ordine" HideSpinButtons="true" Variant="Variant.Text" /></MudTd>
                            <MudTd>
                                <MudStack Row="true" Spacing="1">
                                    <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Primary" Size="Size.Small"
                                                   OnClick="@(() => SalvaTipoSabbiaAsync(context))"
                                                   data-testid="btn-prev-sabbia-salva" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                   OnClick="@(() => EliminaTipoSabbiaAsync(context))"
                                                   data-testid="btn-prev-sabbia-elimina" />
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent><MudText>Nessun tipo sabbia. Usa il pulsante Aggiungi.</MudText></NoRecordsContent>
                    </MudTable>
                </MudPaper>
            </MudTabPanel>

            <!-- Tab Vernice Preventivi -->
            <MudTabPanel Text="Vernice Preventivi" Icon="@Icons.Material.Filled.FormatPaint">
                <MudPaper Class="pa-4 mt-4">
                    <MudText Typo="Typo.h6" Class="mb-1">Tipi Vernice — Preventivi</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">Prezzi e parametri usati nel calcolo preventivi. Non influenzano le tabelle anime.</MudText>

                    <MudButton Variant="Variant.Filled" Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Add"
                               Class="mb-4" OnClick="AggiungiTipoVernice"
                               data-testid="btn-prev-vernice-add">
                        Aggiungi tipo vernice
                    </MudButton>

                    <MudTable Items="@_tipiVernice" Hover="true" Striped="true" data-testid="table-prev-vernice">
                        <HeaderContent>
                            <MudTh>Codice</MudTh>
                            <MudTh>Nome</MudTh>
                            <MudTh>Famiglia</MudTh>
                            <MudTh>€/kg</MudTh>
                            <MudTh>% applicazione</MudTh>
                            <MudTh>Ordine</MudTh>
                            <MudTh>Azioni</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><MudTextField @bind-Value="context.Codice" Variant="Variant.Text" /></MudTd>
                            <MudTd><MudTextField @bind-Value="context.Nome" Variant="Variant.Text" /></MudTd>
                            <MudTd>
                                <MudSelect @bind-Value="context.Famiglia" Variant="Variant.Text" Dense="true">
                                    <MudSelectItem Value="@("acqua")">Ad acqua</MudSelectItem>
                                    <MudSelectItem Value="@("alcool")">All'alcool</MudSelectItem>
                                </MudSelect>
                            </MudTd>
                            <MudTd><MudNumericField @bind-Value="context.PrezzoKg" HideSpinButtons="true" Variant="Variant.Text" Format="F2" /></MudTd>
                            <MudTd><MudNumericField @bind-Value="context.PercentualeApplicazione" HideSpinButtons="true" Variant="Variant.Text" Format="F1" /></MudTd>
                            <MudTd><MudNumericField @bind-Value="context.Ordine" HideSpinButtons="true" Variant="Variant.Text" /></MudTd>
                            <MudTd>
                                <MudStack Row="true" Spacing="1">
                                    <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Primary" Size="Size.Small"
                                                   OnClick="@(() => SalvaTipoVerniceAsync(context))"
                                                   data-testid="btn-prev-vernice-salva" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                   OnClick="@(() => EliminaTipoVerniceAsync(context))"
                                                   data-testid="btn-prev-vernice-elimina" />
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent><MudText>Nessun tipo vernice. Usa il pulsante Aggiungi.</MudText></NoRecordsContent>
                    </MudTable>
                </MudPaper>
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>

@code {
    private bool isLoading = false;
    
    private List<CollaDto> colla = new();
    private List<VerniceDto> vernice = new();
    private List<SabbiaDto> sabbia = new();
    private List<ImballoDto> imballo = new();

    private List<PreventivoTipoSabbiaDto> _tipiSabbia = new();
    private List<PreventivoTipoVerniceDto> _tipiVernice = new();

    protected override async Task OnInitializedAsync()
    {
        await CaricaDatiAsync();
    }

    private async Task CaricaDatiAsync()
    {
        isLoading = true;
        try
        {
            var collaItems   = await Http.GetFromJsonAsync<List<CollaDto>>("/api/Tabelle/colla")   ?? new();
            var verniceItems  = await Http.GetFromJsonAsync<List<VerniceDto>>("/api/Tabelle/vernice") ?? new();
            var sabbiaItems   = await Http.GetFromJsonAsync<List<SabbiaDto>>("/api/Tabelle/sabbia")  ?? new();
            var imballoItems  = await Http.GetFromJsonAsync<List<ImballoDto>>("/api/Tabelle/imballo") ?? new();

            colla   = collaItems;
            vernice  = verniceItems;
            sabbia   = sabbiaItems;
            imballo  = imballoItems;

            _tipiSabbia  = await PreventivoService.GetTipiSabbiaAsync();
            _tipiVernice = await PreventivoService.GetTipiVerniceAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore nel caricamento: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AggiungiColla()   => colla.Add(new CollaDto   { Codice = "", Descrizione = "" });
    private void AggiungiVernice()  => vernice.Add(new VerniceDto  { Codice = "", Descrizione = "" });
    private void AggiungiSabbia()   => sabbia.Add(new SabbiaDto   { Codice = "", Descrizione = "" });
    private void AggiungiImballo()  => imballo.Add(new ImballoDto  { Codice = "", Descrizione = "" });

    private void EliminaColla(CollaDto collaItem)     => colla.Remove(collaItem);
    private void EliminaVernice(VerniceDto verniceItem) => vernice.Remove(verniceItem);
    private void EliminaSabbia(SabbiaDto sabbiaItem)   => sabbia.Remove(sabbiaItem);
    private void EliminaImballo(ImballoDto imballoItem) => imballo.Remove(imballoItem);

    private async Task SalvaCollaAsync()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/api/Tabelle/colla", colla);
            if (response.IsSuccessStatusCode)
                Snackbar.Add("Tabella Colla salvata!", Severity.Success);
            else
                Snackbar.Add($"Errore salvataggio: {response.StatusCode}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    private async Task SalvaVerniceAsync()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/api/Tabelle/vernice", vernice);
            if (response.IsSuccessStatusCode)
                Snackbar.Add("Tabella Vernice salvata!", Severity.Success);
            else
                Snackbar.Add($"Errore salvataggio: {response.StatusCode}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    private async Task SalvaSabbiaAsync()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/api/Tabelle/sabbia", sabbia);
            if (response.IsSuccessStatusCode)
                Snackbar.Add("Tabella Sabbia salvata!", Severity.Success);
            else
                Snackbar.Add($"Errore salvataggio: {response.StatusCode}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    private async Task SalvaImballoAsync()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/api/Tabelle/imballo", imballo);
            if (response.IsSuccessStatusCode)
                Snackbar.Add("Tabella Imballo salvata!", Severity.Success);
            else
                Snackbar.Add($"Errore salvataggio: {response.StatusCode}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    public class CollaDto 
    { 
        public string Codice { get; set; } = string.Empty;
        public string Descrizione { get; set; } = string.Empty;
    }
    
    public class VerniceDto 
    { 
        public string Codice { get; set; } = string.Empty;
        public string Descrizione { get; set; } = string.Empty;
    }
    
    public class SabbiaDto 
    { 
        public string Codice { get; set; } = string.Empty;
        public string Descrizione { get; set; } = string.Empty;
    }
    
    public class ImballoDto 
    { 
        public string Codice { get; set; } = string.Empty;
        public string Descrizione { get; set; } = string.Empty;
    }

    // ── Preventivi: Sabbia ─────────────────────────────────────────────

    private void AggiungiTipoSabbia() => _tipiSabbia.Add(new PreventivoTipoSabbiaDto
    {
        Id = Guid.Empty, Nome = "", Codice = "", Famiglia = "distribut", EuroOra = 70, PrezzoKg = 1.42m, SpariDefault = 40, Attivo = true, Ordine = _tipiSabbia.Count + 1
    });

    private async Task SalvaTipoSabbiaAsync(PreventivoTipoSabbiaDto dto)
    {
        try
        {
            if (dto.Id == Guid.Empty)
            {
                var created = await PreventivoService.CreateTipoSabbiaAsync(dto);
                var idx = _tipiSabbia.IndexOf(dto);
                if (idx >= 0) _tipiSabbia[idx] = created;
            }
            else
            {
                await PreventivoService.UpdateTipoSabbiaAsync(dto);
            }
            Snackbar.Add("Tipo sabbia salvato.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    private async Task EliminaTipoSabbiaAsync(PreventivoTipoSabbiaDto dto)
    {
        if (dto.Id == Guid.Empty) { _tipiSabbia.Remove(dto); return; }
        await PreventivoService.DeleteTipoSabbiaAsync(dto.Id);
        _tipiSabbia.Remove(dto);
        Snackbar.Add("Tipo sabbia eliminato.", Severity.Success);
    }

    // ── Preventivi: Vernice ────────────────────────────────────────────

    private void AggiungiTipoVernice() => _tipiVernice.Add(new PreventivoTipoVerniceDto
    {
        Id = Guid.Empty, Nome = "", Codice = "", Famiglia = "acqua", PrezzoKg = 3.20m, PercentualeApplicazione = 8, Attivo = true, Ordine = _tipiVernice.Count + 1
    });

    private async Task SalvaTipoVerniceAsync(PreventivoTipoVerniceDto dto)
    {
        try
        {
            if (dto.Id == Guid.Empty)
            {
                var created = await PreventivoService.CreateTipoVerniceAsync(dto);
                var idx = _tipiVernice.IndexOf(dto);
                if (idx >= 0) _tipiVernice[idx] = created;
            }
            else
            {
                await PreventivoService.UpdateTipoVerniceAsync(dto);
            }
            Snackbar.Add("Tipo vernice salvato.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    private async Task EliminaTipoVerniceAsync(PreventivoTipoVerniceDto dto)
    {
        if (dto.Id == Guid.Empty) { _tipiVernice.Remove(dto); return; }
        await PreventivoService.DeleteTipoVerniceAsync(dto.Id);
        _tipiVernice.Remove(dto);
        Snackbar.Add("Tipo vernice eliminato.", Severity.Success);
    }
}
