@page "/impostazioni/generali"

<PageTitle>Impostazioni Generali</PageTitle>

<MudPaper Class="pa-4">
    <MudTextField Label="Nome Azienda" @bind-Value="_nomeAzienda" />
    <MudTextField Label="Indirizzo" @bind-Value="_indirizzo" Class="mt-3" />
    <MudTextField Label="Email" @bind-Value="_email" Class="mt-3" />
    
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">
        Salva Impostazioni
    </MudButton>
</MudPaper>

@code {
    private string _nomeAzienda = string.Empty;
    private string _indirizzo = string.Empty;
    private string _email = string.Empty;
}
