@page "/impostazioni/utenti"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Identity
@using MESManager.Infrastructure.Entities
@implements IDisposable
@inject UserManager<ApplicationUser> UserManager
@inject ISnackbar Snackbar

<PageTitle>Profili Utente</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4" data-testid="page-gestione-utenti">

<MudPaper Class="pa-4 mb-2" Elevation="0">
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        Gestisci nome display e colore degli utenti. Per creare o eliminare utenti vai a
        <MudLink Href="/impostazioni/accessi">Gestione Accessi</MudLink>.
    </MudText>
</MudPaper>

<MudTable Items="@_utenti" Hover="true" Dense="true" Striped="true" Elevation="2" data-testid="table-utenti">
    <HeaderContent>
        <MudTh Style="width: 80px;">Ordine</MudTh>
        <MudTh Style="width: 130px;">Username</MudTh>
        <MudTh Style="width: 150px;">Nome display</MudTh>
        <MudTh Style="width: 200px;">Colore</MudTh>
        <MudTh Style="width: 80px;">Attivo</MudTh>
        <MudTh Style="width: 80px;">Azioni</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Ordine">
            <MudNumericField T="int"
                             Value="@context.Ordine"
                             ValueChanged="@((int o) => CambiaOrdine(context, o))"
                             Min="1"
                             Variant="Variant.Text"
                             Style="width: 60px;" />
        </MudTd>
        <MudTd DataLabel="Username">@context.UserName</MudTd>
        <MudTd DataLabel="Nome display">
            @if (_inModifica == context.Id)
            {
                <MudTextField @bind-Value="_nomeModifica"
                              Variant="Variant.Text"
                              Style="width: 140px;" />
            }
            else
            {
                @(string.IsNullOrEmpty(context.Nome) ? "-" : context.Nome)
            }
        </MudTd>
        <MudTd DataLabel="Colore">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <div style="width: 40px; height: 30px; background-color: @(context.Colore ?? "#1976d2"); border-radius: 4px; border: 1px solid #888; cursor: pointer;"
                     @onclick="@(() => ApriColorPicker(context))"></div>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => ApriColorPicker(context))">Cambia</MudButton>
            </MudStack>
        </MudTd>
        <MudTd DataLabel="Attivo">
            <MudSwitch T="bool"
                       Value="@context.Attivo"
                       ValueChanged="@((bool a) => CambiaAttivo(context, a))"
                       Color="Color.Success" />
        </MudTd>
        <MudTd DataLabel="Azioni">
            @if (_inModifica == context.Id)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" OnClick="@(() => SalvaModifica(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small" OnClick="AnnullaModifica" />
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => IniziaModifica(context))" />
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Class="pa-4" Color="Color.Secondary">Nessun utente trovato</MudText>
    </NoRecordsContent>
</MudTable>

</MudContainer>

@* Dialog color picker *@
<MudDialog @bind-Visible="_colorDialogVisible"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Colore per @_utenteColoreCorrente?.UserName</MudText>
    </TitleContent>
    <DialogContent>
        <MudColorPicker @bind-Value="_coloreSelezionato"
                        ColorPickerView="ColorPickerView.Spectrum"
                        DisableAlpha="true"
                        DisableSliders="false"
                        DisableInputs="false"
                        Style="width: 100%;" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="ChiudiColorPicker">Annulla</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ConfermaColore">Conferma</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<ApplicationUser> _utenti = new();
    private string? _inModifica;
    private string _nomeModifica = string.Empty;
    private readonly System.Threading.SemaphoreSlim _coloreLock = new(1, 1);

    private bool _colorDialogVisible;
    private ApplicationUser? _utenteColoreCorrente;
    private MudBlazor.Utilities.MudColor _coloreSelezionato = new("#1976d2");

    protected override void OnInitialized()
    {
        CaricaUtenti();
    }

    private void CaricaUtenti()
    {
        _utenti = UserManager.Users.OrderBy(u => u.Ordine).ThenBy(u => u.UserName).ToList();
    }

    private void IniziaModifica(ApplicationUser utente)
    {
        _inModifica = utente.Id;
        _nomeModifica = utente.Nome;
    }

    private void AnnullaModifica()
    {
        _inModifica = null;
        _nomeModifica = string.Empty;
    }

    private async Task SalvaModifica(ApplicationUser utente)
    {
        if (string.IsNullOrWhiteSpace(_nomeModifica))
        {
            Snackbar.Add("Il nome non puo essere vuoto", Severity.Warning);
            return;
        }
        utente.Nome = _nomeModifica.Trim().ToUpperInvariant();
        var result = await UserManager.UpdateAsync(utente);
        _inModifica = null;
        _nomeModifica = string.Empty;
        CaricaUtenti();
        if (result.Succeeded)
            Snackbar.Add("Nome aggiornato", Severity.Success);
        else
            Snackbar.Add("Errore aggiornamento", Severity.Error);
    }

    private async Task CambiaOrdine(ApplicationUser utente, int nuovoOrdine)
    {
        utente.Ordine = nuovoOrdine;
        await UserManager.UpdateAsync(utente);
        CaricaUtenti();
    }

    private async Task CambiaAttivo(ApplicationUser utente, bool attivo)
    {
        utente.Attivo = attivo;
        await UserManager.UpdateAsync(utente);
        CaricaUtenti();
        Snackbar.Add($"Utente '{utente.UserName}' {(attivo ? "attivato" : "disattivato")}", Severity.Info);
    }

    private void ApriColorPicker(ApplicationUser utente)
    {
        _utenteColoreCorrente = utente;
        _coloreSelezionato = new MudBlazor.Utilities.MudColor(utente.Colore ?? "#1976d2");
        _colorDialogVisible = true;
    }

    private void ChiudiColorPicker()
    {
        _colorDialogVisible = false;
        _utenteColoreCorrente = null;
    }

    private async Task ConfermaColore()
    {
        if (_utenteColoreCorrente == null) return;
        await _coloreLock.WaitAsync();
        try
        {
            _utenteColoreCorrente.Colore = _coloreSelezionato.ToString();
            await UserManager.UpdateAsync(_utenteColoreCorrente);
            CaricaUtenti();
            Snackbar.Add($"Colore per '{_utenteColoreCorrente.UserName}' aggiornato", Severity.Success);
        }
        finally
        {
            _coloreLock.Release();
        }
        _colorDialogVisible = false;
        _utenteColoreCorrente = null;
    }

    public void Dispose() => _coloreLock.Dispose();
}
