@page "/"
@layout MainLayout
@using MESManager.Web.Components.Shared
@using MESManager.Web.Services
@inject AppSettingsService AppSettingsService

<PageTitle>MESManager</PageTitle>

<div class="home-container" style="@GetBackgroundStyle()">
    @* Selettore utente piccolo in alto a destra *@
    <div class="user-selector-floating">
        <UserSelector />
    </div>
</div>

<style>
    .home-container {
        min-height: calc(100vh - 64px);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        margin: -24px;
        padding: 24px;
        position: relative;
    }
    
    .user-selector-floating {
        position: absolute;
        top: 16px;
        right: 16px;
        background: rgba(255, 255, 255, 0.9);
        padding: 8px 16px;
        border-radius: 8px;
        backdrop-filter: blur(10px);
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }
</style>

@code {
    private string _backgroundUrl = string.Empty;

    protected override void OnInitialized()
    {
        var settings = AppSettingsService.GetSettings();
        _backgroundUrl = settings.BackgroundImageUrl;
    }

    private string GetBackgroundStyle()
    {
        if (string.IsNullOrEmpty(_backgroundUrl))
            return "";
        
        return $"background-image: url('{_backgroundUrl}');";
    }
}
