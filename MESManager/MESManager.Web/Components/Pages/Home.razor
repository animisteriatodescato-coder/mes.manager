@page "/"
@layout MainLayout
@using MESManager.Web.Components.Shared

<PageTitle>Dashboard - MESManager</PageTitle>

<MudPaper Class="pa-6 mb-6" Elevation="3">
    <MudGrid>
        <MudItem xs="12" Class="d-flex justify-center align-center">
            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" Class="mr-3" Color="Color.Primary" />
            <MudText Typo="Typo.h5" Class="mr-4">Seleziona Utente:</MudText>
            <UserSelector />
        </MudItem>
    </MudGrid>
</MudPaper>

<MudText Typo="Typo.h3" Class="mb-4">Dashboard Produzione</MudText>
<MudGrid>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6">Macchine Attive</MudText>
            <MudText Typo="Typo.h3" Color="Color.Success">0</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6">Commesse Aperte</MudText>
            <MudText Typo="Typo.h3" Color="Color.Info">0</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>
