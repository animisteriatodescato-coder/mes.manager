@page "/produzione/gantt-macchine"
@layout MainLayout
@inject IJSRuntime JS

<PageTitle>Gantt Macchine</PageTitle>

<MudPaper Class="pa-4 mb-4">
    <MudText Typo="Typo.h5" Class="mb-2">Pianificazione Macchine - Vista Gantt</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary">Visualizzazione temporale delle commesse pianificate per macchina</MudText>
</MudPaper>

<MudPaper Class="pa-4 mb-4">
    <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary">
        <MudButton OnClick="@(() => ChangeViewMode("Quarter Day"))">Quarti Giorno</MudButton>
        <MudButton OnClick="@(() => ChangeViewMode("Half Day"))">Mezze Giornate</MudButton>
        <MudButton OnClick="@(() => ChangeViewMode("Day"))">Giorni</MudButton>
        <MudButton OnClick="@(() => ChangeViewMode("Week"))">Settimane</MudButton>
        <MudButton OnClick="@(() => ChangeViewMode("Month"))">Mesi</MudButton>
    </MudButtonGroup>
</MudPaper>

<MudPaper Class="pa-4">
    <div id="gantt-chart" style="width: 100%; height: 600px; overflow: auto;"></div>
</MudPaper>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100); // Give the DOM a moment to settle
            await JS.InvokeVoidAsync("GanttMacchine.initialize", "gantt-chart");
        }
    }

    private async Task ChangeViewMode(string mode)
    {
        await JS.InvokeVoidAsync("GanttMacchine.changeViewMode", mode);
    }
}
