@page "/produzione/plc-realtime"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = MESManager.Web.Constants.PaginaPolicy.PlcRealtime)]
@using MESManager.Application.DTOs
@using MESManager.Application.Services
@using MESManager.Web.Models
@using MESManager.Web.Services
@using MESManager.Web.Components.Dialogs
@using Microsoft.JSInterop
@using Microsoft.JSInterop.Infrastructure
@using System.Text.Json
@inject NavigationManager Nav
@inject PreferencesService PreferencesService
@inject CurrentUserService CurrentUserService
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject RealtimeStateService RealtimeService
@inject IPageToolbarService PageToolbarService
@implements IAsyncDisposable

<PageTitle>PLC Realtime</PageTitle>

<div class="mes-grid-page" data-testid="page-plc-realtime">
    <MudPaper Class="settings-panel toolbar-sticky pa-2 mb-1" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudTextField @bind-Value="searchText"
                         Placeholder="Cerca..."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Style="width: 250px;"
                         Immediate="true"
                         DebounceInterval="280"
                         OnDebounceIntervalElapsed="OnSearchDebounced" />
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ViewColumn" OnClick="@ToggleColumnPanel">Colonne</MudButton>
            <FixResetMenu OnFix="@FixGridState" OnReset="@ResetToFixedState"
                         ShowGlobalSave="@IsAdmin" OnSaveGlobal="@SaveAsGlobalDefault" />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Settings" OnClick="@(() => _showSettings = !_showSettings)">Impostazioni</MudButton>
        </MudStack>
        @if (_showSettings)
        {
            <MudPaper Class="pa-4 mt-2" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Wrap="Wrap.Wrap">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Font Size:</MudText>
                        <MudNumericField Value="@settings.FontSize" Min="10" Max="24" Step="1"
                                        Variant="Variant.Outlined" Margin="Margin.Dense"
                                        ValueChanged="@(async (int val) => { settings.FontSize = val; await ApplyUiSettings(); })"
                                        Style="width: 80px;" />
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText>Row Height:</MudText>
                        <MudNumericField Value="@settings.RowHeight" Min="25" Max="80" Step="5"
                                        Variant="Variant.Outlined" Margin="Margin.Dense"
                                        ValueChanged="@(async (int val) => { settings.RowHeight = val; await ApplyUiSettings(); })"
                                        Style="width: 80px;" />
                    </MudStack>
                </MudStack>
            </MudPaper>
        }
    </MudPaper>
    <div id="plcRealtimeGrid" class="ag-theme-alpine commesse-grid-container"
         data-testid="grid-plc-realtime">
    </div>
</div>

@code {
    [CascadingParameter(Name = "IsAdmin")] private bool IsAdmin { get; set; }

    private GridUiSettings settings = new();
    private string searchText = string.Empty;
    private bool _showSettings = false;
    private bool _hasRendered = false;
    private bool _disposed = false;
    private List<PlcRealtimeDto> _data = new();

    private void OnDataUpdated(List<PlcRealtimeDto> data)
    {
        if (_disposed) return;
        
        _data = data;
        
        if (_hasRendered && !_disposed)
        {
            InvokeAsync(async () =>
            {
                if (!_disposed)
                {
                    await RefreshGrid();
                    StateHasChanged();
                }
            });
        }
    }

    private async Task OnSearchDebounced(string value)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.setQuickFilter", value);
        }
        catch
        {
            // Error filtering grid
        }
    }

    protected override Task OnInitializedAsync()
    {
        // Sottoscrivi agli aggiornamenti del servizio di stato
        RealtimeService.OnDataUpdated += OnDataUpdated;
        
        // Carica i dati correnti se già disponibili
        if (RealtimeService.CurrentData != null)
        {
            _data = RealtimeService.CurrentData;
        }
        
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hasRendered = true;
            try
            {
                // Registra questa pagina come attiva DOPO il primo render
                PageToolbarService.SetActivePage("plc-realtime", this);
                
                var savedColumnState = await PreferencesService.GetAsync<string>("plc-realtime-grid-columns");
                
                // Imposta l'utente corrente per la griglia (per salvare le preferenze per-utente)
                var userId = CurrentUserService.UserId ?? "";
                await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.setCurrentUser", userId);
                
                var savedSettings = await PreferencesService.GetAsync<GridUiSettings>("plc-realtime-grid-settings");
                if (savedSettings != null) settings = savedSettings;
                
                await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.applySettings", new { fontSize = settings.FontSize, rowHeight = settings.RowHeight });
                await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.init", "plcRealtimeGrid", _data, savedColumnState);
            }
            catch
            {
                // Error initializing grid
            }
        }
    }

    private async Task RefreshGrid()
    {
        if (!_hasRendered || _disposed) return;
        
        try
        {
            await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.updateData", _data);
            await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.refreshCells");
        }
        catch (JSDisconnectedException)
        {
            // Client disconnesso - ignora silenziosamente
        }
        catch
        {
            // Error refreshing grid
        }
    }

    private async Task ToggleColumnPanel()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.toggleColumnPanel");
        }
        catch { }
    }

    private async Task FixGridState()
    {
        try
        {
            var gridState = await JSRuntime.InvokeAsync<string>("plcRealtimeGrid.getState");
            await PreferencesService.SetAsync("plc-realtime-grid-fixed-state", gridState);
            await PreferencesService.SetAsync("plc-realtime-grid-fixed-settings", JsonSerializer.Serialize(settings));
        }
        catch { }
    }

    private async Task ResetToFixedState()
    {
        try
        {
            var fixedState = await PreferencesService.GetAsync<string>("plc-realtime-grid-fixed-state");
            var fixedSettings = await PreferencesService.GetAsync<string>("plc-realtime-grid-fixed-settings");

            if (!string.IsNullOrEmpty(fixedState))
            {
                await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.setState", fixedState);
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.resetState");
            }

            if (!string.IsNullOrEmpty(fixedSettings))
            {
                settings = JsonSerializer.Deserialize<GridUiSettings>(fixedSettings) ?? new GridUiSettings();
            }
            else
            {
                settings = new GridUiSettings();
            }

            await ApplyUiSettings();
            StateHasChanged();
        }
        catch { }
    }

    private async Task SaveAsGlobalDefault()
    {
        try
        {
            var gridState = await JSRuntime.InvokeAsync<string>("plcRealtimeGrid.getState");
            settings.ColumnStateJson = gridState;
            await PreferencesService.SetGlobalAsync("plc-realtime-grid-settings", settings);
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        
        // Deregistra questa pagina
        PageToolbarService.SetActivePage("plc-realtime", null);
        
        // Rimuove la sottoscrizione agli eventi
        RealtimeService.OnDataUpdated -= OnDataUpdated;
        
        try
        {
            var columnState = await JSRuntime.InvokeAsync<string>("plcRealtimeGrid.getColumnState");
            if (!string.IsNullOrEmpty(columnState))
            {
                await PreferencesService.SetAsync("plc-realtime-grid-columns", columnState);
            }
        }
        catch (JSDisconnectedException)
        {
            // Client disconnesso - ignora silenziosamente
        }
        catch { }
    }
    
    private async Task ApplyUiSettings()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.applySettings", new { fontSize = settings.FontSize, rowHeight = settings.RowHeight });
            await PreferencesService.SetAsync("plc-realtime-grid-settings", settings);
        }
        catch { }
    }
}
