@page "/produzione/plc-realtime"
@using MESManager.Application.DTOs
@using MESManager.Application.Services
@using MESManager.Web.Models
@using MESManager.Web.Services
@using Microsoft.JSInterop
@inject NavigationManager Nav
@inject PreferencesService PreferencesService
@inject CurrentUserService CurrentUserService
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject RealtimeStateService RealtimeService
@inject IPageToolbarService PageToolbarService
@implements IAsyncDisposable

<PageTitle>PLC Realtime</PageTitle>

@* Pagina SOLO visualizzazione dati PLC - nessun pulsante sync (sync è in /sync/macchine) *@
<div class="plc-realtime-page" data-testid="page-plc-realtime">
    <div id="plcRealtimeGrid" class="ag-theme-alpine" 
         data-testid="grid-plc-realtime"
         style="width: 100%; height: calc(100vh - 150px);">
    </div>
</div>

<MudDrawer @bind-Open="@settingsOpen" Anchor="Anchor.End" Elevation="1" Variant="@DrawerVariant.Temporary" data-testid="drawer-plc-realtime-settings">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6">Impostazioni Grid</MudText>
    </MudDrawerHeader>
    <MudDivider />
    <MudList T="string">
        <MudListItem T="string">
            <MudSlider @bind-Value="settings.FontSize" Min="10" Max="20" Step="1">Font Size: @settings.FontSize px</MudSlider>
        </MudListItem>
        <MudListItem T="string">
            <MudSlider @bind-Value="settings.RowHeight" Min="25" Max="60" Step="5">Row Height: @settings.RowHeight px</MudSlider>
        </MudListItem>
        <MudListItem T="string">
            <MudSwitch T="bool" @bind-Checked="settings.Zebra" Color="Color.Primary">Righe Zebrate</MudSwitch>
        </MudListItem>
        <MudListItem T="string">
            <MudSwitch T="bool" @bind-Checked="settings.GridLines" Color="Color.Primary">Linee Griglia</MudSwitch>
        </MudListItem>
    </MudList>
</MudDrawer>

<style>
    .plc-realtime-page {
        position: relative;
    }
</style>

@code {
    private GridUiSettings settings = new();
    private string searchText = string.Empty;
    private bool settingsOpen = false;
    private bool _hasRendered = false;
    private List<PlcRealtimeDto> _data = new();

    private void OnDataUpdated(List<PlcRealtimeDto> data)
    {
        _data = data;
        
        if (_hasRendered)
        {
            InvokeAsync(async () =>
            {
                await RefreshGrid();
                StateHasChanged();
            });
        }
    }

    private async Task OnSearchDebounced(string value)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.setQuickFilter", value);
        }
        catch
        {
            // Error filtering grid
        }
    }

    protected override Task OnInitializedAsync()
    {
        // Sottoscrivi agli aggiornamenti del servizio di stato
        RealtimeService.OnDataUpdated += OnDataUpdated;
        
        // Carica i dati correnti se già disponibili
        if (RealtimeService.CurrentData != null)
        {
            _data = RealtimeService.CurrentData;
        }
        
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hasRendered = true;
            try
            {
                // Registra questa pagina come attiva DOPO il primo render
                PageToolbarService.SetActivePage("plc-realtime", this);
                
                var savedColumnState = await PreferencesService.GetAsync<string>("plc-realtime-grid-columns");
                
                // Imposta l'utente corrente per la griglia (per salvare le preferenze per-utente)
                var userId = CurrentUserService.CurrentUserId?.ToString() ?? "";
                await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.setCurrentUser", userId);
                
                await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.init", "plcRealtimeGrid", _data, savedColumnState);
            }
            catch
            {
                // Error initializing grid
            }
        }
    }

    private async Task RefreshGrid()
    {
        if (!_hasRendered) return;
        
        try
        {
            await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.updateData", _data);
            await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.refreshCells");
        }
        catch
        {
            // Error refreshing grid
        }
    }

    private async Task ToggleColumnPanel()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.toggleColumnPanel");
        }
        catch { }
    }

    private async Task ResetGrid()
    {
        try
        {
            await PreferencesService.RemoveAsync("plc-realtime-grid-columns");
            await JSRuntime.InvokeVoidAsync("plcRealtimeGrid.resetGrid");
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        // Deregistra questa pagina
        PageToolbarService.SetActivePage("plc-realtime", null);
        
        // Rimuove la sottoscrizione agli eventi
        RealtimeService.OnDataUpdated -= OnDataUpdated;
        
        try
        {
            var columnState = await JSRuntime.InvokeAsync<string>("plcRealtimeGrid.getColumnState");
            if (!string.IsNullOrEmpty(columnState))
            {
                await PreferencesService.SetAsync("plc-realtime-grid-columns", columnState);
            }
        }
        catch { }
    }
    
    // Metodi pubblici per essere chiamati dalla AppBar (toolbar semplificata)
    public async Task OnSearchDebounced_Public(string value)
    {
        searchText = value;
        await OnSearchDebounced(value);
    }
    
    public async Task ToggleColumnPanel_Public() => await ToggleColumnPanel();
    public async Task ResetGrid_Public() => await ResetGrid();
    
    public void ToggleSettings_Public()
    {
        settingsOpen = !settingsOpen;
        StateHasChanged();
    }
    
    public string SearchText => searchText;
}
