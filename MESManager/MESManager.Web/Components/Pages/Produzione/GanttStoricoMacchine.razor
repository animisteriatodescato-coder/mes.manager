@page "/produzione/gantt-storico"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = MESManager.Web.Constants.PaginaPolicy.GanttStorico)]
@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@using MESManager.Web.Constants
@using System.Net.Http.Json
@using System.Threading
@inject HttpClient Http
@inject IMacchinaAppService MacchinaService
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>Gantt Storico Macchine</PageTitle>

<div data-testid="page-gantt-storico">

    @* ── Toolbar ─────────────────────────────────────────────────────────── *@
    <MudPaper Class="pa-3 mb-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">

            <MudDatePicker Label="Da" @bind-Date="_from"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           data-testid="gantt-storico-da" />

            <MudDatePicker Label="A" @bind-Date="_to"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           data-testid="gantt-storico-a" />

            <MudSelect T="string" Label="Macchina" @bind-Value="_macchinaIdFiltro"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:180px"
                       data-testid="gantt-storico-macchina">
                <MudSelectItem T="string" Value="@("")">Tutte le macchine</MudSelectItem>
                @foreach (var m in _macchine.Where(m => !string.IsNullOrWhiteSpace(m.IndirizzoPLC)))
                {
                    <MudSelectItem T="string" Value="@m.Id.ToString()">@m.Codice &mdash; @m.Nome</MudSelectItem>
                }
            </MudSelect>

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="LoadData" Disabled="@_loading"
                       data-testid="gantt-storico-carica">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                }
                Carica
            </MudButton>

            <MudSwitch @bind-Value="_autoRefresh" Color="Color.Secondary"
                       Label="Auto-refresh 30s"
                       data-testid="gantt-storico-autorefresh" />

            <MudButton Variant="Variant.Outlined" Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="EsportaCsv" Disabled="@(!_segmenti.Any())"
                       data-testid="gantt-storico-export">
                Export CSV
            </MudButton>

        </MudStack>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
            Solo macchine con IP PLC configurato. Usare lo zoom della timeline per dettagli.
        </MudText>
    </MudPaper>

    @* ── KPI Cards — riga orizzontale scorrevole, stile Dashboard Produzione ── *@
    @if (_kpi.Any())
    {
        <div class="kpi-scroll-row mb-3" data-testid="gantt-storico-kpi">
            @foreach (var k in _kpi)
            {
                var domColor = GetDominantColor(k);
                <div class="kpi-compact-card" style="border-top: 4px solid @domColor">

                    @* Nome macchina *@
                    <div class="kpi-card-header">
                        <span class="kpi-machine-num">@k.MacchianaNome</span>
                        <span class="kpi-machine-total">@FormatMinuti(k.TotaleMinuti)</span>
                    </div>

                    @* Barra stacked proporzionale *@
                    <div class="kpi-stacked-bar" title="Distribuzione stati">
                        @if (k.PercAutomatico > 0)
                        { <div style="width:@(k.PercAutomatico.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;background:@MesDesignTokens.PlcStatoAutomatico" title="AUTO @(k.PercAutomatico)%"></div> }
                        @if (k.PercAllarme > 0)
                        { <div style="width:@(k.PercAllarme.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;background:@MesDesignTokens.PlcStatoAllarme" title="ALLARME @(k.PercAllarme)%"></div> }
                        @if (k.PercEmergenza > 0)
                        { <div style="width:@(k.PercEmergenza.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;background:@MesDesignTokens.PlcStatoEmergenza" title="EMERGENZA @(k.PercEmergenza)%"></div> }
                        @if (k.PercManuale > 0)
                        { <div style="width:@(k.PercManuale.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;background:@MesDesignTokens.PlcStatoManuale" title="MANUALE @(k.PercManuale)%"></div> }
                        @if (k.PercSetup > 0)
                        { <div style="width:@(k.PercSetup.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;background:@MesDesignTokens.PlcStatoSetup" title="SETUP @(k.PercSetup)%"></div> }
                        @if (k.PercAltro > 0)
                        { <div style="width:@(k.PercAltro.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;background:@MesDesignTokens.PlcStatoNoConn" title="ALTRO @(k.PercAltro)%"></div> }
                    </div>

                    @* Badge stati colorati: sfondo = colore stato *@
                    <div class="kpi-badges">
                        @if (k.PercAutomatico > 0)
                        { <span class="kpi-badge" style="background:@MesDesignTokens.PlcStatoAutomatico">AUTO @(k.PercAutomatico.ToString("F1"))%</span> }
                        @if (k.PercAllarme > 0)
                        { <span class="kpi-badge" style="background:@MesDesignTokens.PlcStatoAllarme">ALL @(k.PercAllarme.ToString("F1"))%</span> }
                        @if (k.PercEmergenza > 0)
                        { <span class="kpi-badge" style="background:@MesDesignTokens.PlcStatoEmergenza">EMG @(k.PercEmergenza.ToString("F1"))%</span> }
                        @if (k.PercManuale > 0)
                        { <span class="kpi-badge" style="background:@MesDesignTokens.PlcStatoManuale">MAN @(k.PercManuale.ToString("F1"))%</span> }
                        @if (k.PercSetup > 0)
                        { <span class="kpi-badge" style="background:@MesDesignTokens.PlcStatoSetup">SET @(k.PercSetup.ToString("F1"))%</span> }
                        @if (k.PercAltro > 0)
                        { <span class="kpi-badge" style="background:@MesDesignTokens.PlcStatoNoConn">NC @(k.PercAltro.ToString("F1"))%</span> }
                    </div>

                </div>
            }
        </div>
    }

    @* ── Legenda colori ───────────────────────────────────────────────────── *@
    <MudPaper Class="pa-2 mb-2" Elevation="0" Style="border:1px solid var(--mud-palette-lines-default)">
        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1"><b>Legenda:</b></MudText>
            <div style="display:flex;align-items:center;gap:4px">
                <div style="width:14px;height:14px;border-radius:3px;background:@MesDesignTokens.PlcStatoAutomatico"></div>
                <MudText Typo="Typo.caption">Automatico</MudText>
            </div>
            <div style="display:flex;align-items:center;gap:4px">
                <div style="width:14px;height:14px;border-radius:3px;background:@MesDesignTokens.PlcStatoAllarme"></div>
                <MudText Typo="Typo.caption">Allarme</MudText>
            </div>
            <div style="display:flex;align-items:center;gap:4px">
                <div style="width:14px;height:14px;border-radius:3px;background:@MesDesignTokens.PlcStatoEmergenza"></div>
                <MudText Typo="Typo.caption">Emergenza</MudText>
            </div>
            <div style="display:flex;align-items:center;gap:4px">
                <div style="width:14px;height:14px;border-radius:3px;background:@MesDesignTokens.PlcStatoManuale"></div>
                <MudText Typo="Typo.caption">Manuale</MudText>
            </div>
            <div style="display:flex;align-items:center;gap:4px">
                <div style="width:14px;height:14px;border-radius:3px;background:@MesDesignTokens.PlcStatoSetup"></div>
                <MudText Typo="Typo.caption">Setup</MudText>
            </div>
            <div style="display:flex;align-items:center;gap:4px">
                <div style="width:14px;height:14px;border-radius:3px;background:@MesDesignTokens.PlcStatoSconosciuto"></div>
                <MudText Typo="Typo.caption">Altro</MudText>
            </div>
            <div style="display:flex;align-items:center;gap:4px">
                <div style="width:14px;height:14px;border-radius:3px;background:repeating-linear-gradient(45deg,#78909C,#78909C 5px,#B0BEC5 5px,#B0BEC5 10px)"></div>
                <MudText Typo="Typo.caption">Non Connessa</MudText>
            </div>
        </MudStack>
    </MudPaper>

    @* ── Gantt Container ──────────────────────────────────────────────────── *@
    <MudPaper Class="pa-3 mb-2" Elevation="2" Style="overflow:visible" data-testid="gantt-storico-container">
        @if (_loading)
        {
            <div style="display:flex;justify-content:center;padding:60px">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            </div>
        }
        else if (!_segmenti.Any() && _hasRendered)
        {
            <MudAlert Severity="Severity.Info" Class="ma-2">
                Nessun dato disponibile nel periodo selezionato. Verificare che PLCStorico contenga dati e che le macchine abbiano IP PLC configurato.
            </MudAlert>
        }
        <div id="gantt-storico-chart"
             class="gantt-storico-vis"
             style="@(_loading || !_segmenti.Any() ? "display:none" : "display:block")"
             data-testid="gantt-storico-chart">
        </div>
    </MudPaper>

    @* ── Analisi Intervallo ─────────────────────────────────────────────────── *@
    @if (_segmenti.Any())
    {
        <MudPaper Class="pa-3 mt-2" Elevation="1" data-testid="gantt-storico-analisi">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3" Wrap="Wrap.Wrap">
                <MudIcon Icon="@Icons.Material.Filled.Analytics" Color="Color.Primary" />
                <MudText Typo="Typo.subtitle1"><b>Analisi Intervallo</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Filtra i dati già caricati per calcolare pezzi e tempo ciclo medio in uno slot specifico.</MudText>
                <MudSpacer />
                <MudDatePicker Label="Analisi Da" @bind-Date="_analisiDa"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               data-testid="analisi-da" />
                <MudTimePicker Label="Ora Da" @bind-Time="_analisiDaTime"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               AmPm="false" Style="max-width:120px" />
                <MudDatePicker Label="Analisi A" @bind-Date="_analisiA"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               data-testid="analisi-a" />
                <MudTimePicker Label="Ora A" @bind-Time="_analisiATime"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               AmPm="false" Style="max-width:120px" />
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.RestartAlt"
                           OnClick="@ResetAnalisiRange"
                           data-testid="analisi-reset">
                    Reset
                </MudButton>
            </MudStack>

            @{
                var stats = CalcolaStats().ToList();
            }
            @if (stats.Any())
            {
                <MudSimpleTable Dense="true" Hover="true" Striped="true">
                    <thead>
                        <tr>
                            <th>Macchina</th>
                            <th style="text-align:right">Pezzi fatti</th>
                            <th style="text-align:right">Durata tot.</th>
                            <th style="text-align:right">Durata AUTO</th>
                            <th style="text-align:right">% AUTO</th>
                            <th style="text-align:right">Tempo ciclo medio</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in stats)
                        {
                            <tr>
                                <td><b>@row.Macchina</b></td>
                                <td style="text-align:right">
                                    @if (row.Pezzi > 0) { <b>@row.Pezzi</b> } else { <span style="color:var(--mud-palette-text-secondary)">—</span> }
                                </td>
                                <td style="text-align:right">@FormatMinuti(row.DurataTotaleMin)</td>
                                <td style="text-align:right">@FormatMinuti(row.DurataAutoMin)</td>
                                <td style="text-align:right">
                                    @{
                                        var percColor = row.PercAuto >= 70 ? "color:var(--mud-palette-success)" :
                                                        row.PercAuto >= 40 ? "color:var(--mud-palette-warning)" :
                                                                             "color:var(--mud-palette-error)";
                                    }
                                    <span style="@percColor;font-weight:600">@(row.PercAuto.ToString("F1"))%</span>
                                </td>
                                <td style="text-align:right">
                                    @if (row.TempoCicloMedioSec > 0)
                                    { <b>@FormatTempoCiclo(row.TempoCicloMedioSec)</b> }
                                    else
                                    { <span style="color:var(--mud-palette-text-secondary)">—</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Dense="true">Nessun segmento nel range di analisi selezionato.</MudAlert>
            }
        </MudPaper>
    }

</div>

@code {

    // ── Filtri toolbar ────────────────────────────────────────────────────────
    private DateTime? _from = DateTime.Today.AddDays(-1);
    private DateTime? _to   = DateTime.Today.AddDays(1);
    private string _macchinaIdFiltro = string.Empty;
    private bool _autoRefresh;

    // ── Stato pagina ──────────────────────────────────────────────────────────
    private bool _loading;
    private bool _hasRendered;
    private bool _disposed;
    private bool _pendingGanttRender;
    private Timer? _refreshTimer;

    // ── Dati ─────────────────────────────────────────────────────────────────
    private List<PlcGanttSegmentoDto> _segmenti = new();
    private List<PlcKpiStoricoDto>    _kpi      = new();
    private List<MacchinaDto>         _macchine = new();

    // ── Analisi intervallo ────────────────────────────────────────────────────
    private DateTime? _analisiDa;
    private DateTime? _analisiA;

    // Parti time dei picker (separate da Date per MudBlazor v8 compatibility)
    private TimeSpan? _analisiDaTime;
    private TimeSpan? _analisiATime;

    private DateTime? AnalisiDaEffettiva =>
        _analisiDa.HasValue
            ? _analisiDa.Value.Date + (_analisiDaTime ?? TimeSpan.Zero)
            : (DateTime?)null;

    private DateTime? AnalisiAEffettiva =>
        _analisiA.HasValue
            ? _analisiA.Value.Date + (_analisiATime ?? new TimeSpan(23, 59, 59))
            : (DateTime?)null;

    // ─────────────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _macchine = await MacchinaService.GetListaAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hasRendered = true;
            await LoadData();
            return;
        }

        // Dopo ogni render: se è in attesa di aggiornare il Gantt, lo fa ora
        // (la chiamata JS deve avvenire dopo che il DOM è aggiornato)
        if (_pendingGanttRender)
        {
            _pendingGanttRender = false;
            await RenderGantt();
        }
    }

    private async Task LoadData()
    {
        if (_loading || _disposed) return;
        _loading = true;
        StateHasChanged();

        try
        {
            var from = (_from ?? DateTime.Today.AddDays(-1)).ToString("yyyy-MM-ddTHH:mm:ss");
            var to   = (_to   ?? DateTime.Today.AddDays(1)).ToString("yyyy-MM-ddTHH:mm:ss");
            var macQ = string.IsNullOrWhiteSpace(_macchinaIdFiltro) ? "" : $"&macchinaId={_macchinaIdFiltro}";

            var ganttUrl = $"api/Plc/gantt-storico?from={from}&to={to}{macQ}";
            var kpiUrl   = $"api/Plc/kpi-storico?from={from}&to={to}{macQ}";

            var ganttTask = Http.GetFromJsonAsync<List<PlcGanttSegmentoDto>>(ganttUrl);
            var kpiTask   = Http.GetFromJsonAsync<List<PlcKpiStoricoDto>>(kpiUrl);

            await Task.WhenAll(ganttTask, kpiTask);

            _segmenti = ganttTask.Result ?? new();
            _kpi      = kpiTask.Result   ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore caricamento dati: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            _pendingGanttRender = _segmenti.Any();
            // Inizializza il range di analisi sincronizzato con i filtri caricati
            _analisiDa     = _from;
            _analisiA      = _to;
            _analisiDaTime = _from.HasValue ? (TimeSpan?)_from.Value.TimeOfDay : TimeSpan.Zero;
            _analisiATime  = _to.HasValue   ? (TimeSpan?)_to.Value.TimeOfDay   : new TimeSpan(23, 59, 59);
            StateHasChanged();
        }

        UpdateRefreshTimer();
    }

    private async Task RenderGantt()
    {
        if (_disposed || !_segmenti.Any()) return;
        try
        {
            await JS.InvokeVoidAsync("GanttStorico.initialize", "gantt-storico-chart", _segmenti);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore rendering Gantt: {ex.Message}", Severity.Error);
        }
    }

    private async Task EsportaCsv()
    {
        if (!_segmenti.Any()) return;
        try
        {
            await JS.InvokeVoidAsync("GanttStorico.exportCsv", _segmenti);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore export CSV: {ex.Message}", Severity.Error);
        }
    }

    private void UpdateRefreshTimer()
    {
        _refreshTimer?.Dispose();
        if (_autoRefresh && !_disposed)
        {
            _refreshTimer = new Timer(async _ =>
            {
                if (!_disposed)
                    await InvokeAsync(LoadData);
            }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
        }
    }

    private void ResetAnalisiRange()
    {
        _analisiDa     = _from;
        _analisiA      = _to;
        _analisiDaTime = _from.HasValue ? (TimeSpan?)_from.Value.TimeOfDay : TimeSpan.Zero;
        _analisiATime  = _to.HasValue   ? (TimeSpan?)_to.Value.TimeOfDay   : new TimeSpan(23, 59, 59);
    }

    private record AnalisiRow(
        string Macchina,
        int    Pezzi,
        double DurataTotaleMin,
        double DurataAutoMin,
        double TempoCicloMedioSec,
        double PercAuto);

    /// <summary>Calcola statistiche per macchina sull'intervallo di analisi, client-side sui dati già caricati.</summary>
    private IEnumerable<AnalisiRow> CalcolaStats()
    {
        var da = AnalisiDaEffettiva ?? _from ?? DateTime.MinValue;
        var a  = AnalisiAEffettiva  ?? _to   ?? DateTime.MaxValue;

        return _segmenti
            .Where(s => s.Inizio < a && s.Fine > da)
            .GroupBy(s => new { s.MacchinaId, s.MacchianaNome })
            .Select(g =>
            {
                var pezzi         = g.Sum(s => s.CicliFatti);
                var durAutoMin    = g.Where(s => s.StatoMacchina == "AUTOMATICO").Sum(s => s.DurataMinuti);
                var durTotMin     = g.Sum(s => s.DurataMinuti);
                var percAuto      = durTotMin > 0 ? durAutoMin / durTotMin * 100 : 0;
                // Tempo ciclo medio: secondi totali in AUTO diviso pezzi fatti
                var tempoCicloSec = pezzi > 0 ? durAutoMin * 60.0 / pezzi : 0;
                return new AnalisiRow(g.Key.MacchianaNome, pezzi, durTotMin, durAutoMin, tempoCicloSec, percAuto);
            })
            .OrderBy(r => r.Macchina);
    }

    private static string FormatTempoCiclo(double secondi)
    {
        var s = (int)Math.Round(secondi);
        if (s <= 0) return "—";
        var m = s / 60;
        var r = s % 60;
        return m > 0 ? $"{m}m {r:D2}s" : $"{r}s";
    }

    private static string FormatMinuti(double minuti)
    {
        var ore = (int)(minuti / 60);
        var min = (int)(minuti % 60);
        return ore > 0 ? $"{ore}h {min:D2}m" : $"{min}min";
    }

    /// <summary>Restituisce il colore dello stato dominante (max % tempo) per il bordo top della KPI card.</summary>
    private static string GetDominantColor(PlcKpiStoricoDto k)
    {
        var max = new[]
        {
            (k.PercAutomatico, MesDesignTokens.PlcStatoAutomatico),
            (k.PercAllarme,    MesDesignTokens.PlcStatoAllarme),
            (k.PercEmergenza,  MesDesignTokens.PlcStatoEmergenza),
            (k.PercManuale,    MesDesignTokens.PlcStatoManuale),
            (k.PercSetup,      MesDesignTokens.PlcStatoSetup),
            (k.PercAltro,      MesDesignTokens.PlcStatoNoConn)
        }.OrderByDescending(t => t.Item1).First();
        return max.Item2;
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _refreshTimer?.Dispose();
        try
        {
            await JS.InvokeVoidAsync("GanttStorico.destroy");
        }
        catch { /* ignora errori JS su dispose */ }
    }
}
