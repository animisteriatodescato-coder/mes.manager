@page "/produzione/gantt-storico"
@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@using MESManager.Web.Constants
@using System.Net.Http.Json
@using System.Threading
@inject HttpClient Http
@inject IMacchinaAppService MacchinaService
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>Gantt Storico Macchine</PageTitle>

<div data-testid="page-gantt-storico">

    @* ── Toolbar ─────────────────────────────────────────────────────────── *@
    <MudPaper Class="pa-3 mb-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">

            <MudDatePicker Label="Da" @bind-Date="_from"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           data-testid="gantt-storico-da" />

            <MudDatePicker Label="A" @bind-Date="_to"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           data-testid="gantt-storico-a" />

            <MudSelect T="string" Label="Macchina" @bind-Value="_macchinaIdFiltro"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:180px"
                       data-testid="gantt-storico-macchina">
                <MudSelectItem T="string" Value="@("")">Tutte le macchine</MudSelectItem>
                @foreach (var m in _macchine.Where(m => !string.IsNullOrWhiteSpace(m.IndirizzoPLC)))
                {
                    <MudSelectItem T="string" Value="@m.Id.ToString()">@m.Codice &mdash; @m.Nome</MudSelectItem>
                }
            </MudSelect>

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="LoadData" Disabled="@_loading"
                       data-testid="gantt-storico-carica">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                }
                Carica
            </MudButton>

            <MudSwitch @bind-Value="_autoRefresh" Color="Color.Secondary"
                       Label="Auto-refresh 30s"
                       data-testid="gantt-storico-autorefresh" />

            <MudButton Variant="Variant.Outlined" Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="EsportaCsv" Disabled="@(!_segmenti.Any())"
                       data-testid="gantt-storico-export">
                Export CSV
            </MudButton>

        </MudStack>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
            Solo macchine con IP PLC configurato. Usare lo zoom della timeline per dettagli.
        </MudText>
    </MudPaper>

    @* ── KPI Cards — riga orizzontale scorrevole, stile Dashboard Produzione ── *@
    @if (_kpi.Any())
    {
        <div class="kpi-scroll-row mb-3" data-testid="gantt-storico-kpi">
            @foreach (var k in _kpi)
            {
                var domColor = GetDominantColor(k);
                <div class="kpi-compact-card" style="border-top: 4px solid @domColor">

                    @* Nome macchina *@
                    <div class="kpi-card-header">
                        <span class="kpi-machine-num">@k.MacchianaNome</span>
                        <span class="kpi-machine-total">@FormatMinuti(k.TotaleMinuti)</span>
                    </div>

                    @* Barra stacked proporzionale *@
                    <div class="kpi-stacked-bar" title="Distribuzione stati">
                        @if (k.PercAutomatico > 0)
                        { <div style="width:@(k.PercAutomatico.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;background:@MesDesignTokens.PlcStatoAutomatico" title="AUTO @(k.PercAutomatico)%"></div> }
                        @if (k.PercAllarme > 0)
                        { <div style="width:@(k.PercAllarme.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;background:@MesDesignTokens.PlcStatoAllarme" title="ALLARME @(k.PercAllarme)%"></div> }
                        @if (k.PercEmergenza > 0)
                        { <div style="width:@(k.PercEmergenza.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;background:@MesDesignTokens.PlcStatoEmergenza" title="EMERGENZA @(k.PercEmergenza)%"></div> }
                        @if (k.PercManuale > 0)
                        { <div style="width:@(k.PercManuale.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;background:@MesDesignTokens.PlcStatoManuale" title="MANUALE @(k.PercManuale)%"></div> }
                        @if (k.PercSetup > 0)
                        { <div style="width:@(k.PercSetup.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;background:@MesDesignTokens.PlcStatoSetup" title="SETUP @(k.PercSetup)%"></div> }
                        @if (k.PercAltro > 0)
                        { <div style="width:@(k.PercAltro.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;background:@MesDesignTokens.PlcStatoNoConn" title="ALTRO @(k.PercAltro)%"></div> }
                    </div>

                    @* Badge stati colorati: sfondo = colore stato *@
                    <div class="kpi-badges">
                        @if (k.PercAutomatico > 0)
                        { <span class="kpi-badge" style="background:@MesDesignTokens.PlcStatoAutomatico">AUTO @(k.PercAutomatico.ToString("F1"))%</span> }
                        @if (k.PercAllarme > 0)
                        { <span class="kpi-badge" style="background:@MesDesignTokens.PlcStatoAllarme">ALL @(k.PercAllarme.ToString("F1"))%</span> }
                        @if (k.PercEmergenza > 0)
                        { <span class="kpi-badge" style="background:@MesDesignTokens.PlcStatoEmergenza">EMG @(k.PercEmergenza.ToString("F1"))%</span> }
                        @if (k.PercManuale > 0)
                        { <span class="kpi-badge" style="background:@MesDesignTokens.PlcStatoManuale">MAN @(k.PercManuale.ToString("F1"))%</span> }
                        @if (k.PercSetup > 0)
                        { <span class="kpi-badge" style="background:@MesDesignTokens.PlcStatoSetup">SET @(k.PercSetup.ToString("F1"))%</span> }
                        @if (k.PercAltro > 0)
                        { <span class="kpi-badge" style="background:@MesDesignTokens.PlcStatoNoConn">NC @(k.PercAltro.ToString("F1"))%</span> }
                    </div>

                </div>
            }
        </div>
    }

    @* ── Gantt Container ──────────────────────────────────────────────────── *@
    <MudPaper Class="pa-3 mb-2" Elevation="2" data-testid="gantt-storico-container">
        @if (_loading)
        {
            <div style="display:flex;justify-content:center;padding:60px">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            </div>
        }
        else if (!_segmenti.Any() && _hasRendered)
        {
            <MudAlert Severity="Severity.Info" Class="ma-2">
                Nessun dato disponibile nel periodo selezionato. Verificare che PLCStorico contenga dati e che le macchine abbiano IP PLC configurato.
            </MudAlert>
        }
        <div id="gantt-storico-chart"
             class="gantt-storico-vis"
             style="@(_loading || !_segmenti.Any() ? "display:none" : "display:block")"
             data-testid="gantt-storico-chart">
        </div>
    </MudPaper>

    @* ── Legenda colori ───────────────────────────────────────────────────── *@
    <MudPaper Class="pa-2" Elevation="0">
        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Stati:</MudText>
            <MudChip T="string" Style="@($"background:{MesDesignTokens.PlcStatoAutomatico};color:#fff")" Size="Size.Small">AUTOMATICO</MudChip>
            <MudChip T="string" Style="@($"background:{MesDesignTokens.PlcStatoAllarme};color:#fff")" Size="Size.Small">ALLARME</MudChip>
            <MudChip T="string" Style="@($"background:{MesDesignTokens.PlcStatoEmergenza};color:#fff")" Size="Size.Small">EMERGENZA</MudChip>
            <MudChip T="string" Style="@($"background:{MesDesignTokens.PlcStatoManuale};color:#fff")" Size="Size.Small">MANUALE</MudChip>
            <MudChip T="string" Style="@($"background:{MesDesignTokens.PlcStatoSetup};color:#fff")" Size="Size.Small">SETUP</MudChip>
            <MudChip T="string" Style="@($"background:{MesDesignTokens.PlcStatoSconosciuto};color:#fff")" Size="Size.Small">ALTRO</MudChip>
            <MudChip T="string" Style="background:repeating-linear-gradient(45deg,#78909C,#78909C 5px,#B0BEC5 5px,#B0BEC5 10px);color:#fff;text-shadow:0 1px 2px rgba(0,0,0,.5)" Size="Size.Small">NON CONNESSA</MudChip>
        </MudStack>
    </MudPaper>

</div>

@code {

    // ── Filtri toolbar ────────────────────────────────────────────────────────
    private DateTime? _from = DateTime.Today.AddDays(-1);
    private DateTime? _to   = DateTime.Today.AddDays(1);
    private string _macchinaIdFiltro = string.Empty;
    private bool _autoRefresh;

    // ── Stato pagina ──────────────────────────────────────────────────────────
    private bool _loading;
    private bool _hasRendered;
    private bool _disposed;
    private bool _pendingGanttRender;
    private Timer? _refreshTimer;

    // ── Dati ─────────────────────────────────────────────────────────────────
    private List<PlcGanttSegmentoDto> _segmenti = new();
    private List<PlcKpiStoricoDto>    _kpi      = new();
    private List<MacchinaDto>         _macchine = new();

    // ─────────────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _macchine = await MacchinaService.GetListaAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hasRendered = true;
            await LoadData();
            return;
        }

        // Dopo ogni render: se è in attesa di aggiornare il Gantt, lo fa ora
        // (la chiamata JS deve avvenire dopo che il DOM è aggiornato)
        if (_pendingGanttRender)
        {
            _pendingGanttRender = false;
            await RenderGantt();
        }
    }

    private async Task LoadData()
    {
        if (_loading || _disposed) return;
        _loading = true;
        StateHasChanged();

        try
        {
            var from = (_from ?? DateTime.Today.AddDays(-1)).ToString("yyyy-MM-ddTHH:mm:ss");
            var to   = (_to   ?? DateTime.Today.AddDays(1)).ToString("yyyy-MM-ddTHH:mm:ss");
            var macQ = string.IsNullOrWhiteSpace(_macchinaIdFiltro) ? "" : $"&macchinaId={_macchinaIdFiltro}";

            var ganttUrl = $"api/Plc/gantt-storico?from={from}&to={to}{macQ}";
            var kpiUrl   = $"api/Plc/kpi-storico?from={from}&to={to}{macQ}";

            var ganttTask = Http.GetFromJsonAsync<List<PlcGanttSegmentoDto>>(ganttUrl);
            var kpiTask   = Http.GetFromJsonAsync<List<PlcKpiStoricoDto>>(kpiUrl);

            await Task.WhenAll(ganttTask, kpiTask);

            _segmenti = ganttTask.Result ?? new();
            _kpi      = kpiTask.Result   ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore caricamento dati: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            _pendingGanttRender = _segmenti.Any();
            StateHasChanged();
        }

        UpdateRefreshTimer();
    }

    private async Task RenderGantt()
    {
        if (_disposed || !_segmenti.Any()) return;
        try
        {
            await JS.InvokeVoidAsync("GanttStorico.initialize", "gantt-storico-chart", _segmenti);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore rendering Gantt: {ex.Message}", Severity.Error);
        }
    }

    private async Task EsportaCsv()
    {
        if (!_segmenti.Any()) return;
        try
        {
            await JS.InvokeVoidAsync("GanttStorico.exportCsv", _segmenti);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore export CSV: {ex.Message}", Severity.Error);
        }
    }

    private void UpdateRefreshTimer()
    {
        _refreshTimer?.Dispose();
        if (_autoRefresh && !_disposed)
        {
            _refreshTimer = new Timer(async _ =>
            {
                if (!_disposed)
                    await InvokeAsync(LoadData);
            }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
        }
    }

    private static string FormatMinuti(double minuti)
    {
        var ore = (int)(minuti / 60);
        var min = (int)(minuti % 60);
        return ore > 0 ? $"{ore}h {min:D2}m" : $"{min}min";
    }

    /// <summary>Restituisce il colore dello stato dominante (max % tempo) per il bordo top della KPI card.</summary>
    private static string GetDominantColor(PlcKpiStoricoDto k)
    {
        var max = new[]
        {
            (k.PercAutomatico, MesDesignTokens.PlcStatoAutomatico),
            (k.PercAllarme,    MesDesignTokens.PlcStatoAllarme),
            (k.PercEmergenza,  MesDesignTokens.PlcStatoEmergenza),
            (k.PercManuale,    MesDesignTokens.PlcStatoManuale),
            (k.PercSetup,      MesDesignTokens.PlcStatoSetup),
            (k.PercAltro,      MesDesignTokens.PlcStatoNoConn)
        }.OrderByDescending(t => t.Item1).First();
        return max.Item2;
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _refreshTimer?.Dispose();
        try
        {
            await JS.InvokeVoidAsync("GanttStorico.destroy");
        }
        catch { /* ignora errori JS su dispose */ }
    }
}
