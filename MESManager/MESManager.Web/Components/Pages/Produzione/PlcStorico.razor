@page "/produzione/plc-storico"
@using MESManager.Application.DTOs
@using MESManager.Web.Models
@using MESManager.Web.Services
@using Microsoft.JSInterop
@inject HttpClient Http
@inject NavigationManager Nav
@inject PreferencesService PreferencesService
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>PLC Storico</PageTitle>

<div class="plc-storico-page">
    <div class="toolbar-sticky">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap" Class="mb-3">
            <MudText Typo="Typo.h6">Storico Dati PLC</MudText>
            <MudSpacer />
            
            <MudSelect T="Guid?" Label="Macchina" @bind-Value="selectedMacchinaId" 
                      Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 250px;">
                @foreach (var macchina in macchine)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)macchina.Id)">@macchina.Codice - @macchina.Nome</MudSelectItem>
                }
            </MudSelect>
            
            <MudDatePicker Label="Da" @bind-Date="dataInizio" 
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
            
            <MudDatePicker Label="A" @bind-Date="dataFine" 
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
            
            <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                      StartIcon="@Icons.Material.Filled.Search" 
                      OnClick="LoadData" Disabled="!selectedMacchinaId.HasValue">
                Cerca
            </MudButton>
            
            <MudTextField @bind-Value="searchText"
                         Placeholder="Cerca..."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Style="width: 200px;"
                         Immediate="true"
                         DebounceInterval="280"
                         OnDebounceIntervalElapsed="OnSearchDebounced" />
            
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ViewColumn" OnClick="@ToggleColumnPanel">Colonne</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="@ResetGrid">Reset</MudButton>
        </MudStack>
    </div>

    <div id="plcStoricoGrid" class="ag-theme-alpine" 
         style="width: 100%; height: calc(100vh - 200px);">
    </div>
</div>

<style>
    .plc-storico-page {
        position: relative;
    }

    .toolbar-sticky {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--mud-palette-surface);
        padding: 0.5rem 0;
        margin-bottom: 0.5rem;
    }
</style>

@code {
    private List<PlcStoricoDto> _data = new();
    private List<MacchinaDto> macchine = new();
    private GridUiSettings settings = new();
    private string searchText = string.Empty;
    private Guid? selectedMacchinaId;
    private DateTime? dataInizio = DateTime.Today.AddDays(-7);
    private DateTime? dataFine = DateTime.Today;

    private async Task OnSearchDebounced(string value)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("plcStoricoGrid.setQuickFilter", value);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error filtering grid: {ex.Message}");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Http.BaseAddress = new Uri(Nav.BaseUri);
        
        // Carica lista macchine
        try
        {
            macchine = await Http.GetFromJsonAsync<List<MacchinaDto>>("api/Macchine") ?? new();
            if (macchine.Any())
            {
                selectedMacchinaId = macchine.First().Id;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading machines: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var savedColumnState = await PreferencesService.GetAsync<string>("plc-storico-grid-columns");
                await JSRuntime.InvokeVoidAsync("plcStoricoGrid.init", "plcStoricoGrid", _data, savedColumnState);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing grid: {ex.Message}");
            }
        }
    }

    private async Task LoadData()
    {
        if (!selectedMacchinaId.HasValue) return;
        
        try
        {
            var from = dataInizio?.ToString("yyyy-MM-dd");
            var to = dataFine?.ToString("yyyy-MM-dd");
            var url = $"api/Plc/storico/{selectedMacchinaId}?from={from}&to={to}";
            
            _data = await Http.GetFromJsonAsync<List<PlcStoricoDto>>(url) ?? new();
            await RefreshGrid();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
    }

    private async Task RefreshGrid()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("plcStoricoGrid.updateData", _data);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error refreshing grid: {ex.Message}");
        }
    }

    private async Task ToggleColumnPanel()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("plcStoricoGrid.toggleColumnPanel");
        }
        catch { }
    }

    private async Task ResetGrid()
    {
        try
        {
            await PreferencesService.RemoveAsync("plc-storico-grid-columns");
            await JSRuntime.InvokeVoidAsync("plcStoricoGrid.resetGrid");
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            var columnState = await JSRuntime.InvokeAsync<string>("plcStoricoGrid.getColumnState");
            if (!string.IsNullOrEmpty(columnState))
            {
                await PreferencesService.SetAsync("plc-storico-grid-columns", columnState);
            }
        }
        catch { }
    }
}

public class MacchinaDto
{
    public Guid Id { get; set; }
    public string Codice { get; set; } = string.Empty;
    public string Nome { get; set; } = string.Empty;
}
