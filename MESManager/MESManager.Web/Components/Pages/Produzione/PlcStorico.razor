@page "/produzione/plc-storico"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = MESManager.Web.Constants.PaginaPolicy.PlcStorico)]
@using MESManager.Application.DTOs
@using MESManager.Web.Models
@using MESManager.Web.Services
@using Microsoft.JSInterop
@inject NavigationManager Nav
@inject PreferencesService PreferencesService
@inject IJSRuntime JSRuntime
@inject PlcDataService PlcService
@implements IAsyncDisposable

<PageTitle>PLC Storico</PageTitle>

<div class="mes-grid-page" data-testid="page-plc-storico">
    <MudPaper Class="settings-panel toolbar-sticky pa-2 mb-1" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            
            <MudSelect T="string" Label="Colonna filtro" @bind-Value="selectedFilterColumn" 
                      data-testid="select-plc-storico-colonna"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 200px;">
                <MudSelectItem T="string" Value="@("")">Nessun filtro</MudSelectItem>
                <MudSelectItem T="string" Value="@("macchina")">Macchina</MudSelectItem>
                <MudSelectItem T="string" Value="@("operatore")">Operatore</MudSelectItem>
                <MudSelectItem T="string" Value="@("stato")">Stato</MudSelectItem>
                <MudSelectItem T="string" Value="@("commessa")">Commessa</MudSelectItem>
            </MudSelect>
            
            @if (!string.IsNullOrEmpty(selectedFilterColumn))
            {
                <MudTextField @bind-Value="filterValue"
                             data-testid="input-plc-storico-valore"
                             Label="Valore filtro"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Style="width: 200px;" />
            }
            
            <MudDatePicker Label="Da" @bind-Date="dataInizio" 
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
            
            <MudDatePicker Label="A" @bind-Date="dataFine" 
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
            
            <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                      StartIcon="@Icons.Material.Filled.Search" 
                      OnClick="LoadData" data-testid="btn-plc-storico-cerca">
                Cerca
            </MudButton>
            
            <MudTextField @bind-Value="searchText"
                         data-testid="input-plc-storico-search"
                         Placeholder="Cerca..."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Style="width: 200px;"
                         Immediate="true"
                         DebounceInterval="280"
                         OnDebounceIntervalElapsed="OnSearchDebounced" />
            <MudSpacer />
            
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ViewColumn" OnClick="@ToggleColumnPanel" data-testid="btn-plc-storico-colonne">Colonne</MudButton>
            <FixResetMenu OnFix="@FixGridState" OnReset="@ResetToFixedState"
                         ShowGlobalSave="@IsAdmin" OnSaveGlobal="@SaveAsGlobalDefault" />
        </MudStack>
    </MudPaper>

    <div id="plcStoricoGrid" class="ag-theme-alpine mes-ag-grid" 
         data-testid="grid-plc-storico">
    </div>
</div>

<style>
</style>

@code {
    private List<PlcStoricoDto> _allData = new();
    private List<PlcStoricoDto> _data = new();
    private GridUiSettings settings = new();
    private string searchText = string.Empty;
    private string selectedFilterColumn = string.Empty;
    private string filterValue = string.Empty;
    private DateTime? dataInizio = DateTime.Today;
    private DateTime? dataFine = DateTime.Today.AddDays(1);

    [CascadingParameter(Name = "IsAdmin")] private bool IsAdmin { get; set; }

    private async Task OnSearchDebounced(string value)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("plcStoricoGrid.setQuickFilter", value);
        }
        catch
        {
            // Error filtering grid
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Carica dati di oggi prima di inizializzare la grid (così la grid parte già con i dati)
                await LoadData();
                var savedColumnState = await PreferencesService.GetAsync<string>("plc-storico-grid-columns");
                await JSRuntime.InvokeVoidAsync("plcStoricoGrid.init", "plcStoricoGrid", _data, savedColumnState);
            }
            catch
            {
                // Error initializing grid
            }
        }
    }

    private async Task LoadData()
    {
        try
        {
            _allData = await PlcService.LoadStoricoDataAsync(dataInizio, dataFine);
            _data = ApplyFilter(_allData);
            await RefreshGrid();
        }
        catch
        {
            // Error loading data
        }
    }

    private List<PlcStoricoDto> ApplyFilter(List<PlcStoricoDto> data)
    {
        if (string.IsNullOrEmpty(selectedFilterColumn) || string.IsNullOrEmpty(filterValue))
            return data;

        return selectedFilterColumn.ToLower() switch
        {
            "macchina" => data.Where(d => d.MacchianaNome?.Contains(filterValue, StringComparison.OrdinalIgnoreCase) == true).ToList(),
            "operatore" => data.Where(d => d.NomeOperatore?.Contains(filterValue, StringComparison.OrdinalIgnoreCase) == true || 
                                          d.NumeroOperatore?.ToString().Contains(filterValue) == true).ToList(),
            "stato" => data.Where(d => d.StatoMacchina?.Contains(filterValue, StringComparison.OrdinalIgnoreCase) == true).ToList(),
            "commessa" => data.Where(d => d.BarcodeLavorazione.ToString().Contains(filterValue)).ToList(),
            _ => data
        };
    }

    private async Task RefreshGrid()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("plcStoricoGrid.updateData", _data);
        }
        catch
        {
            // Error refreshing grid
        }
    }

    private async Task ToggleColumnPanel()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("plcStoricoGrid.toggleColumnPanel");
        }
        catch { }
    }

    private async Task FixGridState()
    {
        try
        {
            var gridState = await JSRuntime.InvokeAsync<string>("plcStoricoGrid.getColumnState");
            await PreferencesService.SetAsync("plc-storico-grid-fixed-state", gridState);
        }
        catch { }
    }

    private async Task ResetToFixedState()
    {
        try
        {
            var fixedState = await PreferencesService.GetAsync<string>("plc-storico-grid-fixed-state");
            
            if (!string.IsNullOrEmpty(fixedState))
            {
                await JSRuntime.InvokeVoidAsync("plcStoricoGrid.setColumnState", fixedState);
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("plcStoricoGrid.resetGrid");
            }
        }
        catch { }
    }

    private async Task SaveAsGlobalDefault()
    {
        try
        {
            var gridState = await JSRuntime.InvokeAsync<string>("plcStoricoGrid.getColumnState");
            if (!string.IsNullOrEmpty(gridState))
            {
                await PreferencesService.SetGlobalAsync("plc-storico-grid-columns", gridState);
            }
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            var columnState = await JSRuntime.InvokeAsync<string>("plcStoricoGrid.getColumnState");
            if (!string.IsNullOrEmpty(columnState))
            {
                await PreferencesService.SetAsync("plc-storico-grid-columns", columnState);
            }
        }
        catch { }
    }
}
