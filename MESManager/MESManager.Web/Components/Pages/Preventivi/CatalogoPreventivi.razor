    // ── Feature 4: Template ───────────────────────────────────────────────

    private async Task SalvaTemplate()
    {
        if (string.IsNullOrWhiteSpace(_dto.Cliente)) return;
        var nome = $"Template {_dto.SabbiaSnapshot ?? "generico"} {DateTime.Today:yyyy-MM-dd}";
        await PreventivoService.SalvaTemplateAsync(nome, null, _dto);
        _templates = await PreventivoService.GetTemplatesAsync();
        Snackbar.Add($"Template '{nome}' salvato.", Severity.Success);
    }

    private async Task CaricaTemplate(PreventivoTemplateDto? tmpl)
    {
        if (tmpl == null) return;
        var parametri = await PreventivoService.CaricaTemplateAsync(tmpl.Id);
        if (parametri == null) return;
        // Mantieni cliente e stato attuali, applica solo parametri tecnici
        _dto.Figure = parametri.Figure; _dto.PesoAnima = parametri.PesoAnima;
        _dto.Lotto = parametri.Lotto; _dto.Lotto2 = parametri.Lotto2;
        _dto.Lotto3 = parametri.Lotto3; _dto.Lotto4 = parametri.Lotto4;
        _dto.SpariOrari = parametri.SpariOrari; _dto.CostoAttrezzatura = parametri.CostoAttrezzatura;
        _dto.Margine1 = parametri.Margine1; _dto.Margine2 = parametri.Margine2;
        _dto.Margine3 = parametri.Margine3; _dto.Margine4 = parametri.Margine4;
        _dto.TipoSabbiaId = parametri.TipoSabbiaId; _dto.SabbiaSnapshot = parametri.SabbiaSnapshot;
        _dto.EuroOraSabbia = parametri.EuroOraSabbia; _dto.PrezzoSabbiaKg = parametri.PrezzoSabbiaKg;
        _dto.VerniciaturaRichiesta = parametri.VerniciaturaRichiesta;
        _dto.TipoVerniceId = parametri.TipoVerniceId; _dto.VerniceSnapshot = parametri.VerniceSnapshot;
        _dto.CostoVerniceKg = parametri.CostoVerniceKg; _dto.PercentualeVernice = parametri.PercentualeVernice;
        _dto.VerniciaturaPzOra = parametri.VerniciaturaPzOra; _dto.EuroOraVerniciatura = parametri.EuroOraVerniciatura;
        _dto.IncollaggioRichiesto = parametri.IncollaggioRichiesto; _dto.EuroOraIncollaggio = parametri.EuroOraIncollaggio;
        _dto.IncollaggioPzOra = parametri.IncollaggioPzOra;
        _dto.ImballaggioRichiesto = parametri.ImballaggioRichiesto; _dto.EuroOraImballaggio = parametri.EuroOraImballaggio;
        _dto.ImballaggioPzOra = parametri.ImballaggioPzOra; _dto.Sconto = parametri.Sconto;
        _tipoSabbiaSelezionata = parametri.TipoSabbiaId.HasValue
            ? _tipiSabbia.FirstOrDefault(s => s.Id == parametri.TipoSabbiaId)
            : null;
        _tipoVerniceSelezionata = parametri.TipoVerniceId.HasValue
            ? _tipiVernice.FirstOrDefault(v => v.Id == parametri.TipoVerniceId)
            : null;
        Ricalcola();
        Snackbar.Add($"Template '{tmpl.Nome}' caricato.", Severity.Info);
    }

    // ── Impostazioni: Tipi Sabbia ─────────────────────────────────────────

    private void AggiungiTipoSabbia() => _tipiSabbia.Add(new PreventivoTipoSabbiaDto
    {
        Id = Guid.Empty, Codice = "", Nome = "", Famiglia = "distribut",
        EuroOra = 70, PrezzoKg = 1.42m, SpariDefault = 40, Attivo = true,
        Ordine = _tipiSabbia.Count + 1
    });

    private void SincronizzaCodiceSabbia(PreventivoTipoSabbiaDto dto)
    {
        var match = _sabbiaTabelle.FirstOrDefault(t => t.Descrizione == dto.Nome);
        if (match != null) dto.Codice = match.Codice;
    }

    private async Task SalvaTipoSabbiaAsync(PreventivoTipoSabbiaDto dto)
    {
        if (string.IsNullOrWhiteSpace(dto.Nome)) { Snackbar.Add("Seleziona un nome sabbia.", Severity.Warning); return; }
        try
        {
            if (dto.Id == Guid.Empty)
            {
                var created = await PreventivoService.CreateTipoSabbiaAsync(dto);
                var idx = _tipiSabbia.IndexOf(dto);
                if (idx >= 0) _tipiSabbia[idx] = created;
            }
            else
            {
                await PreventivoService.UpdateTipoSabbiaAsync(dto);
            }
            Snackbar.Add("Tipo sabbia salvato.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Errore: {ex.Message}", Severity.Error); }
    }

    private async Task EliminaTipoSabbiaAsync(PreventivoTipoSabbiaDto dto)
    {
        if (dto.Id == Guid.Empty) { _tipiSabbia.Remove(dto); return; }
        await PreventivoService.DeleteTipoSabbiaAsync(dto.Id);
        _tipiSabbia.Remove(dto);
        Snackbar.Add("Tipo sabbia eliminato.", Severity.Success);
    }

