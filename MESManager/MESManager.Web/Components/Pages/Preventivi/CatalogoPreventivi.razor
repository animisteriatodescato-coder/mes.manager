    private async Task CaricaInModifica(PreventivoDto preventivo)
    {
        _dto = new PreventivoDto
        {
            Id = preventivo.Id, Cliente = preventivo.Cliente,
            CodiceArticolo = preventivo.CodiceArticolo, Descrizione = preventivo.Descrizione,
            NoteCliente = preventivo.NoteCliente, DataCreazione = preventivo.DataCreazione,
            TipoSabbiaId = preventivo.TipoSabbiaId, SabbiaSnapshot = preventivo.SabbiaSnapshot,
            EuroOraSabbia = preventivo.EuroOraSabbia, PrezzoSabbiaKg = preventivo.PrezzoSabbiaKg,
            Figure = preventivo.Figure, PesoAnima = preventivo.PesoAnima,
            Lotto = preventivo.Lotto, Lotto2 = preventivo.Lotto2,
            Lotto3 = preventivo.Lotto3, Lotto4 = preventivo.Lotto4,
            Margine1 = preventivo.Margine1, Margine2 = preventivo.Margine2,
            Margine3 = preventivo.Margine3, Margine4 = preventivo.Margine4,
            SpariOrari = preventivo.SpariOrari,
            CostoAttrezzatura = preventivo.CostoAttrezzatura,
            VerniciaturaRichiesta = preventivo.VerniciaturaRichiesta,
            TipoVerniceId = preventivo.TipoVerniceId, VerniceSnapshot = preventivo.VerniceSnapshot,
            CostoVerniceKg = preventivo.CostoVerniceKg, PercentualeVernice = preventivo.PercentualeVernice,
            VerniciaturaPzOra = preventivo.VerniciaturaPzOra, EuroOraVerniciatura = preventivo.EuroOraVerniciatura,
            IncollaggioRichiesto = preventivo.IncollaggioRichiesto, EuroOraIncollaggio = preventivo.EuroOraIncollaggio,
            IncollaggioPzOra = preventivo.IncollaggioPzOra,
            ImballaggioRichiesto = preventivo.ImballaggioRichiesto, EuroOraImballaggio = preventivo.EuroOraImballaggio,
            ImballaggioPzOra = preventivo.ImballaggioPzOra, Stato = preventivo.Stato,
            // Feature v1.65.7
            NoteInterne = preventivo.NoteInterne,
            Sconto = preventivo.Sconto,
            CommessaId = preventivo.CommessaId,
            EmailDestinatario = preventivo.EmailDestinatario,
            EmailInviatoIl = preventivo.EmailInviatoIl,
        };
        _dataCreazione = preventivo.DataCreazione;
        _editingId = preventivo.Id;
        _tipoSabbiaSelezionata  = preventivo.TipoSabbiaId.HasValue
            ? _tipiSabbia.FirstOrDefault(s => s.Id == preventivo.TipoSabbiaId)
            : null;
        _tipoVerniceSelezionata = preventivo.TipoVerniceId.HasValue
            ? _tipiVernice.FirstOrDefault(v => v.Id == preventivo.TipoVerniceId)
            : null;
        Ricalcola();
        if (_tabs != null) await _tabs.ActivatePanelAsync(0);
    }

    private async Task SalvaAsync()
    {
        if (string.IsNullOrWhiteSpace(_dto.Cliente))
        {
            Snackbar.Add("Il campo Cliente è obbligatorio.", Severity.Warning);
            return;
        }
        _isSaving = true;
        _dto.DataCreazione = _dataCreazione ?? DateTime.Today;
        var r = PreventivoService.Calcola(_dto);
        _dto.CalcCostoAnima      = r.CostoAnima;
        _dto.CalcVerniciaturaTot = r.VernTot;
        _dto.CalcPrezzoVendita   = r.PrezzoVendita;
        try
        {
            if (_editingId.HasValue)
            {
                var updated = await PreventivoService.UpdateAsync(_dto);
                if (updated != null)
                {
                    var idx = _preventivi.FindIndex(p => p.Id == updated.Id);
                    if (idx >= 0) _preventivi[idx] = updated;
                }
                Snackbar.Add("Preventivo aggiornato.", Severity.Success);
            }
            else
            {
                var created = await PreventivoService.CreateAsync(_dto);
                _preventivi.Insert(0, created);
                _editingId = created.Id;
                _dto.Id = created.Id;
                Snackbar.Add("Preventivo salvato.", Severity.Success);
            }
        }
        catch (Exception ex) { Snackbar.Add($"Errore: {ex.Message}", Severity.Error); }
        finally { _isSaving = false; }
    }

    // ── Archivio ─────────────────────────────────────────────────────────

    private IEnumerable<PreventivoDto> PreventiviFiltrati =>
        string.IsNullOrWhiteSpace(_searchText)
            ? _preventivi
            : _preventivi.Where(p =>
                p.Cliente.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                p.CodiceArticolo.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                p.SabbiaSnapshot.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                (p.VerniceSnapshot ?? "").Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    private async Task EliminaAsync(PreventivoDto p)
    {
        if (await PreventivoService.DeleteAsync(p.Id)) { _preventivi.Remove(p); Snackbar.Add("Eliminato.", Severity.Info); }
        else Snackbar.Add("Errore eliminazione.", Severity.Error);
    }

    private async Task DuplicaAsync(PreventivoDto p)
    {
        var duplicato = await PreventivoService.DuplicaAsync(p.Id);
        if (duplicato != null)
        {
            _preventivi.Insert(0, duplicato);
            Snackbar.Add($"Preventivo duplicato → N° {duplicato.NumeroPreventivo}", Severity.Success);
        }
    }

    private async Task CambiaStatoAsync(PreventivoDto p, string stato)
    {
        var updated = await PreventivoService.UpdateStatoAsync(p.Id, stato);
        if (updated != null) { p.Stato = stato; Snackbar.Add($"Stato: {stato}", Severity.Success); }
    }

