@page "/preventivi"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = MESManager.Web.Constants.PaginaPolicy.CatPreventivi)]
@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@using MESManager.Web.Components.Dialogs.Preventivi
@inject IPreventivoService PreventivoService
@inject ICommessaAppService CommessaAppService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject HttpClient Http

<PageTitle>Preventivi</PageTitle>

<div data-testid="page-preventivi" class="pa-4">
    <MudTabs @ref="_tabs" PanelClass="pt-4" data-testid="tabs-preventivi">

        <!-- ══════════════════════════════════════════════════
             TAB 1 — Nuovo / Modifica preventivo
        ══════════════════════════════════════════════════ -->
        <MudTabPanel Text="@(_editingId.HasValue ? "Modifica preventivo" : "Nuovo preventivo")"
                     Icon="@Icons.Material.Filled.AddCircleOutline"
                     data-testid="tab-nuovo">
            <MudGrid Spacing="3">

                <!-- ── COLONNA FORM ── -->
                <MudItem xs="12" md="8">

                    <!-- DATI CLIENTE -->
                    <MudPaper Class="pa-4 mb-3" Elevation="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" />
                            <MudText Typo="Typo.subtitle1"><b>DATI CLIENTE</b></MudText>
                            @if (_dto.NumeroPreventivo > 0)
                            {
                                <MudSpacer />
                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Icon="@Icons.Material.Filled.Tag">
                                    N° @_dto.NumeroPreventivo
                                </MudChip>
                            }
                        </MudStack>
                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="6">
                                <MudAutocomplete T="string"
                                                 @bind-Value="_dto.Cliente"
                                                 Label="Cliente *"
                                                 SearchFunc="CercaClienti"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense"
                                                 MinCharacters="0"
                                                 DebounceInterval="200"
                                                 ShowProgressIndicator="true"
                                                 CoerceText="true"
                                                 CoerceValue="true"
                                                 AdornmentIcon="@Icons.Material.Filled.Search"
                                                 data-testid="input-cliente" />
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudTextField @bind-Value="_dto.CodiceArticolo" Label="Codice articolo"
                                              Variant="Variant.Outlined" Margin="Margin.Dense"
                                              data-testid="input-codice-articolo" />
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudDatePicker @bind-Date="_dataCreazione" Label="Data"
                                               Variant="Variant.Outlined" Margin="Margin.Dense"
                                               data-testid="input-data" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_dto.Descrizione" Label="Descrizione articolo"
                                              Variant="Variant.Outlined" Margin="Margin.Dense"
                                              data-testid="input-descrizione" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_dto.NoteCliente"
                                              Label="Note cliente (visibili sul modulo)"
                                              Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2"
                                              data-testid="input-note-cliente" />
                            </MudItem>
                            <!-- Feature 7: Note interne -->
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_dto.NoteInterne"
                                              Label="Note interne (NON escono sul modulo)"
                                              Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2"
                                              HelperText="Visibili solo internamente"
                                              data-testid="input-note-interne" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    <!-- SABBIA -->
                    <MudPaper Class="pa-4 mb-3" Elevation="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Grain" Color="Color.Warning" />
                            <MudText Typo="Typo.subtitle1"><b>TIPO SABBIA</b></MudText>
                        </MudStack>
                        @if (!_tipiSabbia.Any(s => s.Attivo))
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">
                                Nessun tipo sabbia configurato. Vai in <b>Impostazioni prezzi</b> (terza tab) per aggiungerne.
                            </MudAlert>
                        }
                        else
                        {
                            <MudSelect T="PreventivoTipoSabbiaDto?"
                                       @bind-Value="_tipoSabbiaSelezionata"
                                       @bind-Value:after="OnSabbiaSelezionata"
                                       Label="Seleziona tipo sabbia"
                                       Variant="Variant.Outlined" Margin="Margin.Dense"
                                       ToStringFunc="@(s => s == null ? "— nessuna —" : $"{s.Nome}")"
                                       data-testid="select-tipo-sabbia">
                                <MudSelectItem T="PreventivoTipoSabbiaDto?" Value="null">— nessuna —</MudSelectItem>
                                @foreach (var ts in _tipiSabbia.Where(s => s.Attivo).OrderBy(s => s.Ordine))
                                {
                                    <MudSelectItem T="PreventivoTipoSabbiaDto?" Value="ts">
                                        @ts.Nome — €@ts.EuroOra.ToString("N2")/h · @ts.SpariDefault spari/h · €@ts.PrezzoKg.ToString("N4")/kg
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        }
                    </MudPaper>

                    <!-- PARAMETRI PRODUZIONE -->
                    <MudPaper Class="pa-4 mb-3" Elevation="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Info" />
                            <MudText Typo="Typo.subtitle1"><b>PARAMETRI PRODUZIONE</b></MudText>
                        </MudStack>
                        <MudGrid Spacing="2">
                            <MudItem xs="6" sm="4" md="3">
                                <MudNumericField @bind-Value="_dto.Figure" @bind-Value:after="Ricalcola"
                                                 Label="Figure" Min="1"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 data-testid="input-figure" />
                            </MudItem>
                            <MudItem xs="6" sm="4" md="3">
                                <MudNumericField @bind-Value="_dto.PesoAnima" @bind-Value:after="Ricalcola"
                                                 Label="Peso anima (kg)" Min="0.001m" Step="0.01m" Format="N3"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 data-testid="input-peso-anima" />
                            </MudItem>
                            <MudItem xs="6" sm="4" md="3">
                                <MudNumericField @bind-Value="_dto.SpariOrari" @bind-Value:after="Ricalcola"
                                                 Label="Spari/h" Min="1"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 data-testid="input-spari-orari" />
                            </MudItem>
                            <MudItem xs="6" sm="4" md="3">
                                <MudNumericField @bind-Value="_dto.CostoAttrezzatura" @bind-Value:after="Ricalcola"
                                                 Label="Attrezzatura (€)" Min="0" Format="N2"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 data-testid="input-costo-attrezzatura" />
                            </MudItem>
                            <MudItem xs="6" sm="4" md="3">
                                <MudNumericField @bind-Value="_dto.EuroOraSabbia" @bind-Value:after="Ricalcola"
                                                 Label="€/h sabbia" Min="0" Format="N2"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 data-testid="input-euro-ora-sabbia" />
                            </MudItem>
                        </MudGrid>

                        <!-- LOTTI -->
                        <MudDivider Class="my-3" />
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Layers" Color="Color.Info" Size="Size.Small" />
                            <MudText Typo="Typo.body2"><b>LOTTI (fino a 4, il primo è obbligatorio)</b></MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Il calcolo viene eseguito per ogni lotto inserito</MudText>
                        </MudStack>
                        <MudGrid Spacing="2">
                            <MudItem xs="6" sm="3">
                                <MudNumericField @bind-Value="_dto.Lotto" @bind-Value:after="Ricalcola"
                                                 Label="Lotto 1 * (pz)" Min="1"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 data-testid="input-lotto1" />
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudNumericField T="int?" Value="_dto.Lotto2"
                                                 ValueChanged="@(v => { _dto.Lotto2 = v; Ricalcola(); })"
                                                 Label="Lotto 2 (pz)" Min="1"
                                                 Clearable="true"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 data-testid="input-lotto2" />
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudNumericField T="int?" Value="_dto.Lotto3"
                                                 ValueChanged="@(v => { _dto.Lotto3 = v; Ricalcola(); })"
                                                 Label="Lotto 3 (pz)" Min="1"
                                                 Clearable="true"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 data-testid="input-lotto3" />
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudNumericField T="int?" Value="_dto.Lotto4"
                                                 ValueChanged="@(v => { _dto.Lotto4 = v; Ricalcola(); })"
                                                 Label="Lotto 4 (pz)" Min="1"
                                                 Clearable="true"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 data-testid="input-lotto4" />
                            </MudItem>
                        </MudGrid>

                        <!-- MARGINI PER LOTTO -->
                        <MudDivider Class="mt-2 mb-1" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">MARGINE DI PROFITTO PER LOTTO (%)</MudText>
                        <MudGrid Spacing="2">
                            <MudItem xs="6" sm="3">
                                <MudNumericField T="decimal" @bind-Value="_dto.Margine1" @bind-Value:after="Ricalcola"
                                                 Label="Margine L1 (%)" Min="@(0m)" Max="@(100m)"
                                                 Format="N1"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Adornment="Adornment.End" AdornmentText="%"
                                                 data-testid="input-margine1" />
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudNumericField T="decimal" @bind-Value="_dto.Margine2" @bind-Value:after="Ricalcola"
                                                 Label="Margine L2 (%)" Min="@(0m)" Max="@(100m)"
                                                 Format="N1"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Adornment="Adornment.End" AdornmentText="%"
                                                 Disabled="@(!_dto.Lotto2.HasValue || _dto.Lotto2 <= 0)"
                                                 data-testid="input-margine2" />
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudNumericField T="decimal" @bind-Value="_dto.Margine3" @bind-Value:after="Ricalcola"
                                                 Label="Margine L3 (%)" Min="@(0m)" Max="@(100m)"
                                                 Format="N1"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Adornment="Adornment.End" AdornmentText="%"
                                                 Disabled="@(!_dto.Lotto3.HasValue || _dto.Lotto3 <= 0)"
                                                 data-testid="input-margine3" />
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudNumericField T="decimal" @bind-Value="_dto.Margine4" @bind-Value:after="Ricalcola"
                                                 Label="Margine L4 (%)" Min="@(0m)" Max="@(100m)"
                                                 Format="N1"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Adornment="Adornment.End" AdornmentText="%"
                                                 Disabled="@(!_dto.Lotto4.HasValue || _dto.Lotto4 <= 0)"
                                                 data-testid="input-margine4" />
                            </MudItem>
                        </MudGrid>
                        <!-- Feature 8: Sconto volume -->
                        <MudDivider Class="mt-2 mb-1" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">SCONTO VOLUME (% sul prezzo finale)</MudText>
                        <MudGrid Spacing="2">
                            <MudItem xs="6" sm="3">
                                <MudNumericField T="decimal" @bind-Value="_dto.Sconto" @bind-Value:after="Ricalcola"
                                                 Label="Sconto (%)" Min="@(0m)" Max="@(50m)"
                                                 Format="N1"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Adornment="Adornment.End" AdornmentText="%"
                                                 HelperText="Applicato dopo il margine su tutti i lotti"
                                                 data-testid="input-sconto" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                    <MudPaper Class="pa-4 mb-3" Elevation="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.FormatColorFill" Color="Color.Secondary" />
                            <MudText Typo="Typo.subtitle1"><b>VERNICIATURA</b></MudText>
                            <MudSwitch @bind-Value="_dto.VerniciaturaRichiesta" @bind-Value:after="Ricalcola"
                                       Color="Color.Secondary" data-testid="switch-verniciatura" />
                        </MudStack>
                        @if (_dto.VerniciaturaRichiesta)
                        {
                            @if (!_tipiVernice.Any(v => v.Attivo))
                            {
                                <MudAlert Severity="Severity.Info" Dense="true">
                                    Nessun tipo vernice configurato. Vai in <b>Impostazioni prezzi</b> per aggiungerne.
                                </MudAlert>
                            }
                            else
                            {
                                <MudSelect T="PreventivoTipoVerniceDto?"
                                           @bind-Value="_tipoVerniceSelezionata"
                                           @bind-Value:after="OnVerniceSelezionata"
                                           Label="Seleziona tipo vernice"
                                           Variant="Variant.Outlined" Margin="Margin.Dense"
                                           ToStringFunc="@(v => v == null ? "— nessuna —" : v.Nome)"
                                           data-testid="select-tipo-vernice"
                                           Class="mb-3">
                                    <MudSelectItem T="PreventivoTipoVerniceDto?" Value="null">— nessuna —</MudSelectItem>
                                    @foreach (var tv in _tipiVernice.Where(v => v.Attivo).OrderBy(v => v.Ordine))
                                    {
                                        <MudSelectItem T="PreventivoTipoVerniceDto?" Value="tv">
                                            @tv.Nome (@tv.Famiglia) — €@tv.PrezzoKg.ToString("N2")/kg · @tv.PercentualeApplicazione.ToString("N1")%
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            <MudGrid Spacing="2" Class="mt-2">
                                <MudItem xs="6" sm="3">
                                    <MudNumericField @bind-Value="_dto.CostoVerniceKg" @bind-Value:after="Ricalcola"
                                                     Label="€/kg vernice" Min="0" Format="N2"
                                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                                     data-testid="input-costo-vernice-kg" />
                                </MudItem>
                                <MudItem xs="6" sm="3">
                                    <MudNumericField @bind-Value="_dto.PercentualeVernice" @bind-Value:after="Ricalcola"
                                                     Label="% applicazione" Min="0" Max="100" Format="N1"
                                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                                     data-testid="input-perc-vernice" />
                                </MudItem>
                                <MudItem xs="6" sm="3">
                                    <MudNumericField @bind-Value="_dto.VerniciaturaPzOra" @bind-Value:after="Ricalcola"
                                                     Label="Pz/h verniciatura" Min="0"
                                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                                     data-testid="input-verniciatura-pz-ora" />
                                </MudItem>
                                <MudItem xs="6" sm="3">
                                    <MudNumericField @bind-Value="_dto.EuroOraVerniciatura" @bind-Value:after="Ricalcola"
                                                     Label="€/h verniciatura" Min="0" Format="N2"
                                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                                     data-testid="input-euro-ora-verniciatura" />
                                </MudItem>
                            </MudGrid>
                        }
                    </MudPaper>

                    <!-- SERVIZI AGGIUNTIVI -->
                    <MudPaper Class="pa-4 mb-3" Elevation="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Tertiary" />
                            <MudText Typo="Typo.subtitle1"><b>SERVIZI AGGIUNTIVI</b></MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">(calcolati separatamente)</MudText>
                        </MudStack>
                        <!-- Incollaggio -->
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                            <MudSwitch @bind-Value="_dto.IncollaggioRichiesto" @bind-Value:after="Ricalcola"
                                       Color="Color.Tertiary" data-testid="switch-incollaggio" />
                            <MudText Typo="Typo.body2" Style="min-width:90px">Incollaggio</MudText>
                            @if (_dto.IncollaggioRichiesto)
                            {
                                <MudNumericField @bind-Value="_dto.IncollaggioPzOra" @bind-Value:after="Ricalcola"
                                                 Label="Pz/h" Min="0" Style="width:90px"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 data-testid="input-incollaggio-pz-ora" />
                                <MudNumericField @bind-Value="_dto.EuroOraIncollaggio" @bind-Value:after="Ricalcola"
                                                 Label="€/h" Min="0" Format="N2" Style="width:90px"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 data-testid="input-euro-ora-incollaggio" />
                                <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                    = <b>€@_calc.Incollaggio.ToString("N4")</b>/pz
                                </MudText>
                            }
                        </MudStack>
                        <!-- Imballaggio -->
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudSwitch @bind-Value="_dto.ImballaggioRichiesto" @bind-Value:after="Ricalcola"
                                       Color="Color.Tertiary" data-testid="switch-imballaggio" />
                            <MudText Typo="Typo.body2" Style="min-width:90px">Imballaggio</MudText>
                            @if (_dto.ImballaggioRichiesto)
                            {
                                <MudNumericField @bind-Value="_dto.ImballaggioPzOra" @bind-Value:after="Ricalcola"
                                                 Label="Pz/h" Min="0" Style="width:90px"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 data-testid="input-imballaggio-pz-ora" />
                                <MudNumericField @bind-Value="_dto.EuroOraImballaggio" @bind-Value:after="Ricalcola"
                                                 Label="€/h" Min="0" Format="N2" Style="width:90px"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 data-testid="input-euro-ora-imballaggio" />
                                <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                    = <b>€@_calc.Imballaggio.ToString("N4")</b>/pz
                                </MudText>
                            }
                        </MudStack>
                    </MudPaper>

                </MudItem>

                <!-- ── COLONNA CALCOLO ── -->
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 sticky-calc" Elevation="4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Calculate" Color="Color.Warning" />
                            <MudText Typo="Typo.subtitle1"><b>CALCOLO INTERNO</b></MudText>
                        </MudStack>
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                            NON ESCE SUL MODULO CLIENTE
                        </MudAlert>

                        <MudSimpleTable Dense="true" Class="mb-3">
                            <tbody>
                                <tr>
                                    <td><MudText Typo="Typo.caption">Lavorazione</MudText></td>
                                    <td class="text-right"><MudText Typo="Typo.caption">€@_calc.Lavorazione.ToString("N4")</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption">Sabbia</MudText></td>
                                    <td class="text-right"><MudText Typo="Typo.caption">€@_calc.Sabbia.ToString("N4")</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.caption">Lav+Sab / fig</MudText></td>
                                    <td class="text-right"><MudText Typo="Typo.caption">€@_calc.LavSabFig.ToString("N4")</MudText></td>
                                </tr>
                                @if (_dto.VerniciaturaRichiesta)
                                {
                                    <tr>
                                        <td><MudText Typo="Typo.caption">Vern. materiale</MudText></td>
                                        <td class="text-right"><MudText Typo="Typo.caption">€@_calc.VernMateriale.ToString("N4")</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.caption">Vern. manodopera</MudText></td>
                                        <td class="text-right"><MudText Typo="Typo.caption">€@_calc.VernManodopera.ToString("N4")</MudText></td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>

                        <!-- TABELLA PREZZI PER LOTTO -->
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">PREZZO PER LOTTO</MudText>
                        <MudSimpleTable Dense="true" Class="mb-3">
                            <thead>
                                <tr style="border-bottom:1px solid var(--mud-palette-divider)">
                                    <th><MudText Typo="Typo.caption"><b>Lotto (pz)</b></MudText></th>
                                    <th class="text-right"><MudText Typo="Typo.caption"><b>Margine</b></MudText></th>
                                    <th class="text-right"><MudText Typo="Typo.caption"><b>Prezzo/pz</b></MudText></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (lotto, calcLotto) in LottiCalcolati)
                                {
                                    <tr>
                                        <td><MudText Typo="Typo.body2">@lotto</MudText></td>
                                        <td class="text-right">
                                            @if (calcLotto.Margine > 0)
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Warning">+@calcLotto.Margine.ToString("N1")%</MudText>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Default">—</MudText>
                                            }
                                        </td>
                                        <td class="text-right">
                                            <MudText Typo="Typo.body2" Color="Color.Success"><b>€@calcLotto.PrezzoVendita.ToString("N4")</b></MudText>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>

                        @if (_dto.IncollaggioRichiesto || _dto.ImballaggioRichiesto)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Servizi (separati):</MudText>
                            @if (_dto.IncollaggioRichiesto)
                            {
                                <MudText Typo="Typo.caption">Incollaggio: €@_calc.Incollaggio.ToString("N4")/pz</MudText>
                            }
                            @if (_dto.ImballaggioRichiesto)
                            {
                                <MudText Typo="Typo.caption">Imballaggio: €@_calc.Imballaggio.ToString("N4")/pz</MudText>
                            }
                            <MudDivider Class="my-2" />
                        }

                        @if (_dto.Sconto > 0)
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                                Sconto volume @_dto.Sconto.ToString("N1")% già applicato ai prezzi
                            </MudAlert>
                        }

                        <!-- Feature 4: Template -->
                        @if (_templates.Any())
                        {
                            <MudDivider Class="my-2" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">TEMPLATE</MudText>
                            <MudSelect T="PreventivoTemplateDto?" Value="null"
                                       ValueChanged="CaricaTemplate"
                                       Label="Carica da template"
                                       Variant="Variant.Outlined" Margin="Margin.Dense"
                                       ToStringFunc="@(t => t == null ? "— seleziona —" : t.Nome)"
                                       data-testid="select-template">
                                <MudSelectItem T="PreventivoTemplateDto?" Value="null">— seleziona —</MudSelectItem>
                                @foreach (var tmpl in _templates)
                                {
                                    <MudSelectItem T="PreventivoTemplateDto?" Value="tmpl">@tmpl.Nome</MudSelectItem>
                                }
                            </MudSelect>
                        }

                        <MudDivider Class="my-2" />

                        <MudStack Spacing="2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.Save"
                                       OnClick="SalvaAsync" Disabled="_isSaving"
                                       data-testid="btn-salva">
                                @(_isSaving ? "Salvataggio..." : "Salva in archivio")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.Print"
                                       OnClick="ApriModuloCliente"
                                       Disabled="@(string.IsNullOrWhiteSpace(_dto.Cliente))"
                                       data-testid="btn-modulo-cliente">
                                Modulo cliente
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Info" FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.Bookmark"
                                       OnClick="SalvaTemplate"
                                       Disabled="@(string.IsNullOrWhiteSpace(_dto.Cliente))"
                                       data-testid="btn-salva-template">
                                Salva come template
                            </MudButton>
                            @if (_editingId.HasValue)
                            {
                                <MudButton Variant="Variant.Text" FullWidth="true"
                                           StartIcon="@Icons.Material.Filled.AddCircle"
                                           OnClick="NuovoPreventivo"
                                           data-testid="btn-nuovo">
                                    Nuovo preventivo
                                </MudButton>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>

            </MudGrid>
        </MudTabPanel>

        <!-- ══════════════════════════════════════════════════
             TAB 2 — Archivio
        ══════════════════════════════════════════════════ -->
        <MudTabPanel Icon="@Icons.Material.Filled.Archive" data-testid="tab-archivio">
            <TabContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText>Archivio</MudText>
                    <MudBadge Content="@_preventivi.Count" Color="Color.Primary" Overlap="false" />
                </MudStack>
            </TabContent>
            <ChildContent>
                <MudPaper Class="pa-3 mb-3" Elevation="1">
                    <MudTextField @bind-Value="_searchText"
                                  Placeholder="Cerca per cliente, codice, sabbia..."
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                  DebounceInterval="300" OnDebounceIntervalElapsed="@(s => { _searchText = s; StateHasChanged(); })"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Style="max-width:400px"
                                  data-testid="input-archivio-search" />
                </MudPaper>

                @if (_isLoading)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else
                {
                    <MudTable Items="@PreventiviFiltrati" Dense="true" Hover="true"
                              data-testid="table-archivio">
                        <HeaderContent>
                            <MudTh><MudTableSortLabel SortBy="new Func<PreventivoDto, object>(x => x.DataCreazione)">Data</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<PreventivoDto, object>(x => x.Cliente)">Cliente</MudTableSortLabel></MudTh>
                            <MudTh>Codice</MudTh>
                            <MudTh>Sabbia</MudTh>
                            <MudTh>Vernice</MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<PreventivoDto, object>(x => x.CalcPrezzoVendita)">Prezzo</MudTableSortLabel></MudTh>
                            <MudTh>Stato</MudTh>
                            <MudTh>Azioni</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.DataCreazione.ToString("dd/MM/yyyy")</MudTd>
                            <MudTd>@context.Cliente</MudTd>
                            <MudTd><MudText Typo="Typo.caption">@context.CodiceArticolo</MudText></MudTd>
                            <MudTd><MudText Typo="Typo.caption">@context.SabbiaSnapshot</MudText></MudTd>
                            <MudTd><MudText Typo="Typo.caption">@(context.VerniciaturaRichiesta ? context.VerniceSnapshot : "—")</MudText></MudTd>
                            <MudTd><MudText Color="Color.Success"><b>€@context.CalcPrezzoVendita.ToString("N4")</b></MudText></MudTd>
                            <MudTd>
                                @{
                                    var scaduto = context.Stato == "InAttesa" && (DateTime.Today - context.DataCreazione.Date).TotalDays > 90;
                                }
                                @if (scaduto)
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Icon="@Icons.Material.Filled.Warning">Scaduto</MudChip>
                                }
                                else
                                {
                                    <MudSelect T="string" Value="@context.Stato"
                                               ValueChanged="@(s => CambiaStatoAsync(context, s))"
                                               Variant="Variant.Text" Margin="Margin.Dense"
                                               data-testid="@($"select-stato-{context.Id}")">
                                        <MudSelectItem Value="@("InAttesa")">In attesa</MudSelectItem>
                                        <MudSelectItem Value="@("Inviato")">Inviato</MudSelectItem>
                                        <MudSelectItem Value="@("Approvato")">Approvato</MudSelectItem>
                                        <MudSelectItem Value="@("Rifiutato")">Rifiutato</MudSelectItem>
                                    </MudSelect>
                                }
                            </MudTd>
                            <MudTd>
                                <MudStack Row="true" Spacing="0">
                                    <MudTooltip Text="Modifica">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                       OnClick="@(() => CaricaInModifica(context))"
                                                       data-testid="@($"btn-modifica-{context.Id}")" />
                                    </MudTooltip>
                                    <MudTooltip Text="Modulo cliente">
                                        <MudIconButton Icon="@Icons.Material.Filled.Print" Size="Size.Small"
                                                       Color="Color.Secondary"
                                                       OnClick="@(() => ApriModuloClienteConDto(context))"
                                                       data-testid="@($"btn-modulo-{context.Id}")" />
                                    </MudTooltip>
                                    <MudTooltip Text="Duplica">
                                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                                       Color="Color.Info"
                                                       OnClick="@(() => DuplicaAsync(context))"
                                                       data-testid="@($"btn-duplica-{context.Id}")" />
                                    </MudTooltip>
                                    <MudTooltip Text="Elimina">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="@(() => EliminaAsync(context))"
                                                       data-testid="@($"btn-elimina-{context.Id}")" />
                                    </MudTooltip>
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent><MudText>Nessun preventivo trovato.</MudText></NoRecordsContent>
                    </MudTable>
                }
            </ChildContent>
        </MudTabPanel>

        <!-- ══════════════════════════════════════════════════
             TAB 3 — Impostazioni prezzi
        ══════════════════════════════════════════════════ -->
        <MudTabPanel Text="Impostazioni prezzi" Icon="@Icons.Material.Filled.Tune"
                     data-testid="tab-impostazioni">

            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                Associa i nomi sabbia/vernice già presenti in <b>Gestione Tabelle</b> con i prezzi usati nel calcolo preventivi.
            </MudAlert>

            <MudGrid Spacing="3">
                <!-- ── PREZZI SABBIA ── -->
                <MudItem xs="12">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Grain" Color="Color.Warning" />
                            <MudText Typo="Typo.subtitle1"><b>PREZZI SABBIA</b></MudText>
                            <MudSpacer />
                            <MudButton Variant="Variant.Filled" Color="Color.Success"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="AggiungiTipoSabbia"
                                       data-testid="btn-imp-sabbia-add">
                                Aggiungi
                            </MudButton>
                        </MudStack>

                        @if (_tipiSabbia.Count == 0 && _sabbiaTabelle.Count == 0)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true">
                                Prima aggiungi voci nella tabella Sabbia in <b>Impostazioni → Gestione Tabelle</b>.
                            </MudAlert>
                        }
                        else
                        {
                            <MudTable Items="@_tipiSabbia" Dense="true" Hover="true" data-testid="table-imp-sabbia">
                                <HeaderContent>
                                    <MudTh>Nome sabbia (da tabelle)</MudTh>
                                    <MudTh>Famiglia</MudTh>
                                    <MudTh>€/ora macchina</MudTh>
                                    <MudTh>€/kg sabbia</MudTh>
                                    <MudTh>Spari/h default</MudTh>
                                    <MudTh>Attivo</MudTh>
                                    <MudTh>Azioni</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>
                                        @if (context.Id == Guid.Empty)
                                        {
                                            <!-- Nuova riga: dropdown da tabelle esistenti -->
                                            <MudSelect T="string" @bind-Value="context.Nome"
                                                       @bind-Value:after="@(() => SincronizzaCodiceSabbia(context))"
                                                       Variant="Variant.Text" Margin="Margin.Dense"
                                                       Label="Seleziona da tabelle"
                                                       data-testid="select-imp-sabbia-nome">
                                                @foreach (var item in _sabbiaTabelle)
                                                {
                                                    <MudSelectItem Value="@item.Descrizione">@item.Codice — @item.Descrizione</MudSelectItem>
                                                }
                                            </MudSelect>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.body2">@context.Nome</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Codice</MudText>
                                        }
                                    </MudTd>
                                    <MudTd>
                                        <MudSelect @bind-Value="context.Famiglia" Variant="Variant.Text" Margin="Margin.Dense">
                                            <MudSelectItem Value="@("distribut")">Distributori</MudSelectItem>
                                            <MudSelectItem Value="@("cerabeads")">Cerabeads</MudSelectItem>
                                            <MudSelectItem Value="@("normale")">Normale</MudSelectItem>
                                        </MudSelect>
                                    </MudTd>
                                    <MudTd>
                                        <MudNumericField @bind-Value="context.EuroOra" HideSpinButtons="true"
                                                         Variant="Variant.Text" Format="F2" Margin="Margin.Dense" />
                                    </MudTd>
                                    <MudTd>
                                        <MudNumericField @bind-Value="context.PrezzoKg" HideSpinButtons="true"
                                                         Variant="Variant.Text" Format="F4" Margin="Margin.Dense" />
                                    </MudTd>
                                    <MudTd>
                                        <MudNumericField @bind-Value="context.SpariDefault" HideSpinButtons="true"
                                                         Variant="Variant.Text" Margin="Margin.Dense" />
                                    </MudTd>
                                    <MudTd>
                                        <MudCheckBox @bind-Value="context.Attivo" Color="Color.Primary" />
                                    </MudTd>
                                    <MudTd>
                                        <MudStack Row="true" Spacing="1">
                                            <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Primary"
                                                           Size="Size.Small"
                                                           OnClick="@(() => SalvaTipoSabbiaAsync(context))"
                                                           data-testid="@($"btn-imp-sabbia-salva-{context.Id}")" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                           Size="Size.Small"
                                                           OnClick="@(() => EliminaTipoSabbiaAsync(context))"
                                                           data-testid="@($"btn-imp-sabbia-elimina-{context.Id}")" />
                                        </MudStack>
                                    </MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <MudText>Nessun tipo sabbia configurato. Clicca <b>Aggiungi</b>.</MudText>
                                </NoRecordsContent>
                            </MudTable>
                        }
                    </MudPaper>
                </MudItem>

                <!-- ── PREZZI VERNICE ── -->
                <MudItem xs="12">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.FormatColorFill" Color="Color.Secondary" />
                            <MudText Typo="Typo.subtitle1"><b>PREZZI VERNICE</b></MudText>
                            <MudSpacer />
                            <MudButton Variant="Variant.Filled" Color="Color.Success"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="AggiungiTipoVernice"
                                       data-testid="btn-imp-vernice-add">
                                Aggiungi
                            </MudButton>
                        </MudStack>

                        @if (_tipiVernice.Count == 0 && _verniceTabelle.Count == 0)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true">
                                Prima aggiungi voci nella tabella Vernice in <b>Impostazioni → Gestione Tabelle</b>.
                            </MudAlert>
                        }
                        else
                        {
                            <MudTable Items="@_tipiVernice" Dense="true" Hover="true" data-testid="table-imp-vernice">
                                <HeaderContent>
                                    <MudTh>Nome vernice (da tabelle)</MudTh>
                                    <MudTh>Famiglia</MudTh>
                                    <MudTh>€/kg vernice</MudTh>
                                    <MudTh>% applicazione default</MudTh>
                                    <MudTh>Attivo</MudTh>
                                    <MudTh>Azioni</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>
                                        @if (context.Id == Guid.Empty)
                                        {
                                            <MudSelect T="string" @bind-Value="context.Nome"
                                                       @bind-Value:after="@(() => SincronizzaCodiceVernice(context))"
                                                       Variant="Variant.Text" Margin="Margin.Dense"
                                                       Label="Seleziona da tabelle"
                                                       data-testid="select-imp-vernice-nome">
                                                @foreach (var item in _verniceTabelle)
                                                {
                                                    <MudSelectItem Value="@item.Descrizione">@item.Codice — @item.Descrizione</MudSelectItem>
                                                }
                                            </MudSelect>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.body2">@context.Nome</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Codice</MudText>
                                        }
                                    </MudTd>
                                    <MudTd>
                                        <MudSelect @bind-Value="context.Famiglia" Variant="Variant.Text" Margin="Margin.Dense">
                                            <MudSelectItem Value="@("acqua")">Ad acqua</MudSelectItem>
                                            <MudSelectItem Value="@("alcool")">All'alcool</MudSelectItem>
                                        </MudSelect>
                                    </MudTd>
                                    <MudTd>
                                        <MudNumericField @bind-Value="context.PrezzoKg" HideSpinButtons="true"
                                                         Variant="Variant.Text" Format="F2" Margin="Margin.Dense" />
                                    </MudTd>
                                    <MudTd>
                                        <MudNumericField @bind-Value="context.PercentualeApplicazione" HideSpinButtons="true"
                                                         Variant="Variant.Text" Format="F1" Margin="Margin.Dense" />
                                    </MudTd>
                                    <MudTd>
                                        <MudCheckBox @bind-Value="context.Attivo" Color="Color.Primary" />
                                    </MudTd>
                                    <MudTd>
                                        <MudStack Row="true" Spacing="1">
                                            <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Primary"
                                                           Size="Size.Small"
                                                           OnClick="@(() => SalvaTipoVerniceAsync(context))"
                                                           data-testid="@($"btn-imp-vernice-salva-{context.Id}")" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                           Size="Size.Small"
                                                           OnClick="@(() => EliminaTipoVerniceAsync(context))"
                                                           data-testid="@($"btn-imp-vernice-elimina-{context.Id}")" />
                                        </MudStack>
                                    </MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <MudText>Nessun tipo vernice configurato. Clicca <b>Aggiungi</b>.</MudText>
                                </NoRecordsContent>
                            </MudTable>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- ══════════════════════════════════════════════════
             TAB 4 — Report mensile
        ══════════════════════════════════════════════════ -->
        <MudTabPanel Text="Report" Icon="@Icons.Material.Filled.BarChart" data-testid="tab-report">
            <MudGrid Spacing="3" Class="mt-2">
                <!-- Statistiche generali -->
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 text-center" Elevation="2">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Size="Size.Large" />
                        <MudText Typo="Typo.h4"><b>@_preventivi.Count</b></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Preventivi totali</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 text-center" Elevation="2">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" />
                        <MudText Typo="Typo.h4"><b>@_preventivi.Count(p => p.Stato == "Approvato")</b></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Approvati</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 text-center" Elevation="2">
                        <MudIcon Icon="@Icons.Material.Filled.Email" Color="Color.Info" Size="Size.Large" />
                        <MudText Typo="Typo.h4"><b>@_preventivi.Count(p => p.Stato == "Inviato")</b></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Inviati</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 text-center" Elevation="2">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Large" />
                        <MudText Typo="Typo.h4"><b>@_preventivi.Count(p => p.Stato == "InAttesa" && (DateTime.Today - p.DataCreazione.Date).TotalDays > 90)</b></MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Scaduti (>90gg)</MudText>
                    </MudPaper>
                </MudItem>

                <!-- Ultimi 30 giorni -->
                <MudItem xs="12">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudText Typo="Typo.subtitle1" Class="mb-3"><b>ULTIMI 30 GIORNI</b></MudText>
                        @{
                            var ultimi30 = _preventivi.Where(p => (DateTime.Today - p.DataCreazione.Date).TotalDays <= 30).ToList();
                            var clientiDistinti = ultimi30.Select(p => p.Cliente).Distinct().Count();
                        }
                        <MudGrid Spacing="2">
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.h5" Color="Color.Primary">@ultimi30.Count</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Nuovi preventivi</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.h5" Color="Color.Success">@ultimi30.Count(p => p.Stato == "Approvato")</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Approvati</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.h5" Color="Color.Warning">@clientiDistinti</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Clienti diversi</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.h5" Color="Color.Error">@ultimi30.Count(p => p.Stato == "Rifiutato")</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Rifiutati</MudText>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                <!-- Top clienti -->
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudText Typo="Typo.subtitle1" Class="mb-3"><b>TOP 10 CLIENTI</b></MudText>
                        <MudSimpleTable Dense="true">
                            <thead>
                                <tr>
                                    <th>Cliente</th>
                                    <th class="text-right">Preventivi</th>
                                    <th class="text-right">Approvati</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var g in _preventivi
                                    .GroupBy(p => p.Cliente)
                                    .OrderByDescending(g => g.Count())
                                    .Take(10))
                                {
                                    <tr>
                                        <td>@g.Key</td>
                                        <td class="text-right">@g.Count()</td>
                                        <td class="text-right">@g.Count(p => p.Stato == "Approvato")</td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>
                </MudItem>

                <!-- Preventivi per mese (ultimi 6) -->
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="2">
                        <MudText Typo="Typo.subtitle1" Class="mb-3"><b>PREVENTIVI PER MESE (ultimi 6)</b></MudText>
                        <MudSimpleTable Dense="true">
                            <thead>
                                <tr>
                                    <th>Mese</th>
                                    <th class="text-right">Totale</th>
                                    <th class="text-right">Approvati</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var oggi = DateTime.Today;
                                    for (int m = 5; m >= 0; m--)
                                    {
                                        var mese = oggi.AddMonths(-m);
                                        var prev = _preventivi.Where(p =>
                                            p.DataCreazione.Year == mese.Year &&
                                            p.DataCreazione.Month == mese.Month).ToList();
                                        <tr>
                                            <td>@mese.ToString("MMM yyyy")</td>
                                            <td class="text-right">@prev.Count</td>
                                            <td class="text-right">@prev.Count(p => p.Stato == "Approvato")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

    </MudTabs>
</div>

@code {
    private MudTabs? _tabs;

    // Pricing configurati nel DB
    private List<PreventivoTipoSabbiaDto> _tipiSabbia  = new();
    private List<PreventivoTipoVerniceDto> _tipiVernice = new();

    // Nomi da Gestione Tabelle esistenti
    private List<TabellaItem> _sabbiaTabelle  = new();
    private List<TabellaItem> _verniceTabelle = new();

    // Cache clienti per autocomplete
    private List<string> _clientiRagioni = new();

    // Archivio preventivi
    private List<PreventivoDto> _preventivi = new();

    // Feature 4: Template
    private List<PreventivoTemplateDto> _templates = new();

    // Form preventivo
    private PreventivoDto _dto = new();
    private PreventivoCalcoloResult _calc = new();
    private DateTime? _dataCreazione = DateTime.Today;
    private Guid? _editingId;
    private PreventivoTipoSabbiaDto?  _tipoSabbiaSelezionata;
    private PreventivoTipoVerniceDto? _tipoVerniceSelezionata;

    // UI state
    private bool _isLoading;
    private bool _isSaving;
    private string _searchText = string.Empty;

    // ── Inizializzazione ────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        // Carico prima le tabelle esistenti (HttpClient)
        var sabbiaRaw  = await Http.GetFromJsonAsync<List<TabellaItem>>("/api/Tabelle/sabbia")  ?? new();
        var verniceRaw = await Http.GetFromJsonAsync<List<TabellaItem>>("/api/Tabelle/vernice") ?? new();
        _sabbiaTabelle  = sabbiaRaw;
        _verniceTabelle = verniceRaw;

        // Poi le entità EF (sequenziali per DbContext Scoped)
        _tipiSabbia  = await PreventivoService.GetTipiSabbiaAsync();
        _tipiVernice = await PreventivoService.GetTipiVerniceAsync();
        _preventivi  = await PreventivoService.GetAllAsync();
        _templates   = await PreventivoService.GetTemplatesAsync();
        var clienti  = await CommessaAppService.GetClienteNomiDistinctAsync();
        _clientiRagioni = clienti;
        _isLoading = false;
    }

    // ── Calcolo ─────────────────────────────────────────────────────────

    private void Ricalcola()
    {
        _dto.DataCreazione = _dataCreazione ?? DateTime.Today;
        _calc = PreventivoService.Calcola(_dto);
    }

    // Calcola per ogni lotto inserito (Lotto1 sempre, 2-4 se non null)
    private IEnumerable<(int Lotto, PreventivoCalcoloResult Calc)> LottiCalcolati
    {
        get
        {
            if (_dto.Lotto > 0 && _dto.Figure > 0 && _dto.PesoAnima > 0 && _dto.SpariOrari > 0)
            {
                yield return (_dto.Lotto, PreventivoService.CalcolaConLotto(_dto, _dto.Lotto, _dto.Margine1));
                if (_dto.Lotto2.HasValue && _dto.Lotto2 > 0)
                    yield return (_dto.Lotto2.Value, PreventivoService.CalcolaConLotto(_dto, _dto.Lotto2.Value, _dto.Margine2));
                if (_dto.Lotto3.HasValue && _dto.Lotto3 > 0)
                    yield return (_dto.Lotto3.Value, PreventivoService.CalcolaConLotto(_dto, _dto.Lotto3.Value, _dto.Margine3));
                if (_dto.Lotto4.HasValue && _dto.Lotto4 > 0)
                    yield return (_dto.Lotto4.Value, PreventivoService.CalcolaConLotto(_dto, _dto.Lotto4.Value, _dto.Margine4));
            }
        }
    }

    // ── Autocomplete clienti ─────────────────────────────────────────────

    private Task<IEnumerable<string>> CercaClienti(string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(_clientiRagioni.Take(20).AsEnumerable());

        var result = _clientiRagioni
            .Where(r => r.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Take(20);
        return Task.FromResult(result);
    }

    // ── Selezione sabbia/vernice ─────────────────────────────────────────

    private void OnSabbiaSelezionata()
    {
        if (_tipoSabbiaSelezionata == null) return;
        _dto.TipoSabbiaId   = _tipoSabbiaSelezionata.Id;
        _dto.SabbiaSnapshot = _tipoSabbiaSelezionata.Nome;
        _dto.EuroOraSabbia  = _tipoSabbiaSelezionata.EuroOra;
        _dto.PrezzoSabbiaKg = _tipoSabbiaSelezionata.PrezzoKg;
        _dto.SpariOrari     = _tipoSabbiaSelezionata.SpariDefault;
        Ricalcola();
    }

    private void OnVerniceSelezionata()
    {
        if (_tipoVerniceSelezionata == null) return;
        _dto.TipoVerniceId      = _tipoVerniceSelezionata.Id;
        _dto.VerniceSnapshot    = _tipoVerniceSelezionata.Nome;
        _dto.CostoVerniceKg     = _tipoVerniceSelezionata.PrezzoKg;
        _dto.PercentualeVernice = _tipoVerniceSelezionata.PercentualeApplicazione;
        Ricalcola();
    }

    // ── Form preventivo ──────────────────────────────────────────────────

