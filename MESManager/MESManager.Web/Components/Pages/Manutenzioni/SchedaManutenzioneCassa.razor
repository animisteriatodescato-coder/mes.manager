@page "/manutenzioni/casse/scheda/{SchedaId:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = MESManager.Web.Constants.PaginaPolicy.ManutenzioniCasse)]
@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@using MESManager.Domain.Enums
@using ImageMagick
@inject IManutenzioneCassaService ManutenzioneCassaService
@inject IManutenzioneCassaAllegatoService AllegatoService
@inject MESManager.Application.Services.CurrentUserService CurrentUserService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject IDialogService DialogService
@implements IDisposable

<PageTitle>Scheda Manutenzione Cassa</PageTitle>

@if (_loading)
{
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    </MudContainer>
}
else if (_scheda == null)
{
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
        <MudAlert Severity="Severity.Error">Scheda non trovata.</MudAlert>
        <MudButton OnClick="@(() => Nav.NavigateTo("/manutenzioni/casse"))" Class="mt-2">← Torna alle Casse</MudButton>
    </MudContainer>
}
else
{
    @* Input file nascosto: upload diretto HTTP fetch (bypassa SignalR — funziona su mobile) *@
    <input type="file" id="@_uploadInputId" multiple
           accept=".jpg,.jpeg,.png,.gif,.bmp,.webp,.heic,.heif,.pdf,.doc,.docx,.xls,.xlsx"
           style="display:none" />

    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4" data-testid="page-scheda-cassa">

        @* ── HEADER ──────────────────────────────────────────────── *@
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2" Wrap="Wrap.Wrap">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Outlined"
                           OnClick="@(() => Nav.NavigateTo("/manutenzioni/casse"))"
                           data-testid="btn-torna-casse" />
            <MudStack Spacing="0">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.h5">
                        Cassa <b>@_scheda.CodiceCassa</b>
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                        Rif. #@_scheda.CodiceRiferimento
                    </MudChip>
                </MudStack>
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @_scheda.DataEsecuzione.ToString("dddd dd MMMM yyyy")
                    </MudText>
                    @if (!string.IsNullOrEmpty(_scheda.NomeOperatore))
                    {
                        <MudText Typo="Typo.body2">· Operatore: <b>@_scheda.NomeOperatore</b></MudText>
                    }
                </MudStack>
            </MudStack>
            <MudSpacer />

            @* Badge stato *@
            @switch (_scheda.Stato)
            {
                case StatoSchedaManutenzione.InCompilazione:
                    <MudChip T="string" Color="Color.Warning" Icon="@Icons.Material.Filled.Edit">In Compilazione</MudChip>
                    break;
                case StatoSchedaManutenzione.Completata:
                    <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">
                        Completata il @_scheda.DataChiusura?.ToString("dd/MM/yyyy")
                    </MudChip>
                    break;
                case StatoSchedaManutenzione.ConAnomalie:
                    <MudChip T="string" Color="Color.Error" Icon="@Icons.Material.Filled.Warning">
                        Con Anomalie — @_scheda.DataChiusura?.ToString("dd/MM/yyyy")
                    </MudChip>
                    break;
            }

            @if (_scheda.Stato == StatoSchedaManutenzione.InCompilazione)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.CheckCircle"
                           OnClick="@ChiudiScheda" Disabled="@_saving"
                           data-testid="btn-chiudi-scheda-cassa">
                    @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Chiudi Scheda
                </MudButton>
            }

            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Print"
                       OnClick="@StampaScheda"
                       data-testid="btn-stampa-scheda-cassa">
                Stampa PDF
            </MudButton>
        </MudStack>

        @* ── NOTE ────────────────────────────────────────────────── *@
        @if (_scheda.Stato == StatoSchedaManutenzione.InCompilazione)
        {
            <MudTextField Value="@_scheda.Note"
                          ValueChanged="@((string? v) => OnNoteChanged(v))"
                          Label="Note generali scheda (opzionale)"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Lines="10"
                          AutoGrow="true" Class="mb-4"
                          data-testid="tf-note-cassa" />
        }
        else if (!string.IsNullOrEmpty(_scheda.Note))
        {
            <MudAlert Severity="Severity.Normal" Dense="true" Class="mb-4">Note: @_scheda.Note</MudAlert>
        }

        @* ── PROBLEMATICHE ─────────────────────────────────────────── *@
        <MudPaper Elevation="1" Class="pa-3 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
                <MudText Typo="Typo.subtitle1"><b>Problematiche</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Appaiono nel PDF · salvate nel DB</MudText>
                <MudSpacer />
                <MudIconButton Icon="@(_showProblematiche ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                               Size="Size.Small"
                               OnClick="@(() => _showProblematiche = !_showProblematiche)" />
            </MudStack>
            @if (_showProblematiche)
            {
                <MudStack Spacing="1">
                    @if (_problematiche.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Nessuna problematica aggiunta. Usa il pulsante per aggiungere voci che appariranno nel PDF.
                        </MudText>
                    }
                    @for (int i = 0; i < _problematiche.Count; i++)
                    {
                        var idx = i;
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:22px;text-align:right">@(idx+1).</MudText>
                            <MudTextField T="string" Value="@_problematiche[idx]"
                                          ValueChanged="@(async v => { _problematiche[idx] = v ?? ""; await SalvaProblematiche(); })"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          FullWidth="true" Lines="4"
                                          Style="font-size:14px"
                                          Placeholder="es. Sostituzione inserto porta maschio lato SX — pianificare entro 2 settimane" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(async () => { _problematiche.RemoveAt(idx); await SalvaProblematiche(); StateHasChanged(); })"
                                           Title="Rimuovi" />
                        </MudStack>
                    }
                    <MudStack Row="true" Spacing="2" Class="mt-2" Wrap="Wrap.Wrap">
                        <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="@(async () => { _problematiche.Add(""); await SalvaProblematiche(); StateHasChanged(); })">
                            Aggiungi problematica
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.AutoAwesome"
                                   OnClick="@AggiungiProblematicheComuni">
                            Suggerimenti tipici
                        </MudButton>
                    </MudStack>
                </MudStack>
            }
        </MudPaper>

        @* ── TABELLA ATTIVITÀ ──────────────────────────────────────── *@
        @if (!_scheda.Righe.Any())
        {
            <MudAlert Severity="Severity.Info">
                Nessuna attività configurata. Vai alle Impostazioni Manutenzioni per aggiungerne.
            </MudAlert>
        }
        else
        {
            <MudPaper Elevation="2" Class="pa-0">
                <MudTable Items="@_scheda.Righe" Dense="true" Hover="true" Striped="true"
                          data-testid="tbl-righe-scheda-cassa">
                    <HeaderContent>
                        <MudTh Style="width:40px">#</MudTh>
                        <MudTh>Attività</MudTh>
                        <MudTh Style="width:180px">Esito</MudTh>
                        <MudTh>Commento / Anomalia</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudText Typo="Typo.caption">@context.OrdineAttivita</MudText></MudTd>
                        <MudTd>
                            <MudText>@context.NomeAttivita</MudText>
                        </MudTd>
                        <MudTd>
                            @if (_scheda.Stato == StatoSchedaManutenzione.InCompilazione)
                            {
                                <MudSelect Value="@context.Esito"
                                           ValueChanged="@((EsitoAttivitaManutenzione v) => OnEsitoChanged(context, v))"
                                           Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                                           data-testid="@($"sel-esito-cassa-{context.Id}")">
                                    <MudSelectItem Value="EsitoAttivitaManutenzione.NonEseguita">
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                            <MudIcon Icon="@Icons.Material.Filled.Remove" Size="Size.Small" Color="Color.Default" />
                                            <span>Non Eseguita</span>
                                        </MudStack>
                                    </MudSelectItem>
                                    <MudSelectItem Value="EsitoAttivitaManutenzione.OK">
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                            <span>OK</span>
                                        </MudStack>
                                    </MudSelectItem>
                                    <MudSelectItem Value="EsitoAttivitaManutenzione.Anomalia">
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Color="Color.Error" />
                                            <span>Anomalia</span>
                                        </MudStack>
                                    </MudSelectItem>
                                </MudSelect>
                            }
                            else
                            {
                                @switch (context.Esito)
                                {
                                    case EsitoAttivitaManutenzione.OK:
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">OK</MudChip>
                                        break;
                                    case EsitoAttivitaManutenzione.Anomalia:
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Filled.Warning">Anomalia</MudChip>
                                        break;
                                    default:
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Remove">—</MudChip>
                                        break;
                                }
                            }
                        </MudTd>
                        <MudTd>
                            @if (_scheda.Stato == StatoSchedaManutenzione.InCompilazione)
                            {
                                <MudTextField Value="@context.Commento"
                                              ValueChanged="@((string? v) => OnCommentoChanged(context, v))"
                                              Placeholder="Descrivi il problema..."
                                              Variant="Variant.Outlined" Margin="Margin.Dense"
                                              data-testid="@($"tf-commento-cassa-{context.Id}")" />
                            }
                            else
                            {
                                <MudText Typo="Typo.body2">@(context.Commento ?? "—")</MudText>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }

        @* ── RIEPILOGO ──────────────────────────────────────────── *@
        <MudStack Row="true" Spacing="4" Class="mt-4">
            @{
                var totOk          = _scheda.Righe.Count(r => r.Esito == EsitoAttivitaManutenzione.OK);
                var totAnomalie    = _scheda.Righe.Count(r => r.Esito == EsitoAttivitaManutenzione.Anomalia);
                var totNonEseguite = _scheda.Righe.Count(r => r.Esito == EsitoAttivitaManutenzione.NonEseguita);
            }
            <MudPaper Class="pa-3" Elevation="1" Style="min-width:100px; text-align:center">
                <MudText Typo="Typo.h5" Color="Color.Success">@totOk</MudText>
                <MudText Typo="Typo.caption">OK</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="1" Style="min-width:100px; text-align:center">
                <MudText Typo="Typo.h5" Color="Color.Error">@totAnomalie</MudText>
                <MudText Typo="Typo.caption">Anomalie</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="1" Style="min-width:100px; text-align:center">
                <MudText Typo="Typo.h5" Color="Color.Default">@totNonEseguite</MudText>
                <MudText Typo="Typo.caption">Non Eseguite</MudText>
            </MudPaper>
        </MudStack>

        @* ── ALLEGATI ──────────────────────────────────────────── *@
        <MudPaper Elevation="1" Class="pa-3 mt-4" data-testid="sezione-allegati-cassa">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.AttachFile" Color="Color.Secondary" />
                <MudText Typo="Typo.subtitle1"><b>Allegati</b></MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Default">@((_allegati?.Totale ?? 0))</MudChip>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CloudUpload"
                           Disabled="@_uploadingAllegato"
                           Size="Size.Small"
                           OnClick="@ApriFilePickerAsync"
                           data-testid="upload-allegato-cassa">
                    @if (_uploadingAllegato) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                    Carica allegato
                </MudButton>
            </MudStack>

            @if (_loadingAllegati)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else if (_allegati == null || _allegati.Totale == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                    Nessun allegato. @(_scheda.Stato == StatoSchedaManutenzione.InCompilazione ? "Usa il pulsante Aggiungi per caricare foto o documenti." : "")
                </MudText>
            }
            else
            {
                @* Foto *@
                @if (_allegati.Foto.Any())
                {
                    <MudText Typo="Typo.caption" Color="Color.Primary" Class="mb-1"><b>FOTO (@_allegati.Foto.Count)</b></MudText>
                    <MudList T="ManutenzioneCassaAllegatoDto" Dense="true">
                        @foreach (var foto in _allegati.Foto)
                        {
                            <MudListItem>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="width:100%">
                                    <img src="@foto.UrlProxy"
                                         alt="@foto.NomeFile"
                                         style="width:52px;height:52px;object-fit:cover;border-radius:5px;border:1px solid rgba(0,0,0,0.12);flex-shrink:0;background:#e0e0e0"
                                         onerror="this.style.cssText='width:52px;height:52px;flex-shrink:0;filter:grayscale(1) opacity(0.4)'" />
                                    <MudStack Spacing="0" Style="flex:1;min-width:0">
                                        <MudText Typo="Typo.body2" Style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@foto.NomeFile</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatSize(foto.DimensioneBytes)</MudText>
                                    </MudStack>
                                    <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small"
                                                   OnClick="@(() => DownloadAllegato(foto))"
                                                   Title="Scarica" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                   OnClick="@(() => DeleteAllegato(foto))"
                                                   Title="Elimina" />
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                }
                @* Documenti *@
                @if (_allegati.Documenti.Any())
                {
                    <MudText Typo="Typo.caption" Color="Color.Warning" Class="mb-1 mt-2"><b>DOCUMENTI (@_allegati.Documenti.Count)</b></MudText>
                    <MudList T="ManutenzioneCassaAllegatoDto" Dense="true">
                        @foreach (var doc in _allegati.Documenti)
                        {
                            <MudListItem Icon="@GetDocIcon(doc.Estensione)" IconColor="Color.Default">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="width:100%">
                                    <MudText Typo="Typo.body2" Style="flex:1">@doc.NomeFile</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatSize(doc.DimensioneBytes)</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small"
                                                   OnClick="@(() => DownloadAllegato(doc))"
                                                   Title="Scarica" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                   OnClick="@(() => DeleteAllegato(doc))"
                                                   Title="Elimina" />
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                }
            }
        </MudPaper>

        @* ── CONDIZIONI GENERALI DI STAMPA ───────────────────────── *@
        <MudPaper Elevation="1" Class="pa-3 mt-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Gavel" Color="Color.Secondary" />
                <MudText Typo="Typo.subtitle1"><b>Condizioni Generali di Stampa</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Modificabili prima della stampa PDF · non salvate su DB</MudText>
                <MudSpacer />
                <MudButton Size="Size.Small" Variant="Variant.Outlined"
                           Color="@(_includiCondizioni ? Color.Error : Color.Success)"
                           StartIcon="@(_includiCondizioni ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                           OnClick="@(() => _includiCondizioni = !_includiCondizioni)"
                           Class="mr-2">
                    @(_includiCondizioni ? "Escludi dal PDF" : "Includi nel PDF")
                </MudButton>
                <MudIconButton Icon="@(_showCondizioni ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                               Size="Size.Small"
                               OnClick="@(() => _showCondizioni = !_showCondizioni)" />
            </MudStack>
            @if (_showCondizioni)
            {
                <MudStack Spacing="1">
                    @for (int i = 0; i < _condizioni.Count; i++)
                    {
                        var idx = i;
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:22px;text-align:right">@(idx+1).</MudText>
                            <MudTextField T="string" Value="@_condizioni[idx]"
                                          ValueChanged="@(v => _condizioni[idx] = v ?? "")"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          FullWidth="true" Lines="2"
                                          Style="font-size:12px" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => { _condizioni.RemoveAt(idx); StateHasChanged(); })"
                                           Title="Rimuovi" />
                        </MudStack>
                    }
                    <MudStack Row="true" Spacing="2" Class="mt-2">
                        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="@(() => { _condizioni.Add(""); StateHasChanged(); })">
                            Aggiungi condizione
                        </MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.RestartAlt"
                                   OnClick="@RipristinaCondizioni">
                            Ripristina default
                        </MudButton>
                    </MudStack>
                </MudStack>
            }
        </MudPaper>

    </MudContainer>
}

@code {
    [Parameter] public Guid SchedaId { get; set; }

    private bool _loading = true;
    private bool _saving;
    private ManutenzioneCassaSchedaDto? _scheda;

    // ── Condizioni generali di stampa (editabili pre-stampa) ─────────────────
    private bool _showCondizioni;
    private bool _includiCondizioni = false;

    // ── Problematiche da pianificare (editabili pre-stampa) ──────────────────
    private bool _showProblematiche = true;
    private List<string> _problematiche = new();

    private async Task AggiungiProblematicheComuni()
    {
        var suggerimenti = new[]
        {
            "Usura avanzata degli inserti — pianificare sostituzione entro il prossimo ciclo di manutenzione.",
            "Perdita di tenuta sulla cerniera — verificare guarnizioni e bulloneria di chiusura.",
            "Segni di erosione sulla camera di iniezione — valutare ripristino superficiale o sostituzione.",
            "Surriscaldamento localizzato rilevato — controllare circuito di raffreddamento e ugelli.",
            "Gioco eccessivo sui perni di centraggio — misurare tolleranze e pianificare rettifica o sostituzione.",
            "Incrostazioni di sabbia/resina nelle vie di sfiato — pulizia profonda programmata.",
            "Corrosione superficiale sulle guide — trattamento antiossidante e lubrificazione.",
            "Crepa rilevata sul corpo cassa — eseguire controllo non distruttivo (liquidi penetranti) e decidere su riparazione."
        };
        foreach (var s in suggerimenti)
            if (!_problematiche.Contains(s))
                _problematiche.Add(s);
        await SalvaProblematiche();
        StateHasChanged();
    }

    private List<string> _condizioni = new()    {
        "Le attività di manutenzione vengono eseguite da personale qualificato nel rispetto delle normative vigenti in materia di sicurezza sul lavoro (D.Lgs. 81/2008).",
        "La presente scheda costituisce documento ufficiale di avvenuta manutenzione e deve essere conservata agli atti per almeno 5 anni.",
        "Qualsiasi anomalia rilevata durante l\u2019intervento deve essere segnalata tempestivamente al responsabile di reparto e all\u2019ufficio tecnico prima di riprendere la produzione.",
        "La cassa deve essere rimessa in servizio esclusivamente a seguito di verifica con esito positivo da parte dell\u2019operatore responsabile. In caso di anomalie non risolte, la cassa non deve essere utilizzata.",
        "I materiali di consumo impiegati (lubrificanti, guarnizioni, prodotti chimici) devono essere conformi alle specifiche tecniche del fornitore della cassa e compatibili con il tipo di sabbia e resina utilizzati.",
        "Ogni sostituzione di componenti (inserti, piastre, perni) deve essere documentata indicando il codice del pezzo di ricambio e il fornitore, e registrata nel sistema gestionale aziendale.",
        "Le fotografie allegate hanno valore documentale e devono ritrarre fedelmente lo stato della cassa prima, durante e dopo l\u2019intervento; non è ammessa alterazione delle immagini.",
        "In caso di manutenzione straordinaria non pianificata, il responsabile di produzione deve approvare la scheda prima della rimessa in produzione della cassa.",
        "Il piano di manutenzione periodica può essere modificato solo dall\u2019ufficio tecnico sulla base dell\u2019andamento storico delle anomalie rilevate e delle indicazioni del costruttore dell\u2019attrezzatura.",
        "I dati contenuti in questa scheda sono riservati e ad uso interno; la diffusione a terzi è subordinata all\u2019autorizzazione della direzione aziendale.",
        "La firma di chiusura scheda attesta che l\u2019operatore ha eseguito tutte le attività previste con la diligenza richiesta e che le informazioni riportate sono veritiere e complete.",
        "Per le casse soggette a garanzia del costruttore, il mancato rispetto del piano di manutenzione programmata può invalidare la garanzia stessa; è responsabilità del manutentore verificarne i termini."
    };

    private void RipristinaCondizioni() => _condizioni = new()
    {
