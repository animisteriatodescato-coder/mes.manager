    // Allegati
    private AllegatiManutenzioneCassaResponse? _allegati;
    private bool _loadingAllegati;
    private bool _uploadingAllegato;
    private string _uploadInputId => $"upload-cassa-{SchedaId:N}";
    private DotNetObjectReference<SchedaManutenzioneCassa>? _dotnetRef;

    protected override async Task OnInitializedAsync()
    {
        _scheda = await ManutenzioneCassaService.GetSchedaByIdAsync(SchedaId);

        // Se la scheda è ancora InCompilazione, aggiorna l'operatore con l'utente che la sta aprendo
        if (_scheda != null && _scheda.Stato == Domain.Enums.StatoSchedaManutenzione.InCompilazione
            && CurrentUserService.HasUser)
        {
            _scheda = await ManutenzioneCassaService.GetOrCreateSchedaAsync(
                _scheda.CodiceCassa,
                _scheda.DataEsecuzione,
                CurrentUserService.UserId,
                CurrentUserService.UserName);
        }

        _loading = false;
        if (_scheda != null)
        {
            _problematiche = _scheda.Problematiche.Count > 0 ? new(_scheda.Problematiche) : new();
            await CaricaAllegatiAsync();
        }
    }

    private async Task CaricaAllegatiAsync()
    {
        _loadingAllegati = true;
        _allegati = await AllegatoService.GetAllegatiBySchedaAsync(SchedaId);
        _loadingAllegati = false;
    }

    private async Task OnEsitoChanged(ManutenzioneCassaRigaDto riga, EsitoAttivitaManutenzione newEsito)
    {
        riga.Esito = newEsito;
        _scheda = await ManutenzioneCassaService.UpdateRigaAsync(_scheda!.Id, riga);
    }

    private async Task OnCommentoChanged(ManutenzioneCassaRigaDto riga, string? newCommento)
    {
        riga.Commento = newCommento;
        _scheda = await ManutenzioneCassaService.UpdateRigaAsync(_scheda!.Id, riga);
    }

    private async Task OnNoteChanged(string? note)
    {
        if (_scheda == null) return;
        _scheda.Note = note;
        await ManutenzioneCassaService.SaveNoteAsync(_scheda.Id, note);
    }

    private async Task SalvaProblematiche()
    {
        if (_scheda == null) return;
        await ManutenzioneCassaService.SaveProblematicheAsync(_scheda.Id, _problematiche);
    }

    private async Task ChiudiScheda()
    {
        _saving = true;
        _scheda = await ManutenzioneCassaService.ChiudiSchedaAsync(_scheda!.Id);
        _saving = false;
        Snackbar.Add("Scheda chiusa con successo.", Severity.Success);
    }

    // ── Allegati ─────────────────────────────────────────────────────────────

    private async Task ApriFilePickerAsync()
    {
        if (_uploadingAllegato) return;
        _dotnetRef ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("cassaAllegatoUpload.openAndUpload", _uploadInputId, SchedaId, _dotnetRef);
    }

    [Microsoft.JSInterop.JSInvokable]
    public void OnUploadStarted()
    {
        _uploadingAllegato = true;
        StateHasChanged();
    }

    [Microsoft.JSInterop.JSInvokable]
    public async Task OnUploadComplete(List<UploadResult> results)
    {
        _uploadingAllegato = false;
        foreach (var r in results)
        {
            if (r.Success)
                Snackbar.Add($"'{r.Name}' caricato ({FormatSize(r.Size)}).", Severity.Success);
            else
                Snackbar.Add($"Errore '{r.Name}': {r.Error}",
                    Severity.Error, c => c.VisibleStateDuration = 8000);
        }
        if (results.Any(r => r.Success))
            await CaricaAllegatiAsync();
        StateHasChanged();
    }

    public class UploadResult
    {
        public string Name { get; set; } = "";
        public bool Success { get; set; }
        public long Size { get; set; }
        public string? Error { get; set; }
    }

    private async Task DeleteAllegato(ManutenzioneCassaAllegatoDto allegato)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Elimina allegato",
            $"Eliminare '{allegato.NomeFile}'? L'operazione non è reversibile.",
            yesText: "Elimina", cancelText: "Annulla");
        if (confirm != true) return;

        await AllegatoService.DeleteAsync(allegato.Id);
        Snackbar.Add($"'{allegato.NomeFile}' eliminato.", Severity.Info);
        await CaricaAllegatiAsync();
    }

    private async Task DownloadAllegato(ManutenzioneCassaAllegatoDto allegato)
    {
        await JS.InvokeVoidAsync("window.open", allegato.UrlProxy, "_blank");
    }

    // ── Stampa PDF ────────────────────────────────────────────────────────────

    private async Task StampaScheda()
    {
        if (_scheda == null) return;
        var tuttiAllegati = _allegati == null ? new List<ManutenzioneCassaAllegatoDto>() :
            _allegati.Foto.Concat(_allegati.Documenti).ToList();

        // Pre-carica le foto da disco (C# → nessun problema auth popup)
        // Per ogni foto: tenta Magick.NET per HEIC, fallback bytes originali, poi JS fetch come ultima risorsa
        var fotoBase64 = new Dictionary<int, string>();
        var fotoOk = 0;

        foreach (var f in tuttiAllegati.Where(a => a.IsFoto))
        {
            try
            {
                var content = await AllegatoService.GetFileContentAsync(f.Id);
                if (content != null)
                {
                    var bytes = content.Value.Content;
                    var mime = "image/jpeg";
                    var ext = System.IO.Path.GetExtension(content.Value.FileName).ToLowerInvariant();

                    if (ext == ".heic" || ext == ".heif")
                    {
                        try
                        {
                            // Prova conversione Magick.NET → JPEG (HEIC codec nativo)
                            using var magick = new MagickImage(bytes);
                            magick.Quality = 82;
                            magick.Format = MagickFormat.Jpeg;
                            bytes = magick.ToByteArray();
                            // mime rimane "image/jpeg"
                        }
                        catch
                        {
                            // Magick.NET non supporta HEIC su questo server
                            // Lascia bytes originali + mime jpeg: mesStampaCassa farà fetch via API
                            // (il controller proverà di nuovo e servirà JPEG o il raw)
                        }
                    }
                    else if (ext == ".png")  mime = "image/png";
                    else if (ext == ".gif")  mime = "image/gif";
                    else if (ext == ".webp") mime = "image/webp";

                    fotoBase64[f.Id] = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
                    fotoOk++;
                }
                // Se content == null (file non su disco): fotoBase64 non viene popolato
                // → mesStampaCassa farà fetch autenticato tramite API
            }
            catch { /* Eccezione inattesa: JS fetch come fallback */ }
        }

        var totaleFoto = tuttiAllegati.Count(a => a.IsFoto);
        if (totaleFoto > 0)
        {
            var msg = fotoOk == totaleFoto
                ? $"{fotoOk} foto precaricate (embed)"
                : fotoOk > 0
                    ? $"{fotoOk}/{totaleFoto} foto precaricate · {totaleFoto - fotoOk} caricate via API"
                    : $"Foto caricate via API ({totaleFoto})";
            Snackbar.Add(msg, fotoOk == totaleFoto ? Severity.Success : Severity.Info);
        }

        var azienda = Env.ApplicationName;
        var logo = LeggiLogoInline();
        var html = SchedaManutenzioneCassaPrintBuilder.Build(
            _scheda, tuttiAllegati, azienda, logo,
            fotoBase64: fotoBase64.Count > 0 ? fotoBase64 : null,
            problematiche: _problematiche.Count > 0 ? _problematiche : null,
            condizioni: _includiCondizioni ? _condizioni : null);

        // mesStampaCassa: triplice strategia
        //   1. data-URI già embed da C# → usati direttamente
        //   2. UrlProxy rimaste → fetch con credentials dal contesto pagina (cookie validi)
        //   3. Fetch fallita → placeholder testo nel PDF
        await JS.InvokeVoidAsync("mesStampaCassa", html);
    }

    private string? LeggiLogoInline()
    {
        try
        {
            var pngPath = System.IO.Path.Combine(Env.WebRootPath, "images", "logo-intestazione.png");
            if (System.IO.File.Exists(pngPath))
            {
                var b64 = Convert.ToBase64String(System.IO.File.ReadAllBytes(pngPath));
                return $"<img src=\"data:image/png;base64,{b64}\" style=\"max-height:77px;width:auto;display:block\" alt=\"{System.Web.HttpUtility.HtmlEncode(Env.ApplicationName)}\" />";
            }
            var svgPath = System.IO.Path.Combine(Env.WebRootPath, "images", "logo-intestazione.svg");
            if (System.IO.File.Exists(svgPath))
            {
                var svgContent = System.IO.File.ReadAllText(svgPath);
                if (svgContent.StartsWith("<?xml"))
                    svgContent = svgContent.Substring(svgContent.IndexOf("?>") + 2).TrimStart();
                return svgContent;
            }
        }
        catch { }
        return null;
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static string FormatSize(long bytes) =>
        bytes >= 1024 * 1024 ? $"{bytes / 1024.0 / 1024.0:N1} MB" : $"{bytes / 1024.0:N0} KB";

    private static string GetDocIcon(string ext) => ext.ToLowerInvariant() switch
    {
        ".pdf"           => Icons.Material.Filled.PictureAsPdf,
        ".doc" or ".docx" => Icons.Material.Filled.Description,
        ".xls" or ".xlsx" => Icons.Material.Filled.TableChart,
        _                => Icons.Material.Filled.InsertDriveFile
    };

    public void Dispose()
    {
        _dotnetRef?.Dispose();
    }
}
