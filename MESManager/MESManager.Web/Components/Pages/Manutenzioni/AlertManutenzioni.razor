@page "/manutenzioni/alert"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = MESManager.Web.Constants.PaginaPolicy.ManutenzioniAlert)]

<PageTitle>Alert Manutenzioni</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4" data-testid="page-alert-manutenzioni">
    <MudPaper Elevation="1" Class="pa-4">
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            Nessuna manutenzione in scadenza
        </MudAlert>
        <MudText>Pagina predisposta per alert manutenzioni programmate</MudText>
    </MudPaper>
</MudContainer>
