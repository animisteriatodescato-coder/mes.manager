@page "/manutenzioni/griglia"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = MESManager.Web.Constants.PaginaPolicy.ManutenzioniGriglia)]
@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@using MESManager.Application.Services
@using MESManager.Domain.Enums
@inject IManutenzioneService ManutenzioneService
@inject IMacchinaAppService MacchinaService
@inject CurrentUserService CurrentUserService
@inject ISnackbar Snackbar

<PageTitle>Manutenzione Giornaliera</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4 px-3" data-testid="page-griglia-manutenzione">
<MudPaper Elevation="1" Class="pa-3">

    @* ── TOOLBAR ─────────────────────────────────────────────── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2" Wrap="Wrap.Wrap">

        <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Secondary" />
        <MudText Typo="Typo.h6" Class="me-3">Manutenzione Giornaliera</MudText>

        @* Toggle frequenza *@
        <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
            <MudButton Color="@(_tipo == TipoFrequenzaManutenzione.Settimanale ? Color.Primary : Color.Default)"
                       Variant="@(_tipo == TipoFrequenzaManutenzione.Settimanale ? Variant.Filled : Variant.Outlined)"
                       OnClick="@(() => CambiaFrequenza(TipoFrequenzaManutenzione.Settimanale))">
                Settimanale
            </MudButton>
            <MudButton Color="@(_tipo == TipoFrequenzaManutenzione.Mensile ? Color.Secondary : Color.Default)"
                       Variant="@(_tipo == TipoFrequenzaManutenzione.Mensile ? Variant.Filled : Variant.Outlined)"
                       OnClick="@(() => CambiaFrequenza(TipoFrequenzaManutenzione.Mensile))">
                Mensile
            </MudButton>
        </MudButtonGroup>

        @* Data *@
        <MudDatePicker @bind-Date="_dataGiornata"
                       @bind-Date:after="@OnDataChangedAfter"
                       Label="Data"
                       DateFormat="dd/MM/yyyy"
                       Editable="true"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       PickerVariant="PickerVariant.Dialog"
                       Style="max-width:180px"
                       data-testid="dp-data-griglia" />

        @* Operatore (read-only, da login) *@
        <MudChip T="string" Icon="@Icons.Material.Filled.Person"
                 Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Medium">
            @CurrentUserService.UserName
        </MudChip>

        <MudSpacer />

        @* Statistica globale *@
        @{
            var totCelle = _macchine.Count * _attivita.Count;
            var okCelle = _schedeMap.Values.Where(s => s != null)
                .SelectMany(s => s!.Righe)
                .Count(r => r.Esito == EsitoAttivitaManutenzione.OK);
        }
        @if (totCelle > 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Default">
                @okCelle / @totCelle completate
            </MudText>
            <MudProgressLinear Value="@(100.0 * okCelle / totCelle)"
                               Color="@(okCelle == totCelle ? Color.Success : Color.Primary)"
                               Rounded="true" Size="Size.Small" Style="width:120px" />
        }
    </MudStack>

    @* ── GRIGLIA MATRICIALE ──────────────────────────────────── *@
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
    }
    else if (!_attivita.Any())
    {
        <MudAlert Severity="Severity.Info">Nessuna attività configurata per questo tipo. Vai al Catalogo per aggiungerne.</MudAlert>
    }
    else
    {
        <div style="overflow-x:auto;">
            <table class="mes-mant-grid" data-testid="griglia-manutenzione">
                <thead>
                    <tr>
                        <th class="mes-mant-th-mac">Macchina</th>
                        @foreach (var att in _attivita)
                        {
                            <th class="mes-mant-th-att" title="@att.Nome">
                                <span class="mes-mant-att-label" style="font-size:@(att.FontSize > 0 ? att.FontSize : 11)px">@att.Nome</span>
                                <button class="mes-mant-btn-selall"
                                        title="Seleziona tutti OK — @att.Nome"
                                        @onclick="@(() => SelezionaTuttiOkAsync(att))"
                                        disabled="@_saving">
                                    ✅ tutti
                                </button>
                            </th>
                        }
                        <th class="mes-mant-th-prog">Avanzamento</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mac in _macchine)
                    {
                        var scheda = _schedeMap.TryGetValue(mac.Id, out var s) ? s : null;
                        var chiusa = scheda?.Stato == StatoSchedaManutenzione.Completata || scheda?.Stato == StatoSchedaManutenzione.ConAnomalie;

                        @* Conteggio per progress bar *@
                        var righeOk     = scheda?.Righe.Count(r => r.Esito == EsitoAttivitaManutenzione.OK) ?? 0;
                        var righeAnom   = scheda?.Righe.Count(r => r.Esito == EsitoAttivitaManutenzione.Anomalia) ?? 0;
                        var righeNE     = _attivita.Count - righeOk - righeAnom;
                        var progPct     = _attivita.Count > 0 ? (double)(righeOk + righeAnom) / _attivita.Count * 100 : 0;

                        <tr class="@(chiusa ? "mes-mant-row-closed" : "")">
                            @* Colonna macchina *@
                            <td class="mes-mant-td-mac">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.PrecisionManufacturing"
                                             Size="Size.Small" Color="Color.Default" />
                                    <span><b>@mac.Codice</b><br /><span style="font-size:11px;opacity:.75">@mac.Nome</span></span>
                                </MudStack>
                            </td>

                            @* Colonne attività *@
                            @foreach (var att in _attivita)
                            {
                                var riga = scheda?.Righe.FirstOrDefault(r => r.AttivitaId == att.Id);
                                var esito = riga?.Esito ?? EsitoAttivitaManutenzione.NonEseguita;
                                var isEditingComment = _commentEditingRigaId == riga?.Id;

                                <td class="mes-mant-td-cell @GetCellClass(esito)"
                                    data-testid="cell-@mac.Id-@att.Id">
                                    @if (!chiusa)
                                    {
                                        <div class="mes-mant-cell-inner">
                                            @* Due pulsanti grandi sempre visibili *@
                                            <div class="mes-mant-btn-row">
                                                <button class="mes-mant-btn-ok @(esito == EsitoAttivitaManutenzione.OK ? "mes-mant-btn-active-ok" : "")"
                                                        title="OK"
                                                        @onclick="@(() => ImpostaEsito(mac.Id, att, EsitoAttivitaManutenzione.OK))"
                                                        disabled="@_saving">
                                                    ✅
                                                </button>
                                                <button class="mes-mant-btn-anom @(esito == EsitoAttivitaManutenzione.Anomalia ? "mes-mant-btn-active-anom" : "")"
                                                        title="Anomalia"
                                                        @onclick="@(() => ImpostaEsito(mac.Id, att, EsitoAttivitaManutenzione.Anomalia))"
                                                        disabled="@_saving">
                                                    ⚠️
                                                </button>
                                            </div>

                                            @* Commento anomalia — sempre visibile se presente, editabile *@
                                            @if (esito == EsitoAttivitaManutenzione.Anomalia)
                                            {
                                                @if (isEditingComment)
                                                {
                                                    <div class="mes-mant-comment-box" @onclick:stopPropagation>
                                                        @* Dropdown anomalie standard *@
                                                        @if (_anomalieStandard.Any())
                                                        {
                                                            <MudSelect T="string" Value="@_commentDraft"
                                                                       ValueChanged="@((v) => { _commentDraft = v; })"
                                                                       Placeholder="Scegli anomalia..."
                                                                       Variant="Variant.Outlined" Margin="Margin.Dense"
                                                                       Dense="true"
                                                                       Class="mb-1"
                                                                       Style="font-size:11px">
                                                                <MudSelectItem T="string" Value="@("")">— libero —</MudSelectItem>
                                                                @foreach (var anom in _anomalieStandard)
                                                                {
                                                                    <MudSelectItem T="string" Value="@anom.Testo">@anom.Testo</MudSelectItem>
                                                                }
                                                            </MudSelect>
                                                        }
                                                        @{ var txtCommentoId = $"txt-commento-{riga!.Id}"; }
                                                        <MudTextField @bind-Value="_commentDraft"
                                                                      Placeholder="Descrivi l'anomalia..."
                                                                      Variant="Variant.Outlined"
                                                                      Margin="Margin.Dense"
                                                                      Lines="2"
                                                                      Style="font-size:11px"
                                                                      data-testid="@txtCommentoId" />
                                                        <MudStack Row="true" Spacing="1" Class="mt-1" Justify="Justify.FlexEnd">
                                                            <MudButton Size="Size.Small" Variant="Variant.Text"
                                                                       OnClick="@(() => AnnullaCommento())">Ann.</MudButton>
                                                            <MudButton Size="Size.Small" Variant="Variant.Filled"
                                                                       Color="Color.Warning"
                                                                       OnClick="@(() => SalvaCommento(scheda!.Id, riga!))"
                                                                       data-testid="btn-salva-commento">Salva</MudButton>
                                                        </MudStack>
                                                    </div>
                                                }
                                                else
                                                {
                                                    @* Commento salvato sempre visibile — click per editare *@
                                                    <div class="mes-mant-comment-saved"
                                                         @onclick="@(() => ApriCommento(riga))"
                                                         title="Click per modificare il commento">
                                                        @if (!string.IsNullOrEmpty(riga?.Commento))
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Filled.Comment"
                                                                     Size="Size.Small" Color="Color.Warning" Class="me-1" />
                                                            <span class="mes-mant-comment-text">@riga.Commento</span>
                                                        }
                                                        else
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Outlined.AddComment"
                                                                     Size="Size.Small" Color="Color.Default" Style="opacity:.5" />
                                                            <span class="mes-mant-comment-empty">aggiungi nota...</span>
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        @* Readonly quando scheda chiusa *@
                                        <div class="mes-mant-cell-inner" style="cursor:default">
                                            @if (esito == EsitoAttivitaManutenzione.OK)        { <span class="mes-mant-icon-lg">✅</span> }
                                            else if (esito == EsitoAttivitaManutenzione.Anomalia)
                                            {
                                                <span class="mes-mant-icon-lg">⚠️</span>
                                                @if (!string.IsNullOrEmpty(riga?.Commento))
                                                {
                                                    <div class="mes-mant-comment-saved mes-mant-comment-readonly">
                                                        <span class="mes-mant-comment-text">@riga.Commento</span>
                                                    </div>
                                                }
                                            }
                                            else { <span class="mes-mant-empty">—</span> }
                                        </div>
                                    }
                                </td>
                            }

                            @* Colonna avanzamento *@
                            <td class="mes-mant-td-prog">
                                <MudStack AlignItems="AlignItems.Center" Spacing="0">
                                    <MudProgressCircular Value="@progPct"
                                                         Size="Size.Small"
                                                         Color="@(righeAnom > 0 ? Color.Error : (righeOk == _attivita.Count ? Color.Success : Color.Default))" />
                                    <MudText Typo="Typo.caption">@(righeOk + righeAnom)/@_attivita.Count</MudText>
                                    @if (chiusa)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Lock"
                                                 Size="Size.Small" Color="Color.Default" Style="opacity:.5" />
                                    }
                                    else if (scheda != null && (righeOk + righeAnom) == _attivita.Count)
                                    {
                                        @* Tutte compilate: mostra pulsante Chiudi *@
                                        <MudTooltip Text="Chiudi scheda macchina">
                                            @{ var btnChiudiId = $"btn-chiudi-{mac.Id}"; }
                                            <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                                           Color="Color.Success" Size="Size.Small"
                                                           OnClick="@(() => ChiudiScheda(scheda.Id))"
                                                           data-testid="@btnChiudiId" />
                                        </MudTooltip>
                                    }
                                </MudStack>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* ── LEGENDA ──────────────────────────────────────────── *@
        <MudStack Row="true" Spacing="3" Class="mt-3" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.caption" Color="Color.Tertiary">Legenda:</MudText>
            <span class="mes-mant-leg-ok">✅ OK</span>
            <span class="mes-mant-leg-anom">⚠️ Anomalia</span>
            <span class="mes-mant-leg-ne">— Non eseguita</span>
            <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="ms-3">
                * click sulla cella per cambiare stato · ⚠️ click sull'icona commento per annotare
            </MudText>
        </MudStack>
    }

</MudPaper>
</MudContainer>

@code {
    // ── Stato pagina ──────────────────────────────────────────
    private TipoFrequenzaManutenzione _tipo  = TipoFrequenzaManutenzione.Settimanale;
    private DateTime? _dataGiornata          = DateTime.Today;

    private List<MacchinaDto>              _macchine  = new();
    private List<ManutenzioneAttivitaDto>  _attivita  = new();
    private List<AnomaliaStandardDto>      _anomalieStandard = new();
    // macchinaId → scheda (null = non ancora creata per questa macchina in questo giorno)
    private Dictionary<Guid, ManutenzioneSchedaDto?> _schedeMap = new();

    private bool  _loading = true;
    private bool  _saving  = false;

    // Commento inline
    private Guid?  _commentEditingRigaId;
    private string _commentDraft = string.Empty;

    // ── Init ──────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await CaricaDati();
    }

    private async Task CaricaDati()
    {
        _loading = true;
        StateHasChanged();

        // ⚠️ EF Core Scoped DbContext: NON parallelizzare query sullo stesso context
        _macchine = (await MacchinaService.GetListaAsync())
            .OrderBy(m => m.OrdineVisualizazione).ThenBy(m => m.Codice).ToList();
        _attivita = await ManutenzioneService.GetAttivitaAsync(_tipo);
        _anomalieStandard = await ManutenzioneService.GetAnomalieStandardAsync();

        await CaricaSchedeGiorno();
        _loading = false;
    }

    private async Task CaricaSchedeGiorno()
    {
        var data = _dataGiornata ?? DateTime.Today;
        var schede = await ManutenzioneService.GetSchedeAsync(
            tipo: _tipo,
            dal: data.Date,
            al:  data.Date.AddDays(1).AddTicks(-1));

        _schedeMap = _macchine.ToDictionary(
            m => m.Id,
            m => (ManutenzioneSchedaDto?)schede.FirstOrDefault(s => s.MacchinaId == m.Id));
    }

    // ── Cambio frequenza / data ───────────────────────────────
    private async Task CambiaFrequenza(TipoFrequenzaManutenzione tipo)
    {
        if (_tipo == tipo) return;
        _tipo = tipo;
        await CaricaDati();
    }

    private async Task OnDataChangedAfter()
    {
        _loading = true;
        StateHasChanged();
        await CaricaSchedeGiorno();
        _loading = false;
    }

    // method kept for internal use (CambiaFrequenza calls CaricaDati which reloads everything)
    private async Task OnDataChanged(DateTime? nuovaData)
    {
        _dataGiornata = nuovaData;
        _loading = true;
        StateHasChanged();
        await CaricaSchedeGiorno();
        _loading = false;
    }

    // ── Imposta esito diretto (nuovo: 2 pulsanti separati) ────
    /// <summary>Click su pulsante OK o Anomalia: imposta direttamente l'esito desiderato.
    /// Se si clicca sul pulsante già attivo, torna a NonEseguita (toggle off).</summary>
    private async Task ImpostaEsito(Guid macchinaId, ManutenzioneAttivitaDto att, EsitoAttivitaManutenzione nuovoEsito)
    {
        if (_saving) return;
        _saving = true;

        try
        {
            if (_schedeMap[macchinaId] == null)
            {
                var data = _dataGiornata ?? DateTime.Today;
                _schedeMap[macchinaId] = await ManutenzioneService.GetOrCreateSchedaAsync(
                    macchinaId, _tipo, data,
                    CurrentUserService.UserId,
                    CurrentUserService.UserName);
            }

            var scheda = _schedeMap[macchinaId]!;
            var riga   = scheda.Righe.FirstOrDefault(r => r.AttivitaId == att.Id);
            if (riga == null) return;

            // Toggle: se clicco lo stesso esito attivo → torna a NonEseguita
            riga.Esito = (riga.Esito == nuovoEsito)
                ? EsitoAttivitaManutenzione.NonEseguita
                : nuovoEsito;

            // Se diventa Anomalia → apri campo commento
            if (riga.Esito == EsitoAttivitaManutenzione.Anomalia)
            {
                _commentEditingRigaId = riga.Id;
                _commentDraft = riga.Commento ?? string.Empty;
            }
            else
            {
                if (_commentEditingRigaId == riga.Id)
                    AnnullaCommento();
                if (riga.Esito != EsitoAttivitaManutenzione.Anomalia)
                    riga.Commento = null;
            }

            var updated = await ManutenzioneService.UpdateRigaAsync(scheda.Id, riga);
            if (updated != null)
                _schedeMap[macchinaId] = updated;
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    // ── Commenti anomalia ─────────────────────────────────────
    private void ApriCommento(ManutenzioneRigaDto? riga)
    {
        if (riga == null) return;
        _commentEditingRigaId = riga.Id;
        _commentDraft = riga.Commento ?? string.Empty;
    }

    private void AnnullaCommento()
    {
        _commentEditingRigaId = null;
        _commentDraft = string.Empty;
    }

    private async Task SalvaCommento(Guid schedaId, ManutenzioneRigaDto riga)
    {
        riga.Commento = _commentDraft.Trim();
        var updated = await ManutenzioneService.UpdateRigaAsync(schedaId, riga);

        var macchinaId = _schedeMap.FirstOrDefault(kv => kv.Value?.Id == schedaId).Key;
        if (macchinaId != Guid.Empty && updated != null)
            _schedeMap[macchinaId] = updated;

        AnnullaCommento();
        Snackbar.Add("Commento salvato", Severity.Success);
    }

    // ── Chiudi scheda singola macchina ───────────────────────
    private async Task ChiudiScheda(Guid schedaId)
    {
        var closed = await ManutenzioneService.ChiudiSchedaAsync(schedaId);
        if (closed != null)
        {
            var macchinaId = _schedeMap.FirstOrDefault(kv => kv.Value?.Id == schedaId).Key;
            if (macchinaId != Guid.Empty)
                _schedeMap[macchinaId] = closed;
        }
        Snackbar.Add("Scheda chiusa", Severity.Success);
        StateHasChanged();
    }

    // ── Seleziona tutti OK per colonna ───────────────────────
    private async Task SelezionaTuttiOkAsync(ManutenzioneAttivitaDto att)
    {
        if (_saving) return;
        _saving = true;
        try
        {
            var data = _dataGiornata ?? DateTime.Today;
            foreach (var mac in _macchine)
            {
                var scheda = _schedeMap.TryGetValue(mac.Id, out var s) ? s : null;
                var chiusa = scheda?.Stato == StatoSchedaManutenzione.Completata
                          || scheda?.Stato == StatoSchedaManutenzione.ConAnomalie;
                if (chiusa) continue;

                if (_schedeMap[mac.Id] == null)
                {
                    _schedeMap[mac.Id] = await ManutenzioneService.GetOrCreateSchedaAsync(
                        mac.Id, _tipo, data,
                        CurrentUserService.UserId,
                        CurrentUserService.UserName);
                }

                scheda = _schedeMap[mac.Id]!;
                var riga = scheda.Righe.FirstOrDefault(r => r.AttivitaId == att.Id);
                if (riga == null || riga.Esito == EsitoAttivitaManutenzione.OK) continue;

                riga.Esito = EsitoAttivitaManutenzione.OK;
                if (_commentEditingRigaId == riga.Id)
                    AnnullaCommento();
                riga.Commento = null;

                var updated = await ManutenzioneService.UpdateRigaAsync(scheda.Id, riga);
                if (updated != null)
                    _schedeMap[mac.Id] = updated;
            }
            Snackbar.Add($"Tutti OK per «{att.Nome}»", Severity.Success);
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    // ── Helpers UI ────────────────────────────────────────────
    private static string GetCellClass(EsitoAttivitaManutenzione esito) => esito switch
    {
        EsitoAttivitaManutenzione.OK       => "mes-mant-cell-ok",
        EsitoAttivitaManutenzione.Anomalia => "mes-mant-cell-anom",
        _                                  => "mes-mant-cell-ne"
    };

    private static string GetEsitoLabel(EsitoAttivitaManutenzione esito) => esito switch
    {
        EsitoAttivitaManutenzione.OK       => "OK",
        EsitoAttivitaManutenzione.Anomalia => "Anomalia",
        _                                  => "Non eseguita"
    };
}
