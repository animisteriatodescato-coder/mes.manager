@page "/impostazioni/issue-log"
@using MESManager.Application.Interfaces
@using MESManager.Domain.Entities
@using MESManager.Domain.Enums
@inject ITechnicalIssueService IssueService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Issue Log - Archivio Bug & Errori</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.BugReport" Class="mr-2" />
    Archivio Bug & Errori
</MudText>

@* Filtri *@
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudGrid>
        <MudItem xs="12" sm="6" md="2">
            <MudSelect T="IssueStatus?" Label="Stato" @bind-Value="_filterStatus" 
                       Variant="Variant.Outlined" Clearable="true" Dense="true">
                @foreach (var s in Enum.GetValues<IssueStatus>())
                {
                    <MudSelectItem Value="@((IssueStatus?)s)">@s</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudSelect T="IssueArea?" Label="Area" @bind-Value="_filterArea" 
                       Variant="Variant.Outlined" Clearable="true" Dense="true">
                @foreach (var a in Enum.GetValues<IssueArea>())
                {
                    <MudSelectItem Value="@((IssueArea?)a)">@a</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudSelect T="IssueSeverity?" Label="Gravità" @bind-Value="_filterSeverity" 
                       Variant="Variant.Outlined" Clearable="true" Dense="true">
                @foreach (var sv in Enum.GetValues<IssueSeverity>())
                {
                    <MudSelectItem Value="@((IssueSeverity?)sv)">@sv</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudSelect T="IssueEnvironment?" Label="Ambiente" @bind-Value="_filterEnvironment" 
                       Variant="Variant.Outlined" Clearable="true" Dense="true">
                @foreach (var e in Enum.GetValues<IssueEnvironment>())
                {
                    <MudSelectItem Value="@((IssueEnvironment?)e)">@e</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudTextField @bind-Value="_searchTitle" Label="Cerca titolo" 
                          Variant="Variant.Outlined" Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Search" Dense="true" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2" Class="d-flex align-end gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                       StartIcon="@Icons.Material.Filled.FilterAlt"
                       OnClick="ApplicaFiltri">Filtra</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                       OnClick="ResetFiltri">Reset</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@* Barra superiore: pulsante Nuovo Issue + toggle Auto/Manuale *@
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="3">
    <MudButton Variant="Variant.Filled" Color="Color.Success"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => Navigation.NavigateTo("/impostazioni/issue-log/new"))">
        Nuovo Issue
    </MudButton>

    <MudToggleGroup T="string" @bind-Value="_filterAutoCapture" Color="Color.Primary"
                    SelectionMode="SelectionMode.SingleSelection" Dense="true">
        <MudToggleItem Value="@("tutti")" Text="Tutti" />
        <MudToggleItem Value="@("auto")">
            <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" Class="mr-1" />Auto
            @if (_autoOpenCount > 0)
            {
                <MudBadge Content="@_autoOpenCount" Color="Color.Error" Class="ml-1" />
            }
        </MudToggleItem>
        <MudToggleItem Value="@("manuale")" Text="Manuali" />
    </MudToggleGroup>
</MudStack>

@* Tabella Issues *@
<MudTable Items="@IssuesFiltrati" Hover="true" Dense="true" Striped="true" Elevation="2"
          OnRowClick="@((TableRowClickEventArgs<TechnicalIssue> args) => { if (args.Item != null) GoToDetail(args.Item); })"
          T="TechnicalIssue" Style="cursor: pointer;">
    <HeaderContent>
        <MudTh Style="width: 30px;"></MudTh>
        <MudTh Style="width: 120px;">Data</MudTh>
        <MudTh Style="width: 100px;">Stato</MudTh>
        <MudTh Style="width: 80px;">Gravità</MudTh>
        <MudTh Style="width: 70px;">Ambiente</MudTh>
        <MudTh Style="width: 100px;">Area</MudTh>
        <MudTh>Titolo</MudTh>
        <MudTh Style="width: 120px;">Docs</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>
            @if (context.IsAutoCapture)
            {
                <MudTooltip Text="Catturato automaticamente">
                    <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" Color="Color.Default" />
                </MudTooltip>
            }
        </MudTd>
        <MudTd DataLabel="Data">@context.CreatedAt.ToString("dd/MM/yyyy HH:mm")</MudTd>
        <MudTd DataLabel="Stato">
            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                @context.Status
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Gravità">
            <MudChip T="string" Size="Size.Small" Color="@GetSeverityColor(context.Severity)">
                @context.Severity
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Ambiente">
            <MudChip T="string" Size="Size.Small" 
                     Color="@(context.Environment == IssueEnvironment.Prod ? Color.Error : Color.Info)">
                @context.Environment
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Area">@context.Area</MudTd>
        <MudTd DataLabel="Titolo">@context.Title</MudTd>
        <MudTd DataLabel="Docs">
            @if (context.Status == IssueStatus.Resolved && !context.DocsUpdated)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Warning">
                    Non documentato
                </MudChip>
            }
            else if (context.DocsUpdated)
            {
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>Nessun issue trovato</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private List<TechnicalIssue> _issues = new();
    
    // Filtri
    private IssueStatus? _filterStatus;
    private IssueArea? _filterArea;
    private IssueSeverity? _filterSeverity;
    private IssueEnvironment? _filterEnvironment;
    private string? _searchTitle;
    private string _filterAutoCapture = "tutti"; // "tutti" | "auto" | "manuale"

    private int _autoOpenCount = 0;

    // Filtra in memoria per auto/manuale dopo il caricamento dal DB
    private List<TechnicalIssue> IssuesFiltrati => _filterAutoCapture switch
    {
        "auto"    => _issues.Where(i => i.IsAutoCapture).ToList(),
        "manuale" => _issues.Where(i => !i.IsAutoCapture).ToList(),
        _         => _issues
    };

    protected override async Task OnInitializedAsync()
    {
        await CaricaIssues();
    }

    private async Task CaricaIssues()
    {
        _issues = await IssueService.GetAllAsync(
            _filterStatus,
            _filterArea,
            _filterSeverity,
            _filterEnvironment,
            _searchTitle);

        // Conta auto-catturati aperti per il badge
        _autoOpenCount = _issues.Count(i => i.IsAutoCapture
            && (i.Status == IssueStatus.Open || i.Status == IssueStatus.Investigating));
    }

    private async Task ApplicaFiltri()
    {
        await CaricaIssues();
    }

    private async Task ResetFiltri()
    {
        _filterStatus = null;
        _filterArea = null;
        _filterSeverity = null;
        _filterEnvironment = null;
        _searchTitle = null;
        _filterAutoCapture = "tutti";
        await CaricaIssues();
    }

    private void GoToDetail(TechnicalIssue issue)
    {
        Navigation.NavigateTo($"/impostazioni/issue-log/{issue.Id}");
    }

    private Color GetStatusColor(IssueStatus status) => status switch
    {
        IssueStatus.Open => Color.Error,
        IssueStatus.Investigating => Color.Warning,
        IssueStatus.Resolved => Color.Success,
        IssueStatus.Documented => Color.Info,
        _ => Color.Default
    };

    private Color GetSeverityColor(IssueSeverity severity) => severity switch
    {
        IssueSeverity.Critical => Color.Error,
        IssueSeverity.High => Color.Warning,
        IssueSeverity.Medium => Color.Info,
        IssueSeverity.Low => Color.Default,
        _ => Color.Default
    };
}
