@page "/statistiche/produzione"

<PageTitle>Statistiche Produzione</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4" data-testid="page-statistiche-produzione">
<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6">Produzione Mensile</MudText>
            <MudText Typo="Typo.h3">0 pz</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6">Efficienza Media</MudText>
            <MudText Typo="Typo.h3">0%</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudText Class="mt-4">Pagina predisposta per statistiche produzione con grafici</MudText>
</MudContainer>
