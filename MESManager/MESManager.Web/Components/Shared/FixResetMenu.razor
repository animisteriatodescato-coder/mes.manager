@inject IDialogService DialogService

<MudMenu Dense="true" AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
    <ActivatorContent>
        <MudButton Variant="Variant.Outlined" 
                   StartIcon="@Icons.Material.Filled.RestartAlt" 
                   EndIcon="@Icons.Material.Filled.ArrowDropDown"
                   Size="Size.Small">
            Reset
        </MudButton>
    </ActivatorContent>
    <ChildContent>
        <MudMenuItem Icon="@Icons.Material.Filled.PushPin" OnClick="@OnFixClicked">
            Fix - Salva stato attuale
        </MudMenuItem>
        <MudMenuItem Icon="@Icons.Material.Filled.Restore" OnClick="@OnResetClicked">
            Reset - Ripristina stato salvato
        </MudMenuItem>
        @if (ShowGlobalSave)
        {
            <MudDivider />
            <MudMenuItem Icon="@Icons.Material.Filled.PublishedWithChanges" OnClick="@OnSaveGlobalClicked"
                         Style="color: var(--mud-palette-warning-text);">
                Imposta come Default per tutti
            </MudMenuItem>
        }
    </ChildContent>
</MudMenu>

@code {
    [Parameter]
    public EventCallback OnFix { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }

    /// <summary>Mostra la voce "Imposta come Default per tutti" (solo Admin).</summary>
    [Parameter]
    public bool ShowGlobalSave { get; set; } = false;

    /// <summary>Callback per salvare il default globale (solo Admin).</summary>
    [Parameter]
    public EventCallback OnSaveGlobal { get; set; }

    private async Task OnFixClicked()
    {
        var parameters = new DialogParameters<ConfirmDialog>();
        parameters.Add(x => x.ContentText, "Vuoi salvare lo stato attuale come stato di riferimento?");
        parameters.Add(x => x.ButtonText, "Salva");
        parameters.Add(x => x.Color, Color.Primary);

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Conferma Fix", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await OnFix.InvokeAsync();
        }
    }

    private async Task OnResetClicked()
    {
        var parameters = new DialogParameters<ConfirmDialog>();
        parameters.Add(x => x.ContentText, "Vuoi ripristinare lo stato salvato?");
        parameters.Add(x => x.ButtonText, "Ripristina");
        parameters.Add(x => x.Color, Color.Warning);

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Conferma Reset", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await OnReset.InvokeAsync();
        }
    }

    private async Task OnSaveGlobalClicked()
    {
        var parameters = new DialogParameters<ConfirmDialog>();
        parameters.Add(x => x.ContentText, "Vuoi impostare lo stato attuale come DEFAULT per TUTTI gli utenti? Il loro stato personalizzato non verrà cancellato, ma i nuovi utenti partiranno da questa configurazione.");
        parameters.Add(x => x.ButtonText, "Imposta Default");
        parameters.Add(x => x.Color, Color.Warning);

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Conferma Default Globale", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await OnSaveGlobal.InvokeAsync();
        }
    }
}
