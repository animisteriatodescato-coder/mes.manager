@using MESManager.Application.Services
@inject CurrentUserService CurrentUser

@* Mostra l utente autenticato corrente (nome + indicatore colore). *@
@if (CurrentUser.HasUser)
{
    <div class="d-flex align-center gap-2 mr-2">
        @if (!string.IsNullOrEmpty(CurrentUser.UserColor))
        {
            <div style="width:14px; height:14px; border-radius:50%; background-color:@CurrentUser.UserColor; border:1px solid rgba(255,255,255,0.5); flex-shrink:0;"></div>
        }
        <MudText Typo="Typo.body2" Style="opacity:0.9;">@CurrentUser.UserName</MudText>
    </div>
}
