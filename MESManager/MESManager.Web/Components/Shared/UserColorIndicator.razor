@using MESManager.Application.Services
@inject CurrentUserService CurrentUser

@if (CurrentUser.HasUser && !string.IsNullOrEmpty(CurrentUser.UserColor))
{
    <div class="user-color-indicator" style="background-color: @CurrentUser.UserColor;"></div>
}

@code {
    protected override void OnInitialized()
    {
        // Sottoscrivi all'evento di cambio utente per aggiornare la UI
        CurrentUser.OnUserChanged += StateHasChanged;
    }

    public void Dispose()
    {
        CurrentUser.OnUserChanged -= StateHasChanged;
    }
}
