@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@using Microsoft.AspNetCore.Components.Forms
@inject IAiAssistantService AiService
@inject IJSRuntime JS
@implements IDisposable

<div class="ai-panel-root">

    @* ── Header ── *@
    <div class="ai-panel-header">
        <div class="ai-panel-heading">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="color:var(--mud-palette-primary)" />
            <MudText Typo="Typo.h6" Style="font-weight:600">Assistente AI</MudText>
            @* Badge provider/stato *@
            @if (_health != null)
            {
                <MudTooltip Text="@(_health.IsAvailable ? $"{_health.ProviderName} online" : (_health.Error ?? "Provider offline"))">
                    <MudChip T="string" Size="Size.Small"
                             Color="@(_health.IsAvailable ? Color.Success : Color.Error)"
                             Variant="Variant.Outlined" Style="height:22px;font-size:0.7rem;">
                        @_health.ProviderName
                    </MudChip>
                </MudTooltip>
            }
            else if (_healthLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
        </div>
        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       Size="Size.Small"
                       OnClick="OnClose"
                       title="Chiudi" />
    </div>

    @* ── Messages ── *@
    <div id="ai-messages" class="ai-messages-list">

        @if (!_messages.Any())
        {
            @* Stato iniziale: suggerimenti *@
            <div class="ai-welcome">
                <MudIcon Icon="@Icons.Material.Filled.SmartToy" Style="font-size:3rem;color:var(--mud-palette-primary);opacity:.7" />
                <MudText Typo="Typo.body1" Class="mt-2" Style="text-align:center">
                    Ciao! Chiedimi qualcosa sui dati del gestionale.
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1" Style="text-align:center">
                    Esempi di domande:
                </MudText>
                <div class="ai-suggestions">
                    @foreach (var s in _suggestions)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                                 OnClick="@(() => SendSuggestion(s))">@s</MudChip>
                    }
                </div>
            </div>
        }

        @foreach (var msg in _messages)
        {
            <div class="ai-msg-row @(msg.Role == "user" ? "ai-row-user" : "ai-row-assistant")">
                <div class="ai-bubble @(msg.Role == "user" ? "ai-bubble-user" : msg.IsError ? "ai-bubble-error" : "ai-bubble-assistant")">
                    <pre class="ai-bubble-text">@msg.Content</pre>
                    @if (msg.Attachments.Any())
                    {
                        <div class="ai-message-attachments">
                            @foreach (var attachment in msg.Attachments)
                            {
                                <img src="@attachment.DataUrl" alt="@attachment.FileName" class="ai-message-thumb" />
                            }
                        </div>
                    }
                    <div class="ai-bubble-time">@msg.Timestamp.ToString("HH:mm")</div>
                </div>
            </div>
        }

        @if (_loading)
        {
            <div class="ai-msg-row ai-row-assistant">
                <div class="ai-bubble ai-bubble-assistant ai-bubble-loading">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                    <MudText Typo="Typo.caption" Class="ml-2">Elaborazione...</MudText>
                </div>
            </div>
        }

    </div>

    @* ── Input ── *@
    <div class="ai-panel-input">
        @if (_pendingAttachments.Any())
        {
            <div class="ai-pending-attachments">
                @foreach (var attachment in _pendingAttachments)
                {
                    <div class="ai-pending-attachment">
                        <img src="@attachment.DataUrl" alt="@attachment.FileName" />
                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Size="Size.Small"
                                       OnClick="@(() => RemoveAttachment(attachment))"
                                       title="Rimuovi screenshot" />
                    </div>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_uploadError))
        {
            <MudText Typo="Typo.caption" Color="Color.Error">@_uploadError</MudText>
        }

        <div class="ai-input-row">
            <InputFile id="ai-file-input"
                       class="ai-file-input"
                       OnChange="OnFilesSelected"
                       accept="image/png,image/jpeg,image/webp"
                       multiple />
            <label class="ai-attach-label" for="ai-file-input" title="Allega screenshot">
                <MudIcon Icon="@Icons.Material.Filled.AttachFile" Size="Size.Small" />
            </label>

            <MudTextField @bind-Value="_input"
                          Placeholder="Scrivi una domanda..."
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Lines="1"
                          Disabled="@_loading"
                          @onkeydown="OnKeyDown"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Send"
                          OnAdornmentClick="Send"
                          AdornmentColor="Color.Primary"
                          data-testid="ai-input" />
        </div>
    </div>

</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }

    private readonly List<AiChatMessage> _messages = [];
    private string _input   = string.Empty;
    private bool   _loading;
    private bool   _shouldScroll;
    private CancellationTokenSource? _cts;
    private readonly List<AiChatAttachment> _pendingAttachments = [];
    private string? _uploadError;
    private const long MaxAttachmentBytes = 4 * 1024 * 1024;
    private const int MaxAttachments = 3;

    // ── Provider health ───────────────────────────────────────────────────────
    private AiHealthResult? _health;
    private bool _healthLoading = false;

    protected override async Task OnInitializedAsync()
    {
        // Controlla la salute del provider AI all'apertura del pannello
        _healthLoading = true;
        try
        {
            _health = await AiService.CheckHealthAsync();
        }
        catch { /* ignora errori health check all'avvio */ }
        finally
        {
            _healthLoading = false;
        }
    }

    private static readonly string[] _suggestions =
    [
        "A che ora hanno iniziato oggi gli operatori?",
        "Qual è lo stato attuale delle macchine?",
        "Quali commesse sono in lavorazione?",
        "Ci sono stati allarmi oggi?",
        "Dammi i KPI di produzione di oggi",
        "Analizza questo screenshot del gestionale"
    ];

    private async Task SendSuggestion(string text)
    {
        _input = text;
        await Send();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !_loading)
            await Send();
    }

    private async Task Send()
    {
        var trimmed = _input.Trim();
        if ((string.IsNullOrEmpty(trimmed) && !_pendingAttachments.Any()) || _loading) return;

        var attachments = _pendingAttachments.ToList();
        var messageText = string.IsNullOrWhiteSpace(trimmed)
            ? "Analizza lo screenshot allegato."
            : trimmed;

        _messages.Add(new AiChatMessage
        {
            Role      = "user",
            Content   = messageText,
            Attachments = attachments,
            Timestamp = DateTime.Now
        });
        _input = string.Empty;
        _pendingAttachments.Clear();
        _uploadError = null;
        _loading = true;
        _shouldScroll = true;
        StateHasChanged();

        _cts?.Cancel();
        _cts = new CancellationTokenSource(TimeSpan.FromSeconds(60));

        string reply;
        bool   isError = false;
        try
        {
            // Passa la history (tutti i messaggi già presenti meno l'ultimo user appena aggiunto)
            var history = _messages.Take(_messages.Count - 1).ToList();
            reply = await AiService.AskAsync(history, messageText, attachments, _cts.Token);
        }
        catch (OperationCanceledException)
        {
            reply   = "⏱️ Richiesta scaduta (timeout 60s). Riprova.";
            isError = true;
        }
        catch (Exception ex)
        {
            reply   = $"❌ Errore: {ex.Message}";
            isError = true;
        }
        finally
        {
            _loading = false;
        }

        _messages.Add(new AiChatMessage
        {
            Role      = "assistant",
            Content   = reply,
            IsError   = isError,
            Timestamp = DateTime.Now
        });
        _shouldScroll = true;
        StateHasChanged();
    }

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        _uploadError = null;
        var remaining = MaxAttachments - _pendingAttachments.Count;
        if (remaining <= 0)
        {
            _uploadError = $"Puoi allegare al massimo {MaxAttachments} screenshot.";
            return;
        }

        foreach (var file in e.GetMultipleFiles(MaxAttachments).Take(remaining))
        {
            if (!IsSupportedImage(file.ContentType))
            {
                _uploadError = "Formato non supportato. Usa PNG, JPG o WEBP.";
                continue;
            }

            if (file.Size > MaxAttachmentBytes)
            {
                _uploadError = "Screenshot troppo grande. Limite 4 MB per immagine.";
                continue;
            }

            await using var stream = file.OpenReadStream(MaxAttachmentBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _pendingAttachments.Add(new AiChatAttachment
            {
                FileName    = file.Name,
                ContentType = file.ContentType,
                Base64Data  = Convert.ToBase64String(ms.ToArray())
            });
        }
    }

    private void RemoveAttachment(AiChatAttachment attachment)
    {
        _pendingAttachments.Remove(attachment);
    }

    private static bool IsSupportedImage(string contentType) =>
        contentType is "image/png" or "image/jpeg" or "image/webp";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldScroll)
        {
            _shouldScroll = false;
            try
            {
                await JS.InvokeVoidAsync("AiAssistant.scrollToBottom", "ai-messages");
            }
            catch { /* ignora errori JS durante dispose */ }
        }
    }

    public void Dispose() => _cts?.Cancel();
}
