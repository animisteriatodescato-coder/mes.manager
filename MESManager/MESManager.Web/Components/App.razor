<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    
    <!-- AG Grid Community CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ag-grid-community@31.0.0/styles/ag-grid.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ag-grid-community@31.0.0/styles/ag-theme-alpine.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ag-grid-community@31.0.0/styles/ag-theme-alpine-dark.css" />
    
    <!-- Vis-Timeline CSS -->
    <link rel="stylesheet" href="https://unpkg.com/vis-timeline@latest/styles/vis-timeline-graph2d.min.css" />
    <link rel="stylesheet" href="/css/gantt-macchine.css?v=8" />
    <link rel="stylesheet" href="MESManager.Web.styles.css" />
    
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    
    <!-- Error Interceptor: DEVE essere il primo script per catturare tutti gli errori -->
    <script src="/js/error-interceptor.js?v=1"></script>
    
    <!-- MudBlazor JS -->
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    
    <!-- AG Grid Community JS -->
    <script src="https://cdn.jsdelivr.net/npm/ag-grid-community@31.0.0/dist/ag-grid-community.min.js"></script>
    
    <!-- Vis-Timeline JS -->
    <script src="https://unpkg.com/vis-timeline@latest/standalone/umd/vis-timeline-graph2d.min.js"></script>
    
    <!-- Custom Grid Scripts -->
    <!-- Shared components (MUST load first) -->
    <script src="/js/ricetta-column-shared.js?v=1455"></script>
    <!-- Factory centralizzata: UN PUNTO per tutte le grid logic condivisa -->
    <script src="/js/ag-grid-factory.js?v=1500"></script>
    
    <script src="/lib/ag-grid/anime-columns-shared.js?v=1454"></script>
    <!-- Foto Preview: anteprima immagine N in griglia (shared component - carica prima dei grid) -->
    <script src="/lib/ag-grid/foto-preview-shared.js?v=4"></script>
    <script src="/lib/ag-grid/commesse-grid.js?v=1458"></script>
    <script src="/lib/ag-grid/commesse-aperte-grid.js?v=1458"></script>
    <script src="/lib/ag-grid/programma-macchine-grid.js?v=1458"></script>
    <script src="/lib/ag-grid/plc-realtime-grid.js?v=3"></script>
    <script src="/lib/ag-grid/plc-storico-grid.js?v=1"></script>
    <script src="/js/articoli-grid.js?v=1"></script>
    <script src="/js/clienti-grid.js?v=1"></script>
    <script src="/js/anime-grid.js?v=1456"></script>
    <script src="/js/file-utils.js?v=1"></script>
    <script src="/js/gantt/gantt-macchine.js?v=46"></script>
    
    <!-- Blazor framework - loaded last to ensure all scripts are available -->
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
