@using MESManager.Application.DTOs
@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject ILogger<TrasmmettiRicettaMacchinaDialog> Logger

<MudDialog data-testid="dlg-trasmetti-ricetta-macchina">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Send" Color="Color.Success" />
            <MudText Typo="Typo.h6">Trasmetti Ricetta alla Macchina</MudText>
            @if (!string.IsNullOrEmpty(CodiceArticolo))
            {
                <MudChip T="string" Color="Color.Info" Size="Size.Small">@CodiceArticolo</MudChip>
            }
        </MudStack>
    </TitleContent>

    <DialogContent>
        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-6">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.body1">@_loadingMessage</MudText>
            </MudStack>
        }
        else if (_trasmissioneSuccess)
        {
            <MudAlert Severity="Severity.Success" Class="mb-3" Icon="@Icons.Material.Filled.CheckCircle">
                <MudText Typo="Typo.body1">Ricetta trasmessa con successo!</MudText>
                <MudText Typo="Typo.body2" Class="mt-1">
                    Ricetta <strong>@CodiceArticolo</strong> scritta su DB55 (offset 100+) della macchina
                    <strong>@(_macchinaSelezionata?.Codice) — @(_macchinaSelezionata?.Nome)</strong>.
                </MudText>
            </MudAlert>

            @* Stato invio PDF *@
            @if (_risultato?.PdfSaleOrdId > 0)
            {
                @if (_risultato.PdfInviato)
                {
                    <MudAlert Severity="Severity.Success" Icon="@Icons.Material.Filled.PictureAsPdf" Class="mt-1">
                        <MudText Typo="Typo.body2">
                            📄 Scheda PDF <strong>@_risultato.PdfNomeFile</strong> inviata via FTP alla macchina.
                        </MudText>
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Warning" Icon="@Icons.Material.Filled.PictureAsPdf" Class="mt-1">
                        <MudText Typo="Typo.body2">
                            ⚠️ Scheda PDF <strong>@($"{_risultato.PdfSaleOrdId}.pdf")</strong> NON inviata via FTP.
                        </MudText>
                        @if (!string.IsNullOrEmpty(_risultato.PdfErrorMessage))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning" Class="mt-1">
                                Errore: @_risultato.PdfErrorMessage
                            </MudText>
                        }
                    </MudAlert>
                }
            }
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                Seleziona la macchina su cui scrivere i parametri ricetta (DB55 offset&nbsp;100+)
                per <strong>@CodiceArticolo</strong>.
            </MudText>

            @if (_macchine.Count == 0)
            {
                <MudAlert Severity="Severity.Warning">Nessuna macchina con PLC configurato trovata.</MudAlert>
            }
            else
            {
                <MudList T="MacchinaDto" Dense="true">
                    @foreach (var m in _macchine)
                    {
                        bool selected = _macchinaSelezionata?.Id == m.Id;
                        <MudListItem T="MacchinaDto"
                                     OnClick="@(() => OnMacchinaSelected(m))"
                                     Style="@(selected ? "background: rgba(46,125,50,0.08); border-radius: 6px;" : "cursor:pointer;")">
                            <div class="d-flex align-center gap-3 py-1">
                                <MudIcon Icon="@Icons.Material.Filled.SettingsRemote"
                                         Color="@(selected ? Color.Success : Color.Default)" />
                                <div style="flex:1;">
                                    <MudText Typo="Typo.body1"><strong>@m.Codice</strong> — @m.Nome</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Success">
                                        <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" /> PLC: @m.IndirizzoPLC
                                    </MudText>
                                </div>
                                @if (selected)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                                }
                            </div>
                        </MudListItem>
                        <MudDivider />
                    }
                </MudList>

                @if (_macchinaSelezionata != null)
                {
                    <MudAlert Severity="Severity.Info" Class="mt-3" Icon="@Icons.Material.Filled.Info">
                        <MudText Typo="Typo.body2">
                            I parametri della ricetta <strong>@CodiceArticolo</strong> verranno scritti
                            su DB55 (offset 100+) della macchina
                            <strong>@_macchinaSelezionata.Codice — @_macchinaSelezionata.Nome</strong>.<br />
                            <span style="color:#d32f2f;">⚠ I valori attuali sul PLC verranno sovrascritti.</span>
                        </MudText>
                    </MudAlert>
                }
            }
        }
    </DialogContent>

    <DialogActions>
        @if (_trasmissioneSuccess)
        {
            <MudButton OnClick="Close" Variant="Variant.Filled" Color="Color.Success">Chiudi</MudButton>
        }
        else
        {
            <MudButton OnClick="Cancel" Disabled="@_loading">Annulla</MudButton>
            <MudButton OnClick="TrasmmettiAsync"
                       Variant="Variant.Filled"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Send"
                       Disabled="@(_macchinaSelezionata == null || _loading)"
                       data-testid="btn-conferma-trasmetti">
                Trasmetti al PLC
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>Codice articolo della ricetta da trasmettere.</summary>
    [Parameter] public string CodiceArticolo { get; set; } = string.Empty;

    private List<MacchinaDto> _macchine = new();
    private MacchinaDto? _macchinaSelezionata;
    private bool _loading = true;
    private bool _trasmissioneSuccess;
    private RecipeWriteResult? _risultato;
    private string _loadingMessage = "Caricamento macchine...";

    protected override async Task OnInitializedAsync()
    {
        await LoadMacchineAsync();
    }

    private async Task LoadMacchineAsync()
    {
        try
        {
            _loading = true;
            _loadingMessage = "Caricamento macchine...";
            var all = await Http.GetFromJsonAsync<List<MacchinaDto>>("/api/Macchine") ?? new();
            // Solo macchine con PLC configurato, ordinate per codice
            _macchine = all
                .Where(m => !string.IsNullOrEmpty(m.IndirizzoPLC))
                .OrderBy(m => m.Codice)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore caricamento macchine per TrasmmettiRicettaMacchinaDialog");
            Snackbar.Add($"Errore caricamento macchine: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnMacchinaSelected(MacchinaDto m)
    {
        _macchinaSelezionata = _macchinaSelezionata?.Id == m.Id ? null : m;
    }

    private async Task TrasmmettiAsync()
    {
        if (_macchinaSelezionata == null || string.IsNullOrEmpty(CodiceArticolo)) return;

        _loading = true;
        _loadingMessage = $"Trasmissione ricetta a {_macchinaSelezionata.Codice}...";

        try
        {
            var request = new LoadRecipeRequest
            {
                MacchinaId = _macchinaSelezionata.Id,
                CodiceArticolo = CodiceArticolo,
                ForceReload = true
            };

            var response = await Http.PostAsJsonAsync("/api/plc/load-recipe-by-article", request);

            if (response.IsSuccessStatusCode)
            {
                _risultato = await response.Content.ReadFromJsonAsync<RecipeWriteResult>();
                _trasmissioneSuccess = true;
                Logger.LogInformation("[TrasmmettiRicetta] Ricetta trasmessa: {Codice} -> {Macchina} | PDF={Pdf}",
                    CodiceArticolo, _macchinaSelezionata.Codice, _risultato?.PdfInviato);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"❌ Errore trasmissione: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Errore trasmissione ricetta al PLC");
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}
