@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@inject HttpClient Http
@inject IMacchinaAppService MacchinaService
@inject ISnackbar Snackbar

<MudDialog Style="max-height: 90vh;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
            Modifica Anima: @Anime?.CodiceArticolo
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-2" MinimumTabWidth="80px">
            <!-- Tab 1: Identificazione -->
            <MudTabPanel Text="Identificazione" Icon="@Icons.Material.Filled.Info">
                <MudGrid Spacing="1">
                    <MudItem xs="2">
                        <MudTextField Value="@Anime.Id" Label="ID" ReadOnly="true" Variant="Variant.Filled" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudTextField Value="@Anime.CodiceArticolo" Label="Codice Articolo" ReadOnly="true" Variant="Variant.Filled" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="4">
                        <MudTextField Value="@Anime.DescrizioneArticolo" Label="Descrizione" ReadOnly="true" Variant="Variant.Filled" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudTextField Value="@Anime.Cliente" Label="Cliente" ReadOnly="true" Variant="Variant.Filled" Margin="Margin.Dense" />
                    </MudItem>
                    
                    <MudItem xs="3">
                        <MudTextField @bind-Value="Anime.Ubicazione" Label="Ubicazione" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudTextField @bind-Value="Anime.CodiceCassa" Label="Codice Cassa" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudTextField @bind-Value="Anime.CodiceAnime" Label="Codice Anime" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudTextField @bind-Value="Anime.UnitaMisura" Label="Unità Misura" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            
            <!-- Tab 2: Materiali -->
            <MudTabPanel Text="Materiali" Icon="@Icons.Material.Filled.Science">
                <MudGrid Spacing="1">
                    <MudItem xs="3">
                        <MudSelect @bind-Value="ImballoSelezionato" Label="Imballo" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   AnchorOrigin="Origin.BottomCenter" Dense="true">
                            <MudSelectItem Value="@((int?)null)">(nessuno)</MudSelectItem>
                            @foreach (var item in imballoOptions)
                            {
                                <MudSelectItem Value="@(int.TryParse(item.Codice, out var v) ? (int?)v : null)">
                                    @item.Codice - @item.Descrizione
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="3">
                        <MudSelect @bind-Value="Anime.Colla" Label="Colla" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   AnchorOrigin="Origin.BottomCenter" Dense="true">
                            <MudSelectItem Value="@((string?)null)">(nessuna)</MudSelectItem>
                            @foreach (var item in collaOptions)
                            {
                                <MudSelectItem Value="@item.Codice">@item.Codice - @item.Descrizione</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="3">
                        <MudSelect @bind-Value="Anime.Sabbia" Label="Sabbia" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   AnchorOrigin="Origin.BottomCenter" Dense="true">
                            <MudSelectItem Value="@((string?)null)">(nessuna)</MudSelectItem>
                            @foreach (var item in sabbiaOptions)
                            {
                                <MudSelectItem Value="@item.Codice">@(string.IsNullOrEmpty(item.Codice) ? "(nessuna)" : $"{item.Codice} - {item.Descrizione}")</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="3">
                        <MudSelect @bind-Value="Anime.Vernice" Label="Vernice" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   AnchorOrigin="Origin.BottomCenter" Dense="true">
                            <MudSelectItem Value="@((string?)null)">(nessuna)</MudSelectItem>
                            @foreach (var item in verniceOptions)
                            {
                                <MudSelectItem Value="@item.Codice">@item.Codice - @item.Descrizione</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            
            <!-- Tab 3: Produzione -->
            <MudTabPanel Text="Produzione" Icon="@Icons.Material.Filled.Factory">
                <MudGrid Spacing="1">
                    <MudItem xs="2">
                        <MudNumericField @bind-Value="Anime.QuantitaPiano" Label="Qta/Piano" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="2">
                        <MudNumericField @bind-Value="Anime.NumeroPiani" Label="N.Piani" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="2">
                        <MudTextField @bind-Value="Anime.Ciclo" Label="Ciclo" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="2">
                        <MudTextField @bind-Value="Anime.Peso" Label="Peso" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="2">
                        <MudTextField @bind-Value="Anime.Figure" Label="Figure" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="2">
                        <MudTextField @bind-Value="Anime.Maschere" Label="Maschere" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    
                    <MudItem xs="2">
                        <MudSelect @bind-Value="Anime.Incollata" Label="Incollata" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                            <MudSelectItem Value="@((string?)null)">-</MudSelectItem>
                            <MudSelectItem Value="@("Sì")">Sì</MudSelectItem>
                            <MudSelectItem Value="@("No")">No</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="2">
                        <MudSelect @bind-Value="Anime.Assemblata" Label="Assemblata" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                            <MudSelectItem Value="@((string?)null)">-</MudSelectItem>
                            <MudSelectItem Value="@("Sì")">Sì</MudSelectItem>
                            <MudSelectItem Value="@("No")">No</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="2">
                        <MudTextField @bind-Value="Anime.ArmataL" Label="Armata L" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="2">
                        <MudTextField @bind-Value="Anime.TogliereSparo" Label="Tog.Sparo" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="2">
                        <MudNumericField @bind-Value="Anime.Larghezza" Label="Larghezza" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="2">
                        <MudNumericField @bind-Value="Anime.Altezza" Label="Altezza" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    
                    <MudItem xs="2">
                        <MudNumericField @bind-Value="Anime.Profondita" Label="Profondità" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="4">
                        <MudTextField @bind-Value="Anime.Allegato" Label="Allegato" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            
            <!-- Tab 4: Macchine -->
            <MudTabPanel Text="Macchine" Icon="@Icons.Material.Filled.PrecisionManufacturing">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                    Macchine disponibili per questa anima (colonna "MA" delle commesse aperte)
                </MudText>
                <MudStack Row="true" Spacing="1" Class="mb-2">
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.SelectAll" 
                               OnClick="SelezionaTutteLeMacchine">Seleziona Tutto</MudButton>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Deselect" 
                               OnClick="DeselezionaTutteLeMacchine">Deseleziona Tutto</MudButton>
                </MudStack>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var macchina in macchineDisponibili)
                    {
                        <MudCheckBox T="bool" 
                                     Value="@macchineSelezionate.Contains(macchina.Codice)"
                                     ValueChanged="@((bool val) => ToggleMacchina(macchina.Codice, val))"
                                     Label="@macchina.Nome"
                                     Color="Color.Primary"
                                     Dense="true"
                                     Size="Size.Small" />
                    }
                </MudStack>
            </MudTabPanel>
            
            <!-- Tab 5: Note -->
            <MudTabPanel Text="Note" Icon="@Icons.Material.Filled.Notes">
                <MudGrid Spacing="1">
                    <MudItem xs="12">
                        <MudTextField @bind-Value="Anime.Note" Label="Note" Variant="Variant.Outlined" Lines="3" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudSwitch @bind-Value="Anime.TrasmettiTutto" Label="Trasmetti Tutto" Color="Color.Primary" />
                    </MudItem>
                    
                    <!-- Sezione Tracking -->
                    <MudItem xs="12" Class="mt-2">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-1">
                            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="mr-1" />
                            Tracking
                        </MudText>
                    </MudItem>
                    <MudItem xs="3">
                        <MudTextField Value="@(Anime.DataImportazione.ToString("dd/MM/yyyy HH:mm"))" Label="Data Import" ReadOnly="true" Variant="Variant.Filled" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudTextField Value="@(Anime.DataModificaRecord?.ToString("dd/MM/yyyy HH:mm") ?? "-")" Label="Data Modifica" ReadOnly="true" Variant="Variant.Filled" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudTextField Value="@(Anime.UtenteModificaRecord ?? "-")" Label="Utente" ReadOnly="true" Variant="Variant.Filled" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudChip T="string" Color="@(Anime.ModificatoLocalmente ? Color.Warning : Color.Default)" Size="Size.Small">
                            @(Anime.ModificatoLocalmente ? "Modificato" : "Da Mago")
                        </MudChip>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annulla</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" OnClick="Save">
            Salva
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    
    [Parameter] public AnimeDto Anime { get; set; } = new();
    
    private List<TabellaItem> collaOptions = new();
    private List<TabellaItem> verniceOptions = new();
    private List<TabellaItem> sabbiaOptions = new();
    private List<TabellaItem> imballoOptions = new();
    private List<MacchinaDto> macchineDisponibili = new();
    private HashSet<string> macchineSelezionate = new();
    
    private int? ImballoSelezionato
    {
        get => Anime.Imballo;
        set => Anime.Imballo = value;
    }
    
    protected override async Task OnInitializedAsync()
    {
        await CaricaOpzioniAsync();
        ParseMacchineSelezionate();
    }
    
    private async Task CaricaOpzioniAsync()
    {
        try
        {
            collaOptions = await Http.GetFromJsonAsync<List<TabellaItem>>("/api/Tabelle/colla") ?? new();
            verniceOptions = await Http.GetFromJsonAsync<List<TabellaItem>>("/api/Tabelle/vernice") ?? new();
            sabbiaOptions = await Http.GetFromJsonAsync<List<TabellaItem>>("/api/Tabelle/sabbia") ?? new();
            imballoOptions = await Http.GetFromJsonAsync<List<TabellaItem>>("/api/Tabelle/imballo") ?? new();
            macchineDisponibili = await MacchinaService.GetListaAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading options: {ex.Message}");
        }
    }
    
    private void ParseMacchineSelezionate()
    {
        macchineSelezionate.Clear();
        if (!string.IsNullOrWhiteSpace(Anime.MacchineSuDisponibili))
        {
            var codici = Anime.MacchineSuDisponibili.Split(new[] { ';', ',' }, StringSplitOptions.RemoveEmptyEntries);
            foreach (var codice in codici)
            {
                macchineSelezionate.Add(codice.Trim());
            }
        }
    }
    
    private void ToggleMacchina(string codice, bool selected)
    {
        if (selected)
            macchineSelezionate.Add(codice);
        else
            macchineSelezionate.Remove(codice);
        
        AggiornaMacchineString();
    }
    
    private void SelezionaTutteLeMacchine()
    {
        macchineSelezionate.Clear();
        foreach (var m in macchineDisponibili)
        {
            macchineSelezionate.Add(m.Codice);
        }
        AggiornaMacchineString();
    }
    
    private void DeselezionaTutteLeMacchine()
    {
        macchineSelezionate.Clear();
        AggiornaMacchineString();
    }
    
    private void AggiornaMacchineString()
    {
        Anime.MacchineSuDisponibili = string.Join(";", macchineSelezionate.OrderBy(x => x));
    }
    
    private async Task Save()
    {
        try
        {
            Anime.ModificatoLocalmente = true;
            Anime.DataUltimaModificaLocale = DateTime.Now;
            
            var response = await Http.PutAsJsonAsync($"/api/Anime/{Anime.Id}", Anime);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Anima salvata con successo!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(Anime));
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Errore nel salvataggio: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }
    
    private void Cancel() => MudDialog.Cancel();
    
    public class TabellaItem
    {
        public string Codice { get; set; } = string.Empty;
        public string Descrizione { get; set; } = string.Empty;
    }
}
