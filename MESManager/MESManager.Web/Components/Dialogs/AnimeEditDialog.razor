@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@using MESManager.Application.Services
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject IMacchinaAppService MacchinaService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudDialog Class="anime-edit-dialog" Style="max-width: 1380px;" data-testid="dlg-anime-edit">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Edit" />
            <MudText Typo="Typo.h6">Modifica Anima: @Anime?.CodiceArticolo</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (IsReadOnly)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">Modalità sola lettura — le modifiche non sono consentite</MudAlert>
        }
        <MudGrid Spacing="2">
            <!-- COLONNA SINISTRA: DATI -->
            <MudItem xs="7">
                <MudStack Spacing="1">
            <!-- IDENTIFICAZIONE -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Primary" />
                <MudText Typo="Typo.caption" Color="Color.Primary"><b>IDENTIFICAZIONE</b></MudText>
            </MudStack>
            <MudGrid Spacing="1">
                <MudItem xs="1">
                    <MudTextField Value="@Anime.Id" Label="ID" ReadOnly="true" Variant="Variant.Filled" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2">
                    <MudTextField Value="@Anime.CodiceArticolo" Label="Codice" ReadOnly="true" Variant="Variant.Filled" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="4">
                    <MudTextField Value="@Anime.DescrizioneArticolo" Label="Descrizione" ReadOnly="true" Variant="Variant.Filled" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="3">
                    <MudTextField Value="@Anime.Cliente" Label="Cliente" ReadOnly="true" Variant="Variant.Filled" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2">
                    <MudTextField @bind-Value="Anime.Ubicazione" Label="Ubicazione" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>
            <MudGrid Spacing="1">
                <MudItem xs="4">
                    <MudTextField @bind-Value="Anime.CodiceCassa" Label="Codice Cassa" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="5">
                    <MudTextField @bind-Value="Anime.CodiceAnime" Label="Codice Anime" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="3">
                    <MudTextField @bind-Value="Anime.UnitaMisura" Label="Unità Misura" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-1" />

            <!-- IMBALLO -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" Color="Color.Primary" />
                <MudText Typo="Typo.caption" Color="Color.Primary"><b>IMBALLO</b></MudText>
            </MudStack>
            <MudGrid Spacing="1">
                <MudItem xs="4">
                    <MudSelect @bind-Value="ImballoSelezionato" Label="Imballo" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                        <MudSelectItem Value="@((int?)null)">-</MudSelectItem>
                        @foreach (var item in imballoOptions)
                        {
                            <MudSelectItem Value="@(int.TryParse(item.Codice, out var v) ? (int?)v : null)">@item.Descrizione</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField @bind-Value="Anime.QuantitaPiano" Label="Qta/Piano" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="1">
                    <MudNumericField @bind-Value="Anime.NumeroPiani" Label="N.Piani" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2">
                    <MudTextField Value="@TotaleImballo" Label="Totale" ReadOnly="true" Variant="Variant.Filled" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-1" />

            <!-- MATERIALI -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.Science" Size="Size.Small" Color="Color.Primary" />
                <MudText Typo="Typo.caption" Color="Color.Primary"><b>MATERIALI</b></MudText>
            </MudStack>
            <MudGrid Spacing="1">
                <MudItem xs="3">
                    <MudSelect @bind-Value="Anime.Colla" Label="Colla" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                        <MudSelectItem Value="@((string?)null)">-</MudSelectItem>
                        @foreach (var item in collaOptions)
                        {
                            <MudSelectItem Value="@item.Codice">@item.Descrizione</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="3">
                    <MudSelect @bind-Value="Anime.Sabbia" Label="Sabbia" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                        <MudSelectItem Value="@((string?)null)">-</MudSelectItem>
                        @foreach (var item in sabbiaOptions)
                        {
                            <MudSelectItem Value="@item.Codice">@(string.IsNullOrEmpty(item.Descrizione) ? "-" : item.Descrizione)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="4">
                    <MudSelect @bind-Value="Anime.Vernice" Label="Vernice" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                        <MudSelectItem Value="@((string?)null)">-</MudSelectItem>
                        @foreach (var item in verniceOptions)
                        {
                            <MudSelectItem Value="@item.Codice">@item.Descrizione</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-1" />

            <!-- PRODUZIONE -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.Factory" Size="Size.Small" Color="Color.Primary" />
                <MudText Typo="Typo.caption" Color="Color.Primary"><b>PRODUZIONE</b></MudText>
            </MudStack>
            <MudGrid Spacing="1">
                <MudItem xs="1">
                    <MudTextField @bind-Value="Anime.Ciclo" Label="Ciclo" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2">
                    <MudTextField @bind-Value="Anime.Peso" Label="Peso" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2">
                    <MudTextField @bind-Value="Anime.Figure" Label="Figure" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="1">
                    <MudTextField @bind-Value="Anime.Maschere" Label="Maschere" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="3">
                    <MudSelect @bind-Value="Anime.TogliereSparo" Label="Tog.Sparo" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                        <MudSelectItem Value="@((string?)null)">-</MudSelectItem>
                        <MudSelectItem Value="@("0")">No</MudSelectItem>
                        <MudSelectItem Value="@("1")">Sì</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="3">
                    <MudTextField @bind-Value="Anime.ArmataL" Label="Armata L" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>
            <MudGrid Spacing="1">
                <MudItem xs="1">
                    <MudSelect @bind-Value="Anime.Assemblata" Label="Assemblata" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                        <MudSelectItem Value="@((string?)null)">-</MudSelectItem>
                        <MudSelectItem Value="@("Sì")">Sì</MudSelectItem>
                        <MudSelectItem Value="@("No")">No</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField @bind-Value="Anime.Larghezza" Label="Larghezza" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField @bind-Value="Anime.Altezza" Label="Altezza" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2">
                    <MudNumericField @bind-Value="Anime.Profondita" Label="Profondità" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-1" />

            <!-- MACCHINE -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.PrecisionManufacturing" Size="Size.Small" Color="Color.Primary" />
                <MudText Typo="Typo.caption" Color="Color.Primary"><b>MACCHINE</b></MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="SelezionaTutteLeMacchine" Disabled="@IsReadOnly" data-testid="btn-anime-macchine-tutte">Tutte</MudButton>
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="DeselezionaTutteLeMacchine" Disabled="@IsReadOnly" data-testid="btn-anime-macchine-nessuna">Nessuna</MudButton>
            </MudStack>
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="0">
                @foreach (var macchina in macchineDisponibili)
                {
                    <MudCheckBox T="bool" 
                                 Value="@macchineSelezionate.Contains(macchina.Codice)"
                                 ValueChanged="@((bool val) => ToggleMacchina(macchina.Codice, val))"
                                 Label="@macchina.Nome"
                                 Color="Color.Primary"
                                 Dense="true"
                                 Size="Size.Small"
                                 Style="min-width: 55px;" />
                }
            </MudStack>

            <MudDivider Class="my-1" />

            <!-- NOTE -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Color="Color.Primary" />
                <MudText Typo="Typo.caption" Color="Color.Primary"><b>NOTE</b></MudText>
            </MudStack>
            <MudTextField @bind-Value="Anime.Note" Variant="Variant.Outlined" Lines="2" Margin="Margin.Dense" />

            <MudDivider Class="my-1" />

            <!-- DOCUMENTI (nella colonna sinistra) -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Color="Color.Warning" />
                <MudText Typo="Typo.caption" Color="Color.Warning"><b>DOCUMENTI (@allegatiResponse.Documenti.Count)</b></MudText>
                <MudSpacer />
                @if (!IsReadOnly)
                {
                <MudFileUpload T="IBrowserFile" Accept=".pdf,.doc,.docx,.xls,.xlsx,.txt" OnFilesChanged="OnDocumentoUpload" Style="margin: 0;">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Text" Color="Color.Warning" Size="Size.Small" StartIcon="@Icons.Material.Filled.NoteAdd">Aggiungi</MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                }
            </MudStack>
            @if (allegatiResponse.Documenti.Any())
            {
                <MudList T="AllegatoArticoloDto" Dense="true">
                    @foreach (var doc in allegatiResponse.Documenti)
                    {
                        <MudListItem Icon="@GetDocIcon(doc.Estensione)" IconColor="Color.Default">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.caption">@(doc.Descrizione ?? doc.NomeFile)</MudText>
                                <MudStack Row="true" Spacing="0">
                                    <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small" Href="@doc.FileUrl" Target="_blank" />
                                    @if (!IsReadOnly) { <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteAllegato(doc)" /> }
                                </MudStack>
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }
            else
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Nessun documento</MudText>
            }
                </MudStack>
            </MudItem>

            <!-- COLONNA DESTRA: FOTO -->
            <MudItem xs="5">
                <MudPaper Elevation="1" Class="pa-3" Style="height: 100%;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Size="Size.Small" Color="Color.Info" />
                        <MudText Typo="Typo.subtitle2" Color="Color.Info"><b>FOTO (@allegatiResponse.Foto.Count)</b></MudText>
                        @if (isLoadingAllegati)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        }
                        <MudSpacer />
                        @if (!IsReadOnly)
                        {
                        <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" StartIcon="@Icons.Material.Filled.CloudDownload" OnClick="ImportaDaGantt" Disabled="@isImportingFromGantt">
                            @if (isImportingFromGantt) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> } Gantt
                        </MudButton>
                        <MudFileUpload T="IBrowserFile" Accept=".jpg,.jpeg,.png,.gif,.bmp,.webp" OnFilesChanged="OnFotoUpload" Style="margin: 0;">
                            <ActivatorContent>
                                <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small" StartIcon="@Icons.Material.Filled.AddAPhoto">Aggiungi</MudButton>
                            </ActivatorContent>
                        </MudFileUpload>
                        }
                    </MudStack>
                    
                    @if (isUploadingAllegato)
                    {
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
                    }
                    
                    @if (allegatiResponse.Foto.Any())
                    {
                        <MudStack Spacing="2">
                            @foreach (var foto in allegatiResponse.Foto)
                            {
                                <MudCard Elevation="2">
                                    <MudCardMedia Image="@foto.FileUrl" Height="200" Style="cursor: pointer;" @onclick="() => OpenFotoInNewTab(foto)" />
                                    <MudCardContent Class="pa-1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudSelect T="int" Value="@foto.Priorita" ValueChanged="@((int p) => UpdatePriorita(foto, p))" 
                                                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" 
                                                       Style="max-width: 72px;" Label="Prior." Disabled="@IsReadOnly">
                                                <MudSelectItem Value="1">1</MudSelectItem>
                                                <MudSelectItem Value="2">2</MudSelectItem>
                                                <MudSelectItem Value="3">3</MudSelectItem>
                                                <MudSelectItem Value="4">4</MudSelectItem>
                                                <MudSelectItem Value="5">5</MudSelectItem>
                                            </MudSelect>
                                            <MudTooltip Text="@foto.NomeFile">
                                                <MudText Typo="Typo.caption" Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 180px;">
                                                    @(foto.Descrizione ?? foto.NomeFile)
                                                </MudText>
                                            </MudTooltip>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteAllegato(foto)" />
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                            Nessuna foto disponibile
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                            Clicca "Aggiungi" o "Gantt" per importare foto
                        </MudText>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <!-- TRACKING inline con i pulsanti -->
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="flex-grow: 1;">
            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Color="Color.Secondary" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Import: @Anime.DataImportazione.ToString("dd/MM/yy") |
                Mod: @(Anime.DataModificaRecord?.ToString("dd/MM/yy") ?? "-") |
                @(Anime.UtenteModificaRecord ?? "-")
            </MudText>
            <MudChip T="string" Color="@(Anime.ModificatoLocalmente ? Color.Warning : Color.Default)" Size="Size.Small">
                @(Anime.ModificatoLocalmente ? "Mod." : "Mago")
            </MudChip>
        </MudStack>
        <MudButton OnClick="Cancel" data-testid="btn-anime-cancel">Annulla</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" OnClick="Save" Disabled="@IsReadOnly" data-testid="btn-anime-save">Salva</MudButton>
    </DialogActions>
</MudDialog>

@code {
    // Inner class must be defined first
    public class TabellaItem { public string Codice { get; set; } = ""; public string Descrizione { get; set; } = ""; }
    
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public AnimeDto Anime { get; set; } = new();
    [Parameter] public bool IsReadOnly { get; set; }
    
    private List<TabellaItem> collaOptions = new();
    private List<TabellaItem> verniceOptions = new();
    private List<TabellaItem> sabbiaOptions = new();
    private List<TabellaItem> imballoOptions = new();
    private List<MacchinaDto> macchineDisponibili = new();
    private HashSet<string> macchineSelezionate = new();
    
    // Allegati
    private AllegatiArticoloResponse allegatiResponse = new();
    private bool isLoadingAllegati = true;
    
    private int? ImballoSelezionato { get => Anime.Imballo; set => Anime.Imballo = value; }
    
    private string TotaleImballo => ((Anime.QuantitaPiano ?? 0) * (Anime.NumeroPiani ?? 0)).ToString();
    
    // Allegati upload
    private bool isUploadingAllegato = false;
    private bool isImportingFromGantt = false;
    
    protected override async Task OnInitializedAsync()
    {
        await CaricaOpzioniAsync();
        await CaricaAllegatiAsync();
        ParseMacchineSelezionate();
    }
    
    private async Task CaricaOpzioniAsync()
    {
        try
        {
            collaOptions = await Http.GetFromJsonAsync<List<TabellaItem>>("/api/Tabelle/colla") ?? new();
            verniceOptions = await Http.GetFromJsonAsync<List<TabellaItem>>("/api/Tabelle/vernice") ?? new();
            sabbiaOptions = await Http.GetFromJsonAsync<List<TabellaItem>>("/api/Tabelle/sabbia") ?? new();
            imballoOptions = await Http.GetFromJsonAsync<List<TabellaItem>>("/api/Tabelle/imballo") ?? new();
            macchineDisponibili = await MacchinaService.GetListaAsync();
        }
        catch { /* Error loading options */ }
    }
    
    private async Task CaricaAllegatiAsync()
    {
        isLoadingAllegati = true;
        try
        {
            // Cerca per CodiceArticolo (es: "302558") usando API locale
            if (!string.IsNullOrEmpty(Anime.CodiceArticolo))
            {
                allegatiResponse = await Http.GetFromJsonAsync<AllegatiArticoloResponse>($"/api/allegati-articoli/articolo/{Anime.CodiceArticolo}") ?? new();
            }
        }
        catch
        {
            // Error loading allegati
            allegatiResponse = new AllegatiArticoloResponse();
        }
        finally
        {
            isLoadingAllegati = false;
        }
    }
    
    private async Task OnFotoUpload(InputFileChangeEventArgs e)
    {
        await UploadFile(e.File, true);
    }
    
    private async Task OnDocumentoUpload(InputFileChangeEventArgs e)
    {
        await UploadFile(e.File, false);
    }
    
    private async Task UploadFile(IBrowserFile file, bool isFoto)
    {
        if (file == null) return;
        
        isUploadingAllegato = true;
        StateHasChanged();
        
        try
        {
            // Leggi il file
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10MB max
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var contenuto = ms.ToArray();
            
            // Upload tramite API
            var content = new MultipartFormDataContent();
            content.Add(new ByteArrayContent(contenuto), "file", file.Name);
            
            var response = await Http.PostAsync($"/api/allegati-articoli/upload/{Anime.CodiceArticolo}", content);
            
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"{(isFoto ? "Foto" : "Documento")} caricato!", Severity.Success);
                await CaricaAllegatiAsync();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Errore: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore upload: {ex.Message}", Severity.Error);
        }
        finally
        {
            isUploadingAllegato = false;
            StateHasChanged();
        }
    }
    
    private async Task DeleteAllegato(AllegatoArticoloDto allegato)
    {
        try
        {
            var response = await Http.DeleteAsync($"/api/allegati-articoli/{allegato.Id}");
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Allegato eliminato", Severity.Success);
                await CaricaAllegatiAsync();
            }
            else
            {
                Snackbar.Add("Errore eliminazione allegato", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }
    
    private async Task ImportaDaGantt()
    {
        if (string.IsNullOrEmpty(Anime.CodiceArticolo)) return;
        
        isImportingFromGantt = true;
        StateHasChanged();
        
        try
        {
            var response = await Http.PostAsync($"/api/allegati-articoli/import/{Anime.CodiceArticolo}", null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ImportAllegatiResult>();
                if (result != null && result.TotaleImportati > 0)
                {
                    Snackbar.Add($"Importati {result.TotaleImportati} allegati da Gantt", Severity.Success);
                    await CaricaAllegatiAsync();
                }
                else if (result != null && result.TotaleSaltati > 0)
                {
                    Snackbar.Add($"Già importati {result.TotaleSaltati} allegati (nessun nuovo)", Severity.Info);
                }
                else
                {
                    Snackbar.Add("Nessun allegato trovato in Gantt per questo articolo", Severity.Warning);
                }
            }
            else
            {
                Snackbar.Add("Errore importazione da Gantt", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
        finally
        {
            isImportingFromGantt = false;
            StateHasChanged();
        }
    }
    
    private async Task OpenFotoInNewTab(AllegatoArticoloDto foto)
    {
        await JS.InvokeVoidAsync("open", foto.FileUrl, "_blank");
    }
    
    private async Task UpdatePriorita(AllegatoArticoloDto foto, int newPriorita)
    {
        try
        {
            var response = await Http.PutAsJsonAsync($"/api/allegati-articoli/{foto.Id}/priorita", newPriorita);
            if (response.IsSuccessStatusCode)
            {
                foto.Priorita = newPriorita;
                // Riordina le foto per priorità
                allegatiResponse.Foto = allegatiResponse.Foto.OrderBy(f => f.Priorita).ThenBy(f => f.NomeFile).ToList();
                Snackbar.Add($"Priorità aggiornata a {newPriorita}", Severity.Success);
                StateHasChanged();
            }
            else
            {
                Snackbar.Add("Errore aggiornamento priorità", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }
    
    private string GetDocIcon(string estensione) => estensione.ToLowerInvariant() switch
    {
        ".pdf" => Icons.Custom.FileFormats.FilePdf,
        ".doc" or ".docx" => Icons.Custom.FileFormats.FileDocument,
        ".xls" or ".xlsx" => Icons.Custom.FileFormats.FileExcel,
        ".txt" => Icons.Custom.FileFormats.FileDocument,
        _ => Icons.Material.Filled.InsertDriveFile
    };
    
    private void ParseMacchineSelezionate()
    {
        macchineSelezionate.Clear();
        if (!string.IsNullOrWhiteSpace(Anime.MacchineSuDisponibili))
        {
            // Se ci sono macchine già salvate, caricale
            foreach (var codice in Anime.MacchineSuDisponibili.Split(new[] { ';', ',' }, StringSplitOptions.RemoveEmptyEntries))
                macchineSelezionate.Add(codice.Trim());
        }
        else
        {
            // Se non ci sono macchine salvate, seleziona tutte di default
            foreach (var m in macchineDisponibili) 
                macchineSelezionate.Add(m.Codice);
            AggiornaMacchineString();
        }
    }
    
    private void ToggleMacchina(string codice, bool selected)
    {
        if (selected) macchineSelezionate.Add(codice);
        else macchineSelezionate.Remove(codice);
        AggiornaMacchineString();
    }
    
    private void SelezionaTutteLeMacchine()
    {
        macchineSelezionate.Clear();
        foreach (var m in macchineDisponibili) macchineSelezionate.Add(m.Codice);
        AggiornaMacchineString();
    }
    
    private void DeselezionaTutteLeMacchine() { macchineSelezionate.Clear(); AggiornaMacchineString(); }
    
    private void AggiornaMacchineString() => Anime.MacchineSuDisponibili = string.Join(";", macchineSelezionate.OrderBy(x => x));
    
    private async Task Save()
    {
        try
        {
            Anime.ModificatoLocalmente = true;
            Anime.DataUltimaModificaLocale = DateTime.Now;
            var response = await Http.PutAsJsonAsync($"/api/Anime/{Anime.Id}", Anime);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Anima salvata!", Severity.Success);
                await InvokeAsync(StateHasChanged);
                await Task.Delay(100); // Piccolo delay per permettere al rendering di completarsi
                MudDialog.Close(DialogResult.Ok(Anime));
            }
            else Snackbar.Add($"Errore: {await response.Content.ReadAsStringAsync()}", Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add($"Errore: {ex.Message}", Severity.Error); }
    }
    
    private void Cancel() => MudDialog.Cancel();
}
