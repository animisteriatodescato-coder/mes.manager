@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@inject HttpClient Http
@inject IMacchinaAppService MacchinaService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
            Modifica Anima: @Anime?.CodiceArticolo
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-3">
            <!-- Tab 1: Identificazione e Ubicazione -->
            <MudTabPanel Text="Identificazione" Icon="@Icons.Material.Filled.Info">
                <MudGrid Spacing="2">
                    <!-- Sezione Identificazione (readonly) -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Class="mr-1" />
                            Identificazione (da Mago - non modificabile)
                        </MudText>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField Value="@Anime.Id" Label="ID" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField Value="@Anime.CodiceArticolo" Label="Codice Articolo" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@Anime.DescrizioneArticolo" Label="Descrizione" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField Value="@Anime.Cliente" Label="Cliente" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField Value="@Anime.IdArticolo" Label="ID Articolo" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    
                    <!-- Sezione Ubicazione (editabile) -->
                    <MudItem xs="12" Class="mt-4">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Class="mr-1" />
                            Ubicazione e Codici
                        </MudText>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField @bind-Value="Anime.Ubicazione" Label="Ubicazione" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField @bind-Value="Anime.CodiceCassa" Label="Codice Cassa" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField @bind-Value="Anime.CodiceAnime" Label="Codice Anime" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField @bind-Value="Anime.UnitaMisura" Label="Unità Misura" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            
            <!-- Tab 2: Materiali -->
            <MudTabPanel Text="Materiali" Icon="@Icons.Material.Filled.Science">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" Class="mr-1" />
                            Materiali (seleziona da tabelle)
                        </MudText>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSelect @bind-Value="ImballoSelezionato" Label="Imballo" Variant="Variant.Outlined" 
                                   AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem Value="@((int?)null)">(nessuno)</MudSelectItem>
                            @foreach (var item in imballoOptions)
                            {
                                <MudSelectItem Value="@(int.TryParse(item.Codice, out var v) ? (int?)v : null)">
                                    @item.Codice - @item.Descrizione
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSelect @bind-Value="Anime.Colla" Label="Colla" Variant="Variant.Outlined"
                                   AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem Value="@((string?)null)">(nessuna)</MudSelectItem>
                            @foreach (var item in collaOptions)
                            {
                                <MudSelectItem Value="@item.Codice">@item.Codice - @item.Descrizione</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSelect @bind-Value="Anime.Sabbia" Label="Sabbia" Variant="Variant.Outlined"
                                   AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem Value="@((string?)null)">(nessuna)</MudSelectItem>
                            @foreach (var item in sabbiaOptions)
                            {
                                <MudSelectItem Value="@item.Codice">@(string.IsNullOrEmpty(item.Codice) ? "(nessuna)" : $"{item.Codice} - {item.Descrizione}")</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSelect @bind-Value="Anime.Vernice" Label="Vernice" Variant="Variant.Outlined"
                                   AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem Value="@((string?)null)">(nessuna)</MudSelectItem>
                            @foreach (var item in verniceOptions)
                            {
                                <MudSelectItem Value="@item.Codice">@item.Codice - @item.Descrizione</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            
            <!-- Tab 3: Produzione -->
            <MudTabPanel Text="Produzione" Icon="@Icons.Material.Filled.Factory">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Class="mr-1" />
                            Parametri Produzione
                        </MudText>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField @bind-Value="Anime.QuantitaPiano" Label="Quantità Piano" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField @bind-Value="Anime.NumeroPiani" Label="Numero Piani" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField @bind-Value="Anime.Ciclo" Label="Ciclo" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField @bind-Value="Anime.Peso" Label="Peso" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField @bind-Value="Anime.Figure" Label="Figure" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField @bind-Value="Anime.Maschere" Label="Maschere" Variant="Variant.Outlined" />
                    </MudItem>
                    
                    <MudItem xs="12" Class="mt-4">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Small" Class="mr-1" />
                            Lavorazioni
                        </MudText>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSelect @bind-Value="Anime.TogliereSparo" Label="Togliere Sparo" Variant="Variant.Outlined">
                            <MudSelectItem Value="@((string?)null)">(non impostato)</MudSelectItem>
                            <MudSelectItem Value="@("0")">0 - No</MudSelectItem>
                            <MudSelectItem Value="@("1")">1 - Sì</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField @bind-Value="Anime.Incollata" Label="Incollata" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField @bind-Value="Anime.Assemblata" Label="Assemblata" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField @bind-Value="Anime.ArmataL" Label="Armata L" Variant="Variant.Outlined" />
                    </MudItem>
                    
                    <MudItem xs="12" Class="mt-4">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Straighten" Size="Size.Small" Class="mr-1" />
                            Dimensioni
                        </MudText>
                    </MudItem>
                    <MudItem xs="4">
                        <MudNumericField @bind-Value="Anime.Larghezza" Label="Larghezza" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="4">
                        <MudNumericField @bind-Value="Anime.Altezza" Label="Altezza" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="4">
                        <MudNumericField @bind-Value="Anime.Profondita" Label="Profondità" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            
            <!-- Tab 4: Macchine -->
            <MudTabPanel Text="Macchine" Icon="@Icons.Material.Filled.PrecisionManufacturing">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.PrecisionManufacturing" Size="Size.Small" Class="mr-1" />
                            Macchine Disponibili
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                            Seleziona le macchine su cui questa anima può essere prodotta. Le macchine selezionate saranno visibili nella colonna "MA" delle commesse aperte.
                        </MudText>
                    </MudItem>
                    <MudItem xs="12">
                        <MudStack Row="true" Spacing="2" Class="mb-3">
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.SelectAll" 
                                       OnClick="SelezionaTutteLeMacchine">
                                Seleziona Tutto
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Deselect" 
                                       OnClick="DeselezionaTutteLeMacchine">
                                Deseleziona Tutto
                            </MudButton>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12">
                        <MudPaper Outlined="true" Class="pa-3">
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                                @foreach (var macchina in macchineDisponibili)
                                {
                                    <MudCheckBox T="bool" 
                                                 Value="@macchineSelezionate.Contains(macchina.Codice)"
                                                 ValueChanged="@((bool val) => ToggleMacchina(macchina.Codice, val))"
                                                 Label="@($"{macchina.Codice} - {macchina.Nome}")"
                                                 Color="Color.Primary"
                                                 Dense="true" />
                                }
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            
            <!-- Tab 5: Note e Opzioni -->
            <MudTabPanel Text="Note" Icon="@Icons.Material.Filled.Notes">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Class="mr-1" />
                            Note e Allegati
                        </MudText>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="Anime.Note" Label="Note" Variant="Variant.Outlined" 
                                      Lines="4" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="Anime.Allegato" Label="Allegato" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSwitch @bind-Value="Anime.TrasmettiTutto" Label="Trasmetti Tutto" Color="Color.Primary" />
                    </MudItem>
                    
                    <MudItem xs="12" Class="mt-4">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="mr-1" />
                            Tracking
                        </MudText>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField Value="@(Anime.DataImportazione.ToString("dd/MM/yyyy HH:mm"))" Label="Data Importazione" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField Value="@(Anime.DataModificaRecord?.ToString("dd/MM/yyyy HH:mm") ?? "-")" Label="Data Modifica" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField Value="@(Anime.UtenteModificaRecord ?? "-")" Label="Utente Modifica" ReadOnly="true" Variant="Variant.Filled" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudChip T="string" Color="@(Anime.ModificatoLocalmente ? Color.Warning : Color.Default)" Size="Size.Small">
                            @(Anime.ModificatoLocalmente ? "Modificato localmente" : "Da Mago")
                        </MudChip>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annulla</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" OnClick="Save">
            Salva
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    
    [Parameter] public AnimeDto Anime { get; set; } = new();
    
    private List<TabellaItem> collaOptions = new();
    private List<TabellaItem> verniceOptions = new();
    private List<TabellaItem> sabbiaOptions = new();
    private List<TabellaItem> imballoOptions = new();
    private List<MacchinaDto> macchineDisponibili = new();
    private HashSet<string> macchineSelezionate = new();
    
    // Per gestire Imballo che è int? ma le opzioni sono stringhe
    private int? ImballoSelezionato
    {
        get => Anime.Imballo;
        set => Anime.Imballo = value;
    }
    
    protected override async Task OnInitializedAsync()
    {
        await CaricaOpzioniAsync();
        ParseMacchineSelezionate();
    }
    
    private async Task CaricaOpzioniAsync()
    {
        try
        {
            // Carica opzioni dropdown
            collaOptions = await Http.GetFromJsonAsync<List<TabellaItem>>("/api/Tabelle/colla") ?? new();
            verniceOptions = await Http.GetFromJsonAsync<List<TabellaItem>>("/api/Tabelle/vernice") ?? new();
            sabbiaOptions = await Http.GetFromJsonAsync<List<TabellaItem>>("/api/Tabelle/sabbia") ?? new();
            imballoOptions = await Http.GetFromJsonAsync<List<TabellaItem>>("/api/Tabelle/imballo") ?? new();
            
            // Carica lista macchine da impostazioni Gantt
            macchineDisponibili = await MacchinaService.GetListaAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading options: {ex.Message}");
        }
    }
    
    private void ParseMacchineSelezionate()
    {
        macchineSelezionate.Clear();
        if (!string.IsNullOrWhiteSpace(Anime.MacchineSuDisponibili))
        {
            var codici = Anime.MacchineSuDisponibili.Split(new[] { ';', ',' }, StringSplitOptions.RemoveEmptyEntries);
            foreach (var codice in codici)
            {
                macchineSelezionate.Add(codice.Trim());
            }
        }
    }
    
    private void ToggleMacchina(string codice, bool selected)
    {
        if (selected)
            macchineSelezionate.Add(codice);
        else
            macchineSelezionate.Remove(codice);
        
        AggiornaMacchineString();
    }
    
    private void SelezionaTutteLeMacchine()
    {
        macchineSelezionate.Clear();
        foreach (var m in macchineDisponibili)
        {
            macchineSelezionate.Add(m.Codice);
        }
        AggiornaMacchineString();
    }
    
    private void DeselezionaTutteLeMacchine()
    {
        macchineSelezionate.Clear();
        AggiornaMacchineString();
    }
    
    private void AggiornaMacchineString()
    {
        Anime.MacchineSuDisponibili = string.Join(";", macchineSelezionate.OrderBy(x => x));
    }
    
    private async Task Save()
    {
        try
        {
            // Imposta tracking modifiche locali
            Anime.ModificatoLocalmente = true;
            Anime.DataUltimaModificaLocale = DateTime.Now;
            
            var response = await Http.PutAsJsonAsync($"/api/Anime/{Anime.Id}", Anime);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Anima salvata con successo!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(Anime));
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Errore nel salvataggio: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }
    
    private void Cancel() => MudDialog.Cancel();
    
    public class TabellaItem
    {
        public string Codice { get; set; } = string.Empty;
        public string Descrizione { get; set; } = string.Empty;
    }
}
