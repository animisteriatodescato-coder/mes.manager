@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@inject IJSRuntime JS
@inject IPreventivoService PreventivoService
@inject IEmailService EmailService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<MudDialog Class="modulo-cliente-dialog" data-testid="dlg-modulo-cliente">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Description" />
            <MudText Typo="Typo.h6">Modulo Cliente - @Dto?.Cliente</MudText>
            @if (Dto?.NumeroPreventivo > 0)
            {
                <MudChip T="string" Color="Color.Info" Size="Size.Small">N° @Dto.NumeroPreventivo</MudChip>
            }
            <MudSpacer />
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (Dto == null)
        {
            <MudText>Dati non disponibili.</MudText>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                Anteprima — il PDF verrà aperto in una nuova finestra.
            </MudText>

            <!-- Anteprima compatta -->
            <MudSimpleTable Dense="true" Style="font-size:0.88rem">
                <tbody>
                    <tr><td><b>Cliente</b></td><td>@Dto.Cliente</td></tr>
                    @if (!string.IsNullOrWhiteSpace(Dto.CodiceArticolo))
                    { <tr><td><b>Codice articolo</b></td><td>@Dto.CodiceArticolo</td></tr> }
                    @if (!string.IsNullOrWhiteSpace(Dto.Descrizione))
                    { <tr><td><b>Descrizione</b></td><td>@Dto.Descrizione</td></tr> }
                    <tr><td><b>Figure / Peso / Lotto</b></td><td>@Dto.Figure fig. — @Dto.PesoAnima.ToString("N3") kg — @Dto.Lotto pz</td></tr>
                    @if (!string.IsNullOrWhiteSpace(Dto.SabbiaSnapshot))
                    { <tr><td><b>Tipo sabbia</b></td><td>@Dto.SabbiaSnapshot</td></tr> }
                </tbody>
            </MudSimpleTable>
            <MudDivider Class="my-2" />

            <!-- Prezzi per lotto (Feature 12: Margine + Sconto) -->
            <MudSimpleTable Dense="true" Style="font-size:0.88rem">
                <thead>
                    <tr>
                        <th>Lotto</th>
                        <th style="text-align:center">Margine</th>
                        <th style="text-align:center">Sconto</th>
                        <th style="text-align:right">Prezzo/pz</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (lotto, margine, prezzo) in GetLottiPrezziConMargine())
                    {
                        <tr>
                            <td>@lotto pz</td>
                            <td style="text-align:center">@(margine > 0 ? $"+{margine:N1}%" : "—")</td>
                            <td style="text-align:center">@(Dto.Sconto > 0 ? $"-{Dto.Sconto:N1}%" : "—")</td>
                            <td style="text-align:right"><b>€@prezzo.ToString("N4")</b></td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </DialogContent>
    <DialogActions>
        @if (Dto != null && EmailService.IsConfigured)
        {
            <MudTextField @bind-Value="_emailDestinatario"
                          Placeholder="Email destinatario..."
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="min-width:200px"
                          data-testid="input-email-dest" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Info"
                       StartIcon="@Icons.Material.Filled.Email"
                       OnClick="InviaEmailAsync"
                       Disabled="@(_isInvioEmail || string.IsNullOrWhiteSpace(_emailDestinatario))"
                       data-testid="btn-invia-email">
                @(_isInvioEmail ? "Invio..." : "Invia")
            </MudButton>
            @if (Dto.EmailInviatoIl.HasValue)
            {
                <MudText Typo="Typo.caption" Color="Color.Success">
                    @("✓") @Dto.EmailInviatoIl.Value.ToString("dd/MM HH:mm")
                </MudText>
            }
        }
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Print"
                   OnClick="StampaAsync"
                   data-testid="btn-stampa-modulo">
            Stampa / PDF
        </MudButton>
        <MudButton OnClick="Chiudi" data-testid="btn-chiudi-modulo">Chiudi</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public PreventivoDto? Dto { get; set; }

    private string _emailDestinatario = string.Empty;
    private bool _isInvioEmail;

    private async Task StampaAsync()
    {
        if (Dto == null) return;
        var baseUri = Nav.BaseUri.TrimEnd('/');
        var html = ModuloClientePrintBuilder.Build(Dto, baseUri, PreventivoService);
        await JS.InvokeVoidAsync("mesPreventivoPrint", html);
    }

    private void Chiudi() => MudDialog.Close(DialogResult.Ok(true));

    private async Task InviaEmailAsync()
    {
        if (Dto == null || string.IsNullOrWhiteSpace(_emailDestinatario)) return;
        _isInvioEmail = true;
        try
        {
            var baseUri = Nav.BaseUri.TrimEnd('/');
            var html = ModuloClientePrintBuilder.Build(Dto, baseUri, PreventivoService);
            var ok = await EmailService.InviaPreventivoPdfAsync(
                _emailDestinatario, html, Dto.Cliente, Dto.NumeroPreventivo);
            if (ok)
            {
                var aggiornato = await PreventivoService.RegistraInvioEmailAsync(Dto.Id, _emailDestinatario);
                if (aggiornato != null)
                {
                    Dto.EmailDestinatario = aggiornato.EmailDestinatario;
                    Dto.EmailInviatoIl = aggiornato.EmailInviatoIl;
                    Dto.Stato = aggiornato.Stato;
                }
                Snackbar.Add($"Preventivo inviato a {_emailDestinatario}", Severity.Success);
            }
            else
            {
                Snackbar.Add("Invio email non riuscito.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore invio email: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isInvioEmail = false;
        }
    }

    private IEnumerable<(int Lotto, decimal Margine, decimal Prezzo)> GetLottiPrezziConMargine()
    {
        if (Dto == null) yield break;
        if (Dto.Lotto > 0)
        {
            var r = PreventivoService.CalcolaConLotto(Dto, Dto.Lotto, Dto.Margine1);
            yield return (Dto.Lotto, Dto.Margine1, r.PrezzoVendita);
        }
        if (Dto.Lotto2.HasValue && Dto.Lotto2.Value > 0)
        {
            var r = PreventivoService.CalcolaConLotto(Dto, Dto.Lotto2.Value, Dto.Margine2);
            yield return (Dto.Lotto2.Value, Dto.Margine2, r.PrezzoVendita);
        }
        if (Dto.Lotto3.HasValue && Dto.Lotto3.Value > 0)
        {
            var r = PreventivoService.CalcolaConLotto(Dto, Dto.Lotto3.Value, Dto.Margine3);
            yield return (Dto.Lotto3.Value, Dto.Margine3, r.PrezzoVendita);
        }
        if (Dto.Lotto4.HasValue && Dto.Lotto4.Value > 0)
        {
            var r = PreventivoService.CalcolaConLotto(Dto, Dto.Lotto4.Value, Dto.Margine4);
            yield return (Dto.Lotto4.Value, Dto.Margine4, r.PrezzoVendita);
        }
    }
}

