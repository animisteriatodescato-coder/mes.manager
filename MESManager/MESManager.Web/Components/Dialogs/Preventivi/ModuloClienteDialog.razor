@using MESManager.Application.DTOs
@using MESManager.Application.Interfaces
@inject IJSRuntime JS
@inject IPreventivoService PreventivoService
@inject IEmailService EmailService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env

<MudDialog Class="modulo-cliente-dialog" data-testid="dlg-modulo-cliente">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Description" />
            <MudText Typo="Typo.h6">Modulo Cliente - @Dto?.Cliente</MudText>
            @if (Dto?.NumeroPreventivo > 0)
            {
                <MudChip T="string" Color="Color.Info" Size="Size.Small">N° @Dto.NumeroPreventivo</MudChip>
            }
            <MudSpacer />
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (Dto == null)
        {
            <MudText>Dati non disponibili.</MudText>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                Anteprima — il PDF verrà aperto in una nuova finestra.
            </MudText>

            <!-- Anteprima compatta -->
            <MudSimpleTable Dense="true" Style="font-size:0.88rem">
                <tbody>
                    <tr><td><b>Cliente</b></td><td>@Dto.Cliente</td></tr>
                    @if (!string.IsNullOrWhiteSpace(Dto.CodiceArticolo))
                    { <tr><td><b>Codice articolo</b></td><td>@Dto.CodiceArticolo</td></tr> }
                    @if (!string.IsNullOrWhiteSpace(Dto.Descrizione))
                    { <tr><td><b>Descrizione</b></td><td>@Dto.Descrizione</td></tr> }
                    <tr><td><b>Figure / Peso / Lotto</b></td><td>@Dto.Figure fig. — @Dto.PesoAnima.ToString("N3") kg — @Dto.Lotto pz</td></tr>
                    @if (!string.IsNullOrWhiteSpace(Dto.SabbiaSnapshot))
                    { <tr><td><b>Tipo sabbia</b></td><td>@Dto.SabbiaSnapshot</td></tr> }
                </tbody>
            </MudSimpleTable>
            <MudDivider Class="my-2" />

            <!-- Prezzi per lotto (Feature 12: Margine + Sconto) -->
            <MudSimpleTable Dense="true" Style="font-size:0.88rem">
                <thead>
                    <tr>
                        <th>Lotto</th>
                        <th style="text-align:center">Margine</th>
                        <th style="text-align:center">Sconto</th>
                        <th style="text-align:right">Prezzo/pz</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (lotto, margine, prezzo) in GetLottiPrezziConMargine())
                    {
                        <tr>
                            <td>@lotto pz</td>
                            <td style="text-align:center">@(margine > 0 ? $"+{margine:N1}%" : "—")</td>
                            <td style="text-align:center">@(Dto.Sconto > 0 ? $"-{Dto.Sconto:N1}%" : "—")</td>
                            <td style="text-align:right"><b>€@prezzo.ToString("N4")</b></td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>

            <!-- Condizioni di offerta editabili -->
            <MudDivider Class="my-2" />
            <MudPaper Elevation="0" Class="pa-2" Style="border:1px solid var(--mud-palette-lines-default);border-radius:4px">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
                    <MudIcon Icon="@Icons.Material.Filled.Gavel" Size="Size.Small" Color="@(_includiCondizioni ? Color.Secondary : Color.Default)" />
                    <MudText Typo="Typo.subtitle2" Style="@(_includiCondizioni ? "" : "text-decoration:line-through;opacity:.5")"><b>Condizioni di Offerta</b></MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">Modificabili prima della stampa</MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Text" Size="Size.Small"
                               Color="@(_includiCondizioni ? Color.Error : Color.Success)"
                               StartIcon="@(_includiCondizioni ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                               OnClick="@(() => _includiCondizioni = !_includiCondizioni)">
                        @(_includiCondizioni ? "Escludi dal PDF" : "Includi nel PDF")
                    </MudButton>
                    <MudIconButton Icon="@(_showCondizioni ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                   Size="Size.Small"
                                   OnClick="@(() => _showCondizioni = !_showCondizioni)" />
                </MudStack>
                @if (_showCondizioni)
                {
                    <MudStack Spacing="1">
                        @for (int i = 0; i < _condizioni.Count; i++)
                        {
                            var idx = i;
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width:20px;text-align:right">@(idx+1).</MudText>
                                <MudTextField T="string" Value="@_condizioni[idx]"
                                              ValueChanged="@(v => _condizioni[idx] = v ?? "")"
                                              Variant="Variant.Outlined" Margin="Margin.Dense"
                                              FullWidth="true" Lines="2"
                                              Style="font-size:12px" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                               OnClick="@(() => { _condizioni.RemoveAt(idx); StateHasChanged(); })"
                                               Title="Rimuovi" />
                            </MudStack>
                        }
                        <MudStack Row="true" Spacing="2" Class="mt-1">
                            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="@(() => { _condizioni.Add(""); StateHasChanged(); })">
                                Aggiungi condizione
                            </MudButton>
                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Warning"
                                       StartIcon="@Icons.Material.Filled.RestartAlt"
                                       OnClick="@RipristinaCondizioni">
                                Ripristina default
                            </MudButton>
                        </MudStack>
                    </MudStack>
                }
            </MudPaper>
        }
    </DialogContent>
    <DialogActions>
        @if (Dto != null && EmailService.IsConfigured)
        {
            <MudTextField @bind-Value="_emailDestinatario"
                          Placeholder="Email destinatario..."
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Style="min-width:200px"
                          data-testid="input-email-dest" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Info"
                       StartIcon="@Icons.Material.Filled.Email"
                       OnClick="InviaEmailAsync"
                       Disabled="@(_isInvioEmail || string.IsNullOrWhiteSpace(_emailDestinatario))"
                       data-testid="btn-invia-email">
                @(_isInvioEmail ? "Invio..." : "Invia")
            </MudButton>
            @if (Dto.EmailInviatoIl.HasValue)
            {
                <MudText Typo="Typo.caption" Color="Color.Success">
                    @("✓") @Dto.EmailInviatoIl.Value.ToString("dd/MM HH:mm")
                </MudText>
            }
        }
        <MudTooltip Text="Dimensione testo PDF (pt)">
            <MudNumericField T="decimal" @bind-Value="_fontSize"
                             Min="7" Max="14" Step="0.5m"
                             Variant="Variant.Outlined" Margin="Margin.Dense"
                             Style="width:80px" Label="Font" />
        </MudTooltip>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Warning"
                   StartIcon="@Icons.Material.Filled.Lock"
                   OnClick="@(() => StampaAsync(true))"
                   data-testid="btn-stampa-interna">
            Interna
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Print"
                   OnClick="@(() => StampaAsync(false))"
                   data-testid="btn-stampa-cliente">
            Cliente
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.Download"
                   OnClick="ScaricanPdfAsync"
                   Disabled="@_isScaricaPdf"
                   data-testid="btn-scarica-pdf">
            @(_isScaricaPdf ? "Generazione..." : "Scarica PDF")
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.MailOutline"
                   OnClick="ApriMailAsync"
                   data-testid="btn-apri-mail">
            Nuova Mail
        </MudButton>
        <MudButton OnClick="Chiudi" data-testid="btn-chiudi-modulo">Chiudi</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public PreventivoDto? Dto { get; set; }

    private string _emailDestinatario = string.Empty;
    private bool _isInvioEmail;
    private bool _isScaricaPdf;
    private decimal _fontSize = 10.5m;
    private const string FontSizeKey = "preventivo_fontsize";

    // ── Condizioni di offerta (editabili pre-stampa) ──────────────────────────
    private bool _showCondizioni = false;
    private bool _includiCondizioni = false;
    private List<string> _condizioni = new()
    {
        "La presente offerta ha validità <strong>90 giorni</strong> dalla data di emissione.",
        "I prezzi sono soggetti a revisione in funzione dell'andamento dei costi delle materie prime e dei vettori energetici.",
        "Prezzi IVA esclusa. L'imposta sarà applicata secondo l'aliquota vigente al momento della fatturazione.",
        "Pagamento: secondo accordi commerciali in essere."
    };

    private void RipristinaCondizioni() => _condizioni = new()
    {
        "La presente offerta ha validità <strong>90 giorni</strong> dalla data di emissione.",
        "I prezzi sono soggetti a revisione in funzione dell'andamento dei costi delle materie prime e dei vettori energetici.",
        "Prezzi IVA esclusa. L'imposta sarà applicata secondo l'aliquota vigente al momento della fatturazione.",
        "Pagamento: secondo accordi commerciali in essere."
    };

    protected override async Task OnInitializedAsync()
    {
        var saved = await JS.InvokeAsync<string?>("localStorage.getItem", FontSizeKey);
        if (saved != null && decimal.TryParse(saved, System.Globalization.NumberStyles.Float,
            System.Globalization.CultureInfo.InvariantCulture, out var fs) && fs >= 7 && fs <= 14)
            _fontSize = fs;
    }

    private async Task StampaAsync(bool interna)
    {
        if (Dto == null) return;
        await JS.InvokeVoidAsync("localStorage.setItem", FontSizeKey,
            _fontSize.ToString(System.Globalization.CultureInfo.InvariantCulture));
        var baseUri = Nav.BaseUri.TrimEnd('/');
        var logo = LeggiLogoInline();
        var html = ModuloClientePrintBuilder.Build(Dto, baseUri, PreventivoService, interna, _fontSize, logo, _includiCondizioni ? _condizioni : null);
        await JS.InvokeVoidAsync("mesPreventivoPrint", html);
    }

    private string? LeggiLogoInline()
    {
        try
        {
            // PNG preferito: caricato come data URI base64 (sempre visibile in stampa)
            var pngPath = Path.Combine(Env.WebRootPath, "images", "logo-intestazione.png");
            if (File.Exists(pngPath))
            {
                var b64 = Convert.ToBase64String(File.ReadAllBytes(pngPath));
                return $"<img src=\"data:image/png;base64,{b64}\" style=\"max-height:110px;width:auto;display:block\" alt=\"Animisteria Todescato\" />";
            }
            // Fallback SVG inline
            var svgPath = Path.Combine(Env.WebRootPath, "images", "logo-intestazione.svg");
            if (File.Exists(svgPath))
            {
                var svgContent = File.ReadAllText(svgPath);
                // Rimuove la dichiarazione XML se presente (non valida in HTML inline)
                if (svgContent.StartsWith("<?xml"))
                    svgContent = svgContent.Substring(svgContent.IndexOf("?>") + 2).TrimStart();
                return svgContent;
            }
        }
        catch { }
        return null;
    }

    private void Chiudi() => MudDialog.Close(DialogResult.Ok(true));

    private async Task ScaricanPdfAsync()
    {
        if (Dto == null) return;
        _isScaricaPdf = true;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", FontSizeKey,
                _fontSize.ToString(System.Globalization.CultureInfo.InvariantCulture));
            var baseUri = Nav.BaseUri.TrimEnd('/');
            var logo = LeggiLogoInline();
            var html = ModuloClientePrintBuilder.Build(Dto, baseUri, PreventivoService, interna: false, _fontSize, logo, _includiCondizioni ? _condizioni : null);
            // Nome file: Preventivo_N42_BianchiSrl_20260423.pdf
            var clienteSafe = System.Text.RegularExpressions.Regex.Replace(Dto.Cliente ?? "Cliente", @"[^\w]", "");
            var numStr = Dto.NumeroPreventivo > 0 ? $"N{Dto.NumeroPreventivo}" : $"ID{Dto.Id}";
            var fileName = $"Preventivo_{numStr}_{clienteSafe}_{DateTime.Today:yyyyMMdd}.pdf";
            await JS.InvokeVoidAsync("mesPreventivoDownloadPdf", html, fileName);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore generazione PDF: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isScaricaPdf = false;
        }
    }

    private async Task ApriMailAsync()
    {
        if (Dto == null) return;
        var numStr = Dto.NumeroPreventivo > 0 ? $"N\u00b0 {Dto.NumeroPreventivo}" : "";
        var oggetto = string.IsNullOrWhiteSpace(numStr)
            ? $"Offerta \u2013 {Dto.Cliente}"
            : $"Offerta {numStr} \u2013 {Dto.Cliente}";
        var corpo =
            $"Buongiorno,\n\n" +
            $"in allegato alla presente trovate l'offerta richiesta.\n\n" +
            $"Rimaniamo a disposizione per qualsiasi chiarimento.\n\n" +
            $"Cordiali saluti,\n" +
            $"Animisteria Todescato\n" +
            $"Via Luigi Galvani 44/46 - 36066 Sandrigo (VI)\n" +
            $"Tel: 0444 658208\n" +
            $"info@animisteriatodescato.it";
        var destinatario = Dto.EmailDestinatario ?? "";
        await JS.InvokeVoidAsync("mesPreventivoApriMail", destinatario, oggetto, corpo);
    }

    private async Task InviaEmailAsync()
    {
        if (Dto == null || string.IsNullOrWhiteSpace(_emailDestinatario)) return;
        _isInvioEmail = true;
        try
        {
            var baseUri = Nav.BaseUri.TrimEnd('/');
            var logo = LeggiLogoInline();
            var html = ModuloClientePrintBuilder.Build(Dto, baseUri, PreventivoService, interna: false, _fontSize, logo, _includiCondizioni ? _condizioni : null);
            var ok = await EmailService.InviaPreventivoPdfAsync(
                _emailDestinatario, html, Dto.Cliente, Dto.NumeroPreventivo);
            if (ok)
            {
                var aggiornato = await PreventivoService.RegistraInvioEmailAsync(Dto.Id, _emailDestinatario);
                if (aggiornato != null)
                {
                    Dto.EmailDestinatario = aggiornato.EmailDestinatario;
                    Dto.EmailInviatoIl = aggiornato.EmailInviatoIl;
                    Dto.Stato = aggiornato.Stato;
                }
                Snackbar.Add($"Preventivo inviato a {_emailDestinatario}", Severity.Success);
            }
            else
            {
                Snackbar.Add("Invio email non riuscito.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore invio email: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isInvioEmail = false;
        }
    }

    private IEnumerable<(int Lotto, decimal Margine, decimal Prezzo)> GetLottiPrezziConMargine()
    {
        if (Dto == null) yield break;
        if (Dto.Lotto > 0)
        {
            var r = PreventivoService.CalcolaConLotto(Dto, Dto.Lotto, Dto.Margine1);
            yield return (Dto.Lotto, Dto.Margine1, r.PrezzoVendita);
        }
        if (Dto.Lotto2.HasValue && Dto.Lotto2.Value > 0)
        {
            var r = PreventivoService.CalcolaConLotto(Dto, Dto.Lotto2.Value, Dto.Margine2);
            yield return (Dto.Lotto2.Value, Dto.Margine2, r.PrezzoVendita);
        }
        if (Dto.Lotto3.HasValue && Dto.Lotto3.Value > 0)
        {
            var r = PreventivoService.CalcolaConLotto(Dto, Dto.Lotto3.Value, Dto.Margine3);
            yield return (Dto.Lotto3.Value, Dto.Margine3, r.PrezzoVendita);
        }
        if (Dto.Lotto4.HasValue && Dto.Lotto4.Value > 0)
        {
            var r = PreventivoService.CalcolaConLotto(Dto, Dto.Lotto4.Value, Dto.Margine4);
            yield return (Dto.Lotto4.Value, Dto.Margine4, r.PrezzoVendita);
        }
    }
}

