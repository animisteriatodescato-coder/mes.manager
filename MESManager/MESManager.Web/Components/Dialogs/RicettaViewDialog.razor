@using MESManager.Application.DTOs
@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject ILogger<RicettaViewDialog> Logger

<MudDialog Style="max-width: 1000px;" data-testid="dlg-ricetta-view">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Ricetta: @CodiceArticolo</MudText>
            @if (ricetta != null && ricetta.TotaleParametri > 0)
            {
                <MudChip T="string" Color="Color.Info" Size="Size.Small">
                    @ricetta.TotaleParametri parametri
                </MudChip>
            }
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-6">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.body1">Caricamento ricetta in corso...</MudText>
            </MudStack>
        }
        else if (ricetta == null)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4">
                Nessuna ricetta trovata per l'articolo <strong>@CodiceArticolo</strong>.
            </MudAlert>
        }
        else
        {
            <MudStack Spacing="2" Class="mb-3">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                    @ricetta.DescrizioneArticolo
                </MudText>
                <MudDivider />
            </MudStack>

            <MudTable Items="@ricetta.Parametri" 
                     Dense="true" 
                     Hover="true" 
                     Striped="true"
                     FixedHeader="true"
                     Height="450px">
                <HeaderContent>
                    <MudTh Style="width: 80px;">Cod.</MudTh>
                    <MudTh>Descrizione Parametro</MudTh>
                    <MudTh Style="width: 100px; text-align: center;">Indirizzo</MudTh>
                    <MudTh Style="width: 80px; text-align: center;">Area</MudTh>
                    <MudTh Style="width: 80px; text-align: center;">Tipo</MudTh>
                    <MudTh Style="width: 80px; text-align: center;">UM</MudTh>
                    <MudTh Style="width: 120px; text-align: right;"><strong>Valore</strong></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Cod.">
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@context.CodiceParametro</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Descrizione">@context.DescrizioneParametro</MudTd>
                    <MudTd DataLabel="Indirizzo" Style="text-align: center;">@context.Indirizzo</MudTd>
                    <MudTd DataLabel="Area" Style="text-align: center;">@context.Area</MudTd>
                    <MudTd DataLabel="Tipo" Style="text-align: center;">@context.Tipo</MudTd>
                    <MudTd DataLabel="UM" Style="text-align: center;">@(context.UM ?? "-")</MudTd>
                    <MudTd DataLabel="Valore" Style="text-align: right; cursor: pointer;">
                        <MudTooltip Text="Doppio clic per modificare">
                            <MudText @ondblclick="@(async () => { if (!IsReadOnly) await OpenModificaAsync(context); })"
                                     Typo="Typo.body1" Color="Color.Primary">
                                <strong>@context.Valore</strong>
                            </MudText>
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </DialogContent>
    <DialogActions>
        @if (ShowImportButton && !IsReadOnly && !string.IsNullOrEmpty(CodiceArticolo))
        {
            <MudButton OnClick="ApriImportaRicettaAsync"
                       Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Download"
                       data-testid="btn-importa-ricetta-da-macchina">
                Importa da Macchina
            </MudButton>
        }
        @if (ShowTransmitButton && !IsReadOnly && !string.IsNullOrEmpty(CodiceArticolo) && ricetta != null)
        {
            <MudButton OnClick="ApriTrasmmettiRicettaAsync"
                       Variant="Variant.Outlined"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Send"
                       data-testid="btn-trasmetti-toggle">
                Trasmetti alla Macchina
            </MudButton>
        }
        <MudSpacer />
        <MudButton OnClick="Close" Variant="Variant.Filled" Color="Color.Primary">Chiudi</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string CodiceArticolo { get; set; } = string.Empty;

    /// <summary>Se true, mostra il pulsante "Importa da Macchina" nel footer del dialog.</summary>
    [Parameter] public bool ShowImportButton { get; set; } = false;

    /// <summary>Se true, mostra il pulsante "Trasmetti alla Macchina" (invia ricetta al PLC).</summary>
    [Parameter] public bool ShowTransmitButton { get; set; } = false;

    /// <summary>Se true, nasconde i pulsanti di scrittura (modalità sola lettura).</summary>
    [Parameter] public bool IsReadOnly { get; set; } = false;

    private RicettaArticoloDto? ricetta;
    private bool isLoading = true;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadRicetta();
    }
    
    private async Task LoadRicetta()
    {
        if (string.IsNullOrWhiteSpace(CodiceArticolo))
        {
            isLoading = false;
            return;
        }
        
        try
        {
            isLoading = true;
            
            await JS.InvokeVoidAsync("console.log", $"[RicettaViewDialog] Caricamento ricetta per: {CodiceArticolo}");
            
            // Usa endpoint diretto invece di search
            var response = await Http.GetAsync($"/api/RicetteArticoli/{string.Join('/', CodiceArticolo.Split('/').Select(Uri.EscapeDataString))}");
            
            await JS.InvokeVoidAsync("console.log", $"[RicettaViewDialog] Response status: {response.StatusCode}");
            
            if (response.IsSuccessStatusCode)
            {
                ricetta = await response.Content.ReadFromJsonAsync<RicettaArticoloDto>();
                await JS.InvokeVoidAsync("console.log", $"[RicettaViewDialog] Ricetta caricata: {ricetta?.TotaleParametri ?? 0} parametri");
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("console.error", $"[RicettaViewDialog] Error: {response.StatusCode} - {errorContent}");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore caricamento ricetta: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private async Task ApriImportaRicettaAsync()
    {
        var parameters = new DialogParameters<ImportaRicettaMacchinaDialog>
        {
            { x => x.CodiceArticolo, CodiceArticolo }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };
        var dialog = await DialogService.ShowAsync<ImportaRicettaMacchinaDialog>(
            "Importa Ricetta da Macchina", parameters, options);
        var result = await dialog.Result;
        // Se l'import ha avuto successo, ricarica la ricetta nel dialog corrente
        if (result is { Canceled: false, Data: true })
        {
            await LoadRicetta();
        }
    }

    private void Close() => MudDialog.Close();

    private async Task ApriTrasmmettiRicettaAsync()
    {
        var parameters = new DialogParameters<TrasmmettiRicettaMacchinaDialog>
        {
            { x => x.CodiceArticolo, CodiceArticolo }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };
        await DialogService.ShowAsync<TrasmmettiRicettaMacchinaDialog>(
            "Trasmetti Ricetta alla Macchina", parameters, options);
    }

    private async Task OpenModificaAsync(ParametroRicettaArticoloDto parametro)
    {
        var dlgParams = new DialogParameters<ModificaValoreRicettaDialog>
        {
            { x => x.Parametro, parametro }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };
        var dialog = await DialogService.ShowAsync<ModificaValoreRicettaDialog>("", dlgParams, options);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: int newVal })
        {
            parametro.Valore = newVal;
            var response = await Http.PutAsJsonAsync(
                $"/api/RicetteArticoli/parametro/{parametro.ParametroId}/valore",
                new { Valore = newVal });
            if (response.IsSuccessStatusCode)
                Snackbar.Add($"{parametro.DescrizioneParametro} → {newVal}", Severity.Success);
            else
                Snackbar.Add("Errore durante il salvataggio", Severity.Error);
        }
    }
}
