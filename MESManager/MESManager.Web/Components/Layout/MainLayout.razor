                                    <div style="display: flex; align-items: center; gap: 8px;"><span style="font-size: 13px;">&#9889;</span><span>PLC Realtime</span></div>
                                </MudNavLink>
                            }
                            @if (_canPlcSt)
                            {
                                <MudNavLink Href="/produzione/plc-storico">
                                    <div style="display: flex; align-items: center; gap: 8px;"><span style="font-size: 13px;">&#128220;</span><span>PLC Storico</span></div>
                                </MudNavLink>
                            }
                            @if (_canGantt)
                            {
                                <MudNavLink Href="/produzione/gantt-storico">
                                    <div style="display: flex; align-items: center; gap: 8px;"><span style="font-size: 13px;">&#128202;</span><span>Gantt Storico</span></div>
                                </MudNavLink>
