@inherits LayoutComponentBase
@using MESManager.Web.Services
@using MESManager.Web.Components.Shared
@using MESManager.Web.Constants
@using System.Security.Claims
@implements IDisposable

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@* CSS variables custom: accessibili da tutti i file CSS dell'app come var(--mes-*)
   Fornisce i valori iniziali (SSR). ThemeCssService.ApplyAsync() li aggiorna dopo il primo render. *@
@{
    var _s          = UserThemeService.GetEffectiveSettings();
    var _panelOp    = _s.ThemePanelOpacity;
    // Risolve AppBar/Drawer con variante dark mode (stessa logica di ThemeCssService, ZERO duplicazione)
    var _appBarBg   = (_isDarkMode && !string.IsNullOrEmpty(_s.ThemeAppBarBgColorDark))
        ? _s.ThemeAppBarBgColorDark
        : (!string.IsNullOrEmpty(_s.ThemeAppBarBgColor) ? _s.ThemeAppBarBgColor : MesDesignTokens.AppBarBg(_isDarkMode));
    var _drawerBg   = (_isDarkMode && !string.IsNullOrEmpty(_s.ThemeDrawerBgColorDark))
        ? _s.ThemeDrawerBgColorDark
        : (!string.IsNullOrEmpty(_s.ThemeDrawerBgColor) ? _s.ThemeDrawerBgColor : _appBarBg);
    var _buttonColor = !string.IsNullOrEmpty(_s.ThemeButtonColor) ? _s.ThemeButtonColor : _s.ThemePrimaryColor;
    var _buttonText  = !string.IsNullOrEmpty(_s.ThemeButtonTextColor) ? _s.ThemeButtonTextColor : AppSettingsService.ComputeTextOnBackground(_buttonColor);
    // Sorgente tinting righe: cascade drawer → appbar. Se entrambi acromatici → token fisso (stessa logica ThemeCssService)
    var _rowTintColor = MesDesignTokens.IsSufficientlyChromatic(_drawerBg)  ? _drawerBg
                      : MesDesignTokens.IsSufficientlyChromatic(_appBarBg)  ? _appBarBg
                      : null;
}
<style>
    :root {
        --mes-text-on-primary: @(_s.ThemeTextOnPrimary);
        --mes-primary: @(_s.ThemePrimaryColor);
        --mes-primary-text: @(_s.ThemePrimaryTextColor);
        --mes-nav-text: @(string.IsNullOrEmpty(_s.ThemeNavTextColor) ? MesDesignTokens.NavTextAuto(_isDarkMode) : _s.ThemeNavTextColor);
        --mes-bg-opacity: @(_s.ThemeBgOpacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture));
        --mes-panel-opacity: @(_s.ThemePanelOpacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture));
        --mes-appbar-bg: @_appBarBg;
        --appbar-height: 48px; /* Dense=true MudBlazor */
        --mes-drawer-bg: @_drawerBg;
        --mes-button-color: @_buttonColor;
        --mes-button-text: @_buttonText;
        /* Colori tabelle — tinting dal menu laterale/appbar se saturo, altrimenti token fisso */
        --mes-row-odd:  @(_rowTintColor is null ? MesDesignTokens.RowOdd(_isDarkMode)  : MesDesignTokens.RowOddFromColor(_rowTintColor, _isDarkMode));
        --mes-row-even: @(_rowTintColor is null ? MesDesignTokens.RowEven(_isDarkMode) : MesDesignTokens.RowEvenFromColor(_rowTintColor, _isDarkMode));
        --mes-row-text: @MesDesignTokens.RowText(_isDarkMode);
        --mes-grid-header-bg: var(--mes-drawer-bg);
        --mes-glass-grid: @MesDesignTokens.GlassGrid(_isDarkMode, _panelOp);
        /* Token AG Grid panel — used by app.css (.mud-theme-dark) and catalog/program pages */
        --mes-text-primary:    @MesDesignTokens.RowText(_isDarkMode);
        --mes-bg-secondary:    @(_isDarkMode ? MesDesignTokens.AgPanelBgDark : "#F5F5F5");
        --mes-bg-surface:      @(_isDarkMode ? MesDesignTokens.AgInputBgDark : "#FFFFFF");
        --mes-grid-border:     @(_isDarkMode ? MesDesignTokens.AgInputBorderDark : "#e0e0e0");
        --mes-ag-panel-bg:     @(_isDarkMode ? MesDesignTokens.AgPanelBgDark : "#FFFFFF");
        --mes-ag-input-bg:     @(_isDarkMode ? MesDesignTokens.AgInputBgDark : "#FFFFFF");
        --mes-ag-input-border: @(_isDarkMode ? MesDesignTokens.AgInputBorderDark : "#e0e0e0");
        /* Glass effect + Machine card — aggiornati da ThemeCssService su ogni cambio */
        --mes-glass-panel:             @MesDesignTokens.GlassPanel(_isDarkMode, _panelOp);
        --mes-machine-card-bg:         @MesDesignTokens.MachineCardBg(_isDarkMode);
        --mes-machine-card-text:       @MesDesignTokens.MachineCardText(_isDarkMode);
        --mes-machine-card-text-muted: @MesDesignTokens.MachineCardTextMuted(_isDarkMode);
        --mes-machine-card-number:     @MesDesignTokens.MachineCardNumber(_isDarkMode);
        /* AG Grid celle condizionali — aggiornate da ThemeCssService su dark mode toggle */
        --mes-readonly-cell-bg:   @(_isDarkMode ? "rgba(255,255,255,0.06)" : "rgba(0,0,0,0.04)");
        --mes-stato-aperta-bg:    @(_isDarkMode ? "#1b3a22" : "#e8f5e9");
        --mes-stato-aperta-color: @(_isDarkMode ? "#80c783" : "#2e7d32");
        --mes-stato-chiusa-bg:    @(_isDarkMode ? "#3a1828" : "#fce4ec");
        --mes-stato-chiusa-color: @(_isDarkMode ? "#f48fb1" : "#c2185b");
        --mes-count-foto-bg:      @(_isDarkMode ? "#1b3a22" : "#e8f5e9");
        --mes-count-foto-color:   @(_isDarkMode ? "#80c783" : "#2e7d32");
        --mes-count-doc-bg:       @(_isDarkMode ? "#0d2740" : "#e3f2fd");
        --mes-count-doc-color:    @(_isDarkMode ? "#90caf9" : "#1565c0");
        /* % Scarti (PLC Storico) — stesso pattern di mes-stato-*/
        --mes-scarti-ok-bg:       @(_isDarkMode ? "#1a3a5c" : "#e3f2fd");
        --mes-scarti-ok-color:    @(_isDarkMode ? "#64b5f6" : "#1565c0");
        --mes-scarti-warn-bg:     @(_isDarkMode ? "#4a2e00" : "#fff3e0");
        --mes-scarti-warn-color:  @(_isDarkMode ? "#ffa726" : "#e65100");
        --mes-scarti-error-bg:    @(_isDarkMode ? "#5c1022" : "#fce4ec");
        --mes-scarti-error-color: @(_isDarkMode ? "#e57373" : "#b71c1c");
    }
    /* Drawer nav: icone +15% (13→15, 16→18), testo BOLD */
    .mud-drawer [data-testid="nav-menu"] span[style*="font-size: 13px"] { font-size: 15px !important; }
    .mud-drawer [data-testid="nav-menu"] span[style*="font-size: 16px"] { font-size: 18px !important; text-transform: uppercase !important; font-weight: 700 !important; letter-spacing: 0.07em !important; }
    .mud-drawer [data-testid="nav-menu"] span:not([style]) { font-size: 15px; font-weight: 700 !important; }
    .mud-drawer [data-testid="nav-menu"] .mud-nav-link-text { font-size: 15px !important; font-weight: 700 !important; }
    .mud-drawer [data-testid="nav-menu"] .mud-list-item-text span { font-size: 15px !important; font-weight: 700 !important; }
    .mud-drawer [data-testid="nav-menu"] .mud-nav-link-text span { font-weight: 700 !important; }

    /* ── Titoli gruppi nav: spostati in app.css (BIBBIA: CSS globali → app.css) ── */
    /* Colore testo nav: usa impostazione utente (--mes-nav-text) */
    .mud-drawer [data-testid="nav-menu"] .mud-nav-link-text,
    .mud-drawer [data-testid="nav-menu"] .mud-nav-link-text span,
    .mud-drawer [data-testid="nav-menu"] span:not([style]),
    .mud-drawer .mud-nav-group-header .mud-typography,
    .mud-drawer .mud-nav-group-header span {
        color: var(--mes-nav-text) !important;
    }
    /* AppBar: testo e titolo seguono lo stesso colore del menu laterale */
    .mud-appbar .mud-toolbar-appbar,
    .mud-appbar .mud-toolbar,
    .mud-appbar .mud-typography,
    .mud-appbar h1, .mud-appbar h2, .mud-appbar h3, .mud-appbar h4, .mud-appbar h5, .mud-appbar h6,
    .mud-appbar span:not(.mud-chip-content):not(.mud-icon-root),
    [data-testid="main-appbar"],
    [data-testid="main-appbar"] .mud-typography,
    [data-testid="main-appbar"] span:not(.mud-icon-root) {
        color: var(--mes-nav-text) !important;
    }
</style>

<style>
    /* ── AG Grid — usa CSS vars definite in :root sopra ─────────────────── */
    .ag-theme-alpine .ag-root-wrapper,
    .ag-theme-alpine-dark .ag-root-wrapper {
        background-color: var(--mes-glass-grid) !important;
    }
    .ag-theme-alpine .ag-header,
    .ag-theme-alpine-dark .ag-header,
    .ag-theme-alpine .ag-header-row,
    .ag-theme-alpine-dark .ag-header-row {
        background-color: var(--mes-grid-header-bg) !important;
    }
    .ag-theme-alpine .ag-header-cell,
    .ag-theme-alpine-dark .ag-header-cell,
    .ag-theme-alpine .ag-header-cell-text,
    .ag-theme-alpine-dark .ag-header-cell-text,
    .ag-theme-alpine .ag-header-icon,
    .ag-theme-alpine-dark .ag-header-icon {
        color: var(--mes-nav-text) !important;
    }
    .ag-theme-alpine .ag-row-even,
    .ag-theme-alpine-dark .ag-row-even {
        background-color: var(--mes-row-even) !important;
    }
    .ag-theme-alpine .ag-row-odd,
    .ag-theme-alpine-dark .ag-row-odd {
        background-color: var(--mes-row-odd) !important;
    }
    .ag-theme-alpine .ag-cell,
    .ag-theme-alpine-dark .ag-cell {
        color: var(--mes-row-text) !important;
    }
    /* ── Classi condizionali (cellClassRules) — usano CSS vars aggiornate da ThemeCssService */
    /* Colonne read-only (Codice, Descrizione, Cliente) */
    .ag-theme-alpine .ag-cell.mes-readonly-cell {
        background-color: var(--mes-readonly-cell-bg) !important;
    }
    /* Stato commessa */
    .ag-theme-alpine .ag-cell.mes-stato-aperta {
        background-color: var(--mes-stato-aperta-bg) !important;
        color: var(--mes-stato-aperta-color) !important;
        font-weight: bold;
    }
    .ag-theme-alpine .ag-cell.mes-stato-chiusa {
        background-color: var(--mes-stato-chiusa-bg) !important;
        color: var(--mes-stato-chiusa-color) !important;
        font-weight: bold;
    }
    /* Contatori allegati */
    .ag-theme-alpine .ag-cell.mes-count-foto {
        background-color: var(--mes-count-foto-bg) !important;
        color: var(--mes-count-foto-color) !important;
        font-weight: bold;
    }
    .ag-theme-alpine .ag-cell.mes-count-doc {
        background-color: var(--mes-count-doc-bg) !important;
        color: var(--mes-count-doc-color) !important;
        font-weight: bold;
    }
    /* % Scarti (PlcStorico) — usa CSS vars dark/light come mes-stato-* */
    .ag-theme-alpine .ag-cell.mes-scarti-ok {
        background-color: var(--mes-scarti-ok-bg) !important;
        color: var(--mes-scarti-ok-color) !important;
        font-weight: bold;
    }
    .ag-theme-alpine .ag-cell.mes-scarti-warn {
        background-color: var(--mes-scarti-warn-bg) !important;
        color: var(--mes-scarti-warn-color) !important;
        font-weight: bold;
    }
    .ag-theme-alpine .ag-cell.mes-scarti-error {
        background-color: var(--mes-scarti-error-bg) !important;
        color: var(--mes-scarti-error-color) !important;
        font-weight: bold;
    }
    /* ── Barra paginazione — colore testo uguale agli header colonne ────────
       Questo stile carica DOPO app.css (inline) quindi vince su qualsiasi
       override AG Grid. Copre: "1 to 100 of 663", "Page 1 of 7", "100 ▼". */
    .ag-theme-alpine .ag-paging-panel,
    .ag-theme-alpine .ag-paging-panel span,
    .ag-theme-alpine .ag-paging-row-summary-panel,
    .ag-theme-alpine .ag-paging-page-summary-panel,
    .ag-theme-alpine .ag-paging-page-size,
    .ag-theme-alpine .ag-paging-page-size span,
    .ag-theme-alpine .ag-paging-button,
    .ag-theme-alpine .ag-picker-field-display {
        color: var(--mes-row-text) !important;
    }
    .ag-theme-alpine .ag-paging-button .ag-icon {
        color: var(--mes-row-text) !important;
    }
</style>

<style>
    /* ══ AppBar + Drawer: colori separati — sempre applicati (con o senza sfondo) ════════ */
    .mud-appbar {
        background-color: var(--mes-appbar-bg) !important;
    }
    .mud-drawer {
        background-color: var(--mes-drawer-bg) !important;
    }
    /* Trasparenza interna drawer: sfondo transparent per tutti i blocchi figli */
    .mud-drawer .mud-drawer-content,
    .mud-drawer .mud-drawer-header,
    .mud-drawer .mud-navmenu,
    .mud-drawer .mud-nav-group,
    .mud-drawer .mud-nav-group-items,
    .mud-drawer .mud-nav-link,
    .mud-drawer .mud-list,
    .mud-drawer [data-testid="nav-menu"] {
        background-color: transparent !important;
        background: transparent !important;
    }
    /* ══ Pulsanti principali (Color.Primary Variant.Filled) — colore separato dal Primary ═══ */
    .mud-button-root.mud-button-filled-primary {
        background-color: var(--mes-button-color) !important;
        color: var(--mes-button-text) !important;
    }
    .mud-button-root.mud-button-filled-primary .mud-icon-root {
        color: var(--mes-button-text) !important;
    }
    .mud-button-root.mud-button-filled-primary:hover {
        filter: brightness(0.90);
    }
</style>

<style>
    /* ══ Machine card — sempre applicato, indipendente dallo sfondo ════════════ */
    .machine-card {
        background: var(--mes-machine-card-bg) !important;
    }
    .machine-card,
    .machine-card .mud-typography,
    .machine-card .mud-card-header,
    .machine-card .mud-card-content,
    .machine-card .mud-card-actions,
    .machine-card .mud-input-label,
    .machine-card p,
    .machine-card span:not(.mud-chip-content) {
        color: var(--mes-machine-card-text) !important;
    }
    .machine-card .machine-number {
        color: var(--mes-machine-card-number) !important;
    }
    .machine-card .section-title {
        color: var(--mes-machine-card-text-muted) !important;
    }

    /* ══ Glass effect — attivo solo quando MudLayout ha classe .mes-has-bg ════ */

    /* Pannelli nel contenuto pagina — esclude le machine-card */
    .mes-has-bg .mud-main-content .mud-paper:not(.machine-card),
    .mes-has-bg .mud-main-content .mud-card:not(.machine-card) {
        background-color: var(--mes-glass-panel) !important;
        background:        var(--mes-glass-panel) !important;
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
    }

    /* AppBar + Drawer — blur aggiuntivo con sfondo immagine */
    .mes-has-bg .mud-appbar {
        backdrop-filter: blur(12px) saturate(1.4);
        -webkit-backdrop-filter: blur(12px) saturate(1.4);
    }
    .mes-has-bg .mud-drawer {
        backdrop-filter: blur(12px) saturate(1.4);
        -webkit-backdrop-filter: blur(12px) saturate(1.4);
    }

    /* Backdrop blur griglie con sfondo attivo */
    .mes-has-bg .mud-main-content .ag-theme-alpine .ag-root-wrapper,
    .mes-has-bg .mud-main-content .ag-theme-alpine-dark .ag-root-wrapper {
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
    }
</style>

<MudLayout Class="@(!string.IsNullOrEmpty(AppSettingsService.GetSettings().BackgroundImageUrl) ? "mes-has-bg" : "")">
    @* Sfondo immagine su tutte le pagine (eccetto Home che ha il proprio) *@
    @if (!IsHomePage() && !string.IsNullOrEmpty(AppSettingsService.GetSettings().BackgroundImageUrl))
    {
        <div aria-hidden="true" style="position:fixed;inset:0;z-index:0;pointer-events:none;
                    background-image:url('@AppSettingsService.GetSettings().BackgroundImageUrl');
                    background-size:cover;background-position:center;
                    opacity:var(--mes-bg-opacity);"></div>
    }
    <MudAppBar Elevation="1" Dense="true" data-testid="main-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        @if (IsHomePage())
        {
            <div class="ml-3 d-flex flex-column" style="line-height: 1.2;">
                <MudText Typo="Typo.h5" Style="margin-bottom: -2px;">Todescato MES</MudText>
                <MudText Typo="Typo.caption" Style="opacity: 0.7; font-size: 10px;">powered by Fabio</MudText>
            </div>
        }
        else
        {
            <MudText Typo="Typo.h5" Class="ml-3">@GetPageTitle()</MudText>
        }
        <MudSpacer />
        
        @* Nome utente autenticato — visibile al centro-destra della AppBar *@
        <UserSelector />
        
        @* Contenuto custom da pagine specifiche (es. PlcRealtime) *@
        @if (AppBarContentService.Content != null)
        {
            @AppBarContentService.Content
        }
        else
        {
            @* Menu categorie principale - solo se non siamo su una pagina con toolbar *@
            <MudMenu Icon="@Icons.Material.Filled.Apps" Color="Color.Inherit" AnchorOrigin="Origin.BottomCenter">
                <MudMenuItem OnClick="@(() => SetCategory("Produzione"))">Produzione</MudMenuItem>
                <MudMenuItem OnClick="@(() => SetCategory("Programma"))">Programma</MudMenuItem>
                <MudMenuItem OnClick="@(() => SetCategory("Cataloghi"))">Cataloghi</MudMenuItem>
                <MudMenuItem OnClick="@(() => SetCategory("Manutenzioni"))">Manutenzioni</MudMenuItem>
                <MudMenuItem OnClick="@(() => SetCategory("Sync"))">Sync</MudMenuItem>
                <MudMenuItem OnClick="@(() => SetCategory("Statistiche"))">Statistiche</MudMenuItem>
                <MudMenuItem OnClick="@(() => SetCategory("Impostazioni"))">Impostazioni</MudMenuItem>
            </MudMenu>
        }
        
        @if (_isAdmin)
        {
            <MudTooltip Text="Assistente AI" Arrow="true" Placement="Placement.Bottom">
                <MudIconButton Icon="@Icons.Material.Filled.AutoAwesome"
                               Color="Color.Inherit"
                               OnClick="@ToggleAiPanel"
                               data-testid="ai-assistant-btn" />
            </MudTooltip>
        }
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                       Color="Color.Inherit" 
                       OnClick="@ToggleTheme" />
        <MudTooltip Text="@FullscreenTooltip" Arrow="true" Placement="Placement.Bottom">
            <MudIconButton Icon="@FullscreenIcon"
                           Color="Color.Inherit"
                           OnClick="ToggleFullscreen"
                           data-testid="fullscreen-btn" />
        </MudTooltip>
        <AuthorizeView>
            <Authorized>
                <MudTooltip Text="@context.User.Identity?.Name" Arrow="true">
                    <MudIconButton Icon="@Icons.Material.Filled.AccountCircle"
                                   Color="Color.Inherit"
                                   Size="Size.Small"
                                   Class="mr-0" />
                </MudTooltip>
                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                               Color="Color.Inherit"
                               Title="@($"Esci ({context.User.Identity?.Name})")"
                               OnClick="Logout" />
            </Authorized>
        </AuthorizeView>
    </MudAppBar>
    
    @* Indicatore colore utente corrente *@
    <UserColorIndicator />
    
    @* Sottomenu dinamico per categoria *@
    @if (!string.IsNullOrEmpty(_currentCategory))
    {
        <MudAppBar Elevation="0" Dense="true" Color="Color.Default">
            <MudText Typo="Typo.subtitle1" Class="mr-4">@_currentCategory</MudText>
            @foreach (var item in GetMenuItems(_currentCategory))
            {
                <MudButton Href="@item.Url" Color="Color.Inherit" Size="Size.Small" Class="mr-1">
                    @item.Title
                </MudButton>
            }
        </MudAppBar>
    }
    
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="DrawerVariant.Responsive" Width="@(_miniDrawer ? "52px" : "185px")" Class="@DrawerMiniClass">
        <MudDrawerHeader Style="display: flex; justify-content: space-between; align-items: center; min-height: 32px; padding: 2px 4px 2px 8px;">
            @if (!_miniDrawer)
            {
                <MudText Typo="Typo.caption" Style="font-family: monospace; color: var(--mes-nav-text); opacity: 0.7; font-size: 11px;">
                    @AppVersion.Display
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                               Size="Size.Small"
                               Color="Color.Inherit"
                               Style="color: var(--mes-nav-text); opacity: 0.75;"
                               OnClick="ToggleMiniDrawer"
                               Title="Riduci menu" />
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                               Size="Size.Small"
                               Color="Color.Inherit"
                               Style="color: var(--mes-nav-text); opacity: 0.75; margin: 0 auto;"
                               OnClick="ToggleMiniDrawer"
                               Title="Espandi menu" />
            }
        </MudDrawerHeader>
        <MudNavMenu data-testid="nav-menu">
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home" IconColor="Color.Primary">Home</MudNavLink>

            @* Programma - claim-aware per Visualizzazione *@
            <AuthorizeView Roles="Admin,Produzione,Ufficio,Manutenzione,Visualizzazione">
                <Authorized Context="progCtx">
                    @{
                        bool _isProgBase = progCtx.User.IsInRole("Admin") || progCtx.User.IsInRole("Produzione") || progCtx.User.IsInRole("Ufficio") || progCtx.User.IsInRole("Manutenzione");
                        bool _canProg    = _isProgBase || progCtx.User.HasClaim(PaginaPolicy.ClaimType, "programma-macchine");
                        bool _canComm    = _isProgBase || progCtx.User.HasClaim(PaginaPolicy.ClaimType, "commesse-aperte");
                        bool _canGanttP  = _isProgBase || progCtx.User.HasClaim(PaginaPolicy.ClaimType, "gantt-macchine");
                    }
                    @if (_canProg || _canComm || _canGanttP)
                    {
                        <MudNavGroup Title="Programma" Icon="@Icons.Material.Filled.CalendarMonth" IconColor="Color.Primary" Expanded="@_expandedProg" ExpandedChanged="@(v => OnNavGroupToggled("prog", v))" Class="nav-sec-prog">
                            <ChildContent>
                                @if (_canProg)
                                {
                                    <MudNavLink Href="/programma/programma-macchine">
                                        <div style="display: flex; align-items: center; gap: 8px;"><span style="font-size: 13px;">&#128295;</span><span>Programma</span></div>
                                    </MudNavLink>
                                }
                                @if (_canComm)
                                {
                                    <MudNavLink Href="/programma/commesse-aperte">
                                        <div style="display: flex; align-items: center; gap: 8px;"><span style="font-size: 13px;">&#128203;</span><span>Commesse</span></div>
                                    </MudNavLink>
                                }
                                @if (_canGanttP)
                                {
                                    <MudNavLink Href="/programma/gantt-macchine">
                                        <div style="display: flex; align-items: center; gap: 8px;"><span style="font-size: 13px;">&#128202;</span><span>Gantt</span></div>
                                    </MudNavLink>
                                }
                            </ChildContent>
                        </MudNavGroup>
                    }
                </Authorized>
            </AuthorizeView>

            @* Produzione - Admin/Produzione/Manutenzione sempre; Visualizzazione solo pagine abilitate via claims *@
