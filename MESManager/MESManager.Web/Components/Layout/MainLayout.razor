                <Authorized Context="prodCtx">
                    @{
                        bool _isProdAdmin = prodCtx.User.IsInRole("Admin") || prodCtx.User.IsInRole("Produzione") || prodCtx.User.IsInRole("Manutenzione");
                        bool _canDash     = _isProdAdmin || prodCtx.User.HasClaim(PaginaPolicy.ClaimType, "dashboard");
                        bool _canPlcRT    = _isProdAdmin || prodCtx.User.HasClaim(PaginaPolicy.ClaimType, "plc-realtime");
                        bool _canPlcSt    = _isProdAdmin || prodCtx.User.HasClaim(PaginaPolicy.ClaimType, "plc-storico");
                        bool _canGantt    = _isProdAdmin || prodCtx.User.HasClaim(PaginaPolicy.ClaimType, "gantt-storico");
                        bool _canIncoll   = _isProdAdmin || prodCtx.User.HasClaim(PaginaPolicy.ClaimType, "incollaggio");
                    }
                    @if (_canDash || _canPlcRT || _canPlcSt || _canGantt || _canIncoll)
                    {
                        <MudNavGroup Title="Produzione" Icon="@Icons.Material.Filled.Factory" IconColor="Color.Warning" Expanded="@_expandedProd" ExpandedChanged="@(v => OnNavGroupToggled("prod", v))" Class="nav-sec-produzione">
