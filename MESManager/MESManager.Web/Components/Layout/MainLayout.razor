    </MudDrawer>

    @* ── AI Assistant Drawer (solo Admin) ────────────────────────────────── *@
    @if (_isAdmin)
    {
        <MudDrawer @bind-Open="_aiPanelOpen"
                   Anchor="Anchor.End"
                   Variant="DrawerVariant.Temporary"
                   Width="430px"
                   Elevation="4"
                   data-testid="ai-assistant-drawer">
            <AiAssistantPanel OnClose="@(() => _aiPanelOpen = false)" />
        </MudDrawer>
    }

    <CascadingValue Value="@_isReadOnly" Name="IsReadOnly">
    <CascadingValue Value="@_isAdmin" Name="IsAdmin">
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-0">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <MudAlert Severity="Severity.Error" Class="ma-4">
                        <MudText Typo="Typo.h6">Si è verificato un errore</MudText>
                        <MudText>@ex.Message</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="RecoverFromError" Class="mt-2">
                            Riprova
                        </MudButton>
                    </MudAlert>
                </ErrorContent>
            </ErrorBoundary>
        </MudContainer>
    </MudMainContent>
    </CascadingValue>
    </CascadingValue>
</MudLayout>
