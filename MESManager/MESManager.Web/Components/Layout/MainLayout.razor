@inherits LayoutComponentBase
@using MESManager.Web.Services
@using MESManager.Web.Components.Shared
@using MESManager.Web.Constants
@implements IDisposable

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@* CSS variables custom: accessibili da tutti i file CSS dell'app come var(--mes-*) *@
<style>
    :root {
        --mes-text-on-primary: @(AppSettingsService.GetSettings().ThemeTextOnPrimary);
        --mes-primary: @(AppSettingsService.GetSettings().ThemePrimaryColor);
        --mes-primary-text: @(AppSettingsService.GetSettings().ThemePrimaryTextColor);
        --mes-nav-text: @(string.IsNullOrEmpty(AppSettingsService.GetSettings().ThemeNavTextColor) ? (_isDarkMode ? "#FFFFFF" : "#1A1A1A") : AppSettingsService.GetSettings().ThemeNavTextColor);
        --mes-bg-opacity: @(AppSettingsService.GetSettings().ThemeBgOpacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture));
        --mes-panel-opacity: @(AppSettingsService.GetSettings().ThemePanelOpacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture));
        /* Colori tabelle — calcolati server-side, usati da app.css via var() */
        --mes-row-odd:  @(_isDarkMode ? "#262636" : "#F0F0F8");
        --mes-row-even: @(_isDarkMode ? "#303042" : "#FAFAFD");
        --mes-row-text: @(_isDarkMode ? "#E6E6F0" : "#1E1E28");
        --mes-grid-header-bg: @(_isDarkMode ? "#14182A" : "#1E2846");
        --mes-glass-grid: @(_isDarkMode ? $"rgba(28,28,40,{AppSettingsService.GetSettings().ThemePanelOpacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)})" : $"rgba(248,248,252,{AppSettingsService.GetSettings().ThemePanelOpacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)})");
    }
    /* Drawer nav: icone +15% (13→15, 16→18), testo non bold */
    .mud-drawer [data-testid="nav-menu"] span[style*="font-size: 13px"] { font-size: 15px !important; }
    .mud-drawer [data-testid="nav-menu"] span[style*="font-size: 16px"] { font-size: 18px !important; }
    .mud-drawer [data-testid="nav-menu"] span:not([style]) { font-size: 15px; font-weight: normal !important; }
    .mud-drawer [data-testid="nav-menu"] .mud-nav-link-text { font-size: 15px !important; font-weight: normal !important; }
    .mud-drawer [data-testid="nav-menu"] .mud-list-item-text span { font-size: 15px !important; font-weight: normal !important; }
    .mud-drawer [data-testid="nav-menu"] .mud-nav-link-text span { font-weight: normal !important; }
    .mud-drawer .mud-nav-group-header { font-weight: normal !important; }
    .mud-drawer .mud-nav-group-header span,
    .mud-drawer .mud-nav-group-header .mud-typography { font-weight: normal !important; }
    /* Colore testo nav: usa impostazione utente (--mes-nav-text) */
    .mud-drawer [data-testid="nav-menu"] .mud-nav-link-text,
    .mud-drawer [data-testid="nav-menu"] .mud-nav-link-text span,
    .mud-drawer [data-testid="nav-menu"] span:not([style]),
    .mud-drawer .mud-nav-group-header .mud-typography,
    .mud-drawer .mud-nav-group-header span {
        color: var(--mes-nav-text) !important;
    }
    /* AppBar: testo e titolo seguono lo stesso colore del menu laterale */
    .mud-appbar .mud-toolbar-appbar,
    .mud-appbar .mud-toolbar,
    .mud-appbar .mud-typography,
    .mud-appbar h1, .mud-appbar h2, .mud-appbar h3, .mud-appbar h4, .mud-appbar h5, .mud-appbar h6,
    .mud-appbar span:not(.mud-chip-content):not(.mud-icon-root),
    [data-testid="main-appbar"],
    [data-testid="main-appbar"] .mud-typography,
    [data-testid="main-appbar"] span:not(.mud-icon-root) {
        color: var(--mes-nav-text) !important;
    }
</style>
@{
    var _bgActive = !string.IsNullOrEmpty(AppSettingsService.GetSettings().BackgroundImageUrl);
    var _panelOpStr = AppSettingsService.GetSettings().ThemePanelOpacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    // Colori calcolati server-side da _isDarkMode — evita dipendenza da .mud-theme-dark CSS
    var _glassPanel = _isDarkMode
        ? $"rgba(18,18,28,{_panelOpStr})"      // dark: grigio scuro quasi nero
        : $"rgba(255,255,255,{_panelOpStr})";   // light: bianco semi-trasparente
    var _glassGrid = _isDarkMode
        ? $"rgba(28,28,40,{_panelOpStr})"
        : $"rgba(248,248,252,{_panelOpStr})";
    // Righe: in dark mode grigio medio visibile (NON nero), in light mode grigio chiaro — FULLY OPAQUE
    var _rowEven = _isDarkMode ? "#303042" : "#FAFAFD";
    var _rowOdd  = _isDarkMode ? "#262636" : "#F0F0F8";
    // Testo celle: bianco in dark, scuro in light
    var _rowText = _isDarkMode ? "#E6E6F0" : "#1E1E28";
    // Header griglia: colore scuro senza color-mix (evita CSS parsing failure)
    var _gridHeaderBg = _isDarkMode ? "#14182A" : "#1E2846";
    // AppBar + Drawer: primary in light, scuro in dark (dark mode deve restare scuro)
    var _appBarBg = _isDarkMode ? "#0E101C" : "var(--mes-primary)";
    var _drawerBg = _appBarBg;
}

<style>
    /* ── AG Grid — usa CSS vars definite in :root sopra ─────────────────── */
    .ag-theme-alpine .ag-root-wrapper,
    .ag-theme-alpine-dark .ag-root-wrapper {
        background-color: var(--mes-glass-grid) !important;
    }
    .ag-theme-alpine .ag-header,
    .ag-theme-alpine-dark .ag-header,
    .ag-theme-alpine .ag-header-row,
    .ag-theme-alpine-dark .ag-header-row {
        background-color: var(--mes-grid-header-bg) !important;
    }
    .ag-theme-alpine .ag-header-cell,
    .ag-theme-alpine-dark .ag-header-cell,
    .ag-theme-alpine .ag-header-cell-text,
    .ag-theme-alpine-dark .ag-header-cell-text {
        color: rgba(255,255,255,0.95) !important;
    }
    .ag-theme-alpine .ag-row-even,
    .ag-theme-alpine-dark .ag-row-even {
        background-color: var(--mes-row-even) !important;
    }
    .ag-theme-alpine .ag-row-odd,
    .ag-theme-alpine-dark .ag-row-odd {
        background-color: var(--mes-row-odd) !important;
    }
    .ag-theme-alpine .ag-cell,
    .ag-theme-alpine-dark .ag-cell {
        color: var(--mes-row-text) !important;
    }
</style>

@if (_bgActive)
{
    <style>
        /* ===== GLASS EFFECT — solo con sfondo attivo ===== */

        /* Pannelli nel contenuto pagina — esclude le machine-card della dashboard (hanno stile proprio) */
        .mud-main-content .mud-paper:not(.machine-card),
        .mud-main-content .mud-card:not(.machine-card) {
            background-color: @_glassPanel !important;
            background:        @_glassPanel !important;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }

        /* Dashboard machine-card: dark/light gestito server-side (C# _isDarkMode) */
        .machine-card {
            background: @(_isDarkMode
                ? "radial-gradient(ellipse at center, rgba(62,62,82,0.97) 0%, rgba(40,40,58,0.98) 55%, rgba(22,22,36,0.99) 100%)"
                : "radial-gradient(ellipse at center, #ffffff 30%, #e2e6ea 80%, #cfd5db 100%)") !important;
        }
        .machine-card,
        .machine-card .mud-typography,
        .machine-card .mud-card-header,
        .machine-card .mud-card-content,
        .machine-card .mud-card-actions,
        .machine-card .mud-input-label,
        .machine-card p,
        .machine-card span:not(.mud-chip-content) {
            color: @(_isDarkMode ? "rgba(230,230,240,0.95)" : "#1a1a1a") !important;
        }
        .machine-card .machine-number {
            color: @(_isDarkMode ? "rgba(255,255,255,0.98)" : "var(--mes-primary-text, var(--mud-palette-primary))") !important;
        }
        .machine-card .section-title {
            color: @(_isDarkMode ? "rgba(200,200,215,0.80)" : "#333333") !important;
        }

        /* AppBar: stessa formula del drawer — dark=quasi nero, light=primary trasparente */
        .mud-appbar {
            background-color: @_appBarBg !important;
            backdrop-filter: blur(12px) saturate(1.4);
            -webkit-backdrop-filter: blur(12px) saturate(1.4);
        }

        /* Drawer: stesso stile dell'AppBar, dark = quasi nero */
        .mud-drawer {
            background-color: @_drawerBg !important;
            backdrop-filter: blur(12px) saturate(1.4);
            -webkit-backdrop-filter: blur(12px) saturate(1.4);
        }
        .mud-drawer .mud-drawer-content,
        .mud-drawer .mud-drawer-header,
        .mud-drawer .mud-navmenu,
        .mud-drawer .mud-nav-group,
        .mud-drawer .mud-nav-group-items,
        .mud-drawer .mud-nav-link,
        .mud-drawer .mud-list,
        .mud-drawer [data-testid="nav-menu"] {
            background-color: transparent !important;
            background: transparent !important;
        }

        /* ── Backdrop blur per griglie (solo con sfondo) ── */
        .mud-main-content .ag-theme-alpine .ag-root-wrapper,
        .mud-main-content .ag-theme-alpine-dark .ag-root-wrapper {
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
        }
    </style>
}

<MudLayout Class="@(!string.IsNullOrEmpty(AppSettingsService.GetSettings().BackgroundImageUrl) ? "mes-has-bg" : "")">
    @* Sfondo immagine su tutte le pagine (eccetto Home che ha il proprio) *@
    @if (!IsHomePage() && !string.IsNullOrEmpty(AppSettingsService.GetSettings().BackgroundImageUrl))
    {
        <div aria-hidden="true" style="position:fixed;inset:0;z-index:0;pointer-events:none;
                    background-image:url('@AppSettingsService.GetSettings().BackgroundImageUrl');
                    background-size:cover;background-position:center;
                    opacity:var(--mes-bg-opacity);"></div>
    }
    <MudAppBar Elevation="1" data-testid="main-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        @if (IsHomePage())
        {
            <div class="ml-3 d-flex flex-column" style="line-height: 1.2;">
                <MudText Typo="Typo.h5" Style="margin-bottom: -2px;">Todescato MES</MudText>
                <MudText Typo="Typo.caption" Style="opacity: 0.7; font-size: 10px;">powered by Marra</MudText>
            </div>
        }
        else
        {
            <MudText Typo="Typo.h5" Class="ml-3">@GetPageTitle()</MudText>
        }
        <MudSpacer />
        
        @* Contenuto custom da pagine specifiche (es. PlcRealtime) *@
        @if (AppBarContentService.Content != null)
        {
            @AppBarContentService.Content
        }
        else if (IsPlcRealtimePage())
        {
            @* Controlli specifici per PLC Realtime *@
            @RenderPlcRealtimeToolbar()
        }
        else
        {
            @* Menu categorie principale - solo se non siamo su una pagina con toolbar *@
            <MudMenu Icon="@Icons.Material.Filled.Apps" Color="Color.Inherit" AnchorOrigin="Origin.BottomCenter">
                <MudMenuItem OnClick="@(() => SetCategory("Produzione"))">Produzione</MudMenuItem>
                <MudMenuItem OnClick="@(() => SetCategory("Programma"))">Programma</MudMenuItem>
                <MudMenuItem OnClick="@(() => SetCategory("Cataloghi"))">Cataloghi</MudMenuItem>
                <MudMenuItem OnClick="@(() => SetCategory("Manutenzioni"))">Manutenzioni</MudMenuItem>
                <MudMenuItem OnClick="@(() => SetCategory("Sync"))">Sync</MudMenuItem>
                <MudMenuItem OnClick="@(() => SetCategory("Statistiche"))">Statistiche</MudMenuItem>
                <MudMenuItem OnClick="@(() => SetCategory("Impostazioni"))">Impostazioni</MudMenuItem>
            </MudMenu>
        }
        
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                       Color="Color.Inherit" 
                       OnClick="@ToggleTheme" />
    </MudAppBar>
    
    @* Indicatore colore utente corrente *@
    <UserColorIndicator />
    
    @* Sottomenu dinamico per categoria *@
    @if (!string.IsNullOrEmpty(_currentCategory))
    {
        <MudAppBar Elevation="0" Dense="true" Color="Color.Default">
            <MudText Typo="Typo.subtitle1" Class="mr-4">@_currentCategory</MudText>
            @foreach (var item in GetMenuItems(_currentCategory))
            {
                <MudButton Href="@item.Url" Color="Color.Inherit" Size="Size.Small" Class="mr-1">
                    @item.Title
                </MudButton>
            }
        </MudAppBar>
    }
    
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2">
        <MudDrawerHeader Style="display: flex; justify-content: space-between; align-items: center;">
            <MudText Typo="Typo.h6">Menu</MudText>
            <MudText Typo="Typo.caption" Style="@($"font-family: monospace; color: {(_isDarkMode ? "rgba(230,230,230,0.5)" : "rgba(0,0,0,0.3)")}; font-size: 11px;")">
                @AppVersion.Display
            </MudText>
        </MudDrawerHeader>
        <MudNavMenu data-testid="nav-menu">
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home" IconColor="Color.Primary">Home</MudNavLink>
            
            <MudNavGroup Expanded="true">
                <TitleContent>
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 16px; display: inline-flex; align-items: center;">�</span>
                        <span style="line-height: normal;">Programma Irene</span>
                    </div>
                </TitleContent>
                <ChildContent>
                    <MudNavLink Href="/programma/programma-macchine">
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <span style="font-size: 13px;">🔧</span>
                            <span>Programma</span>
                        </div>
                    </MudNavLink>
                    <MudNavLink Href="/programma/commesse-aperte">
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <span style="font-size: 13px;">📋</span>
                            <span>Commesse</span>
                        </div>
                    </MudNavLink>
                    <MudNavLink Href="/programma/gantt-macchine">
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <span style="font-size: 13px;">📊</span>
                            <span>Gantt</span>
                        </div>
                    </MudNavLink>
                </ChildContent>
            </MudNavGroup>
            
            <MudNavGroup Title="Produzione" Icon="@Icons.Material.Filled.Factory" IconColor="Color.Warning">
                <MudNavLink Href="/produzione/dashboard">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">📈</span>
                        <span>Dashboard</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/produzione/plc-realtime">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">⚡</span>
                        <span>PLC Realtime</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/produzione/plc-storico">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">📜</span>
                        <span>PLC Storico</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/produzione/incollaggio">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">🔗</span>
                        <span>Incollaggio</span>
                    </div>
                </MudNavLink>
            </MudNavGroup>
            
            <MudNavGroup Title="Cataloghi" Icon="@Icons.Material.Filled.LibraryBooks" IconColor="Color.Info">
                <MudNavLink Href="/cataloghi/commesse">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">📦</span>
                        <span>Commesse</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/cataloghi/anime">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">🎯</span>
                        <span>Anime</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/cataloghi/articoli">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">📁</span>
                        <span>Articoli</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/cataloghi/clienti">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">👥</span>
                        <span>Clienti</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/cataloghi/ricette">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">📝</span>
                        <span>Ricette</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/cataloghi/preventivi-anime/nuovo">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">💰</span>
                        <span>Preventivi Lavorazioni Anime</span>
                    </div>
                </MudNavLink>
            </MudNavGroup>
            
            <MudNavGroup Title="Manutenzioni" Icon="@Icons.Material.Filled.Build" IconColor="Color.Secondary">
                <MudNavLink Href="/manutenzioni/alert">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">⚠️</span>
                        <span>Alert</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/manutenzioni/catalogo">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">🔩</span>
                        <span>Catalogo</span>
                    </div>
                </MudNavLink>
            </MudNavGroup>
            
            <MudNavGroup Title="Sync" Icon="@Icons.Material.Filled.Sync" IconColor="Color.Success">
                <MudNavLink Href="/sync/gantt">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">🔄</span>
                        <span>Gantt</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/sync/mago">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">🧙</span>
                        <span>Mago</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/sync/macchine">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">🤖</span>
                        <span>Macchine</span>
                    </div>
                </MudNavLink>
            </MudNavGroup>
            
            <MudNavGroup Title="Statistiche" Icon="@Icons.Material.Filled.BarChart" IconColor="Color.Tertiary">
                <MudNavLink Href="/statistiche/produzione">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">📉</span>
                        <span>Produzione</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/statistiche/ordini">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">📊</span>
                        <span>Ordini</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/statistiche/plc-storico">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">📡</span>
                        <span>PLC Storico</span>
                    </div>
                </MudNavLink>
            </MudNavGroup>
            
            <MudNavGroup Title="Impostazioni" Icon="@Icons.Material.Filled.Settings" IconColor="Color.Dark">
                <MudNavLink Href="/impostazioni/gantt">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">⚙️</span>
                        <span>Gantt Macchine</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/impostazioni/tabelle">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">📊</span>
                        <span>Tabelle</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/impostazioni/utenti">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">👤</span>
                        <span>Utenti</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/impostazioni/operatori">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">👷</span>
                        <span>Operatori</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/impostazioni/generali">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">🔧</span>
                        <span>Generali</span>
                    </div>
                </MudNavLink>
                <MudNavLink Href="/impostazioni/issue-log" Icon="@Icons.Material.Filled.BugReport">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 13px;">🐛</span>
                        <span>Issue Log</span>
                    </div>
                </MudNavLink>
            </MudNavGroup>
        </MudNavMenu>
    </MudDrawer>
    
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <MudAlert Severity="Severity.Error" Class="ma-4">
                        <MudText Typo="Typo.h6">Si è verificato un errore</MudText>
                        <MudText>@ex.Message</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="RecoverFromError" Class="mt-2">
                            Riprova
                        </MudButton>
                    </MudAlert>
                </ErrorContent>
            </ErrorBoundary>
        </MudContainer>
    </MudMainContent>
</MudLayout>
