{
  "PlcSync": {
    "PollingIntervalSeconds": 4,
    "EnableRealtime": true,
    "EnableStorico": true,
    "EnableEvents": true,
    "MachineConfigPath": "Configuration/machines",
    
    "PlcDefaults": {
      "Rack": 0,
      "Slot": 1,
      "DbNumber": 55,
      "DbStart": 0,
      "DbLength": 200,
      "TimeoutMs": 5000,
      "ReconnectDelayMs": 3000
    }
  },
  
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "MESManager.PlcSync": "Debug"
    }
  }
}
