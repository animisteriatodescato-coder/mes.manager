# ============================================================================
# PlcMagoSync - Configurazione Ambiente Locale
# ============================================================================
# 
# ISTRUZIONI:
# 1. Copia questo file e rinominalo in ".env.local"
# 2. Compila i valori sottostanti con le tue credenziali
# 3. NON committare .env.local (è protetto da .gitignore)
# 4. Riavvia l'applicazione
#
# ============================================================================

# Google Sheets ID
# Ottieni questo valore dall'URL del tuo Google Sheet:
# https://docs.google.com/spreadsheets/d/{GOOGLE_SHEET_ID}/edit
GOOGLE_SHEET_ID=1-SoQMJt_5tAZFlSEuSNMOLOYBSwvoXFnrCayehhx1Qg

# Percorso del file Service Account JSON
# Scarica questo file da Google Cloud Console
# Usa percorso assoluto: C:\path\to\service-account.json (Windows)
#                        /path/to/service-account.json (Linux/macOS)
SERVICE_ACCOUNT_JSON_PATH=C:\Progetti\PlcMultiMachine\service-account.json

# Stringa di connessione SQL Server
# Formato: Data Source=server;Initial Catalog=database;User Id=user;Password=password;
MAGO_CONNECTION_STRING=Data Source=192.168.1.72\SQLEXPRESS;Initial Catalog=TODESCATO_NET;User Id=Gantt;Password=Gantt2019;
