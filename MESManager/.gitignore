# =========================
# MESManager Security .gitignore
# =========================

# Credenziali e segreti (in chiaro e criptati)
appsettings.Secrets.json
appsettings.*.Secrets.json
appsettings.Secrets.encrypted
*.secrets.json
*.secrets.encrypted
secrets.json

# User Secrets (già ignorati di default, ma per sicurezza)
secrets/

# File di configurazione locali con credenziali
appsettings.Local.json
appsettings.*.Local.json
appsettings.Database.json
appsettings.Database.*.json
.credentials.local

# Log files (potrebbero contenere info sensibili)
*.log
logs/
app.log
app.error.log
web-run.log

# Impostazioni runtime (generate a runtime, non da committare)
wwwroot/app-settings.json
MESManager.Web/wwwroot/app-settings.json
.dev-data-protection-keys/

# RAG - LanceDB locale (generato da rag/index_codebase.py)
rag/lancedb/

# Build outputs
bin/
obj/
publish/
out/
backups/
docs2/
MESManager.Web/wwwroot/SyncBackups/
wwwroot/SyncBackups/

# IDE
.vs/
.vscode/settings.json
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates

# NuGet
*.nupkg
.nuget/
packages/

# Test results
TestResults/
*.trx

# Visual regression
tests/MESManager.E2E/UPDATE_BASELINES.flag

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Backup files
*.bak
*.backup
*~

# Temporary files
*.tmp
*.temp
*.swp

# Coverage
coverage/
*.coverage
*.coveragexml

# Excel temp files
~$*.xlsx
~$*.xls
*.xlsx
*.xls

# Risultati temporanei
risultato-*.txt
api-result.txt
api-check.txt
final-fix.txt
fix-result.txt
fk-check.txt
insert-test.txt
plc-fix-success.txt
